<script>
/* checkboxes -> selection bar */
const bar = document.getElementById('sel-bar');
const cnt = document.getElementById('sel-count');
function refresh() {
  const checked = document.querySelectorAll('.r-check input:checked');
  if (checked.length > 0) {
    bar.classList.add('is-open');
    cnt.textContent = checked.length + ' selected';
  } else {
    bar.classList.remove('is-open');
  }
}
document.querySelectorAll('.r-check input').forEach(cb => {
  cb.addEventListener('click', e => e.stopPropagation());
  cb.addEventListener('change', refresh);
});
document.getElementById('sel-clear').addEventListener('click', () => {
  document.querySelectorAll('.r-check input:checked').forEach(cb => cb.checked = false);
  refresh();
});

/* filter button group */
document.querySelectorAll('.f-grp button').forEach(b => {
  b.addEventListener('click', () => {
    b.parentElement.querySelectorAll('button').forEach(x => x.classList.remove('is-active'));
    b.classList.add('is-active');
  });
});

/* prevent row nav when clicking inline action buttons */
document.querySelectorAll('.r-act').forEach(btn => {
  btn.addEventListener('click', e => { e.preventDefault(); e.stopPropagation(); });
});
</script>
