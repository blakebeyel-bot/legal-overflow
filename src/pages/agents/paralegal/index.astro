<script>
/* ---------- waveform bars ---------- */
(function buildWave(){
  const wave = document.getElementById('wave');
  const N = 56;
  for (let i = 0; i < N; i++) {
    const b = document.createElement('span');
    b.className = 'bar';
    // varied amplitude per bar
    const amp = (0.35 + 0.65 * Math.abs(Math.sin(i * 0.42 + 1.3)));
    b.style.setProperty('--d', (i * 60) + 'ms');
    b.style.animationDelay = (i * 60) + 'ms';
    b.style.animationDuration = (900 + (i % 5) * 150) + 'ms';
    b.style.height = (10 + amp * 70) + 'px';
    b.style.opacity = (0.55 + amp * 0.45).toFixed(2);
    wave.appendChild(b);
  }
})();

/* ---------- demo transcript loop ---------- */
const SCRIPT = [
  { role: 'you',   label: 'You',        text: 'Good morning. What needs my attention today?', hold: 1200 },
  { role: 'tool',  label: 'Tool',       text: 'Reading inbox · last 16 hours · 24 messages', hold: 1100 },
  { role: 'tool',  label: 'Tool',       text: 'Cross-checking calendar · next 5 business days', hold: 1100 },
  { role: 'agent', label: 'Paralegal',  text: 'Three items. <em>One</em>, Sarah Chen at Acme sent her redline on the MSA last night. Response due Friday, she flagged Section 11 indemnity and the cap. <em>Two</em>, the Holton DPA is auto-renewing in 11 days. <em>Three</em>, you have a 2pm with Magic on the lease.', hold: 2400 },
  { role: 'you',   label: 'You',        text: 'Pull Acme up. Run a quick-scan against my playbook and read me the cap issue.', hold: 1300 },
  { role: 'tool',  label: 'Tool',       text: 'Loading vault: Magic / Vendor MSA — Acme Robotics (v3)', hold: 900 },
  { role: 'tool',  label: 'Tool',       text: 'Running quick-scan · playbook: client-side, SaaS, 2026', hold: 1100 },
  { role: 'agent', label: 'Paralegal',  text: 'Cap is 100% of fees with no super-cap on IP, confidentiality, or indemnity. Your playbook floor is 200% with super-caps on all three. I have drafted a reply to Sarah pushing back on Section 12.4 and proposing the standard ladder. Want me to read it before anything goes out?', hold: 2400 },
  { role: 'you',   label: 'You',        text: 'Read it.', hold: 900 },
  { role: 'agent', label: 'Paralegal',  text: '"Sarah, thanks for the redline. On the cap, we will need to land at 200% of trailing-12 fees with the standard super-cap exclusions for IP indemnity, confidentiality, and the gross-negligence carve-out. Happy to walk through it Thursday." <em>Speak "approve" or "edit" to continue.</em>', hold: 2600 },
];

const root = document.getElementById('transcript');
const statusEl = document.getElementById('demo-status');
let timers = [];

function clearTimers() { timers.forEach(t => clearTimeout(t)); timers = []; }

function runLoop() {
  clearTimers();
  root.innerHTML = '';
  let acc = 0;
  SCRIPT.forEach((line, i) => {
    timers.push(setTimeout(() => {
      const row = document.createElement('div');
      row.className = 't-row ' + line.role;
      row.innerHTML = `<span class="t-role">${line.label}</span><span class="t-body">${line.text}</span>`;
      root.appendChild(row);
      requestAnimationFrame(() => row.classList.add('is-in'));
      // keep last 7 rows
      while (root.children.length > 7) root.removeChild(root.firstChild);
      // status
      if (line.role === 'you') statusEl.textContent = 'Listening · you';
      else if (line.role === 'agent') statusEl.textContent = 'Speaking · Paralegal';
      else statusEl.textContent = 'Tool call';
    }, acc));
    acc += line.hold;
  });
  // restart
  timers.push(setTimeout(() => {
    statusEl.textContent = 'Loop · restarting';
    timers.push(setTimeout(runLoop, 1400));
  }, acc));
}
runLoop();

document.getElementById('demo-replay').addEventListener('click', () => {
  clearTimers();
  runLoop();
});

/* ---------- modal ---------- */
const veil = document.getElementById('modal-veil');
document.getElementById('cta-btn').addEventListener('click', () => veil.classList.add('is-open'));
document.getElementById('modal-close').addEventListener('click', () => veil.classList.remove('is-open'));
veil.addEventListener('click', (e) => { if (e.target === veil) veil.classList.remove('is-open'); });
window.addEventListener('keydown', (e) => { if (e.key === 'Escape') veil.classList.remove('is-open'); });
</script>
