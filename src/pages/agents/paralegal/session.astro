  sel.classList.toggle('is-open');
});
document.addEventListener('click', () => sel.classList.remove('is-open'));

/* ---------- mic wave ---------- */
(function micWave(){
  const w = document.getElementById('mic-wave');
  for (let i = 0; i < 28; i++) {
    const b = document.createElement('span');
    b.className = 'bar';
    b.style.animationDelay = (i * 70) + 'ms';
    b.style.animationDuration = (700 + (i % 5) * 120) + 'ms';
    b.style.height = (8 + Math.abs(Math.sin(i * .4)) * 28) + 'px';
    b.style.opacity = (0.55 + Math.abs(Math.cos(i * .3)) * 0.4).toFixed(2);
    w.appendChild(b);
  }
})();

/* ---------- timer ---------- */
(function timer(){
  const el = document.getElementById('timer');
  let s = 14 * 60 + 32;
  setInterval(() => {
    s++;
    const h = String(Math.floor(s/3600)).padStart(2,'0');
    const m = String(Math.floor((s%3600)/60)).padStart(2,'0');
    const sec = String(s%60).padStart(2,'0');
    el.textContent = `${h}:${m}:${sec}`;
  }, 1000);
})();

/* ---------- transcript streaming ---------- */
const ROOT = document.getElementById('tr-scroll');
const STATE = document.getElementById('mic-state');

const STREAM = [
  { kind:'you',   who:'You',        ts:'08:42:11', text:'Good morning. What needs my attention today?', hold: 1200 },
