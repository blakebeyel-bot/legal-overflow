];

let idx = 0;
function pushRow(item) {
  const row = document.createElement('div');
  row.className = 'tr-row ' + item.kind;

  let bodyHtml = '';
  if (item.kind === 'job') {
    bodyHtml = `
      <div class="tr-job">
        <div class="tr-job-h"><span class="lab">Background job · forked</span><span class="eta">${item.job.eta}</span></div>
        <div class="tr-job-title">${item.job.title}</div>
        <div class="tr-job-bar"><span style="--w: ${item.job.w}%"></span></div>
        <div class="tr-job-foot"><span>${item.job.sub}</span><span>${item.job.w}%</span></div>
      </div>`;
  } else if (item.kind === 'find') {
    bodyHtml = `
      <div class="tr-finding ${item.f.sev}">
        <span class="sev">${item.f.sev}</span>
        <span class="loc">${item.f.loc}</span>
        <span class="spec">${item.f.spec}</span>
      </div>`;
  } else {
    bodyHtml = item.text;
  }

  row.innerHTML = `
    <div class="tr-role">
      <span class="who">${item.who}</span>
      <span class="ts">${item.ts}</span>
    </div>
    <div class="tr-body">${bodyHtml}</div>`;
  ROOT.appendChild(row);
  requestAnimationFrame(() => row.classList.add('is-in'));
  ROOT.scrollTop = ROOT.scrollHeight;

  // update state
  if (item.kind === 'you') STATE.innerHTML = 'Listening<em>… you</em>';
  else if (item.kind === 'agent') STATE.innerHTML = 'Speaking<em>… Paralegal</em>';
  else STATE.innerHTML = 'Tool call';
}

function runStream() {
  if (idx >= STREAM.length) {
    // loop after pause
    setTimeout(() => {
      ROOT.innerHTML = '';
      idx = 0;
      runStream();
    }, 4500);
    return;
  }
  const item = STREAM[idx++];
  pushRow(item);
  setTimeout(runStream, item.hold || 700);
}
setTimeout(runStream, 600);

/* ---------- mobile tabs ---------- */
document.querySelectorAll('.mob-tab').forEach(b => {
  b.addEventListener('click', () => {
    document.querySelectorAll('.mob-tab').forEach(x => x.classList.remove('is-active'));
    b.classList.add('is-active');
    document.querySelectorAll('.col').forEach(c => c.classList.remove('is-active'));
    document.getElementById(b.dataset.col).classList.add('is-active');
  });
});

/* ---------- mute ---------- */
const mute = document.getElementById('mute-btn');
mute.addEventListener('click', () => mute.classList.toggle('muted'));

/* ---------- ptt visual feedback ---------- */
const ptt = document.getElementById('ptt');
['mousedown','touchstart','keydown'].forEach(e => window.addEventListener(e, () => ptt.style.transform = 'scale(.94)'));
['mouseup','touchend','keyup'].forEach(e => window.addEventListener(e, () => ptt.style.transform = ''));
</script>
