<script>
/**
 * Phase 1 data-loader.
 *
 * If the page is opened with ?id=<uuid>, fetch the real matter from
 * /api/paralegal-matters-get and replace the demo content with live data.
 *
 * Without ?id=, the page stays in demo/preview mode (the static visual
 * walkthrough the user lands on from /agents/paralegal/?walk=true).
 */
import { getSupabase } from '../../../lib/supabase';

const params = new URLSearchParams(location.search);
const matterId = params.get('id');
if (!matterId) {
  // No id = no matter to display. Bounce to the matter log so the user
  // never sees the static placeholder skeleton.
  location.replace('/agents/paralegal/matters/');
  throw new Error('redirecting to /matters/');
} else {
  const supabase = getSupabase();
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    location.href = `/login/?redirect=/agents/paralegal/matter/?id=${matterId}`;
    throw new Error('not signed in');
  }
  const accessToken = session.access_token;

  function escapeHtml(s) {
    return String(s ?? '').replace(/[<>&"]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
  }

  function fmt(d) {
    if (!d) return '—';
    return new Date(d).toLocaleDateString(undefined, { month: 'short', day: '2-digit', year: 'numeric' });
  }

  const STAGE_LABELS = { intake:'Intake', conflict:'Conflict', quick_scan:'Quick scan', redline:'Redline', sign:'Sign', watch:'Watch' };
  const STAGE_ORDER = ['intake', 'conflict', 'quick_scan', 'redline', 'sign', 'watch'];

  function applyMatter(matter, items, pending, audit) {
    const idShort = matter.id.slice(0, 8).toUpperCase();
    const stage = matter.stage || 'intake';
    const stageIdx = STAGE_ORDER.indexOf(stage);

    // ----- Header
    document.title = `Matter · ${matter.client} — Legal Overflow`;
    const mheadId = document.querySelector('.mhead-id');
    if (mheadId) {
      const opened = fmt(matter.created_at);
      const voiceTag = matter.voice_enabled ? '<span class="new">Voice-enabled</span>' : '';
      const due = matter.response_due ? `<span class="urg">Response ${fmt(matter.response_due)}</span>` : '';
      mheadId.innerHTML = `<span>MTR-${idShort} · Opened ${opened}</span>${voiceTag}${due}`;
    }
    const h1 = document.querySelector('.mhead h1');
    if (h1) {
      h1.innerHTML = matter.matter_type
        ? `${escapeHtml(matter.matter_type)} — <em>${escapeHtml(matter.counter_party || matter.client)}</em>`
        : escapeHtml(matter.client);
    }
    const who = document.querySelector('.mhead .who');
    if (who) {
      const parts = [`Client · <b>${escapeHtml(matter.client)}</b>`];
      if (matter.counter_party) parts.push(`Counter-party · <b>${escapeHtml(matter.counter_party)}</b>`);
      if (matter.posture) parts.push(`Posture · <b>${escapeHtml(matter.posture)}</b>`);
      who.innerHTML = parts.join(' &nbsp;·&nbsp; ');
    }

    // ----- Metabar cells
    const cells = document.querySelectorAll('.metabar .mb-cell');
    if (cells.length >= 6) {
      cells[0].querySelector('.v').innerHTML = matter.posture ? escapeHtml(matter.posture) : '—';
      cells[0].querySelector('.vsub').textContent = matter.playbook_vault_item_id ? 'Playbook linked' : 'No playbook yet';

      cells[1].querySelector('.v').textContent = matter.response_due ? fmt(matter.response_due) : '—';
      if (matter.response_due) {
        const days = Math.round((new Date(matter.response_due) - Date.now()) / 86400000);
        cells[1].querySelector('.vsub').textContent = days >= 0 ? `${days} day${days === 1 ? '' : 's'}` : `${Math.abs(days)} days overdue`;
      } else {
        cells[1].querySelector('.vsub').textContent = 'No deadline set';
        cells[1].classList.remove('warn');
      }

      // Findings / documents / voice sessions / hours come from items + audit
      const findings = items.filter(i => i.item_kind === 'tr_review' || i.item_kind === 'redline_run').length;
      cells[2].querySelector('.v').innerHTML = findings ? `${findings} open` : '0 open';
      cells[2].querySelector('.vsub').textContent = findings ? `From ${findings} review run${findings === 1 ? '' : 's'}` : 'No reviews yet';

      const docs = items.filter(i => i.item_kind === 'library_document' || i.item_kind === 'vault_item').length;
      cells[3].querySelector('.v').innerHTML = docs ? `${docs} <em>· linked</em>` : '0';
      cells[3].querySelector('.vsub').textContent = docs ? 'Linked from vault + library' : 'No documents linked';

      const voiceTurns = audit.filter(a => a.kind === 'voice_turn').length;
      cells[4].querySelector('.v').innerHTML = voiceTurns ? `${voiceTurns} <em>· turns</em>` : '0';
      cells[4].querySelector('.vsub').textContent = voiceTurns ? 'Voice activity logged' : 'No sessions yet';

      cells[5].querySelector('.v').innerHTML = `${Number(matter.hours_billed || 0).toFixed(1)} <em>hrs</em>`;
      cells[5].querySelector('.vsub').textContent = 'Manual entry · Clio sync future';
    }

    // ----- Stage track
    const trackR = document.querySelector('.track-r');
    if (trackR) trackR.innerHTML = `Currently <em>${STAGE_LABELS[stage]}</em>`;
    const trackL = document.querySelector('.track-l');
    if (trackL) trackL.textContent = `§ Stage track · ${String(stageIdx + 1).padStart(2, '0')} of 06`;
    const nodes = document.querySelectorAll('.track-nodes .tn');
    const labels = ['Intake', 'Conflict', 'Quick scan', 'Redline', 'Sign', 'Watch'];
    nodes.forEach((n, i) => {
      n.classList.remove('done', 'current');
      if (i < stageIdx) n.classList.add('done');
      else if (i === stageIdx) n.classList.add('current');
      const lbl = n.querySelector('.lbl');
      if (lbl && labels[i]) lbl.textContent = labels[i];
    });
    const trackDone = document.querySelector('.track-bar-done');
    if (trackDone) trackDone.style.width = `${(stageIdx / 5) * 100}%`;

    // ----- "Where we are" summary
    const summaryP = document.querySelector('.col-l .sec:first-of-type p');
    if (summaryP) {
      if (audit.length > 0) {
        summaryP.innerHTML = `Matter opened ${fmt(matter.created_at)}. Currently in <em>${STAGE_LABELS[stage]}</em> stage. ${audit.length} audit event${audit.length === 1 ? '' : 's'} logged. ${pending.length} action${pending.length === 1 ? '' : 's'} ${pending.length === 1 ? 'is' : 'are'} pending voice approval.`;
      } else {
        summaryP.innerHTML = `Matter just opened. Once the voice agent is wired up (Phase 3+), every turn, tool call, and approval will land in the timeline below.`;
      }
    }

    // ----- Activity timeline (audit log + Graph mail + calendar, merged)
    const tl = document.querySelector('.col-l .tl');
    const tlMeta = document.querySelector('.col-l .sec:nth-of-type(2) .sec-meta');
    if (tl) {
      // Audit always renders synchronously; mail + calendar load async and
      // merge in once available (handled by appendGraphTimeline below).
      const seedRows = audit.length === 0
        ? `<div id="tl-seed-empty" style="padding:18px 0;font-family:var(--serif);font-style:italic;font-size:16px;color:var(--ink-3)">No activity yet. Open a voice session, link items from your Vault / Library, or connect Microsoft 365 to start populating this timeline.</div>`
        : audit.slice(0, 20).map(a => renderTimelineRow(a)).join('');
      tl.innerHTML = seedRows;
      if (tlMeta) tlMeta.textContent = `${audit.length} audit events`;
    }
    appendGraphTimeline(matter); // async — fires Graph fetches in parallel

    // ----- Findings list (Phase 4 fills this from TR runs; empty in Phase 1)
    const fList = document.querySelector('.f-list');
    if (fList) {
      fList.innerHTML = `<div style="padding:18px 14px;font-family:var(--serif);font-style:italic;font-size:15px;color:var(--ink-3);background:var(--paper)">No findings yet. Run a quick-scan or redline on a linked document (Phase 4 wires this).</div>`;
    }

    // ----- Working documents (from items)
    const docsList = document.querySelector('.col-l .docs');
    if (docsList) {
      if (items.length === 0) {
        docsList.innerHTML = `<div style="padding:18px 0;font-family:var(--serif);font-style:italic;font-size:15px;color:var(--ink-3)">No linked items yet. From Vault or Library, use "Link to matter" to attach documents here.</div>`;
      } else {
        docsList.innerHTML = items.map(it => renderDocRow(it)).join('');
      }
    }

    // ----- Right rail — approval card (hide if no pending; Phase 5 populates)
    const apprCard = document.querySelector('.col-r .card.is-voice');
    if (apprCard) {
      if (pending.length === 0) {
        apprCard.style.display = 'none';
      } else {
        const action = pending[0];
        apprCard.querySelector('.appr-l').textContent = `Awaiting voice approval · 1 of ${pending.length}`;
        apprCard.querySelector('.card-t').innerHTML = `${action.action_kind.replace(/_/g, ' ')} · <em>${escapeHtml(action.payload?.subject || action.payload?.title || 'pending')}</em>`;
      }
    }
  }

  // ---- Graph timeline (Phase 2): merge Outlook mail + Calendar into the
  // activity timeline. Runs async after the audit-log render so the page
  // paints instantly even if Graph is slow / disconnected. ----
  async function appendGraphTimeline(matter) {
    const tl = document.querySelector('.col-l .tl');
    if (!tl) return;
    // Kick both fetches in parallel. Mail uses Graph $search across the
    // ENTIRE inbox (no date cap) when the matter has a counter_party or
    // client name; it falls back to "last 30 days" only when the matter
    // is brand-new with no keywords yet.
    const mailUrl = new URL('/.netlify/functions/microsoft-mail-recent', location.origin);
    mailUrl.searchParams.set('matter_id', matter.id);
    mailUrl.searchParams.set('top', '25');
    const calUrl = new URL('/.netlify/functions/microsoft-calendar-list', location.origin);
    calUrl.searchParams.set('days_ahead', '14');
    calUrl.searchParams.set('days_back', '3');

    const [mailRes, calRes] = await Promise.allSettled([
      fetch(mailUrl, { headers: { Authorization: `Bearer ${accessToken}` } }).then(r => r.json().then(j => ({ ok: r.ok, status: r.status, ...j }))),
      fetch(calUrl, { headers: { Authorization: `Bearer ${accessToken}` } }).then(r => r.json().then(j => ({ ok: r.ok, status: r.status, ...j }))),
    ]);

    // Handle the not-connected case once for both
    const notConnected = (mailRes.status === 'fulfilled' && mailRes.value.not_connected)
      || (calRes.status === 'fulfilled' && calRes.value.not_connected);
    if (notConnected) {
      const seedEmpty = document.getElementById('tl-seed-empty');
      const banner = `<div id="tl-msft-banner" style="padding:14px 16px;margin:0 0 12px;background:rgba(106,71,194,.04);border-left:3px solid var(--voice);border-radius:0 4px 4px 0;font-size:13.5px;color:var(--ink-2);font-family:var(--sans);line-height:1.5">
        <b style="color:var(--ink)">Connect Microsoft 365</b> so the Paralegal can pull recent inbox messages, calendar events, and attachments into this matter timeline.
        &nbsp;<a href="/account/" style="color:var(--accent-deep);font-weight:500;border-bottom:1px solid var(--accent)">Connect →</a>
      </div>`;
      if (seedEmpty) seedEmpty.insertAdjacentHTML('beforebegin', banner);
      else tl.insertAdjacentHTML('afterbegin', banner);
      return;
    }

    const mailItems = (mailRes.status === 'fulfilled' && mailRes.value.ok) ? (mailRes.value.messages || []) : [];
    const calItems = (calRes.status === 'fulfilled' && calRes.value.ok) ? (calRes.value.events || []) : [];

    if (mailItems.length === 0 && calItems.length === 0) {
      const tlMeta = document.querySelector('.col-l .sec:nth-of-type(2) .sec-meta');
      if (tlMeta) tlMeta.textContent = `${(tlMeta.textContent || '0').replace(/\D/g, '') || 0} audit · 0 inbox · 0 calendar`;
      return;
    }

    // Merge with audit-driven rows. Audit rows are already in the DOM;
    // we just append email + calendar rows and re-sort by timestamp.
    const seedEmpty = document.getElementById('tl-seed-empty');
    if (seedEmpty) seedEmpty.remove();

    const mailRows = mailItems.map(renderMailRow).filter(Boolean);
    const calRows = calItems.map(renderCalRow).filter(Boolean);
    // Just append; the audit rows are most recent first already, and the
    // new rows have data-ts attributes we sort on.
    const existingRows = Array.from(tl.querySelectorAll('.tl-row')).map(el => ({
      el, ts: Number(el.dataset.ts || 0),
    }));
    const newRows = [...mailRows, ...calRows].map(html => {
      const tmp = document.createElement('div');
      tmp.innerHTML = html;
      const el = tmp.firstElementChild;
      return { el, ts: Number(el.dataset.ts || 0) };
    });
    const merged = [...existingRows, ...newRows].sort((a, b) => b.ts - a.ts);
    tl.innerHTML = '';
    merged.forEach(r => tl.appendChild(r.el));

    const tlMeta = document.querySelector('.col-l .sec:nth-of-type(2) .sec-meta');
    if (tlMeta) {
      tlMeta.textContent = `${existingRows.length} audit · ${mailItems.length} inbox · ${calItems.length} calendar`;
    }
  }

  function renderMailRow(msg) {
    const ts = msg.receivedDateTime ? new Date(msg.receivedDateTime).getTime() : Date.now();
    const t = new Date(ts);
    const hhmm = t.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    const day = t.toLocaleDateString(undefined, { weekday: 'short' });
    const sender = msg.from?.emailAddress?.name || msg.from?.emailAddress?.address || 'Unknown';
    const subject = msg.subject || '(no subject)';
    const preview = (msg.bodyPreview || '').slice(0, 180);
    const attach = msg.hasAttachments
      ? `<div class="tl-attach"><span class="ic">ATT</span> Has attachments · <a href="#" data-mail-id="${escapeHtml(msg.id)}" class="mail-open-link">Open</a></div>`
      : '';
    return `<div class="tl-row email" data-ts="${ts}">
      <div class="tl-t"><span class="day">${day}</span>${hhmm}</div>
      <div class="tl-dot"></div>
      <div class="tl-body">
        <span class="ki">Email · ${escapeHtml(sender)}</span>
        <em>${escapeHtml(subject)}</em>
        <div style="font-family:var(--sans);font-size:13px;color:var(--ink-3);margin-top:4px;line-height:1.4">${escapeHtml(preview)}…</div>
        ${attach}
      </div>
    </div>`;
  }

  function renderCalRow(ev) {
    const startIso = ev.start?.dateTime || ev.start;
    const ts = startIso ? new Date(startIso).getTime() : Date.now();
    const t = new Date(ts);
    const hhmm = ev.isAllDay ? 'All day' : t.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    const day = t.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' });
    const subject = ev.subject || '(no title)';
    const where = ev.location?.displayName || '';
    const organizer = ev.organizer?.emailAddress?.name || '';
    const meta = [where, organizer].filter(Boolean).join(' · ');
    return `<div class="tl-row tool" data-ts="${ts}">
      <div class="tl-t"><span class="day">${day}</span>${hhmm}</div>
      <div class="tl-dot"></div>
      <div class="tl-body">
        <span class="ki">Calendar</span>
        <em>${escapeHtml(subject)}</em>
        ${meta ? `<div style="font-family:var(--mono);font-size:9.5px;color:var(--ink-4);letter-spacing:.04em;margin-top:3px">${escapeHtml(meta)}</div>` : ''}
      </div>
    </div>`;
  }

  function renderTimelineRow(a) {
    const t = new Date(a.occurred_at);
    const hhmm = t.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    const day = t.toLocaleDateString(undefined, { weekday: 'short' });
    let cls = 'tool', label = a.kind.toUpperCase(), body = '';
    if (a.kind === 'voice_turn') {
      cls = 'voice';
      label = `Voice · ${a.payload?.speaker || 'agent'}`;
      body = escapeHtml(a.payload?.transcript || '').slice(0, 280);
    } else if (a.kind === 'tool_call') {
      cls = 'tool';
      label = `Tool · ${a.payload?.tool_name || 'call'}`;
      body = `Duration ${a.payload?.duration_ms || '?'}ms`;
    } else if (a.kind === 'approval') {
      cls = 'doc';
      label = `Approval · ${a.payload?.decision || 'unresolved'}`;
      body = escapeHtml(a.payload?.phrase || '');
    } else {
      cls = 'tool';
      body = escapeHtml(JSON.stringify(a.payload || {})).slice(0, 200);
    }
    return `<div class="tl-row ${cls}" data-ts="${t.getTime()}">
      <div class="tl-t"><span class="day">${day}</span>${hhmm}</div>
      <div class="tl-dot"></div>
      <div class="tl-body">
        <span class="ki">${escapeHtml(label)}</span>
        ${body}
      </div>
    </div>`;
  }

  function renderDocRow(item) {
    const kindLabel = {
      vault_item: 'VAULT',
      library_document: 'DOCX',
      chat: 'CHAT',
      email_thread: 'EML',
      calendar_event: 'CAL',
      redline_run: 'REDLINE',
      compare_run: 'COMPARE',
      tr_review: 'TABLE',
      citation_run: 'CITES',
      manual_note: 'NOTE',
    }[item.item_kind] || item.item_kind.toUpperCase();
    const title = item.metadata?.title || `Linked ${item.item_kind.replace(/_/g, ' ')}`;
    const meta = item.metadata?.summary || `Attached ${fmt(item.attached_at)}`;
    const linkPath = {
      vault_item: `/workspace/vault/?item=${item.item_ref_id}`,
      library_document: `/workspace/library/?id=${item.item_ref_id}`,
      chat: `/workspace/chat/?id=${item.item_ref_id}`,
    }[item.item_kind];
    const a_open = linkPath ? `<a href="${linkPath}" class="doc">` : `<div class="doc">`;
    const a_close = linkPath ? `</a>` : `</div>`;
    return `${a_open}
      <span class="doc-ic">${kindLabel}</span>
      <span class="doc-name">${escapeHtml(title)}</span>
      <span class="doc-meta">${escapeHtml(meta)}</span>
      <span class="doc-r"><span class="lab">Linked</span>${item.attached_by}</span>
    ${a_close}`;
  }

  // Fetch + render
  async function refreshMatter() {
    try {
      const r = await fetch(`/.netlify/functions/paralegal-matters-get?id=${encodeURIComponent(matterId)}`, {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok) {
        console.error('[matter] load failed', j);
        const h1 = document.querySelector('.mhead h1');
        if (h1) h1.textContent = j.error || 'Matter not found';
        return;
      }
      applyMatter(j.matter, j.items || [], j.pending_actions || [], j.recent_audit || []);
    } catch (err) {
      console.error('[matter] fetch failed', err);
    }
  }
  await refreshMatter();

  // ----- Attach-item picker (vault / library / chats)
  const attachVeil = document.getElementById('attach-veil');
  const attachBtn = document.getElementById('btn-attach-item');
  const attachClose = document.getElementById('attach-close');
  const attachSearch = document.getElementById('attach-search');
  const attachResults = document.getElementById('attach-results');
  const attachErr = document.getElementById('attach-error');
  let attachSource = 'vault';

  function openAttach() {
    attachVeil.style.display = 'flex';
    attachSearch.value = '';
    attachSearch.focus();
    loadAttachResults();
  }
  function closeAttach() {
    attachVeil.style.display = 'none';
  }
  attachBtn.addEventListener('click', openAttach);
  attachClose.addEventListener('click', closeAttach);
  attachVeil.addEventListener('click', e => { if (e.target === attachVeil) closeAttach(); });
  window.addEventListener('keydown', e => { if (e.key === 'Escape') closeAttach(); });

  document.querySelectorAll('.att-tab').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.att-tab').forEach(x => {
        x.classList.remove('is-active');
        x.style.background = 'transparent';
        x.style.borderColor = 'var(--rule-thread)';
        x.style.color = 'var(--ink-3)';
      });
      b.classList.add('is-active');
      b.style.background = 'var(--paper-2)';
      b.style.borderColor = 'var(--ink)';
      b.style.color = 'var(--ink)';
      attachSource = b.dataset.source;
      loadAttachResults();
    });
  });

  let attachDebounce;
  attachSearch.addEventListener('input', () => {
    clearTimeout(attachDebounce);
    attachDebounce = setTimeout(loadAttachResults, 220);
  });

  async function loadAttachResults() {
    const q = attachSearch.value.trim();
    attachResults.innerHTML = `<div style="padding:18px;font-family:var(--mono);font-size:10px;color:var(--ink-3)">Searching…</div>`;
    attachErr.style.display = 'none';
    try {
      let items = [];
      if (attachSource === 'vault') {
        const url = new URL('/.netlify/functions/workspace-vault-list', location.origin);
        if (q) url.searchParams.set('q', q);
        url.searchParams.set('limit', '40');
        const r = await fetch(url, { headers: { Authorization: `Bearer ${accessToken}` } });
        const j = await r.json();
        if (!r.ok) throw new Error(j.error || 'Vault search failed');
        items = (j.items || []).map(v => ({
          kind: 'vault_item',
          ref_id: v.id,
          title: v.title || '(untitled)',
          meta: `${(v.content || '').slice(0, 80)}…`,
        }));
      } else if (attachSource === 'library') {
        const url = new URL('/.netlify/functions/workspace-library-list', location.origin);
        const r = await fetch(url, { headers: { Authorization: `Bearer ${accessToken}` } });
        const j = await r.json();
        if (!r.ok) throw new Error(j.error || 'Library list failed');
        const filtered = q
          ? (j.documents || []).filter(d => (d.filename || d.original_filename || '').toLowerCase().includes(q.toLowerCase()))
          : (j.documents || []);
        items = filtered.slice(0, 40).map(d => ({
          kind: 'library_document',
          ref_id: d.id,
          title: d.filename || d.original_filename || '(untitled)',
          meta: `${d.file_type || ''} · ${((d.size_bytes || 0) / 1024).toFixed(1)} KB`,
        }));
      } else if (attachSource === 'chats') {
        const url = new URL('/.netlify/functions/workspace-chats-list', location.origin);
        url.searchParams.set('limit', '40');
        const r = await fetch(url, { headers: { Authorization: `Bearer ${accessToken}` } });
        const j = await r.json();
        if (!r.ok) throw new Error(j.error || 'Chat list failed');
        const filtered = q
          ? (j.chats || []).filter(c => (c.title || '').toLowerCase().includes(q.toLowerCase()))
          : (j.chats || []);
        items = filtered.slice(0, 40).map(c => ({
          kind: 'chat',
          ref_id: c.id,
          title: c.title || '(Untitled chat)',
          meta: `${c.model || ''} · updated ${new Date(c.updated_at).toLocaleDateString()}`,
        }));
      }

      if (items.length === 0) {
        attachResults.innerHTML = `<div style="padding:18px;font-family:var(--serif);font-style:italic;font-size:15px;color:var(--ink-3)">No matching items.</div>`;
        return;
      }
      attachResults.innerHTML = items.map(it => `
        <div class="att-row" data-kind="${it.kind}" data-ref="${it.ref_id}" data-title="${escapeHtml(it.title)}" style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;padding:10px 14px;border-bottom:1px dotted var(--rule-soft);cursor:pointer;background:var(--paper)">
          <div>
            <div style="font-family:var(--serif);font-size:15px;color:var(--ink);line-height:1.3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escapeHtml(it.title)}</div>
            <div style="font-family:var(--mono);font-size:9.5px;color:var(--ink-4);letter-spacing:.04em;margin-top:2px">${escapeHtml(it.meta)}</div>
          </div>
          <button style="font-family:var(--mono);font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;padding:5px 10px;border:1px solid var(--ink);border-radius:2px;background:var(--ink);color:var(--paper);cursor:pointer">Attach</button>
        </div>
      `).join('');

      attachResults.querySelectorAll('.att-row').forEach(row => {
        row.addEventListener('click', () => attachItem({
          kind: row.dataset.kind,
          ref_id: row.dataset.ref,
          title: row.dataset.title,
        }));
      });
    } catch (err) {
      attachErr.textContent = err.message || 'Search failed';
      attachErr.style.display = 'block';
      attachResults.innerHTML = '';
    }
  }

  async function attachItem({ kind, ref_id, title }) {
    attachErr.style.display = 'none';
    try {
      const r = await fetch('/.netlify/functions/paralegal-matter-items-attach', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          matter_id: matterId,
          item_kind: kind,
          item_ref_id: ref_id,
          metadata: { title },
          attached_by: 'user',
        }),
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Attach failed');
      closeAttach();
      await refreshMatter();
    } catch (err) {
      attachErr.textContent = err.message || 'Attach failed';
      attachErr.style.display = 'block';
    }
  }
}
</script>

</body>
</html>
