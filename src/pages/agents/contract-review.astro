---
import Consent from '../../partials/consent.astro';
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Contract Review — Legal Overflow</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<link rel="stylesheet" href="/contract-review.css" />
<style>
  /* Page-local overrides so the preview's CSS plays with the site nav */
  .cr-sub-nav {
    max-width: 1400px; margin: 0 auto; padding: 14px 40px 0;
    display: flex; gap: 24px; align-items: center;
    border-bottom: 1px solid var(--rule-soft);
  }
  .cr-sub-nav .tab {
    font-family: var(--mono); font-size: 11.5px; letter-spacing: .08em; text-transform: uppercase;
    color: var(--ink-3); padding: 10px 0; cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color .2s ease, border-color .2s ease;
  }
  .cr-sub-nav .tab:hover { color: var(--ink); }
  .cr-sub-nav .tab.active { color: var(--ink); border-bottom-color: var(--accent-deep); }
  .cr-quota { margin-left: auto; font-family: var(--mono); font-size: 11px; color: var(--ink-3); letter-spacing: .04em; text-transform: uppercase; }
  .cr-quota .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--accent); margin-right: 8px; vertical-align: middle; }
  /* Hide duplicate elements from the ported preview (its own nav, kickers we don't want) */
  .view .banner { background: rgba(10,125,87,.06); border: 1px solid var(--rule-soft); padding: 14px 18px; border-radius: 6px; font-size: 13.5px; color: var(--ink-2); display: flex; gap: 14px; align-items: center; margin: 16px 0 24px; }
  .view .banner-tag { font-family: var(--mono); font-size: 10px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; background: var(--accent-deep); color: var(--paper); padding: 3px 8px; border-radius: 999px; }
  .cr-empty-state { padding: 40px; text-align: center; color: var(--ink-3); font-family: var(--mono); font-size: 12px; letter-spacing: .04em; text-transform: uppercase; }
</style>
</head>
<body>
<div id="grain"></div>

<header class="nav">
  <a href="/" class="brand">
    <svg class="brand-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="1"/><path d="M20 6 L20 34 M8 14 L32 14 M8 26 L32 26" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="20" cy="14" r="2.5" fill="currentColor"/><circle cx="20" cy="26" r="2.5" fill="var(--accent)"/></svg>
    <span class="brand-text"><span>Legal</span><span class="brand-over">Overflow</span></span>
  </a>
  <nav class="nav-links">
    <a href="/#skills">Skills</a>
    <a href="/#articles">Resources</a>
    <a href="/agents/">Agents</a>
    <a href="/#services">Services</a>
    <a href="/about/">About</a>
  </nav>
  <div class="nav-right">
    <span class="nav-meta" id="nav-clock">—</span>
    <button id="cr-signout" class="nav-sub" style="border:none;font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;cursor:pointer;">Sign out</button>
  </div>
</header>

<!-- Sub-nav — view tabs for Configure | Review | Archive -->
<div class="cr-sub-nav">
  <span class="tab active" data-view="configure">Configure</span>
  <span class="tab" data-view="review">Review</span>
  <span class="tab" data-view="history">Archive</span>
  <span class="cr-quota" id="quota-indicator"><span class="dot"></span><span id="quota-text">Loading…</span></span>
</div>

<main>
  <!-- ============================================================
       VIEW: Configure — playbook upload path (MVP)
       ============================================================ -->
  <section id="view-configure" class="view active">
    <div class="kicker">
      <span class="kicker-dash"></span>
      <span>Step 1 · Configure</span>
    </div>

    <h1 class="hero-title">
      <span class="rise rise-1">The firm is</span>
      <span class="rise rise-2"><em>learning</em> to</span>
      <span class="rise rise-3">read its own contracts.</span>
    </h1>

    <p class="hero-sub rise rise-3">
      Upload your negotiating playbook once. Every contract you review after that is read in your voice,
      against your positions, flagging the deal-breakers you've already decided are deal-breakers.
    </p>

    <!-- Profile status banner -->
    <div id="profile-status" class="banner" style="display:none;">
      <span class="banner-tag">Profile</span>
      <span id="profile-status-text">Profile loaded. Head to Review when ready.</span>
    </div>

    <!-- Compact fast-track bar: already have a playbook? -->
    <div class="fast-track fast-track-compact" id="fast-track">
      <div class="fast-track-copy">
        <span class="fast-track-title">Already have a <em>playbook</em>?</span>
        <span class="fast-track-sub">.docx · .pdf · .md · .txt — skip the form and parse your document</span>
      </div>
      <button id="playbook-upload-btn" class="btn btn-ghost btn-sm">
        Upload
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
    </div>

    <input type="file" id="playbook-file-input" accept=".docx,.pdf,.md,.txt" style="display:none;" />

    <!-- Main: form + brainstorm-chat helper, side by side -->
    <div class="configure-grid">
      <!-- Left: the form (primary path) -->
      <div class="panel quick-setup-panel">
        <div class="quick-setup-header">
          <h2 class="quick-setup-heading">Tell us <em>how you negotiate.</em></h2>
          <p class="quick-setup-lede">Fill in what you can. Stuck on a field? Ask the brainstorm assistant on the right for suggestions.</p>
        </div>
        <div class="quick-setup-body">
          <div class="qs-grid">
            <label class="qs-field">
              <span class="qs-label">Company legal name</span>
              <input type="text" id="qs-company" placeholder="e.g., Magic Inc." />
            </label>
            <label class="qs-field">
              <span class="qs-label">Primary jurisdiction (state)</span>
              <input type="text" id="qs-jurisdiction" placeholder="e.g., Florida" />
            </label>
            <label class="qs-field">
              <span class="qs-label">Industry</span>
              <select id="qs-industry">
                <option value="">Select…</option>
                <option>Software / SaaS</option>
                <option>Professional Services</option>
                <option>Construction</option>
                <option>Manufacturing</option>
                <option>Healthcare</option>
                <option>Financial Services</option>
                <option>Retail / Consumer</option>
                <option>Logistics / Transportation</option>
                <option>Energy / Utilities</option>
                <option>Other</option>
              </select>
            </label>
            <label class="qs-field">
              <span class="qs-label">Typical role in contracts</span>
              <select id="qs-role">
                <option value="">Select…</option>
                <option>Vendor / Provider</option>
                <option>Customer / Buyer</option>
                <option>Licensor</option>
                <option>Licensee</option>
                <option>Contractor</option>
                <option>Subcontractor</option>
                <option>Mixed (both sides)</option>
              </select>
            </label>
            <label class="qs-field qs-field-wide">
              <span class="qs-label-row">
                <span class="qs-label">What does the company do? (2–3 sentences)</span>
                <button type="button" class="qs-help-btn" data-help-field="description">Ask for ideas</button>
              </span>
              <textarea id="qs-description" rows="2" placeholder="We build marketing-automation software for mid-market e-commerce teams."></textarea>
            </label>
            <label class="qs-field">
              <span class="qs-label">Liability cap preference</span>
              <select id="qs-liability">
                <option value="">Select…</option>
                <option>1× fees (aggressive)</option>
                <option>2× fees paid</option>
                <option>Fees paid in prior 12 months</option>
                <option>Greater of $X or 2× fees</option>
                <option>No preference yet</option>
              </select>
            </label>
            <label class="qs-field">
              <span class="qs-label">Payment terms preference</span>
              <select id="qs-payment">
                <option value="">Select…</option>
                <option>Net 15</option>
                <option>Net 30</option>
                <option>Net 45</option>
                <option>Net 60 (reluctantly)</option>
                <option>Upon receipt</option>
                <option>No preference yet</option>
              </select>
            </label>
            <label class="qs-field qs-field-wide">
              <span class="qs-label-row">
                <span class="qs-label">Deal-breakers / red flags (one per line)</span>
                <button type="button" class="qs-help-btn" data-help-field="red_flags">Ask for ideas</button>
              </span>
              <textarea id="qs-red-flags" rows="5" placeholder="Auto-renewal without written notice&#10;Unlimited indemnification&#10;Waiver of jury trial&#10;Unilateral modification rights"></textarea>
            </label>
            <label class="qs-field qs-field-wide">
              <span class="qs-label-row">
                <span class="qs-label">Anything else worth knowing? (insurance limits, statutes, tone — optional)</span>
                <button type="button" class="qs-help-btn" data-help-field="notes">Ask for ideas</button>
              </span>
              <textarea id="qs-notes" rows="3" placeholder="We carry $5M cyber. Please cite FL prompt-payment statute where relevant."></textarea>
            </label>
          </div>
          <div style="margin-top: 20px; display:flex; gap:12px; flex-wrap:wrap; align-items:center;">
            <button class="btn btn-primary" id="qs-submit-btn">
              Build profile
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </button>
            <span id="qs-status" class="qs-status"></span>
          </div>
        </div>
      </div>

      <!-- Right: brainstorm chat helper -->
      <div class="panel chat-panel brainstorm-panel">
        <div class="chat-topbar">
          <div>
            <div class="chat-topbar-title">Brainstorm <em>assistant</em></div>
            <div style="font-size:12px;color:var(--ink-3);margin-top:2px;">Stuck? Ask for suggestions — one click pastes into the form.</div>
          </div>
          <div class="chat-topbar-status"><span class="live-dot" style="width:6px;height:6px"></span> Ready</div>
        </div>
        <div class="chat-scroll" id="chat-scroll"></div>
        <div class="msg-counter" id="msg-counter" style="display:none;">
          <span id="msg-counter-label">0 of 15 messages</span>
          <div class="msg-counter-bar"><div class="msg-counter-fill" id="msg-counter-fill"></div></div>
          <span>Cap: 15</span>
        </div>
        <div class="chat-input-area">
          <div class="chat-input-row">
            <textarea class="chat-input" id="chat-input" rows="1" placeholder='e.g., "What red flags should a SaaS vendor watch for?"'></textarea>
            <button class="btn btn-primary btn-sm" id="send-btn">
              Send
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Parse results — shown after submit -->
    <div class="playbook-parse hidden" id="playbook-parse">
      <div class="playbook-parse-title">Your profile is <em>saved</em></div>
      <div id="playbook-parse-fields"></div>
      <div style="margin-top:20px; display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn btn-primary btn-sm" id="goto-review-btn">
          Go to Review
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
        <button class="btn btn-ghost btn-sm" id="playbook-reupload-btn">Edit / re-run</button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       VIEW: Review — upload contract → progress → results
       ============================================================ -->
  <section id="view-review" class="view">
    <div class="kicker">
      <span class="kicker-dash"></span>
      <span>Step 2 · Review</span>
    </div>

    <h1 class="hero-title">
      <span class="rise rise-1">Upload a contract.</span>
      <span class="rise rise-2">Get it <em>back</em>, marked up,</span>
      <span class="rise rise-3">in about sixty seconds.</span>
    </h1>

    <p class="hero-sub rise rise-3">
      PDF or Word. The platform classifies the document, fans out to every specialist in your profile,
      applies native tracked changes, and returns the file in the format you sent it.
    </p>

    <!-- Quota-exceeded state -->
    <div id="review-blocked" class="quota-block hidden">
      <h3>You've used all <em>3</em> trial reviews this window.</h3>
      <p>Your trial allows three full contract reviews per 30-day window. Your window resets automatically, or upgrade for more capacity.</p>
    </div>

    <!-- Upload -->
    <div id="review-upload" class="panel" style="padding:40px;">
      <div class="upload-posture">
        <label for="deal-posture-select" class="upload-posture-label">Deal posture <span class="req">*</span></label>
        <select id="deal-posture-select" required>
          <option value="">Select the deal's negotiating posture…</option>
          <option value="our_paper">Our paper — client's own form</option>
          <option value="their_paper_high_leverage">Their paper — we need this deal</option>
          <option value="their_paper_low_leverage">Their paper — they need this deal</option>
          <option value="negotiated_draft">Negotiated draft — both sides editing</option>
        </select>
        <div class="upload-posture-hint">Affects how aggressively the specialists push back on deviations from the playbook.</div>
      </div>
      <div class="dropzone" id="dropzone">
        <div class="dropzone-title">Drop a contract <em>here</em></div>
        <div class="dropzone-sub">or click to select a file</div>
        <div class="format-row">
          <span>.pdf</span>
          <span>.docx</span>
          <span>Up to 50 MB</span>
        </div>
      </div>
      <input type="file" id="contract-file-input" accept=".pdf,.docx,.txt,.md" style="display:none;" />
    </div>

    <!-- Classification confirm (between upload and progress) -->
    <div id="review-confirm" class="panel hidden">
      <div class="confirm-head">
        <div class="kicker"><span class="kicker-dash"></span><span>Confirm</span></div>
        <h2 class="confirm-title">Classified as <em id="confirm-contract-type">—</em></h2>
        <div class="confirm-sub" id="confirm-sub">Running standard pipeline. Change mode if you disagree.</div>
        <div class="confirm-confidence" id="confirm-confidence"></div>
      </div>

      <!-- Governing-agreement context: shown when classifier marks doc as subordinate -->
      <div id="confirm-governing" class="confirm-governing hidden">
        <div class="confirm-governing-head">Governing MSA / master-agreement context</div>
        <div class="confirm-governing-sub">This looks like a subordinate document. The specialists need to know what the governing MSA covers so they don't flag provisions already handled upstream.</div>
        <div class="confirm-governing-tabs">
          <button type="button" class="cg-tab active" data-cg-tab="summary">Paste key terms</button>
          <button type="button" class="cg-tab" data-cg-tab="file">Upload MSA file</button>
          <button type="button" class="cg-tab" data-cg-tab="skip">Skip (no MSA)</button>
        </div>
        <div class="confirm-governing-body">
          <textarea id="cg-summary" class="cg-panel" rows="4" placeholder="e.g. Indemnification is mutual; liability cap is 2× fees paid in prior 12 months; IP ownership retained by Provider; 30-day termination for convenience; Delaware governing law."></textarea>
          <div id="cg-file-panel" class="cg-panel hidden">
            <input type="file" id="cg-file-input" accept=".pdf,.docx,.txt,.md" />
            <div class="cg-file-hint">Upload the MSA file; the specialists will treat it as context for what's already covered.</div>
          </div>
          <div id="cg-skip-panel" class="cg-panel hidden">
            <div class="cg-file-hint">Proceeding without MSA context. Specialists will assume no governing agreement — this may produce more "missing provision" findings.</div>
          </div>
        </div>
      </div>

      <div class="confirm-mode-row">
        <div class="confirm-mode-label">Pipeline mode</div>
        <div class="confirm-mode-options">
          <button type="button" class="confirm-mode-btn" data-mode="express">Express</button>
          <button type="button" class="confirm-mode-btn" data-mode="standard">Standard</button>
          <button type="button" class="confirm-mode-btn" data-mode="comprehensive">Comprehensive</button>
        </div>
      </div>

      <div class="confirm-actions">
        <button type="button" class="btn btn-primary" id="confirm-start-btn">
          Run review <span id="confirm-countdown" class="confirm-countdown"></span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
        <button type="button" class="btn btn-ghost btn-sm" id="confirm-cancel-btn">Cancel</button>
      </div>
    </div>

    <!-- Progress -->
    <div id="review-progress" class="panel hidden">
      <div class="progress-file">
        <div class="progress-file-icon" id="progress-file-icon">DOCX</div>
        <div>
          <div class="progress-file-name" id="progress-file-name">file.docx</div>
          <div class="progress-file-sub" id="progress-file-sub">Uploading…</div>
        </div>
        <div class="progress-elapsed">
          <span class="progress-elapsed-label">Elapsed</span>
          <span class="progress-elapsed-time" id="progress-elapsed-time">0:00</span>
        </div>
      </div>
      <div class="stage-list">
        <div class="stage pending" data-stage="extract">
          <div class="stage-icon"><span>01</span></div>
          <div class="stage-label">Extract canonical text</div>
          <div class="stage-detail"></div>
        </div>
        <div class="stage pending" data-stage="classify">
          <div class="stage-icon"><span>02</span></div>
          <div class="stage-label">Classify document</div>
          <div class="stage-detail"></div>
        </div>
        <div class="stage pending" data-stage="specialists">
          <div class="stage-icon"><span>03</span></div>
          <div class="stage-label">Run specialist reviewers</div>
          <div class="stage-detail"></div>
        </div>
        <div class="stage pending" data-stage="audit">
          <div class="stage-icon"><span>04</span></div>
          <div class="stage-label">Critical-issues sweep</div>
          <div class="stage-detail"></div>
        </div>
        <div class="stage pending" data-stage="assemble">
          <div class="stage-icon"><span>05</span></div>
          <div class="stage-label">Assemble markup &amp; summary</div>
          <div class="stage-detail"></div>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="review-results" class="panel hidden">
      <div class="results-head">
        <div class="kicker results-head-kicker">
          <span class="kicker-dash"></span>
          <span id="results-subtitle">Review complete</span>
        </div>
        <div class="results-head-title" id="results-title">Review — <em>—</em></div>
        <div class="results-head-sub" id="results-sub">— findings</div>
        <div class="results-meta">
          <div><div class="results-meta-l">Contract type</div><div class="results-meta-v" id="results-ct">—</div></div>
          <div><div class="results-meta-l">Pipeline</div><div class="results-meta-v" id="results-mode">—</div></div>
          <div><div class="results-meta-l">Findings</div><div class="results-meta-v" id="results-count">—</div></div>
          <div><div class="results-meta-l">Tokens</div><div class="results-meta-v" id="results-tokens">—</div></div>
        </div>
      </div>
      <div class="severity-row">
        <div class="sev blocker"><div class="sev-l">Blocker</div><div class="sev-n" id="sev-blocker">0</div></div>
        <div class="sev major"><div class="sev-l">Major</div><div class="sev-n" id="sev-major">0</div></div>
        <div class="sev moderate"><div class="sev-l">Moderate</div><div class="sev-n" id="sev-moderate">0</div></div>
        <div class="sev minor"><div class="sev-l">Minor</div><div class="sev-n" id="sev-minor">0</div></div>
      </div>

      <!-- Tabbed results panel: Top 3 | All Findings | Structural | Coverage -->
      <div class="results-tabs-wrap">
        <nav class="results-tabs" role="tablist" aria-label="Review results">
          <button type="button" class="results-tab active" data-tab="priority" role="tab">Top 3<span class="tab-count" id="tab-count-priority">0</span></button>
          <button type="button" class="results-tab" data-tab="findings" role="tab">All Findings<span class="tab-count" id="tab-count-findings">0</span></button>
          <button type="button" class="results-tab" data-tab="structural" role="tab">Structural<span class="tab-count" id="tab-count-structural">0</span></button>
          <button type="button" class="results-tab" data-tab="coverage" role="tab">Coverage<span class="tab-count" id="tab-count-coverage">0</span></button>
        </nav>

        <!-- Tab: Top 3 to Raise -->
        <div class="tab-panel active" data-tab-panel="priority">
          <div class="priority-three-section" id="priority-three-section">
            <div class="priority-three-head">
              <div class="priority-three-title">Top 3 to Raise</div>
              <div class="priority-three-sub">Partner-level summary. Raise these on a call before sending the full redline.</div>
            </div>
            <div class="priority-three-list" id="priority-three-list">
              <div class="findings-empty">No priority findings for this review.</div>
            </div>
          </div>
        </div>

        <!-- Tab: All Findings (filterable) -->
        <div class="tab-panel" data-tab-panel="findings">
          <div class="findings-section" id="findings-section">
            <div class="findings-head">
              <div>
                <span class="findings-title">All Findings</span>
                <div class="findings-sub" id="findings-sub">Click any finding to expand its details.</div>
              </div>
              <div class="findings-filters" id="findings-filters" role="tablist" aria-label="Filter findings by severity"></div>
            </div>
            <div class="findings-list" id="findings-list">
              <div class="findings-empty">Loading findings…</div>
            </div>
          </div>
        </div>

        <!-- Tab: Structural issues / missing clauses -->
        <div class="tab-panel" data-tab-panel="structural">
          <div class="structural-section" id="structural-section">
            <div class="structural-head">
              <div class="structural-title">Structural issues / missing clauses</div>
              <div class="structural-sub">Findings that can't be pinned to a specific line of text. Usually the most strategic items — read these first.</div>
            </div>
            <div class="structural-list" id="structural-list">
              <div class="findings-empty">No structural issues for this review.</div>
            </div>
          </div>
        </div>

        <!-- Tab: Coverage pass — per-specialist audit trail -->
        <div class="tab-panel" data-tab-panel="coverage">
          <div class="coverage-section" id="coverage-section">
            <div class="coverage-head">
              <div class="coverage-title">Coverage Pass</div>
              <div class="coverage-sub">Every specialist's enumeration of what it checked, grouped by specialist. Expand each specialist to see the full list.</div>
            </div>
            <div class="coverage-list" id="coverage-list">
              <div class="findings-empty">No coverage data for this review.</div>
            </div>
          </div>
        </div>
      </div>

      <div class="action-row" id="results-actions"></div>
      <div class="back-row">
        <button class="btn btn-ghost btn-sm" id="review-another-btn">← Review another contract</button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       VIEW: Archive
       ============================================================ -->
  <section id="view-history" class="view">
    <div class="kicker">
      <span class="kicker-dash"></span>
      <span>Archive</span>
    </div>
    <h1 class="hero-title">
      <span class="rise rise-1">Every contract</span>
      <span class="rise rise-2">the platform has <em>read</em>.</span>
    </h1>
    <p class="hero-sub rise rise-3">Click any row to reopen its outputs.</p>

    <div class="panel history-list" id="history-list">
      <div class="history-col-head">
        <div>Contract</div>
        <div>Type</div>
        <div>Date</div>
        <div>Findings</div>
        <div>Status</div>
      </div>
      <div id="history-rows">
        <div class="cr-empty-state">Loading…</div>
      </div>
    </div>
  </section>
</main>

<script>
  import { getSupabase } from '../../lib/supabase';
  import * as api from '../../lib/client-api';

  const supabase = getSupabase();

  // ---- Auth gate ----
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    location.href = '/login/?redirect=/agents/contract-review/';
  }

  // ---- Sign out ----
  document.getElementById('cr-signout').addEventListener('click', async () => {
    await supabase.auth.signOut();
    location.href = '/';
  });

  // ---- Clock ----
  (function clock() {
    const el = document.getElementById('nav-clock');
    if (!el) return;
    function tick() {
      const d = new Date();
      let h = d.getHours();
      const ampm = h >= 12 ? 'PM' : 'AM';
      h = h % 12; if (h === 0) h = 12;
      const mm = String(d.getMinutes()).padStart(2, '0');
      el.textContent = `COCOA · ${h}:${mm} ${ampm}`;
    }
    tick(); setInterval(tick, 30000);
  })();

  // ---- View switcher ----
  const tabs = document.querySelectorAll('.cr-sub-nav .tab');
  const views = document.querySelectorAll('.view');
  function switchView(name) {
    tabs.forEach(t => t.classList.toggle('active', t.dataset.view === name));
    views.forEach(v => v.classList.toggle('active', v.id === 'view-' + name));
    if (name === 'history') loadArchive();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  tabs.forEach(t => t.addEventListener('click', () => switchView(t.dataset.view)));
  document.getElementById('goto-review-btn')?.addEventListener('click', () => switchView('review'));
  document.getElementById('review-another-btn')?.addEventListener('click', () => {
    document.getElementById('review-results').classList.add('hidden');
    document.getElementById('review-upload').classList.remove('hidden');
    document.getElementById('review-progress').classList.add('hidden');
  });

  // Latest-known profile — used by the chat so it layers nuance on top
  // of whatever the quick-setup form / playbook upload already saved.
  let currentProfile = null;

  // ---- Profile status / quota ----
  async function refreshStatus() {
    try {
      const profile = await api.getProfile();
      currentProfile = profile;
      const banner = document.getElementById('profile-status');
      const txt = document.getElementById('profile-status-text');
      if (profile) {
        banner.style.display = 'flex';
        txt.textContent = 'Profile loaded. Head to Review when ready.';
      } else {
        banner.style.display = 'none';
      }
    } catch (e) {
      console.error('profile status:', e);
    }
    try {
      const reviews = await api.listReviews();
      const used = reviews.length;
      const cap = 3; // trial
      const remaining = Math.max(0, cap - used);
      const text = document.getElementById('quota-text');
      text.textContent = `${remaining} of ${cap} reviews left`;
    } catch (e) {
      console.error('quota status:', e);
    }
  }
  // First refreshStatus() is awaited by the chat opener below.

  // ---- Playbook upload ----
  const playbookBtn = document.getElementById('playbook-upload-btn');
  const playbookInput = document.getElementById('playbook-file-input');
  const fastTrack = document.getElementById('fast-track');
  playbookBtn.addEventListener('click', () => playbookInput.click());
  fastTrack.addEventListener('click', (e) => { if (e.target === fastTrack || e.target.closest('.fast-track-copy')) playbookInput.click(); });
  document.getElementById('playbook-reupload-btn')?.addEventListener('click', () => playbookInput.click());

  playbookInput.addEventListener('change', async () => {
    const file = playbookInput.files?.[0];
    if (!file) return;
    const fastTrackCopy = fastTrack.querySelector('.fast-track-sub');
    fastTrackCopy.textContent = 'Parsing…';
    try {
      const result = await api.uploadPlaybook(file);
      fastTrackCopy.textContent = 'Parsed. Your profile is saved — scroll down to view it.';
      const panel = document.getElementById('playbook-parse');
      const fields = document.getElementById('playbook-parse-fields');
      fields.innerHTML = renderProfileSummary(result.profile);
      panel.classList.remove('hidden');
      currentProfile = result.profile;
      await refreshStatus();
      // Bring the summary panel into view so users don't miss it
      panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (err) {
      fastTrackCopy.textContent = 'Error: ' + err.message;
    }
  });

  // ---- Quick Setup form — one API call via uploadPlaybook ----
  const qsSubmit = document.getElementById('qs-submit-btn');
  const qsStatus = document.getElementById('qs-status');
  if (qsSubmit) {
    qsSubmit.addEventListener('click', async () => {
      const val = (id) => (document.getElementById(id)?.value || '').trim();
      const company = val('qs-company');
      const industry = val('qs-industry');
      const role = val('qs-role');
      const jurisdiction = val('qs-jurisdiction');
      const description = val('qs-description');
      const liability = val('qs-liability');
      const payment = val('qs-payment');
      const redFlags = val('qs-red-flags');
      const notes = val('qs-notes');

      if (!company || !description) {
        qsStatus.className = 'qs-status err';
        qsStatus.textContent = 'Please fill in at least company name and description.';
        return;
      }

      // Build a structured "playbook" text blob. The workflow-configurator
      // agent reads this and normalizes it into the profile schema.
      const blob = [
        'COMPANY CONTRACT-REVIEW PLAYBOOK',
        '================================',
        '',
        `Company legal name: ${company}`,
        industry && `Industry: ${industry}`,
        role && `Typical role in contracts: ${role}`,
        jurisdiction && `Primary jurisdiction: ${jurisdiction}`,
        '',
        'Business description:',
        description,
        '',
        'Commercial positions:',
        liability && `- Liability cap preference: ${liability}`,
        payment && `- Payment terms preference: ${payment}`,
        '',
        redFlags && 'Red flags / deal-breakers (one per line):',
        redFlags,
        '',
        notes && 'Additional notes and preferences:',
        notes && notes,
      ].filter(Boolean).join('\n');

      const file = new File([blob], 'quick-setup.txt', { type: 'text/plain' });

      qsSubmit.disabled = true;
      qsStatus.className = 'qs-status';
      qsStatus.textContent = 'Building profile…';
      try {
        const result = await api.uploadPlaybook(file);
        qsStatus.className = 'qs-status ok';
        qsStatus.textContent = 'Profile saved — see summary below.';
        const panel = document.getElementById('playbook-parse');
        const fields = document.getElementById('playbook-parse-fields');
        fields.innerHTML = renderProfileSummary(result.profile);
        panel.classList.remove('hidden');
        currentProfile = result.profile;
        await refreshStatus();
        panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } catch (err) {
        qsStatus.className = 'qs-status err';
        qsStatus.textContent = 'Error: ' + err.message;
      } finally {
        qsSubmit.disabled = false;
      }
    });
  }

  function renderProfileSummary(profile) {
    const rows = [];
    const push = (k, v) => rows.push(`<div class="playbook-parse-line"><span class="playbook-parse-k">${k}</span><span class="playbook-parse-v">${v || '—'}</span><span class="playbook-parse-check">✓ ingested</span></div>`);
    push('Company', profile.company?.name || profile.company_name);
    push('Industry', profile.industry || profile.sector);
    push('Role', profile.role || profile.typical_role);
    push('Jurisdiction', profile.jurisdiction || profile.governing_law);
    const positions = profile.positions ? Object.keys(profile.positions).length : 0;
    push('Positions', positions ? `${positions} position group(s)` : '—');
    const redFlags = Array.isArray(profile.red_flags) ? profile.red_flags.length : (profile.red_flags ? Object.keys(profile.red_flags).length : 0);
    push('Red flags', redFlags ? `${redFlags} flag(s)` : '—');
    return rows.join('');
  }

  // ---- Brainstorm chat (helps the user fill the form) ----
  const chatScroll = document.getElementById('chat-scroll');
  const chatInput = document.getElementById('chat-input');
  const sendBtn = document.getElementById('send-btn');
  const msgCounter = document.getElementById('msg-counter');
  const msgCounterLabel = document.getElementById('msg-counter-label');
  const msgCounterFill = document.getElementById('msg-counter-fill');
  const chatHistory = [];

  // Map of backend suggest-field names to the form input IDs they should
  // write into. The chat model is told the exact set of allowed names.
  const FIELD_TO_INPUT_ID = {
    company: 'qs-company',
    jurisdiction: 'qs-jurisdiction',
    industry: 'qs-industry',
    role: 'qs-role',
    description: 'qs-description',
    liability: 'qs-liability',
    payment: 'qs-payment',
    red_flags: 'qs-red-flags',
    notes: 'qs-notes',
  };
  const FIELD_LABEL = {
    company: 'Company', jurisdiction: 'Jurisdiction', industry: 'Industry',
    role: 'Role', description: 'Description', liability: 'Liability cap',
    payment: 'Payment terms', red_flags: 'Red flags', notes: 'Notes',
  };

  // Build a snapshot of current form values (used by the brainstorm chat
  // so it knows what's filled in and what's still blank).
  function collectFormState() {
    const val = (id) => (document.getElementById(id)?.value || '').trim();
    return {
      company: val('qs-company'),
      jurisdiction: val('qs-jurisdiction'),
      industry: val('qs-industry'),
      role: val('qs-role'),
      description: val('qs-description'),
      liability: val('qs-liability'),
      payment: val('qs-payment'),
      red_flags: val('qs-red-flags'),
      notes: val('qs-notes'),
    };
  }

  // Paste a suggestion into a form field. Textareas append (newline-joined),
  // selects match by option text, inputs replace.
  function applySuggestionToField(field, text) {
    const id = FIELD_TO_INPUT_ID[field];
    if (!id) return false;
    const el = document.getElementById(id);
    if (!el) return false;
    if (el.tagName === 'SELECT') {
      const match = Array.from(el.options).find(o =>
        o.value.toLowerCase() === text.toLowerCase() ||
        o.textContent.trim().toLowerCase() === text.toLowerCase()
      );
      if (match) el.value = match.value;
      else el.value = text; // fall through — may not match, but the model tried
    } else if (el.tagName === 'TEXTAREA') {
      const existing = el.value.trim();
      el.value = existing ? `${existing}\n${text}` : text;
    } else {
      el.value = text;
    }
    // Brief visual flash so the user sees which field got filled
    el.style.transition = 'background-color .6s ease';
    el.style.backgroundColor = 'color-mix(in oklab, var(--accent) 20%, transparent)';
    setTimeout(() => { el.style.backgroundColor = ''; }, 700);
    return true;
  }

  function addChatBubble(role, text) {
    const row = document.createElement('div');
    row.className = 'msg ' + (role === 'user' ? 'user' : 'bot');
    const avatar = document.createElement('div');
    avatar.className = 'avatar';
    avatar.textContent = role === 'user' ? 'YOU' : 'CR';
    const bubble = document.createElement('div');
    bubble.className = 'bubble';

    let prose = text;
    const suggestions = []; // [{ field, value }]
    if (role === 'bot') {
      // Extract <suggest field="red_flags">...</suggest> tags
      const suggestRegex = /<suggest(?:\s+field="([^"]*)")?>([\s\S]*?)<\/suggest>/gi;
      let m;
      while ((m = suggestRegex.exec(text)) !== null) {
        suggestions.push({ field: (m[1] || '').trim(), value: m[2].trim() });
      }
      prose = text.replace(suggestRegex, '').replace(/\n{3,}/g, '\n\n').trim();

      // Minimal safe markdown: escape then render **bold** and *italic*
      const escaped = prose
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      const rendered = escaped
        .replace(/\*\*([^*\n]+?)\*\*/g, '<strong>$1</strong>')
        .replace(/(^|[\s(])\*([^*\n]+?)\*(?=[\s.,!?)]|$)/g, '$1<em>$2</em>');
      bubble.innerHTML = rendered;
    } else {
      bubble.textContent = prose;
    }

    row.appendChild(avatar);
    row.appendChild(bubble);
    chatScroll.appendChild(row);

    if (suggestions.length) {
      const pills = document.createElement('div');
      pills.className = 'suggest-pills';
      suggestions.forEach(({ field, value }) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'suggest-pill';
        const label = FIELD_LABEL[field] || field || 'Suggestion';
        btn.innerHTML =
          `<span class="suggest-plus">+</span>` +
          `<span class="suggest-text"><span class="suggest-field-tag">Add to ${escapeHtml(label)}</span>${escapeHtml(value)}</span>`;
        btn.addEventListener('click', () => {
          if (btn.classList.contains('added')) return;
          if (applySuggestionToField(field, value)) {
            btn.classList.add('added');
            btn.querySelector('.suggest-plus').textContent = '✓';
          }
        });
        pills.appendChild(btn);
      });
      chatScroll.appendChild(pills);
    }

    chatScroll.scrollTop = chatScroll.scrollHeight;
  }

  function updateMsgCounter() {
    const used = chatHistory.filter(m => m.role === 'user').length;
    if (used === 0) { msgCounter.style.display = 'none'; return; }
    msgCounter.style.display = 'flex';
    msgCounterLabel.textContent = `${used} of 15 messages`;
    msgCounterFill.style.width = `${Math.min(100, (used / 15) * 100)}%`;
  }

  async function sendChat(seedMessage = null) {
    const text = (seedMessage ?? chatInput.value).trim();
    if (!text) return;
    chatHistory.push({ role: 'user', content: text });
    addChatBubble('user', text);
    chatInput.value = '';
    updateMsgCounter();
    sendBtn.disabled = true;
    sendBtn.textContent = '…';
    try {
      // Pass current form state + any saved profile so the model knows
      // context. Backend handles brainstorm-mode formatting.
      const resp = await api.configuratorChat(
        chatHistory,
        false,
        { saved_profile: currentProfile, form_state: collectFormState(), mode: 'brainstorm' },
      );
      chatHistory.push({ role: 'assistant', content: resp.reply });
      addChatBubble('bot', resp.reply);
    } catch (err) {
      addChatBubble('bot', 'Error: ' + err.message);
    } finally {
      sendBtn.disabled = false;
      sendBtn.textContent = 'Send';
    }
  }

  sendBtn.addEventListener('click', () => sendChat());
  chatInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChat(); }
  });

  // Per-field "Ask for ideas" buttons — seed the chat with a targeted prompt
  document.querySelectorAll('.qs-help-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const field = btn.dataset.helpField;
      const label = FIELD_LABEL[field] || field;
      // Draft a targeted prompt and fire it; the user can still edit
      // the textarea before sending (we actually just send directly for
      // speed — one click = suggestions).
      const seed = `Suggest 5 good entries for the "${label}" field based on the company context I've filled in so far. Return each as a <suggest field="${field}"> tag.`;
      sendChat(seed);
    });
  });

  // Opening message — depends on whether a profile is already saved
  (async () => {
    await refreshStatus();
    if (currentProfile) {
      addChatBubble('bot',
        "Welcome back. Your profile is already saved. I can help refine it — ask for more red flags, voice preferences, or anything else. Click any suggestion I give you to paste it into the form.");
    } else {
      addChatBubble('bot',
        "Hi — I'm here to help you fill the form on the left. Ask me for ideas on any field (red flags, descriptions, payment terms, etc.) or use the *Ask for ideas* buttons next to each field. Every suggestion I give comes with a one-click paste.");
    }
  })();

  // ---- Contract upload + progress polling ----
  const dropzone = document.getElementById('dropzone');
  const contractInput = document.getElementById('contract-file-input');
  dropzone.addEventListener('click', () => contractInput.click());
  dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('dragging'); });
  dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragging'));
  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('dragging');
    const file = e.dataTransfer?.files?.[0];
    if (file) handleContractUpload(file);
  });
  contractInput.addEventListener('change', () => {
    const file = contractInput.files?.[0];
    if (file) handleContractUpload(file);
  });

  const STAGE_MAP = {
    queued:      'extract',
    classifying: 'classify',
    analyzing:   'specialists',
    auditing:    'audit',
    compiling:   'assemble',
    complete:    'assemble',
  };

  // Pending review state between upload and confirm
  let pendingKickoff = null;
  let pendingFile = null;
  let confirmCountdownInterval = null;
  let confirmTimeoutMs = 10000;

  async function handleContractUpload(file) {
    // Validate deal_posture before doing anything
    const postureSelect = document.getElementById('deal-posture-select');
    const dealPosture = postureSelect?.value || '';
    if (!dealPosture) {
      postureSelect?.focus();
      alert('Please select the deal posture before uploading a contract.');
      return;
    }

    document.getElementById('review-upload').classList.add('hidden');
    const progress = document.getElementById('review-progress');
    progress.classList.remove('hidden');
    const ext = (file.name.split('.').pop() || '').toUpperCase();
    document.getElementById('progress-file-icon').textContent = ext;
    document.getElementById('progress-file-name').textContent = file.name;
    document.getElementById('progress-file-sub').textContent = `${Math.round(file.size / 1024)} KB · classifying…`;

    try {
      const kickoff = await api.startReview(file, dealPosture);
      pendingKickoff = kickoff;
      pendingFile = file;

      if (kickoff.profile_mode === 'baseline_only') {
        if (!progress.querySelector('.baseline-banner')) {
          const banner = document.createElement('div');
          banner.className = 'banner baseline-banner';
          banner.innerHTML =
            `<span class="banner-tag">Baseline</span>` +
            `<span>Running an industry-baseline review because no profile is saved. <a href="#view-configure" data-view="configure">Fill the Configure form</a> for a tailored review driven by your own red flags and positions.</span>`;
          progress.insertBefore(banner, progress.firstChild);
          banner.querySelector('a')?.addEventListener('click', (e) => {
            e.preventDefault();
            switchView('configure');
          });
        }
      }
      markStage('extract', 'done');
      markStage('classify', 'done');

      // Transition to the confirmation panel. Hide progress until confirm fires.
      progress.classList.add('hidden');
      showConfirmPanel(kickoff);
    } catch (err) {
      document.getElementById('progress-file-sub').textContent = 'Error: ' + err.message;
    }
  }

  function showConfirmPanel(kickoff) {
    const confirmPanel = document.getElementById('review-confirm');
    confirmPanel.classList.remove('hidden');

    document.getElementById('confirm-contract-type').textContent = kickoff.contract_type || 'unclassified';
    const modeLabel = kickoff.pipeline_mode || 'standard';
    const conf = typeof kickoff.confidence === 'number' ? kickoff.confidence : 0;
    const confPct = Math.round(conf * 100);
    const confLabel = conf >= 0.85 ? 'high' : conf >= 0.6 ? 'medium' : 'low';
    document.getElementById('confirm-sub').textContent =
      `Running the ${modeLabel} pipeline. Change the mode below if you disagree.`;
    document.getElementById('confirm-confidence').innerHTML =
      `Classification confidence: <strong>${confPct}%</strong> (${confLabel}).` +
      (kickoff.reasoning ? ` ${escapeHtml(kickoff.reasoning)}` : '');

    // Highlight the recommended mode button
    document.querySelectorAll('.confirm-mode-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.mode === modeLabel);
    });

    // Show governing-agreement panel if classifier flagged subordinate type
    const governingEl = document.getElementById('confirm-governing');
    governingEl.classList.toggle('hidden', !kickoff.is_subordinate);

    // Start 10-second auto-proceed countdown (pauses when user interacts)
    startConfirmCountdown();
  }

  function startConfirmCountdown() {
    const btn = document.getElementById('confirm-start-btn');
    const label = document.getElementById('confirm-countdown');
    let remaining = Math.floor(confirmTimeoutMs / 1000);
    label.textContent = ` (auto-proceeding in ${remaining}s)`;
    if (confirmCountdownInterval) clearInterval(confirmCountdownInterval);
    confirmCountdownInterval = setInterval(() => {
      remaining--;
      if (remaining <= 0) {
        clearInterval(confirmCountdownInterval);
        confirmCountdownInterval = null;
        btn.click();
      } else {
        label.textContent = ` (auto-proceeding in ${remaining}s)`;
      }
    }, 1000);
  }

  function cancelConfirmCountdown() {
    if (confirmCountdownInterval) {
      clearInterval(confirmCountdownInterval);
      confirmCountdownInterval = null;
      document.getElementById('confirm-countdown').textContent = '';
    }
  }

  // Wire confirm panel interactions
  document.querySelectorAll('.confirm-mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      cancelConfirmCountdown();
      document.querySelectorAll('.confirm-mode-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });
  document.querySelectorAll('.cg-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      cancelConfirmCountdown();
      document.querySelectorAll('.cg-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const which = tab.dataset.cgTab;
      document.getElementById('cg-summary').classList.toggle('hidden', which !== 'summary');
      document.getElementById('cg-file-panel').classList.toggle('hidden', which !== 'file');
      document.getElementById('cg-skip-panel').classList.toggle('hidden', which !== 'skip');
    });
  });
  document.getElementById('cg-summary')?.addEventListener('focus', cancelConfirmCountdown);

  document.getElementById('confirm-cancel-btn')?.addEventListener('click', () => {
    cancelConfirmCountdown();
    document.getElementById('review-confirm').classList.add('hidden');
    document.getElementById('review-upload').classList.remove('hidden');
    pendingKickoff = null;
    pendingFile = null;
  });

  document.getElementById('confirm-start-btn')?.addEventListener('click', async () => {
    cancelConfirmCountdown();
    if (!pendingKickoff) return;

    // Gather final pipeline mode + governing context
    const activeModeBtn = document.querySelector('.confirm-mode-btn.active');
    const finalMode = activeModeBtn?.dataset.mode || pendingKickoff.pipeline_mode || 'standard';

    let governingCtx = null;
    const governingEl = document.getElementById('confirm-governing');
    if (!governingEl.classList.contains('hidden')) {
      const activeTab = document.querySelector('.cg-tab.active')?.dataset.cgTab;
      if (activeTab === 'summary') {
        const text = document.getElementById('cg-summary').value.trim();
        if (text) governingCtx = { mode: 'summary', text };
      }
      // file upload mode: TODO — would need a separate upload endpoint. For now, skip.
    }

    // Hide confirm, show progress
    document.getElementById('review-confirm').classList.add('hidden');
    const progress = document.getElementById('review-progress');
    progress.classList.remove('hidden');
    document.getElementById('progress-file-sub').textContent =
      `${pendingKickoff.contract_type} · ${finalMode}`;

    // Start elapsed-time ticker
    const reviewStartedAt = Date.now();
    const elapsedEl = document.getElementById('progress-elapsed-time');
    const tickInterval = setInterval(() => {
      const secs = Math.floor((Date.now() - reviewStartedAt) / 1000);
      const m = Math.floor(secs / 60);
      const s = String(secs % 60).padStart(2, '0');
      if (elapsedEl) elapsedEl.textContent = `${m}:${s}`;
    }, 1000);

    try {
      await api.confirmReview(pendingKickoff.review_id, finalMode, governingCtx);

      const final = await api.pollReview(pendingKickoff.review_id, (snap) => {
        const stage = STAGE_MAP[snap.review.status] || 'specialists';
        const order = ['extract','classify','specialists','audit','assemble'];
        const idx = order.indexOf(stage);
        order.forEach((s, i) => {
          markStage(s, i < idx ? 'done' : i === idx && snap.review.status !== 'complete' ? 'running' : i === idx ? 'done' : 'pending');
        });
        const activeEl = document.querySelector('.stage.running .stage-detail');
        if (activeEl) activeEl.textContent = snap.review.progress_message || '';
      });
      if (final.review.status === 'failed') {
        throw new Error(final.review.error_message || 'Review failed');
      }
      showResults(final);
      await refreshStatus();
    } catch (err) {
      document.getElementById('progress-file-sub').textContent = 'Error: ' + err.message;
    } finally {
      clearInterval(tickInterval);
      pendingKickoff = null;
      pendingFile = null;
    }
  });

  function markStage(name, state) {
    const el = document.querySelector(`.stage[data-stage="${name}"]`);
    if (!el) return;
    el.classList.remove('pending', 'active', 'done');
    el.classList.add(state);
  }

  function showResults(snap) {
    document.getElementById('review-progress').classList.add('hidden');
    const r = snap.review;
    document.getElementById('review-results').classList.remove('hidden');
    document.getElementById('results-subtitle').textContent = new Date(r.completed_at || r.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    document.getElementById('results-title').innerHTML = `Review — <em>${escapeHtml(r.filename)}</em>`;
    const totalFindings = (r.severity_counts?.blocker || 0) + (r.severity_counts?.major || 0) + (r.severity_counts?.moderate || 0) + (r.severity_counts?.minor || 0);
    document.getElementById('results-sub').textContent = `${totalFindings} finding(s) · ${r.severity_counts?.blocker || 0} blocker(s)`;
    document.getElementById('results-ct').textContent = r.contract_type || '—';
    document.getElementById('results-mode').textContent = r.pipeline_mode || '—';
    document.getElementById('results-count').textContent = String(totalFindings);
    document.getElementById('results-tokens').textContent = String(r.total_tokens || 0);
    document.getElementById('sev-blocker').textContent = String(r.severity_counts?.blocker || 0);
    document.getElementById('sev-major').textContent = String(r.severity_counts?.major || 0);
    document.getElementById('sev-moderate').textContent = String(r.severity_counts?.moderate || 0);
    document.getElementById('sev-minor').textContent = String(r.severity_counts?.minor || 0);

    const actions = document.getElementById('results-actions');
    actions.innerHTML = '';
    if (snap.downloads?.annotated) {
      actions.appendChild(btn('Annotated contract', snap.downloads.annotated, true));
    }
    if (snap.downloads?.summary) {
      actions.appendChild(btn('Review summary', snap.downloads.summary, false));
    }
    if (snap.downloads?.findings_json) {
      actions.appendChild(btn('findings.json', snap.downloads.findings_json, false));
    }

    // Populate the in-browser findings viewer
    loadFindingsInline(snap.downloads?.findings_json);
  }

  // ---- In-browser findings viewer (per-container factory) ----
  // Each instance owns its own filter state and DOM. Used by both the
  // Review results panel and each expanded Archive row.
  function createFindingsViewer({ filtersEl, listEl }) {
    let findings = [];
    let activeFilter = 'all'; // all | blocker | major | moderate | minor

    const tally = () => {
      const t = { all: findings.length, blocker: 0, major: 0, moderate: 0, minor: 0 };
      for (const f of findings) {
        const sev = (f.severity || '').toLowerCase();
        if (t[sev] != null) t[sev]++;
      }
      return t;
    };

    const renderFilters = () => {
      const counts = tally();
      filtersEl.innerHTML = '';
      for (const sev of ['all', 'blocker', 'major', 'moderate', 'minor']) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = `findings-filter ${sev}${activeFilter === sev ? ' active' : ''}`;
        const label = sev.charAt(0).toUpperCase() + sev.slice(1);
        btn.innerHTML = `${escapeHtml(label)}<span class="ff-count">${counts[sev] || 0}</span>`;
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          activeFilter = sev;
          renderFilters();
          renderList();
        });
        filtersEl.appendChild(btn);
      }
    };

    const renderList = () => {
      const filtered = activeFilter === 'all'
        ? findings
        : findings.filter(f => (f.severity || '').toLowerCase() === activeFilter);

      if (!filtered.length) {
        const msg = activeFilter === 'all'
          ? 'No findings — this contract is clean against your playbook.'
          : `No ${activeFilter} findings.`;
        listEl.innerHTML = `<div class="findings-empty">${escapeHtml(msg)}</div>`;
        return;
      }

      // Two-key sort: Tier-1 (playbook-driven, has profile_refs) before
      // Tier-2 (industry baseline). Within tier: Blocker > Major > Moderate > Minor.
      const sevOrder = { blocker: 0, major: 1, moderate: 2, minor: 3 };
      const isTier1 = (f) => Array.isArray(f.profile_refs) && f.profile_refs.length > 0;
      const sorted = [...filtered].sort((a, b) => {
        const ta = isTier1(a) ? 0 : 1;
        const tb = isTier1(b) ? 0 : 1;
        if (ta !== tb) return ta - tb;
        const sa = sevOrder[(a.severity || '').toLowerCase()] ?? 99;
        const sb = sevOrder[(b.severity || '').toLowerCase()] ?? 99;
        return sa - sb;
      });

      listEl.innerHTML = '';
      sorted.forEach((f, idx) => listEl.appendChild(renderFindingCard(f, idx)));
    };

    return {
      async loadFrom(url, priorityEl, structuralEl, coverageEl, tabRoot, tabCounts) {
        if (!url) {
          listEl.innerHTML = '<div class="findings-empty">No findings file available for this review.</div>';
          findings = [];
          renderFilters();
          return;
        }
        listEl.innerHTML = '<div class="findings-empty">Loading findings…</div>';
        let priorityIds = [];
        let coverageAggregate = [];
        let isLegacySchema = false;
        try {
          const resp = await fetch(url);
          if (!resp.ok) throw new Error('Fetch returned ' + resp.status);
          const data = await resp.json();
          if (Array.isArray(data)) {
            findings = data;
            isLegacySchema = true;
          } else if (data && Array.isArray(data.findings)) {
            findings = data.findings;
            priorityIds = Array.isArray(data.priority_three) ? data.priority_three : [];
            coverageAggregate = Array.isArray(data.coverage_pass_aggregate) ? data.coverage_pass_aggregate : [];
            isLegacySchema = !('schema_version' in data) || data.schema_version < 2;
          } else {
            findings = [];
          }
        } catch (err) {
          listEl.innerHTML = `<div class="findings-empty">Could not load findings: ${escapeHtml(err.message)}</div>`;
          return;
        }
        activeFilter = 'all';
        renderFilters();
        renderList();

        const priorityCount = priorityEl ? renderPriorityThree(priorityEl, findings, priorityIds) : 0;
        const structuralCount = structuralEl ? renderStructural(structuralEl, findings) : 0;
        const coverageCount = coverageEl ? renderCoverage(coverageEl, coverageAggregate) : 0;

        // Populate tab counts + legacy-schema badge
        if (tabCounts) {
          if (tabCounts.priority)    tabCounts.priority.textContent    = priorityCount || 0;
          if (tabCounts.findings)    tabCounts.findings.textContent    = findings.length;
          if (tabCounts.structural)  tabCounts.structural.textContent  = structuralCount;
          if (tabCounts.coverage)    tabCounts.coverage.textContent    = coverageCount;
        }
        if (tabRoot) {
          tabRoot.classList.toggle('legacy-schema', isLegacySchema);
        }

        // Default-tab logic: Top 3 if populated, otherwise All Findings
        if (tabRoot) {
          const initialTab = priorityCount > 0 ? 'priority' : 'findings';
          activateTab(tabRoot, initialTab);
        }
      },
    };
  }

  // Tab-panel switching (scoped to a specific tab-root — lets Review panel
  // and each Archive drawer have independent tab state).
  function activateTab(root, tabName) {
    root.querySelectorAll('.results-tab').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.tab === tabName);
    });
    root.querySelectorAll('.tab-panel').forEach(panel => {
      panel.classList.toggle('active', panel.dataset.tabPanel === tabName);
    });
  }

  function wireTabs(root) {
    root.querySelectorAll('.results-tab').forEach(btn => {
      btn.addEventListener('click', () => activateTab(root, btn.dataset.tab));
    });
  }

  /**
   * Render the coverage-pass section: one collapsible per specialist.
   * Returns the total coverage-entry count for tab-badge display.
   */
  function renderCoverage(sectionEl, coverageAggregate) {
    const listEl = sectionEl.querySelector('.coverage-list') || sectionEl;
    if (!Array.isArray(coverageAggregate) || coverageAggregate.length === 0) {
      listEl.innerHTML = '<div class="findings-empty">No coverage data for this review (legacy schema or clean pass).</div>';
      return 0;
    }
    // Group by specialist
    const bySpecialist = {};
    for (const entry of coverageAggregate) {
      const key = entry.specialist || 'unknown';
      (bySpecialist[key] ||= []).push(entry);
    }
    listEl.innerHTML = '';
    for (const [spec, entries] of Object.entries(bySpecialist)) {
      const wrap = document.createElement('details');
      wrap.className = 'coverage-specialist';
      wrap.innerHTML = `
        <summary class="coverage-specialist-summary">
          <span class="coverage-specialist-name">${escapeHtml(spec)}</span>
          <span class="coverage-specialist-count">${entries.length} item${entries.length === 1 ? '' : 's'}</span>
          <span class="coverage-collapse-arrow" aria-hidden="true">▸</span>
        </summary>
        <div class="coverage-entries">
          ${entries.map(e => `
            <div class="coverage-entry status-${escapeHtml((e.status || 'unknown').replace(/_/g, '-'))}">
              <div class="coverage-entry-head">
                <span class="coverage-status">${escapeHtml(e.status || '—')}</span>
                <span class="coverage-item">${escapeHtml(e.item || '—')}</span>
                <span class="coverage-source">${escapeHtml(e.source || '—')}</span>
              </div>
              ${e.evidence ? `<div class="coverage-evidence">${escapeHtml(e.evidence)}</div>` : ''}
              ${e.profile_ref ? `<div class="coverage-profile-ref">profile: ${escapeHtml(e.profile_ref)}${e.playbook_fit ? ` · fit: ${escapeHtml(e.playbook_fit)}` : ''}</div>` : ''}
            </div>
          `).join('')}
        </div>
      `;
      listEl.appendChild(wrap);
    }
    return coverageAggregate.length;
  }

  /**
   * A finding is "structural" (missing clause / whole-agreement issue) when:
   *   - it has no source_text (or a placeholder), OR
   *   - its location says "Entire agreement — missing" / "missing" etc., OR
   *   - its markup_type is "insert" AND anchor_text is null
   */
  function isStructuralFinding(f) {
    const loc = (f.location || '').toLowerCase();
    if (loc.includes('missing') || loc.includes('entire agreement')) return true;
    if (!f.source_text || f.source_text.trim().length < 4) {
      if (f.markup_type === 'insert' || f.markup_type === 'annotate') return true;
    }
    if (f.markup_type === 'insert' && !f.anchor_text) return true;
    return false;
  }

  function renderStructural(sectionEl, allFindings) {
    const listEl = sectionEl.querySelector('.structural-list') || sectionEl;
    const structural = allFindings.filter(isStructuralFinding);
    if (!structural.length) {
      listEl.innerHTML = '<div class="findings-empty">No structural issues for this review.</div>';
      return 0;
    }
    listEl.innerHTML = '';
    const sevOrder = { blocker: 0, major: 1, moderate: 2, minor: 3 };
    const isTier1 = (f) => Array.isArray(f.profile_refs) && f.profile_refs.length > 0;
    const sorted = [...structural].sort((a, b) => {
      // Existential first
      if (a.existential && !b.existential) return -1;
      if (!a.existential && b.existential) return 1;
      const ta = isTier1(a) ? 0 : 1;
      const tb = isTier1(b) ? 0 : 1;
      if (ta !== tb) return ta - tb;
      return (sevOrder[(a.severity || '').toLowerCase()] ?? 99) - (sevOrder[(b.severity || '').toLowerCase()] ?? 99);
    });
    sorted.forEach((f, i) => listEl.appendChild(renderFindingCard(f, i)));
    return sorted.length;
  }

  function renderPriorityThree(sectionEl, allFindings, priorityIds) {
    const section = sectionEl;
    const listEl = section.querySelector('.priority-three-list') || section;
    if (!Array.isArray(priorityIds) || priorityIds.length === 0) {
      listEl.innerHTML = '<div class="findings-empty">No priority findings for this review.</div>';
      return 0;
    }
    const resolved = priorityIds.slice(0, 3).map(id => {
      if (typeof id === 'number') return allFindings[id] || null;
      return allFindings.find(f => f.id === id) || null;
    }).filter(Boolean);
    if (!resolved.length) {
      listEl.innerHTML = '<div class="findings-empty">No priority findings for this review.</div>';
      return 0;
    }
    listEl.innerHTML = '';
    resolved.forEach((f, i) => {
      const sev = (f.severity || 'minor').toLowerCase();
      const card = document.createElement('div');
      card.className = `priority-card sev-${sev}${f.existential ? ' existential' : ''}`;
      const existentialTag = f.existential ? '<span class="finding-existential">EXISTENTIAL</span>' : '';
      card.innerHTML = `
        <div class="priority-card-head">
          <span class="priority-card-num">${i + 1}</span>
          <span class="finding-sev-tag ${sev}">${escapeHtml(f.severity || 'Minor')}</span>
          ${existentialTag}
          <span class="finding-category">${escapeHtml(f.category || '—')}</span>
          <span class="finding-preview">${escapeHtml((f.location || '').slice(0, 80))}</span>
        </div>
        ${f.materiality_rationale ? `<div class="priority-card-rationale">${escapeHtml(f.materiality_rationale)}</div>` : ''}
        ${f.position ? `<div class="priority-card-ask"><span class="priority-card-label">Opening ask:</span> ${escapeHtml(f.position)}</div>` : ''}
      `;
      listEl.appendChild(card);
    });
    return resolved.length;
  }

  // Single viewer for the Review panel. Archive creates its own per row.
  const reviewFindingsViewer = createFindingsViewer({
    filtersEl: document.getElementById('findings-filters'),
    listEl: document.getElementById('findings-list'),
  });

  async function loadFindingsInline(findingsUrl) {
    const tabRoot = document.querySelector('#review-results .results-tabs-wrap');
    const tabCounts = {
      priority:   document.getElementById('tab-count-priority'),
      findings:   document.getElementById('tab-count-findings'),
      structural: document.getElementById('tab-count-structural'),
      coverage:   document.getElementById('tab-count-coverage'),
    };
    if (tabRoot && !tabRoot.dataset.tabsWired) {
      wireTabs(tabRoot);
      tabRoot.dataset.tabsWired = '1';
    }
    await reviewFindingsViewer.loadFrom(
      findingsUrl,
      document.getElementById('priority-three-section'),
      document.getElementById('structural-section'),
      document.getElementById('coverage-section'),
      tabRoot,
      tabCounts,
    );
  }

  // Click-to-collapse on the Review Findings section header
  {
    const collapseBtn = document.getElementById('findings-collapse-btn');
    const section = document.getElementById('findings-section');
    collapseBtn?.addEventListener('click', () => {
      const collapsed = section.classList.toggle('collapsed');
      collapseBtn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
    });
  }

  function renderFindingCard(f, idx) {
    const severity = (f.severity || 'minor').toLowerCase();
    const card = document.createElement('div');
    card.className = `finding-card sev-${severity}${f.existential ? ' existential' : ''}`;

    const previewSource = f.external_comment || f.source_text || f.anchor_text || '';
    const preview = previewSource.split('\n')[0].slice(0, 140);

    const tierTag = Array.isArray(f.profile_refs) && f.profile_refs.length > 0
      ? '<span class="finding-tier tier-client-position" title="Driven by the client\'s negotiating position / profile">CLIENT POSITION</span>'
      : '<span class="finding-tier tier-baseline" title="Standard industry-practice check">INDUSTRY BASELINE</span>';

    const existentialTag = f.existential
      ? '<span class="finding-existential" title="Enforcement as written would eliminate the client\'s business model, core IP, market access, or ability to serve other customers.">EXISTENTIAL</span>'
      : '';

    const head = document.createElement('div');
    head.className = 'finding-head';
    head.innerHTML = `
      <span class="finding-sev-tag ${severity}">${escapeHtml(f.severity || 'Minor')}</span>
      ${existentialTag}
      ${tierTag}
      <span class="finding-category">${escapeHtml(f.category || '—')}</span>
      <span class="finding-markup">${escapeHtml(f.markup_type || '—')}</span>
      <span class="finding-preview">${escapeHtml(preview)}</span>
      <span class="finding-toggle" aria-hidden="true">›</span>
    `;
    head.addEventListener('click', () => card.classList.toggle('open'));

    const body = document.createElement('div');
    body.className = 'finding-body';

    const blocks = [];
    if (f.specialist || f.jurisdiction_assumed) {
      const meta = [];
      if (f.specialist) meta.push(`<span class="finding-meta-chip">${escapeHtml(f.specialist)}</span>`);
      if (f.jurisdiction_assumed) meta.push(`<span class="finding-meta-chip jurisdiction">Jurisdiction assumed: ${escapeHtml(f.jurisdiction_assumed)}</span>`);
      blocks.push(`<div class="finding-block"><div class="finding-meta-row">${meta.join('')}</div></div>`);
    }
    if (f.materiality_rationale) {
      blocks.push(`
        <div class="finding-block">
          <div class="finding-block-label">Materiality — why this matters for this deal</div>
          <div class="finding-comment">${escapeHtml(f.materiality_rationale)}</div>
        </div>`);
    }
    if (f.position || f.fallback || f.walkaway) {
      const rows = [];
      if (f.position) rows.push(`<div class="neg-row"><span class="neg-label">Opening ask</span><span class="neg-value">${escapeHtml(f.position)}</span></div>`);
      if (f.fallback) rows.push(`<div class="neg-row"><span class="neg-label">Fallback</span><span class="neg-value">${escapeHtml(f.fallback)}</span></div>`);
      if (f.walkaway) rows.push(`<div class="neg-row walkaway"><span class="neg-label">Walkaway</span><span class="neg-value">${escapeHtml(f.walkaway)}</span></div>`);
      blocks.push(`
        <div class="finding-block">
          <div class="finding-block-label">Negotiating ladder</div>
          <div class="neg-ladder">${rows.join('')}</div>
        </div>`);
    }
    if (f.external_comment) {
      blocks.push(`
        <div class="finding-block">
          <div class="finding-block-label">Margin comment (counterparty-facing)</div>
          <div class="finding-comment">${escapeHtml(f.external_comment)}</div>
        </div>`);
    }
    if (f.source_text) {
      const strikeClass = (f.markup_type === 'delete' || f.markup_type === 'replace') ? ' strike' : '';
      blocks.push(`
        <div class="finding-block">
          <div class="finding-block-label">Source text ${f.markup_type === 'delete' ? '(to remove)' : f.markup_type === 'replace' ? '(to replace)' : ''}</div>
          <div class="finding-source${strikeClass}">${escapeHtml(f.source_text)}</div>
        </div>`);
    } else if (f.anchor_text) {
      blocks.push(`
        <div class="finding-block">
          <div class="finding-block-label">Anchor (for insertion)</div>
          <div class="finding-source">${escapeHtml(f.anchor_text)}</div>
        </div>`);
    }
    if (f.suggested_text) {
      blocks.push(`
        <div class="finding-block">
          <div class="finding-block-label">Proposed replacement language</div>
          <div class="finding-suggested">${escapeHtml(f.suggested_text)}</div>
        </div>`);
    }
    if (f.internal_comment) {
      blocks.push(`
        <div class="finding-block">
          <div class="finding-block-label">Internal note</div>
          <div class="finding-comment">${escapeHtml(f.internal_comment)}</div>
        </div>`);
    }
    body.innerHTML = blocks.join('');

    card.appendChild(head);
    card.appendChild(body);
    return card;
  }

  function btn(text, href, primary) {
    const a = document.createElement('a');
    a.className = 'btn ' + (primary ? 'btn-primary' : 'btn-ghost');
    a.href = href;
    a.target = '_blank';
    a.rel = 'noopener';
    a.textContent = text;
    return a;
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  // ---- Archive ----
  async function loadArchive() {
    const rows = document.getElementById('history-rows');
    rows.innerHTML = '<div class="cr-empty-state">Loading…</div>';
    try {
      const reviews = await api.listReviews();
      if (!reviews.length) {
        rows.innerHTML = '<div class="cr-empty-state">No reviews yet. Head to Review and drop a contract in.</div>';
        return;
      }
      rows.innerHTML = reviews.map(r => {
        const findings = (r.severity_counts?.blocker || 0) + (r.severity_counts?.major || 0) + (r.severity_counts?.moderate || 0) + (r.severity_counts?.minor || 0);
        const statusLabel = r.status === 'complete' ? 'Complete' : r.status === 'failed' ? 'Failed' : 'In progress';
        const statusClass = r.status === 'complete' ? 'complete' : r.status === 'failed' ? 'escalated' : '';
        // Each row is wrapped so we can append a collapsible drawer below
        return `
          <div class="history-row-wrap" data-review-id="${r.id}">
            <div class="history-row" role="button" aria-expanded="false" tabindex="0">
              <div class="h-name">${escapeHtml(r.filename)}</div>
              <div class="h-meta">${escapeHtml(r.contract_type || '—')}</div>
              <div class="h-meta emph">${new Date(r.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>
              <div class="h-meta">${findings} findings</div>
              <div>
                <span class="status-pill ${statusClass}">${statusLabel}</span>
                <span class="history-row-arrow" aria-hidden="true">▸</span>
              </div>
            </div>
            <div class="history-row-drawer hidden"></div>
          </div>`;
      }).join('');
      rows.querySelectorAll('.history-row-wrap').forEach(wrap => {
        const row = wrap.querySelector('.history-row');
        row.addEventListener('click', () => toggleArchiveRow(wrap));
        row.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleArchiveRow(wrap); }
        });
      });
    } catch (err) {
      rows.innerHTML = `<div class="cr-empty-state">Error: ${escapeHtml(err.message)}</div>`;
    }
  }

  /**
   * Expand / collapse an archive row's inline findings drawer. On first
   * open, fetches the review snapshot + findings and builds a fresh
   * viewer (each row keeps its own filter state).
   */
  async function toggleArchiveRow(wrap) {
    const row = wrap.querySelector('.history-row');
    const drawer = wrap.querySelector('.history-row-drawer');
    const isOpen = wrap.classList.contains('open');

    if (isOpen) {
      wrap.classList.remove('open');
      row.setAttribute('aria-expanded', 'false');
      drawer.classList.add('hidden');
      return;
    }

    wrap.classList.add('open');
    row.setAttribute('aria-expanded', 'true');
    drawer.classList.remove('hidden');

    // Fetch once, cache on the wrap element
    if (!drawer.dataset.loaded) {
      drawer.innerHTML = '<div class="findings-empty">Loading review…</div>';
      try {
        const snap = await api.getReview(wrap.dataset.reviewId);
        drawer.innerHTML = renderArchiveDrawer(snap);
        drawer.dataset.loaded = '1';

        // Wire download buttons + findings viewer
        const r = snap.review;
        if (r.status === 'failed') return;
        if (r.status !== 'complete') return;

        const filtersEl = drawer.querySelector('.findings-filters');
        const listEl = drawer.querySelector('.findings-list');
        const priorityEl = drawer.querySelector('.priority-three-section');
        const structuralEl = drawer.querySelector('.structural-section');
        const coverageEl = drawer.querySelector('.coverage-section');
        const tabRoot = drawer.querySelector('.results-tabs-wrap');
        const tabCounts = tabRoot ? {
          priority:   tabRoot.querySelector('[data-count="priority"]'),
          findings:   tabRoot.querySelector('[data-count="findings"]'),
          structural: tabRoot.querySelector('[data-count="structural"]'),
          coverage:   tabRoot.querySelector('[data-count="coverage"]'),
        } : null;
        if (tabRoot) wireTabs(tabRoot);
        const viewer = createFindingsViewer({ filtersEl, listEl });
        viewer.loadFrom(snap.downloads?.findings_json, priorityEl, structuralEl, coverageEl, tabRoot, tabCounts);
      } catch (err) {
        drawer.innerHTML = `<div class="findings-empty">Could not load: ${escapeHtml(err.message)}</div>`;
      }
    }
  }

  function renderArchiveDrawer(snap) {
    const r = snap.review;
    if (r.status === 'failed') {
      return `<div class="findings-empty">This review failed: ${escapeHtml(r.error_message || 'no error message recorded.')}</div>`;
    }
    if (r.status !== 'complete') {
      return `<div class="findings-empty">Still running — ${escapeHtml(r.progress_message || r.status)}</div>`;
    }
    const sc = r.severity_counts || {};
    const total = (sc.blocker || 0) + (sc.major || 0) + (sc.moderate || 0) + (sc.minor || 0);
    const d = snap.downloads || {};
    const downloadLinks = [
      d.annotated     ? `<a class="btn btn-primary btn-sm" href="${escapeHtml(d.annotated)}" target="_blank" rel="noopener">Annotated contract</a>` : '',
      d.summary       ? `<a class="btn btn-ghost btn-sm" href="${escapeHtml(d.summary)}" target="_blank" rel="noopener">Review summary</a>` : '',
      d.findings_json ? `<a class="btn btn-ghost btn-sm" href="${escapeHtml(d.findings_json)}" target="_blank" rel="noopener">findings.json</a>` : '',
    ].filter(Boolean).join('');

    return `
      <div class="drawer-head">
        <div class="severity-row">
          <div class="sev blocker"><div class="sev-l">Blocker</div><div class="sev-n">${sc.blocker || 0}</div></div>
          <div class="sev major"><div class="sev-l">Major</div><div class="sev-n">${sc.major || 0}</div></div>
          <div class="sev moderate"><div class="sev-l">Moderate</div><div class="sev-n">${sc.moderate || 0}</div></div>
          <div class="sev minor"><div class="sev-l">Minor</div><div class="sev-n">${sc.minor || 0}</div></div>
        </div>
      </div>

      <div class="results-tabs-wrap">
        <nav class="results-tabs" role="tablist" aria-label="Review results">
          <button type="button" class="results-tab active" data-tab="priority" role="tab">Top 3<span class="tab-count" data-count="priority">0</span></button>
          <button type="button" class="results-tab" data-tab="findings" role="tab">All Findings<span class="tab-count" data-count="findings">${total}</span></button>
          <button type="button" class="results-tab" data-tab="structural" role="tab">Structural<span class="tab-count" data-count="structural">0</span></button>
          <button type="button" class="results-tab" data-tab="coverage" role="tab">Coverage<span class="tab-count" data-count="coverage">0</span></button>
        </nav>

        <div class="tab-panel active" data-tab-panel="priority">
          <div class="priority-three-section">
            <div class="priority-three-head">
              <div class="priority-three-title">Top 3 to Raise</div>
              <div class="priority-three-sub">Partner-level summary — raise these on a call before sending the full redline.</div>
            </div>
            <div class="priority-three-list"></div>
          </div>
        </div>

        <div class="tab-panel" data-tab-panel="findings">
          <div class="findings-section">
            <div class="findings-head">
              <div>
                <span class="findings-title">All Findings</span>
                <div class="findings-sub">Click any finding to see the source, proposed language, and comment.</div>
              </div>
              <div class="findings-filters" role="tablist" aria-label="Filter findings by severity"></div>
            </div>
            <div class="findings-list"><div class="findings-empty">Loading findings…</div></div>
          </div>
        </div>

        <div class="tab-panel" data-tab-panel="structural">
          <div class="structural-section">
            <div class="structural-head">
              <div class="structural-title">Structural issues / missing clauses</div>
              <div class="structural-sub">Findings that can't be pinned to a specific line of text.</div>
            </div>
            <div class="structural-list"></div>
          </div>
        </div>

        <div class="tab-panel" data-tab-panel="coverage">
          <div class="coverage-section">
            <div class="coverage-head">
              <div class="coverage-title">Coverage Pass</div>
              <div class="coverage-sub">Every specialist's enumeration of what it checked, grouped by specialist.</div>
            </div>
            <div class="coverage-list"></div>
          </div>
        </div>
      </div>

      ${downloadLinks ? `<div class="action-row">${downloadLinks}</div>` : ''}
    `;
  }
</script>

<Consent />
</body>
</html>
