    <div class="run-banner is-running" id="cv-banner">
      <div class="rb-l">
        <span class="rb-kick" id="cv-rb-kick"><span class="pip"></span>QUEUED · 0/0 CHECKED</span>
        <span class="rb-t" id="cv-rb-title"><em>Preparing run…</em></span>
        <span class="rb-meta" id="cv-rb-meta"><span id="cv-rb-pages">— PP</span><span id="cv-rb-submitted">SUBMITTED —</span><span id="cv-rb-runtime">RUNTIME · 00:00</span></span>
      </div>
      <div class="rb-stats">
        <div class="rb-stat"><span class="rb-stat-l">CITES</span><span class="rb-stat-v" id="cv-rb-cites"><em>0</em></span></div>
        <div class="rb-stat"><span class="rb-stat-l">VERIFIED</span><span class="rb-stat-v ok" id="cv-rb-ok">0</span></div>
        <div class="rb-stat"><span class="rb-stat-l">FLAGGED</span><span class="rb-stat-v md" id="cv-rb-md">0</span></div>
        <div class="rb-stat"><span class="rb-stat-l">NOT FOUND</span><span class="rb-stat-v hi" id="cv-rb-hi">0</span></div>
      </div>
      <div class="rb-actions" id="cv-rb-actions">
        <button class="ws-btn" id="cv-corrected-btn" style="display:none;">↓ Corrected brief</button>
        <button class="ws-btn" id="cv-restart-btn" style="display:none;">New run</button>
      </div>
    </div>

    <div class="split">
      <div class="brief">
        <div class="brief-head">
          <span class="lab"><span class="pip"></span>BRIEF · <span id="cv-brief-state">STREAMING</span></span>
          <span class="legend">
            <span><span class="pp ok-pp"></span>VERIFIED</span>
            <span><span class="pp md-pp"></span>FLAGGED</span>
            <span><span class="pp hi-pp"></span>NOT FOUND</span>
