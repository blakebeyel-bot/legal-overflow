    <div class="ms-cell"><span class="ms-l">FLAGGED</span><span class="ms-v" style="color:var(--md)" id="cv-stat-flagged">—</span><span class="ms-d">PINPOINT / TREATMENT</span></div>
    <div class="ms-cell"><span class="ms-l">NOT FOUND</span><span class="ms-v" style="color:var(--hi)" id="cv-stat-notfound">—</span><span class="ms-d">NOT IN COURTLISTENER</span></div>
    <div class="ms-cell"><span class="ms-l">QUOTA</span><span class="ms-v" id="cv-stat-quota">—</span><span class="ms-d">TRIAL · 30-DAY WINDOW</span></div>
