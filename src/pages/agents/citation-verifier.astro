<script>
  import { getSupabase } from '../../lib/supabase';

  const supabase = getSupabase();
  console.log('[citation-verifier] init');

  // ---- Auth gate ----
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    location.href = '/login/?redirect=/agents/citation-verifier/';
    throw new Error('Not signed in — redirecting');
  }

  let currentSessionUserId = session?.user?.id || null;
  supabase.auth.onAuthStateChange((event, newSession) => {
    const newUserId = newSession?.user?.id || null;
    if (event === 'SIGNED_OUT' || newUserId !== currentSessionUserId) {
      currentSessionUserId = newUserId;
      location.reload();
    }
  });

  // Universal author override — pull the user's display_name from
  // profiles so the Word comments embedded in the corrected brief
  // are attributed to them, not "Citation Verifier". Falls back to
  // 'Legal Overflow' for new accounts (matches the server-side
  // getUserDisplayName helper). RLS allows reading own profile row.
  let commentAuthor = 'Legal Overflow';
  let commentInitials = 'LO';
  try {
    const { data: profile } = await supabase
      .from('profiles')
      .select('display_name')
      .eq('id', session.user.id)
      .maybeSingle();
    const name = (profile?.display_name || '').trim();
    if (name) {
      commentAuthor = name;
      commentInitials = name.split(/\s+/).map((p) => p[0]?.toUpperCase() || '').join('').slice(0, 4) || 'LO';
    }
  } catch (err) {
    console.warn('[citation-verifier] display_name lookup failed:', err?.message);
  }

  // ---- Element refs ----
  const fileInput   = document.getElementById('cv-file');
  const styleSel    = document.getElementById('cv-style');
  const rulesetSel  = document.getElementById('cv-ruleset');
  const retainCb    = document.getElementById('cv-retain-text');
  const disclaimCb  = document.getElementById('cv-disclaimer');
  const startBtn    = document.getElementById('cv-start-btn');
  const errorBox    = document.getElementById('cv-error');

  const uploadEl    = document.getElementById('cv-upload');
  const runEl       = document.getElementById('cv-run');
  const banner      = document.getElementById('cv-banner');
  const rbKick      = document.getElementById('cv-rb-kick');
  const rbTitle     = document.getElementById('cv-rb-title');
  const rbPages     = document.getElementById('cv-rb-pages');
  const rbSubmitted = document.getElementById('cv-rb-submitted');
  const rbRuntime   = document.getElementById('cv-rb-runtime');
  const rbCites     = document.getElementById('cv-rb-cites');
  const rbOk        = document.getElementById('cv-rb-ok');
  const rbMd        = document.getElementById('cv-rb-md');
  const rbHi        = document.getElementById('cv-rb-hi');
  const rbActions   = document.getElementById('cv-rb-actions');
  const restartBtn  = document.getElementById('cv-restart-btn');
  const briefBody   = document.getElementById('cv-brief-body');
  const briefEmpty  = document.getElementById('cv-brief-empty');
  const briefState  = document.getElementById('cv-brief-state');
  const citesList   = document.getElementById('cv-cites-list');
  const citesEmpty  = document.getElementById('cv-cites-empty');
  const citesKick   = document.getElementById('cv-cites-kick');
  const citesH      = document.getElementById('cv-cites-h');
  const cntIssues   = document.getElementById('cv-cnt-issues');
  const cntAll      = document.getElementById('cv-cnt-all');
  const cntCases    = document.getElementById('cv-cnt-cases');
  const cntStatutes = document.getElementById('cv-cnt-statutes');
  const tabsEl      = document.getElementById('cv-tabs');
  const secMeta     = document.getElementById('cv-sec-meta');

  // ---- Stats refs ----
  const statRuns     = document.getElementById('cv-stat-runs');
  const statVerified = document.getElementById('cv-stat-verified');
  const statFlagged  = document.getElementById('cv-stat-flagged');
  const statNotfound = document.getElementById('cv-stat-notfound');
  const statQuota    = document.getElementById('cv-stat-quota');

  function gate() {
    startBtn.disabled = !(fileInput.files?.length && disclaimCb.checked);
  }
  fileInput.addEventListener('change', gate);
  disclaimCb.addEventListener('change', gate);
  startBtn.addEventListener('click', startRun);
  restartBtn.addEventListener('click', () => location.reload());
  document.getElementById('cv-corrected-btn')?.addEventListener('click', () => downloadCorrectedDocx());

  document.getElementById('cv-signout')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    location.href = '/';
  });

  function showError(msg) {
    errorBox.textContent = msg;
    errorBox.style.display = 'block';
  }
  function clearError() { errorBox.style.display = 'none'; errorBox.textContent = ''; }

  // ---- Quota & lifetime stats ----
  const QUOTA_WINDOW_MS = 30 * 24 * 60 * 60 * 1000;
  // Mirrors limits in netlify/lib/supabase-admin.js. The actual cap is the
  // user's profile.citation_cap_override, falling back to the tier default.
  const TIER_LIMITS = { trial: 3, standard: 25, pro: 100, admin: 9999, enterprise: 99999 };

  async function refreshStats() {
    try {
      const userId = session.user.id;

      // Pull the user's profile so we know their real cap. RLS policy on
      // profiles permits a user to read their own row.
      const { data: profile } = await supabase
        .from('profiles')
        .select('tier, citation_cap_override')
        .eq('id', userId)
        .maybeSingle();
      const tier = profile?.tier || 'trial';
      const cap = (profile?.citation_cap_override != null && profile.citation_cap_override >= 0)
        ? profile.citation_cap_override
        : (TIER_LIMITS[tier] ?? 3);

      const since = new Date(Date.now() - QUOTA_WINDOW_MS).toISOString();
      // Quota count (window)
      const { count: usedCount, error: quotaErr } = await supabase
        .from('verification_runs')
        .select('id', { count: 'exact', head: true })
        .gte('created_at', since);
      if (!quotaErr) {
        const used = usedCount || 0;
        const remaining = Math.max(0, cap - used);
        statQuota.innerHTML = `${remaining}<em>/${cap}</em>`;
        const quotaEl = document.getElementById('cv-quota');
        const quotaText = document.getElementById('cv-quota-text');
        const paywall = document.getElementById('cv-paywall');
        quotaEl.style.display = 'flex';
        quotaText.textContent = `${remaining} of ${cap} citation checks left this 30-day window · tier: ${tier}`;
        quotaEl.classList.remove('is-low', 'is-out');
        if (remaining === 0) {
          quotaEl.classList.add('is-out');
          paywall.style.display = 'block';
          if (uploadEl) uploadEl.style.display = 'none';
        } else if (remaining <= Math.max(1, Math.floor(cap * 0.1))) {
          quotaEl.classList.add('is-low');
        }
      }

      // Lifetime aggregates (all runs)
      const { data: rows, error: aggErr } = await supabase
        .from('verification_runs')
        .select('id, citation_count, flag_count_review, flag_count_nonconforming, existence_not_found_count')
        .eq('status', 'complete');
      if (!aggErr) {
        let totalCites = 0, totalFlagged = 0, totalNotFound = 0;
        (rows || []).forEach(r => {
          totalCites += (r.citation_count || 0);
          totalFlagged += (r.flag_count_review || 0) + (r.flag_count_nonconforming || 0);
          totalNotFound += (r.existence_not_found_count || 0);
        });
        const verified = Math.max(0, totalCites - totalFlagged - totalNotFound);
        statRuns.textContent = (rows || []).length.toString();
        statVerified.textContent = verified.toString();
        statFlagged.textContent = totalFlagged.toString();
        statNotfound.textContent = totalNotFound.toString();
      }
    } catch (e) {
      console.error('[citation-verifier] refreshStats:', e);
    }
  }
  refreshStats();

  // ---- Run start ----
  async function startRun() {
    clearError();
    if (!fileInput.files?.length) return showError('Please pick a file first.');
    if (!disclaimCb.checked) return showError('Please acknowledge the disclaimer.');

    startBtn.disabled = true;
    const file = fileInput.files[0];

    // Switch to unified run view
    uploadEl.style.display = 'none';
    runEl.style.display = '';
    banner.classList.add('is-running');
    secMeta.textContent = `CURRENT RUN · ${file.name.toUpperCase()}`;
    rbTitle.innerHTML = `<em>${escapeHtml(file.name)}</em>`;

    // Kick off the local document render in parallel with the upload — gives
    // the user a live preview of their actual brief while the backend runs.
    renderDocument(file).catch(e => console.error('[citation-verifier] render error:', e));
    const submitTime = new Date();
    const hh = String(submitTime.getHours()).padStart(2,'0');
    const mm = String(submitTime.getMinutes()).padStart(2,'0');
    rbSubmitted.textContent = `SUBMITTED ${hh}:${mm}`;
    rbKick.innerHTML = `<span class="pip"></span>QUEUED · 0/0 CHECKED`;

    // Local runtime tick
    const runtimeStart = Date.now();
    const runtimeTicker = setInterval(() => {
      const elapsed = Math.floor((Date.now() - runtimeStart) / 1000);
      const m = String(Math.floor(elapsed / 60)).padStart(2,'0');
      const s = String(elapsed % 60).padStart(2,'0');
      rbRuntime.textContent = `RUNTIME · ${m}:${s}`;
    }, 1000);

    const fd = new FormData();
    fd.append('file', file);
    fd.append('style', styleSel.value);
    fd.append('ruleset', rulesetSel.value);
    fd.append('retain_text', retainCb.checked ? 'true' : 'false');
    fd.append('disclaimer_version', '1.1');

    let res;
    try {
      res = await fetch('/.netlify/functions/verify-citations-start', {
        method: 'POST',
        headers: { Authorization: `Bearer ${session.access_token}` },
        body: fd,
      });
    } catch (e) {
      clearInterval(runtimeTicker);
      runEl.style.display = 'none';
      uploadEl.style.display = '';
      showError('Upload failed: ' + e.message);
      startBtn.disabled = false;
      return;
    }

    const data = await res.json().catch(() => ({}));
    if (res.status === 403 && data.pending_approval) {
      clearInterval(runtimeTicker);
      runEl.style.display = 'none';
      uploadEl.style.display = '';
      const pending = document.getElementById('cv-pending');
      if (pending) pending.style.display = 'block';
      uploadEl.style.display = 'none';
      startBtn.disabled = false;
      return;
    }
    if (res.status === 429 && data.quota) {
      clearInterval(runtimeTicker);
      runEl.style.display = 'none';
      uploadEl.style.display = 'none';
      document.getElementById('cv-paywall').style.display = 'block';
      startBtn.disabled = false;
      return;
    }
    if (!res.ok || !data.ok) {
      clearInterval(runtimeTicker);
      runEl.style.display = 'none';
      uploadEl.style.display = '';
      showError(data.error || `Server returned ${res.status}`);
      startBtn.disabled = false;
      return;
    }

    pollStatus(data.run_id, runtimeTicker);
  }

  // ---- Poll + stream ----
  const STATUS_LABELS = {
    queued: 'QUEUED',
    extracting: 'EXTRACTING CITATIONS',
    classifying: 'CLASSIFYING AGAINST BLUEBOOK',
    checking_existence: 'CHECKING COURTLISTENER',
    validating: 'RUNNING TABLE VALIDATORS',
    judging: 'REVIEWING CROSS-CITATION ISSUES',
    building_outputs: 'BUILDING REPORT',
    complete: 'RUN COMPLETE',
    failed: 'RUN FAILED',
  };

  let renderedIds = new Set();
  let currentTab = 'issues';
  let allCitations = [];
  let runFormat = null;

  // Tab switching
  tabsEl.querySelectorAll('.ct').forEach(b => b.addEventListener('click', () => {
    tabsEl.querySelectorAll('.ct').forEach(x => x.classList.remove('is-active'));
    b.classList.add('is-active');
    currentTab = b.dataset.tab;
    renderCites();
  }));

  async function pollStatus(runId, runtimeTicker) {
    const POLL_MS = 2000;

    const tick = async () => {
      try {
        const r = await fetch(
          `/.netlify/functions/verify-citations-status?run_id=${runId}&include_citations=1`,
          { headers: { Authorization: `Bearer ${session.access_token}` } }
        );
        if (!r.ok) {
          setTimeout(tick, POLL_MS * 2);
          return;
        }
        const data = await r.json();
        if (!data.ok || !data.run) {
          setTimeout(tick, POLL_MS * 2);
          return;
        }
        const run = data.run;
        const cites = data.citations || [];
        runFormat = run.file_format;

        updateBanner(run, cites);
        ingestCitations(cites);
        renderCites();

        if (run.status === 'complete') {
          clearInterval(runtimeTicker);
          banner.classList.remove('is-running');
          briefState.textContent = 'COMPLETE';
          rbKick.innerHTML = `<span class="pip"></span>RUN COMPLETE · ${cites.length}/${cites.length} CHECKED`;
          renderDownloadActions(run);
          refreshStats();
          return;
        }
        if (run.status === 'failed') {
          clearInterval(runtimeTicker);
          banner.classList.remove('is-running');
          briefState.textContent = 'FAILED';
          rbKick.innerHTML = `<span class="pip" style="background:var(--hi)"></span>RUN FAILED`;
          rbActions.innerHTML = '';
          const back = document.createElement('button');
          back.className = 'ws-btn';
          back.textContent = 'New run';
          back.addEventListener('click', () => location.reload());
          rbActions.appendChild(back);
          if (run.error_message) {
            const errEl = document.createElement('div');
            errEl.className = 'cv-error';
            errEl.style.marginTop = '14px';
            errEl.textContent = run.error_message;
            runEl.insertBefore(errEl, runEl.firstChild);
          }
          return;
        }
        setTimeout(tick, POLL_MS);
      } catch (e) {
        console.error('[citation-verifier] poll error:', e);
        setTimeout(tick, POLL_MS * 2);
      }
    };
    tick();
  }

  function updateBanner(run, cites) {
    const total = run.citation_count || cites.length || 0;
    const review = run.flag_count_review || 0;
    const nonConforming = run.flag_count_nonconforming || 0;
    const notFound = run.existence_not_found_count || 0;
    const verified = Math.max(0, total - review - nonConforming - notFound);

    rbCites.innerHTML = `<em>${total}</em>`;
    rbOk.textContent = String(verified).padStart(2,'0');
    rbMd.textContent = String(review + nonConforming).padStart(2,'0');
    rbHi.textContent = String(notFound).padStart(2,'0');

    const checked = cites.filter(c => c.flags !== undefined).length || cites.length;
    if (run.status !== 'complete' && run.status !== 'failed') {
      const label = STATUS_LABELS[run.status] || run.status.toUpperCase();
      rbKick.innerHTML = `<span class="pip"></span>${label} · ${checked}/${total || '—'} CHECKED`;
    }

    // Right panel header
    const issues = review + nonConforming + notFound;
    citesKick.textContent = `— ${run.status === 'complete' ? 'CITATIONS' : 'STREAMING'} · ${total} TOTAL`;
    if (run.status === 'complete') {
      if (issues === 0) {
        citesH.innerHTML = `<em>All ${total} verified</em>.`;
      } else {
        const crit = nonConforming + notFound;
        citesH.innerHTML = `<em>${issues} issue${issues===1?'':'s'}</em>. ${crit} critical.`;
      }
    } else {
      citesH.innerHTML = `<em>Verifying…</em> ${checked}/${total || '—'}`;
    }
  }

  // Map of cid → anchor info. Anchors come in two flavors:
  //   { kind: 'el', el: HTMLElement }      — exact-match wrap or PDF rect
  //   { kind: 'fallback', ratio: number }  — proportional scroll target (0..1)
  const citeAnchors = new Map();
  // Map of cid → 1-indexed document position. Recomputed by walking the brief
  // body in DOM order so the [N] footnote in the document and the CITE · NN
  // label in the right panel always agree, regardless of the order the
  // backend streamed the citations in.
  let docOrder = new Map();

  function recomputeDocOrder() {
    docOrder = new Map();
    if (docKind === 'pdf') {
      // For PDFs, walk pages top-to-bottom; within each page sort highlights
      // by visual top, then left.
      const pages = briefBody.querySelectorAll('.pdf-page');
      let n = 1;
      pages.forEach(page => {
        const seen = new Set();
        const hls = Array.from(page.querySelectorAll('.pdf-hl'));
        hls.sort((a, b) => {
          const ta = parseFloat(a.style.top), tb = parseFloat(b.style.top);
          if (Math.abs(ta - tb) > 4) return ta - tb;
          return parseFloat(a.style.left) - parseFloat(b.style.left);
        });
        hls.forEach(hl => {
          const cid = hl.dataset.c;
          if (!cid || seen.has(cid)) return;
          seen.add(cid);
          docOrder.set(cid, n++);
          // Update the [N] number chip on the first highlight rectangle of
          // each citation so it matches the right panel.
          const chip = hl.querySelector('.pdf-hl-num');
          if (chip) chip.textContent = `[${docOrder.get(cid)}]`;
        });
      });
    } else {
      const seen = new Set();
      let n = 1;
      briefBody.querySelectorAll('.cite').forEach(span => {
        const cid = span.dataset.c;
        if (!cid || seen.has(cid)) return;
        seen.add(cid);
        docOrder.set(cid, n++);
        // The CSS `counter(fn)` already produces this number visually for
        // .cite::after — but only when the wraps are in DOM order. Since we
        // append wraps as citations stream in, DOM order DOES equal document
        // order (Range.surroundContents preserves position). So the CSS
        // counter and our docOrder map agree.
      });
    }
  }

  function ingestCitations(cites) {
    allCitations = cites;
    cites.forEach((c, i) => {
      const cid = c.id || `c${i+1}`;
      const tier = tierOf(c);
      if (!renderedIds.has(cid)) {
        // First time we've seen this citation — try to overlay it on the rendered document.
        const anchor = highlightInBrief(c, i, cid, tier);
        if (anchor) {
          renderedIds.add(cid);
          citeAnchors.set(cid, anchor);
        } else if (docRendered) {
          // Document rendered but we couldn't locate the cite — set a
          // proportional fallback so clicking still moves to the right area.
          renderedIds.add(cid);
          citeAnchors.set(cid, { kind: 'fallback', ratio: cites.length ? i / cites.length : 0 });
        }
        // If render isn't ready, retry next tick (don't add to renderedIds).
      } else {
        // Already overlaid — just update the tier in case classification changed.
        updateBriefBadge(cid, tier);
      }
    });
    // After every ingest pass, refresh the document-position map so the right
    // panel's CITE · NN labels match the [N] footnotes in the document.
    recomputeDocOrder();
    // Also refresh the corrected-brief CTA so its label & visibility stay
    // in sync with the latest streamed findings.
    refreshCorrectedDownloadAffordance();
  }

  function tierOf(c) {
    const flags = c.flags || [];
    if (c.existence_status === 'existence_not_found') return 'hi';
    if (flags.some(f => f.severity === 'non_conforming')) return 'hi';
    if (flags.some(f => f.severity === 'review')) return 'md';
    return 'ok';
  }

  // ---- Document rendering ----
  // The brief panel renders the actual uploaded file so the user can see their
  // own document with citation badges overlaid. DOCX uses mammoth → HTML;
  // PDF uses pdf.js with a text layer + absolutely-positioned highlight overlays.
  let docRendered = false;
  let docKind = null;          // 'docx' | 'pdf'
  let pdfPagesInfo = [];       // for PDF mode: { pageEl, textItems, viewport }
  let originalDocxBytes = null; // ArrayBuffer of the uploaded DOCX (for corrected-brief export)
  let originalFileName = '';
  // Map of "fixKey" → { cid, original, corrected, flagIndex, applied }
  // fixKey = `${cid}::${flagIndex}` so each flag with a suggested_fix is
  // independently togglable.
  const appliedFixes = new Map();

  async function renderDocument(file) {
    docRendered = false;
    originalFileName = file.name || 'document';
    const name = (file.name || '').toLowerCase();
    if (name.endsWith('.docx')) {
      docKind = 'docx';
      // Stash the raw bytes so we can rebuild a corrected DOCX later
      // without re-uploading or relying on a server round-trip.
      originalDocxBytes = await file.arrayBuffer();
      await renderDocx(file);
    } else if (name.endsWith('.pdf')) {
      docKind = 'pdf';
      originalDocxBytes = null;
      await renderPdf(file);
    } else {
      briefBody.innerHTML = '<div class="brief-empty">Preview not available for this file type.</div>';
      return;
    }
    docRendered = true;
    // Reapply any citations we already received while the doc was rendering.
    if (allCitations.length) {
      const pending = allCitations.slice();
      renderedIds = new Set();
      citeAnchors.clear();
      ingestCitations(pending);
      renderCites();
    }
  }

  async function renderDocx(file) {
    if (typeof mammoth === 'undefined') {
      // Wait briefly for the deferred CDN script.
      await new Promise(r => {
        const t = setInterval(() => {
          if (typeof mammoth !== 'undefined') { clearInterval(t); r(); }
        }, 50);
        setTimeout(() => { clearInterval(t); r(); }, 5000);
      });
    }
    if (typeof mammoth === 'undefined') {
      briefBody.innerHTML = '<div class="brief-empty">Could not load DOCX renderer. Citations will still verify.</div>';
      return;
    }
    const ab = originalDocxBytes || await file.arrayBuffer();
    const result = await mammoth.convertToHtml({ arrayBuffer: ab });
    briefBody.innerHTML = result.value || '<div class="brief-empty">Document was empty.</div>';
  }

  async function renderPdf(file) {
    // Lazy-load pdf.js as an ES module (avoids needing a build dep)
    const pdfjsLib = await import(/* @vite-ignore */ 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs');
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs';
    const ab = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument({ data: ab }).promise;
    briefBody.innerHTML = '';
    pdfPagesInfo = [];
    const targetWidth = briefBody.clientWidth - 48;
    for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
      const page = await pdf.getPage(pageNum);
      const baseViewport = page.getViewport({ scale: 1 });
      const scale = targetWidth / baseViewport.width;
      const viewport = page.getViewport({ scale });
      const pageEl = document.createElement('div');
      pageEl.className = 'pdf-page';
      pageEl.style.width = viewport.width + 'px';
      pageEl.style.height = viewport.height + 'px';
      const canvas = document.createElement('canvas');
      canvas.width = viewport.width;
      canvas.height = viewport.height;
      pageEl.appendChild(canvas);
      const textLayer = document.createElement('div');
      textLayer.className = 'pdf-textlayer';
      pageEl.appendChild(textLayer);
      briefBody.appendChild(pageEl);

      await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
      const textContent = await page.getTextContent();
      const items = textContent.items.map(item => {
        const tx = pdfjsLib.Util.transform(viewport.transform, item.transform);
        const span = document.createElement('span');
        span.textContent = item.str;
        const fontHeight = Math.hypot(tx[2], tx[3]);
        span.style.left = tx[4] + 'px';
        span.style.top = (tx[5] - fontHeight) + 'px';
        span.style.fontSize = fontHeight + 'px';
        span.style.fontFamily = 'serif';
        textLayer.appendChild(span);
        return { str: item.str, span };
      });
      pdfPagesInfo.push({ pageEl, items, viewport });
    }
  }

  // Walks the rendered document, locates the citation text, and wraps it with a
  // colored badge tied to the cite-row. Returns an anchor descriptor on success,
  // null on failure.
  function highlightInBrief(c, idx, cid, tier) {
    if (!docRendered) return null;
    if (briefEmpty) briefEmpty.style.display = 'none';
    const needle = (c.display_text || c.candidate_text || '').trim();
    if (!needle) return null;

    const variants = buildNeedleVariants(needle);
    if (docKind === 'pdf') {
      const el = highlightPdf(variants, idx, cid, tier);
      return el ? { kind: 'el', el } : null;
    }
    const el = highlightHtml(variants, idx, cid, tier);
    return el ? { kind: 'el', el } : null;
  }

  // Build progressively-looser candidate strings to search for. Order matters —
  // first match wins, so put the most-specific variants first.
  function buildNeedleVariants(needle) {
    const norm = (s) => s.replace(/\s+/g, ' ').replace(/[‘’]/g, "'").replace(/[“”]/g, '"').trim();
    const out = [];
    const add = (s) => { if (s && s.length >= 6 && !out.includes(s)) out.push(s); };

    add(needle);
    add(norm(needle));
    add(needle.replace(/\s+/g, ' '));

    // Reporter pattern e.g. "207 So. 3d 207" or "550 U.S. 544"
    const reporter = needle.match(/\d+\s+[A-Z][A-Za-z\.\s]{1,12}\s+\d+(?:\s*,\s*\d+)?/);
    if (reporter) add(reporter[0]);

    // Case name only: text before " v. " ... up to the comma before the reporter
    const vMatch = needle.match(/^([^,]+v\.\s+[^,]+),/);
    if (vMatch) add(vMatch[1].trim());

    // First clause before the first comma (e.g. case name without reporter)
    const firstClause = needle.split(',')[0];
    if (firstClause && firstClause.length >= 12) add(firstClause.trim());

    // Statute pattern e.g. "Fla. Stat. § 218.74(2)" or "§ 218.74"
    const statute = needle.match(/§\s*[\d\.]+(?:\([^)]+\))?/);
    if (statute) add(statute[0]);

    // Federal-rule pattern e.g. "Fed. R. Civ. P. 12(b)(6)"
    const fedRule = needle.match(/Fed\.\s*R\.\s*[A-Za-z\.]+\s*\d+(?:\([^)]+\))?/);
    if (fedRule) add(fedRule[0]);

    return out;
  }

  function highlightHtml(variants, idx, cid, tier) {
    // First pass: try to wrap inside a single text node (preserves inline styling).
    const walker = document.createTreeWalker(briefBody, NodeFilter.SHOW_TEXT, {
      acceptNode: (n) => n.parentElement?.closest('.cite, script, style') ? NodeFilter.FILTER_REJECT : NodeFilter.FILTER_ACCEPT,
    });
    const nodes = [];
    let n;
    while ((n = walker.nextNode())) nodes.push(n);

    for (const variant of variants) {
      for (const node of nodes) {
        const idxIn = node.textContent.indexOf(variant);
        if (idxIn < 0) continue;
        const range = document.createRange();
        range.setStart(node, idxIn);
        range.setEnd(node, idxIn + variant.length);
        const span = document.createElement('span');
        span.className = `cite ${tier}`;
        span.dataset.c = cid;
        span.dataset.idx = String(idx + 1);
        try {
          range.surroundContents(span);
          span.addEventListener('click', () => activateCite(cid));
          return span;
        } catch (e) {
          // Range crosses element boundary — try cross-node match below.
        }
      }
    }

    // Second pass: try matching across adjacent text nodes (for cases where
    // bold/italic styling splits the citation, e.g. "<i>Walbridge</i>, 207...").
    for (const variant of variants) {
      const wrapped = wrapAcrossNodes(nodes, variant, cid, tier, idx);
      if (wrapped) return wrapped;
    }
    return null;
  }

  // Concatenate text-node content into one string, locate the variant, then
  // walk back to the originating nodes and create one wrapping span per node
  // (each marked with the same cid so they all activate together).
  function wrapAcrossNodes(nodes, variant, cid, tier, idx) {
    if (!nodes.length || variant.length < 8) return null;
    let concat = '';
    const offsets = []; // [{ node, start, end }]
    for (const node of nodes) {
      offsets.push({ node, start: concat.length, end: concat.length + node.textContent.length });
      concat += node.textContent;
    }
    const at = concat.indexOf(variant);
    if (at < 0) return null;
    const stop = at + variant.length;

    const spans = [];
    let firstSpan = null;
    for (const seg of offsets) {
      const overlapStart = Math.max(at, seg.start);
      const overlapEnd = Math.min(stop, seg.end);
      if (overlapEnd <= overlapStart) continue;
      try {
        const range = document.createRange();
        range.setStart(seg.node, overlapStart - seg.start);
        range.setEnd(seg.node, overlapEnd - seg.start);
        const span = document.createElement('span');
        span.className = `cite ${tier}`;
        span.dataset.c = cid;
        if (!firstSpan) span.dataset.idx = String(idx + 1);
        range.surroundContents(span);
        span.addEventListener('click', () => activateCite(cid));
        spans.push(span);
        if (!firstSpan) firstSpan = span;
      } catch (e) {
        // If any sub-range fails, abort and undo prior wraps.
        spans.forEach(s => {
          const parent = s.parentNode;
          while (s.firstChild) parent.insertBefore(s.firstChild, s);
          parent.removeChild(s);
        });
        return null;
      }
      if (overlapEnd >= stop) break;
    }
    return firstSpan;
  }

  function highlightPdf(variants, idx, cid, tier) {
    // For PDFs we can't wrap text spans cleanly (each char run is its own
    // <span>), so we draw highlight rectangles over the union of matching
    // spans. We search per-page by concatenating items and locating the slice.
    const norm = (s) => s.replace(/\s+/g, ' ');
    let target = null;
    let foundPage = null;
    let at = -1;
    let concat = null;

    outer: for (const v of variants) {
      const t = norm(v);
      for (const page of pdfPagesInfo) {
        const c = norm(page.items.map(it => it.str).join(' '));
        const i = c.indexOf(t);
        if (i >= 0) { foundPage = page; at = i; target = t; concat = c; break outer; }
      }
    }
    if (!foundPage) return null;

    const page = foundPage;
    // Map the concatenated index back to source items by walking until we
    // cover [at, at+target.length].
    let cursor = 0;
    const matchSpans = [];
    for (const it of page.items) {
      const s = norm(it.str);
      const segStart = cursor;
      const segEnd = cursor + s.length;
      const overlapStart = Math.max(at, segStart);
      const overlapEnd = Math.min(at + target.length, segEnd);
      if (overlapEnd > overlapStart) matchSpans.push(it.span);
      cursor = segEnd + 1; // +1 for the joining space
      if (cursor > at + target.length) break;
    }
    if (!matchSpans.length) return null;

    // Build one highlight per visual line (group spans whose top is within
    // a few px of each other).
    const groups = [];
    matchSpans.forEach(sp => {
      const top = parseFloat(sp.style.top);
      const left = parseFloat(sp.style.left);
      const width = sp.offsetWidth;
      const height = parseFloat(sp.style.fontSize);
      const g = groups.find(x => Math.abs(x.top - top) < 4);
      if (g) {
        g.left = Math.min(g.left, left);
        g.right = Math.max(g.right, left + width);
        g.height = Math.max(g.height, height);
      } else {
        groups.push({ top, left, right: left + width, height });
      }
    });

    let firstHl = null;
    groups.forEach((g, gi) => {
      const hl = document.createElement('div');
      hl.className = `pdf-hl ${tier}`;
      hl.dataset.c = cid;
      hl.style.left = (g.left - 2) + 'px';
      hl.style.top = (g.top - 1) + 'px';
      hl.style.width = (g.right - g.left + 4) + 'px';
      hl.style.height = (g.height + 4) + 'px';
      if (gi === 0) {
        // Placeholder number — recomputeDocOrder() will overwrite this with the
        // citation's true document position once highlight placement settles.
        const num = document.createElement('span');
        num.className = 'pdf-hl-num';
        num.textContent = `[—]`;
        hl.appendChild(num);
      }
      hl.addEventListener('click', () => activateCite(cid));
      page.pageEl.appendChild(hl);
      if (!firstHl) firstHl = hl;
    });
    return firstHl;
  }

  function updateBriefBadge(cid, tier) {
    if (docKind === 'pdf') {
      briefBody.querySelectorAll(`.pdf-hl[data-c="${cid}"]`).forEach(el => {
        el.classList.remove('ok','md','hi');
        el.classList.add(tier);
      });
    } else {
      const badge = briefBody.querySelector(`.cite[data-c="${cid}"]`);
      if (!badge) return;
      badge.classList.remove('ok','md','hi');
      badge.classList.add(tier);
    }
  }

  function renderCites() {
    if (!allCitations.length) {
      if (citesEmpty) citesEmpty.style.display = '';
      return;
    }
    if (citesEmpty) citesEmpty.style.display = 'none';

    // Filter
    let filtered = allCitations.map((c, i) => ({ c, i, tier: tierOf(c) }));
    let issuesCount = 0, casesCount = 0, statutesCount = 0;
    filtered.forEach(({ c, tier }) => {
      if (tier !== 'ok') issuesCount++;
      const t = (c.citation_type || '').toLowerCase();
      if (t.includes('case')) casesCount++;
      else if (t.includes('statute') || t.includes('regulation') || t.includes('rule')) statutesCount++;
    });

    cntIssues.textContent = `[${issuesCount}]`;
    cntAll.textContent = `[${allCitations.length}]`;
    cntCases.textContent = `[${casesCount}]`;
    cntStatutes.textContent = `[${statutesCount}]`;

    if (currentTab === 'issues') filtered = filtered.filter(x => x.tier !== 'ok');
    else if (currentTab === 'cases') filtered = filtered.filter(x => (x.c.citation_type || '').toLowerCase().includes('case'));
    else if (currentTab === 'statutes') filtered = filtered.filter(x => {
      const t = (x.c.citation_type || '').toLowerCase();
      return t.includes('statute') || t.includes('regulation') || t.includes('rule');
    });

    // Always sort by document position so the panel reads top-to-bottom in the
    // same order as the citations appear in the document. Citations whose
    // anchor wasn't located fall to the bottom (preserving array order among
    // themselves).
    const posOf = (cid) => docOrder.has(cid) ? docOrder.get(cid) : 9e9;
    filtered.sort((a, b) => {
      const cidA = a.c.id || `c${a.i+1}`;
      const cidB = b.c.id || `c${b.i+1}`;
      return posOf(cidA) - posOf(cidB);
    });

    if (!filtered.length) {
      citesList.innerHTML = `<div class="cites-empty">No ${currentTab === 'issues' ? 'issues' : currentTab} in this run.</div>`;
      return;
    }

    citesList.innerHTML = filtered.map(({ c, i, tier }) => {
      const cid = c.id || `c${i+1}`;
      // Use document position for the CITE · NN label so the right panel and
      // the [N] footnote in the brief always agree. Citations that couldn't
      // be located in the document show "—".
      const docNum = docOrder.get(cid);
      const numLabel = docNum != null ? String(docNum).padStart(2,'0') : '—';
      const flags = c.flags || [];
      const statusLabel = tier === 'hi' ? (c.existence_status === 'existence_not_found' ? 'NOT FOUND' : 'NON-CONFORMING')
        : tier === 'md' ? `FLAGGED${flags[0]?.rule_cite ? ' · ' + escapeHtml(flags[0].rule_cite.split(/\s+/)[0] || '').toUpperCase() : ''}`
        : 'VERIFIED';
      const findingsHtml = flags.length === 0
        ? '<em>passes all applicable form tests</em>'
        : flags.map((f, fi) => {
            const fixKey = `${cid}::${fi}`;
            const isApplied = appliedFixes.has(fixKey) && appliedFixes.get(fixKey).applied;
            const ruleStr = f.rule_cite ? `${escapeHtml(f.rule_cite)} — ` : '';
            const original = c.display_text || c.candidate_text || '';
            // Only render a Fix button for STRUCTURAL / Bluebook-format issues —
            // things the validator can mechanically rewrite (missing periods,
            // "vs." → "v.", wrong reporter abbreviation, comma placement, etc.).
            // Existence and substantive findings get embedded as Word comments
            // in the corrected DOCX instead (see NON_FIXABLE_CATEGORIES above).
            const canFix = !!f.suggested_fix
              && !!original
              && original.trim() !== String(f.suggested_fix).trim()
              && !NON_FIXABLE_CATEGORIES.has((f.category || '').toLowerCase());
            const previewBlock = isApplied
              ? `<div class="cr-fix-preview"><b>Applied:</b> ${escapeHtml(f.suggested_fix)}</div>`
              : '';
            const fixBtn = canFix
              ? `<button class="cr-fix${isApplied ? ' is-applied' : ''}"
                          data-fix-key="${fixKey}"
                          data-cid="${cid}"
                          data-flag-idx="${fi}">
                   ${isApplied
                      ? '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3 3 7-7"/></svg>Fixed · undo'
                      : '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 8h12M8 2l6 6-6 6"/></svg>Fix citation'}
                 </button>`
              : '';
            // The corrected-brief export only embeds Word comments for
            // existence-verdict issues — i.e. cases the verifier couldn't
            // confirm via CL / Justia / Cornell. Format/substantive flags
            // either get auto-fixed or are surface-level noise the lawyer
            // doesn't need re-flagged at the comment level.
            const isExistenceFinding = (f.category || '').toLowerCase() === 'existence';
            const commentHint = isExistenceFinding && docKind === 'docx'
              ? `<div class="cr-comment-hint">
                   <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                     <path d="M2 3h12v9H7l-3 3v-3H2V3z"/>
                   </svg>
                   Will be commented in corrected brief
                 </div>`
              : '';
            return `<div class="cr-flag">${ruleStr}${escapeHtml(f.message || '')}${fixBtn}${commentHint}${previewBlock}</div>`;
          }).join('');

      const existenceCheck = c.existence_status;
      const existsClass = existenceCheck === 'existence_not_found' ? 'bad'
        : existenceCheck === 'existence_verified' ? 'ok'
        : existenceCheck === 'not_applicable' || !existenceCheck ? 'warn' : 'warn';
      const quoteClass = flags.some(f => /quote|pinpoint/i.test(f.message || f.rule_cite || '')) ? 'warn' : (tier === 'hi' ? 'bad' : 'ok');
      const treatmentClass = flags.some(f => /treatment|overruled|distinguished|abrogated/i.test(f.message || f.rule_cite || '')) ? 'warn' : (tier === 'hi' ? 'bad' : 'ok');

      let cm = c.court_meta || c.citation_type || '';
      // Surface the verification source when it wasn't CourtListener — the
      // citation was rescued via the Justia / Cornell fallback waterfall.
      const url = c.courtlistener_url || '';
      let viaTag = '';
      if (c.existence_status === 'existence_verified') {
        if (/justia\.com/i.test(url)) viaTag = ' · VIA JUSTIA';
        else if (/law\.cornell\.edu/i.test(url)) viaTag = ' · VIA CORNELL';
      }
      cm = (cm || '') + viaTag;

      const anchor = citeAnchors.get(cid);
      const noAnchor = !anchor || anchor.kind === 'fallback';
      return `<div class="cite-row${noAnchor ? ' no-anchor' : ''}" data-c="${cid}">
        <div class="cr-row"><span class="cr-id">CITE · ${numLabel}</span><span class="cr-status ${tier}"><span class="pip"></span>${statusLabel}</span></div>
        <span class="cr-cite">${escapeHtml(c.display_text || c.candidate_text || '(text not retained)')}</span>
        <span class="cr-finding">${findingsHtml}</span>
        <div class="cr-meta">
          <span>${escapeHtml(cm.toUpperCase())}</span>
          <span class="checks">
            <span class="check ${existsClass}">${iconFor(existsClass)}EXISTS</span>
            <span class="check ${quoteClass}">${iconFor(quoteClass)}QUOTE</span>
            <span class="check ${treatmentClass}">${iconFor(treatmentClass)}TREATMENT</span>
          </span>
        </div>
      </div>`;
    }).join('');

    citesList.querySelectorAll('.cite-row').forEach(row => {
      row.addEventListener('click', (e) => {
        // Don't bubble row-clicks from the inner Fix button — that has its
        // own handler and we don't want activateCite to fire on top of it.
        if (e.target.closest('.cr-fix')) return;
        activateCite(row.dataset.c);
      });
    });
    citesList.querySelectorAll('.cr-fix').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const fixKey = btn.dataset.fixKey;
        const cid = btn.dataset.cid;
        const flagIdx = parseInt(btn.dataset.flagIdx, 10);
        toggleFix({ fixKey, cid, flagIdx });
      });
    });
  }

  // Categories whose findings can't be mechanically rewritten — they get
  // embedded as Word comments instead of as text replacements when the
  // user downloads the corrected brief. Existence findings (CL/Justia/Cornell
  // could not locate the case) and substantive-law flags need human judgment;
  // dropping them silently from the corrected DOCX would be dangerous.
  const NON_FIXABLE_CATEGORIES = new Set(['existence', 'substantive']);

  // ---- Fix application ----
  // Toggling a fix updates the live document preview AND records the fix so
  // we can rebuild a corrected DOCX on download. Each flag with a
  // suggested_fix is independently togglable.
  function toggleFix({ fixKey, cid, flagIdx }) {
    const cite = allCitations.find((c, i) => (c.id || `c${i+1}`) === cid);
    if (!cite) return;
    const flag = (cite.flags || [])[flagIdx];
    if (!flag || !flag.suggested_fix) return;
    const original = cite.display_text || cite.candidate_text || '';
    if (!original) return;
    const corrected = String(flag.suggested_fix);

    const existing = appliedFixes.get(fixKey);
    if (existing && existing.applied) {
      // Undo
      undoFixInBrief({ cid, original: existing.corrected, restored: existing.original });
      appliedFixes.set(fixKey, { ...existing, applied: false });
    } else {
      // Apply
      applyFixToBrief({ cid, original, corrected });
      appliedFixes.set(fixKey, { cid, original, corrected, flagIdx, applied: true });
    }
    renderCites();          // re-render so the button label flips
    refreshCorrectedDownloadAffordance();
    activateCite(cid);      // keep the same row selected so user doesn't lose context
  }

  function applyFixToBrief({ cid, original, corrected }) {
    if (docKind === 'pdf') {
      // PDFs aren't editable in-place — flip the highlight tier so the user
      // visually sees that this cite is "fixed" but the download stays the
      // marked source.
      briefBody.querySelectorAll(`.pdf-hl[data-c="${cid}"]`).forEach(el => el.classList.add('is-fixed'));
      return;
    }
    // DOCX (mammoth-rendered) — replace the text content of the wrapped
    // .cite span(s) with the corrected text. If the citation was wrapped
    // across multiple text nodes (italic case-name + plain reporter), we
    // join them into the first span and empty the rest so the line still
    // flows naturally.
    const spans = Array.from(briefBody.querySelectorAll(`.cite[data-c="${cid}"]`));
    if (!spans.length) return;
    spans[0].textContent = corrected;
    spans[0].classList.add('is-fixed');
    for (let i = 1; i < spans.length; i++) {
      spans[i].textContent = '';
      spans[i].classList.add('is-fixed');
    }
  }

  function undoFixInBrief({ cid, restored }) {
    if (docKind === 'pdf') {
      briefBody.querySelectorAll(`.pdf-hl[data-c="${cid}"]`).forEach(el => el.classList.remove('is-fixed'));
      return;
    }
    const spans = Array.from(briefBody.querySelectorAll(`.cite[data-c="${cid}"]`));
    if (!spans.length) return;
    spans[0].textContent = restored;
    spans[0].classList.remove('is-fixed');
    for (let i = 1; i < spans.length; i++) {
      spans[i].textContent = '';
      spans[i].classList.remove('is-fixed');
    }
  }

  // Show / hide the "Corrected brief" download. Visible whenever we have a
  // DOCX in memory AND there's something worth exporting — either a Fix has
  // been applied, or there are non-fixable findings that should be embedded
  // as Word comments. The button label tells the user exactly what they're
  // about to download.
  function refreshCorrectedDownloadAffordance() {
    const btn = document.getElementById('cv-corrected-btn');
    if (!btn) return;
    const supported = docKind === 'docx' && !!originalDocxBytes;
    if (!supported) { btn.style.display = 'none'; return; }

    const fixCount = Array.from(appliedFixes.values()).filter(v => v.applied).length;
    const commentCount = countCommentTargets();

    if (fixCount === 0 && commentCount === 0) {
      btn.style.display = 'none';
      return;
    }
    btn.style.display = '';
    const parts = [];
    if (fixCount) parts.push(`${fixCount} fix${fixCount === 1 ? '' : 'es'}`);
    if (commentCount) parts.push(`${commentCount} comment${commentCount === 1 ? '' : 's'}`);
    btn.textContent = `↓ Corrected brief (${parts.join(' · ')})`;
  }

  function countCommentTargets() {
    // Mirror buildCommentTargets — only existence-verdict issues become
    // comments, everything else is either fixed or not worth commenting.
    let n = 0;
    allCitations.forEach((c) => {
      if (
        c.existence_status === 'existence_not_found' ||
        c.existence_status === 'existence_name_mismatch' ||
        c.existence_status === 'existence_location_mismatch'
      ) n++;
    });
    return n;
  }

  // ---- Corrected DOCX export ----
  // Rebuild the original DOCX with two passes:
  //   1. Apply every "Fix" the user clicked — string-replace the original
  //      citation text with the validator's suggested_fix inside
  //      word/document.xml. Preserves original Word formatting because we
  //      mutate the existing zip rather than re-serializing fresh markup.
  //   2. Embed every NON-fixable finding (existence-check failures, substantive
  //      flags) as a native Word comment anchored to the post-fix citation
  //      text. The lawyer sees these in Word's review pane the same way they'd
  //      see any tracked-changes comment — impossible to miss when reviewing
  //      the corrected file.
  async function downloadCorrectedDocx() {
    if (!originalDocxBytes) {
      alert('Original document is no longer in memory. Re-upload to export a corrected brief.');
      return;
    }
    if (typeof JSZip === 'undefined') {
      // Wait briefly for the deferred CDN script.
      await new Promise(r => {
        const t = setInterval(() => { if (typeof JSZip !== 'undefined') { clearInterval(t); r(); } }, 50);
        setTimeout(() => { clearInterval(t); r(); }, 5000);
      });
    }
    if (typeof JSZip === 'undefined') {
      alert('Could not load DOCX writer (JSZip). Try again or refresh.');
      return;
    }

    const fixes = Array.from(appliedFixes.values()).filter(v => v.applied);

    // Build the list of citations that need a Word comment in the output.
    // A citation gets a comment if it has any flag in NON_FIXABLE_CATEGORIES,
    // OR if the existence check returned not_found / name_mismatch / location_mismatch
    // and wasn't rescued by the Justia/Cornell fallback. This is the lawyer's
    // safety net for things they shouldn't forget to investigate manually.
    const commentTargets = buildCommentTargets(fixes);

    if (!fixes.length && !commentTargets.length) {
      alert('Nothing to export — apply at least one Fix or run on a brief that has issues to comment.');
      return;
    }

    let zip;
    try {
      zip = await JSZip.loadAsync(originalDocxBytes);
    } catch (e) {
      alert('Could not parse the original DOCX: ' + e.message);
      return;
    }
    const docXmlFile = zip.file('word/document.xml');
    if (!docXmlFile) {
      alert('Unexpected DOCX structure — word/document.xml missing.');
      return;
    }
    let xml = await docXmlFile.async('string');

    // ---- Pass 1: Structural fixes ----
    // Sort fixes by original-string length descending so a longer original
    // (e.g. full citation) is replaced before any of its substrings, which
    // could otherwise be partially overwritten by an earlier shorter fix.
    fixes.sort((a, b) => b.original.length - a.original.length);

    let appliedCount = 0;
    const skipped = [];
    for (const fix of fixes) {
      if (xml.includes(fix.original)) {
        xml = xml.split(fix.original).join(escapeXml(fix.corrected));
        appliedCount++;
        continue;
      }
      const tolerantRe = buildTolerantDocxRegex(fix.original);
      if (tolerantRe && tolerantRe.test(xml)) {
        xml = xml.replace(tolerantRe, escapeXml(fix.corrected));
        appliedCount++;
        continue;
      }
      skipped.push(fix.original);
    }

    // ---- Pass 2: Word comments for non-fixable findings ----
    // Find existing max comment id so we don't collide with anything Word
    // already had in the source file.
    let nextCommentId = await getNextCommentId(zip);
    const addedComments = [];
    const commentSkipped = [];
    for (const tgt of commentTargets) {
      const id = nextCommentId++;
      const insertion = insertCommentMarkers(xml, tgt.targetText, id);
      if (insertion.applied) {
        xml = insertion.xml;
        addedComments.push({ id, body: tgt.body, target: tgt.targetText });
      } else {
        commentSkipped.push(tgt.targetText);
      }
    }

    // Persist mutated document.xml.
    zip.file('word/document.xml', xml);

    // Write/update word/comments.xml + relationships + content types if we
    // added any comments.
    if (addedComments.length) {
      await ensureCommentsPart(zip, addedComments);
    }

    const blob = await zip.generateAsync({
      type: 'blob',
      mimeType: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
    });

    const baseName = (originalFileName || 'document').replace(/\.docx$/i, '');
    triggerDownload(blob, `${baseName} — corrected.docx`);

    // Summary alert — only if anything's worth telling the user.
    const lines = [];
    if (fixes.length) {
      lines.push(`${appliedCount} of ${fixes.length} fix${fixes.length === 1 ? '' : 'es'} applied.`);
    }
    if (commentTargets.length) {
      lines.push(`${addedComments.length} of ${commentTargets.length} unfixable finding${commentTargets.length === 1 ? '' : 's'} embedded as Word comment${commentTargets.length === 1 ? '' : 's'}.`);
    }
    const allSkipped = [...skipped, ...commentSkipped];
    if (allSkipped.length) {
      lines.push('');
      lines.push(`${allSkipped.length} citation${allSkipped.length === 1 ? '' : 's'} couldn't be located in the document XML (typically because the text was split across italic/plain runs):`);
      allSkipped.slice(0, 6).forEach(s => lines.push('• ' + (s.length > 80 ? s.slice(0, 77) + '…' : s)));
      if (allSkipped.length > 6) lines.push(`• …and ${allSkipped.length - 6} more`);
    }
    if (lines.length) alert(lines.join('\n'));
  }

  // ---- Comment-target collection ----
  // The corrected brief IS the final brief — structural fixes the user clicked
  // are already baked in as plain-text edits (no track changes needed). The
  // only annotations that should remain are Word comments asking the lawyer
  // to manually verify cases that the existence-check waterfall couldn't
  // confirm. Everything else has been resolved.
  //
  // So a citation gets a comment if and only if its existence verdict is one
  // of:
  //   - existence_not_found       (CL + Justia + Cornell all came up dry)
  //   - existence_name_mismatch   (cite resolves to a different case name)
  //   - existence_location_mismatch (case is real but at a different cite)
  //
  // Format flags, abbreviation flags, etc. are NOT commented — they were
  // either auto-fixed or are below-the-line noise the lawyer doesn't need to
  // re-review at the comment level.
  function buildCommentTargets(fixes) {
    const out = [];
    // Comments must anchor to the post-fix text — if the user fixed a cite,
    // the original text is no longer in the document.
    const fixedTextByCid = new Map();
    fixes.forEach(f => fixedTextByCid.set(f.cid, f.corrected));

    allCitations.forEach((c, i) => {
      const cid = c.id || `c${i+1}`;
      const targetText = fixedTextByCid.get(cid) || c.display_text || c.candidate_text;
      if (!targetText) return;

      let body = null;
      if (c.existence_status === 'existence_not_found') {
        body = 'NOT LOCATED · Citation Verifier could not find this citation in CourtListener, Justia, or Cornell. Verify against your source before filing.';
      } else if (c.existence_status === 'existence_name_mismatch') {
        body = 'NAME MISMATCH · The cited case name does not match what the reporter at this volume/page contains. Verify the case name.';
      } else if (c.existence_status === 'existence_location_mismatch') {
        body = 'LOCATION MISMATCH · The case exists but at a different volume/page. Verify the pinpoint cite.';
      }
      if (!body) return;

      out.push({ cid, targetText, body });
    });
    return out;
  }

  // ---- Word comment XML helpers ----

  // Walk the original word/comments.xml (if present) to find the highest w:id
  // already in use so we can pick safe new IDs.
  async function getNextCommentId(zip) {
    const f = zip.file('word/comments.xml');
    if (!f) return 1000; // start well clear of any IDs Word might re-use
    let s = '';
    try { s = await f.async('string'); } catch { return 1000; }
    let max = -1;
    s.replace(/<w:comment\b[^>]*\bw:id="(\d+)"/g, (_, id) => {
      const n = parseInt(id, 10);
      if (n > max) max = n;
      return _;
    });
    return Math.max(1000, max + 1);
  }

  // Locate the citation text in document.xml and wrap the surrounding
  // <w:r>...</w:r> with comment range markers + a commentReference run.
  // Falls back gracefully if the text was split across multiple runs.
  function insertCommentMarkers(xml, targetText, commentId) {
    if (!targetText) return { xml, applied: false };

    // Try to find a single <w:t> run that contains the literal text.
    const at = xml.indexOf(targetText);
    if (at < 0) {
      // Last-resort: tolerant regex that allows tag boundaries between chars.
      const re = buildTolerantDocxRegex(targetText);
      if (!re) return { xml, applied: false };
      const m = re.exec(xml);
      if (!m) return { xml, applied: false };
      return wrapRangeAt(xml, m.index, m.index + m[0].length, commentId);
    }
    return wrapRangeAt(xml, at, at + targetText.length, commentId);
  }

  // Given a [start, end] character range that's known to land inside one or
  // more <w:r>...</w:r> elements, expand outward to the surrounding run
  // boundaries and inject the comment markers.
  function wrapRangeAt(xml, start, end, commentId) {
    // Walk back from `start` to find the nearest <w:r ...> opening.
    const before = xml.slice(0, start);
    const runOpen = Math.max(before.lastIndexOf('<w:r '), before.lastIndexOf('<w:r>'));
    if (runOpen < 0) return { xml, applied: false };

    // Walk forward from `end` to find the next </w:r> closing.
    const after = xml.indexOf('</w:r>', end);
    if (after < 0) return { xml, applied: false };
    const runClose = after + '</w:r>'.length;

    const startMarker = `<w:commentRangeStart w:id="${commentId}"/>`;
    const endMarker = `<w:commentRangeEnd w:id="${commentId}"/>` +
                      `<w:r><w:rPr><w:rStyle w:val="CommentReference"/></w:rPr>` +
                      `<w:commentReference w:id="${commentId}"/></w:r>`;

    const newXml =
      xml.slice(0, runOpen) +
      startMarker +
      xml.slice(runOpen, runClose) +
      endMarker +
      xml.slice(runClose);
    return { xml: newXml, applied: true };
  }

  // Build (or extend) word/comments.xml with the new comment definitions, and
  // make sure the relationship + content-type entries exist so Word actually
  // loads the comments part.
  async function ensureCommentsPart(zip, comments) {
    const NS_W = 'http://schemas.openxmlformats.org/wordprocessingml/2006/main';
    const existing = zip.file('word/comments.xml');
    let body = '';
    if (existing) {
      const s = await existing.async('string');
      // Splice new <w:comment> nodes in just before </w:comments>.
      const closeIdx = s.lastIndexOf('</w:comments>');
      if (closeIdx > 0) {
        body = s.slice(0, closeIdx) + comments.map(buildCommentXml).join('') + s.slice(closeIdx);
      } else {
        body = buildFreshCommentsXml(comments);
      }
    } else {
      body = buildFreshCommentsXml(comments);
    }
    zip.file('word/comments.xml', body);

    // Relationships
    const relsFile = zip.file('word/_rels/document.xml.rels');
    if (relsFile) {
      let rels = await relsFile.async('string');
      if (!/Type="[^"]*\/comments"/.test(rels)) {
        const insert = `<Relationship Id="rIdCV${Date.now()}" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/comments" Target="comments.xml"/>`;
        rels = rels.replace('</Relationships>', insert + '</Relationships>');
        zip.file('word/_rels/document.xml.rels', rels);
      }
    }

    // Content types
    const ctFile = zip.file('[Content_Types].xml');
    if (ctFile) {
      let ct = await ctFile.async('string');
      if (!/wordprocessingml\.comments\+xml/.test(ct)) {
        const override = `<Override PartName="/word/comments.xml" ContentType="application/vnd.openxmlformats-officedocument.wordprocessingml.comments+xml"/>`;
        ct = ct.replace('</Types>', override + '</Types>');
        zip.file('[Content_Types].xml', ct);
      }
    }
  }

  function buildFreshCommentsXml(comments) {
    return `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>` +
      `<w:comments xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main">` +
      comments.map(buildCommentXml).join('') +
      `</w:comments>`;
  }

  function buildCommentXml(c) {
    const date = new Date().toISOString();
    // Preserve paragraph breaks in the body — split on blank lines.
    const paragraphs = String(c.body || '').split(/\n\n+/).map(par => {
      const lines = par.split('\n');
      const runs = lines.map((line, i) => {
        const text = `<w:t xml:space="preserve">${escapeXml(line)}</w:t>`;
        // Insert a soft line break between consecutive lines within the same paragraph.
        return i === 0
          ? `<w:r>${text}</w:r>`
          : `<w:r><w:br/>${text}</w:r>`;
      }).join('');
      return `<w:p>${runs}</w:p>`;
    }).join('');
    // Author + initials come from the user's display_name (set in
    // /account/) so the comments in the corrected brief read as the
    // user's redlines, not platform-branded notes. Falls back to
    // 'Legal Overflow' / 'LO' for accounts that haven't set a name.
    const escAuthor = escapeXml(commentAuthor);
    const escInitials = escapeXml(commentInitials);
    return `<w:comment w:id="${c.id}" w:author="${escAuthor}" w:initials="${escInitials}" w:date="${date}">${paragraphs}</w:comment>`;
  }

  function escapeXml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&apos;');
  }
  // Allow runs of inline tags (e.g. <w:rPr>...</w:rPr></w:r><w:r>...<w:t>) to
  // appear between any two characters of the original text — handles the
  // common "italic case name + plain reporter" run-split.
  function buildTolerantDocxRegex(original) {
    if (!original || original.length < 4) return null;
    const escaped = original.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    // Insert "(?:<[^>]+>)*" between every literal char so any number of
    // intervening XML tags is allowed. Cap original length to keep the
    // regex from getting absurd.
    if (original.length > 200) return null;
    const tolerant = escaped.split('').join('(?:<[^>]+>)*');
    try { return new RegExp(tolerant); } catch { return null; }
  }

  function triggerDownload(blob, filename) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    setTimeout(() => { URL.revokeObjectURL(url); a.remove(); }, 200);
  }

  function iconFor(cls) {
    if (cls === 'ok') return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l3 3 7-7"/></svg>';
    if (cls === 'bad') return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4l8 8M12 4l-8 8"/></svg>';
    return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 4v5M8 12h.01"/></svg>';
  }

  // Scroll a target element into the centered visible area of a scrollable
  // container, using getBoundingClientRect — works regardless of whether the
  // container or any intermediate ancestor is the offsetParent of the target.
  function scrollIntoContainer(container, target, opts = {}) {
    if (!container || !target) return;
    const cRect = container.getBoundingClientRect();
    const tRect = target.getBoundingClientRect();
    const currentScroll = container.scrollTop;
    // Distance from the container's top edge to the target's top edge.
    const delta = tRect.top - cRect.top;
    // Center the target vertically within the container's visible area.
    const desired = currentScroll + delta - (container.clientHeight - tRect.height) / 2;
    const max = container.scrollHeight - container.clientHeight;
    container.scrollTo({
      top: Math.max(0, Math.min(max, desired)),
      behavior: opts.behavior || 'smooth',
    });
  }

  function activateCite(cid) {
    document.querySelectorAll('body.cv-page .cite').forEach(x => x.classList.toggle('is-active', x.dataset.c === cid));
    document.querySelectorAll('body.cv-page .pdf-hl').forEach(x => x.classList.toggle('is-active', x.dataset.c === cid));

    // ---- Right panel: bring the matching cite-row into view ----
    // If the row for this citation isn't visible under the current tab filter
    // (e.g. user clicked a verified cite while the Issues tab is active),
    // auto-switch to "All" so the card always shows up.
    let tgtRow = citesList.querySelector(`.cite-row[data-c="${cid}"]`);
    if (!tgtRow && currentTab !== 'all') {
      currentTab = 'all';
      tabsEl.querySelectorAll('.ct').forEach(x => x.classList.toggle('is-active', x.dataset.tab === 'all'));
      renderCites();
      tgtRow = citesList.querySelector(`.cite-row[data-c="${cid}"]`);
    }

    document.querySelectorAll('body.cv-page .cite-row').forEach(x => x.classList.toggle('is-active', x.dataset.c === cid));

    if (tgtRow) {
      // Wait one frame so the layout from any tab switch / re-render settles
      // before we measure rects — otherwise getBoundingClientRect can return
      // stale values from before the new innerHTML painted.
      requestAnimationFrame(() => {
        scrollIntoContainer(citesList, tgtRow);
        // Flash the row briefly so it's obvious which card just opened.
        tgtRow.style.transition = 'background .3s ease';
        const prev = tgtRow.style.background;
        tgtRow.style.background = 'rgba(10,125,87,.12)';
        setTimeout(() => { tgtRow.style.background = prev; }, 600);
      });
    }

    // ---- Left panel: scroll the brief to the citation ----
    const anchor = citeAnchors.get(cid);
    if (anchor && anchor.kind === 'el' && anchor.el && document.contains(anchor.el)) {
      scrollIntoContainer(briefBody, anchor.el);
      // Flash the anchor so the user can see where it landed.
      anchor.el.style.transition = 'box-shadow .35s ease';
      anchor.el.style.boxShadow = '0 0 0 2px var(--accent-deep)';
      setTimeout(() => { anchor.el.style.boxShadow = ''; }, 800);
    } else if (anchor && anchor.kind === 'fallback') {
      // No exact location — scroll proportionally so the user lands roughly
      // where this citation is in the document.
      const max = briefBody.scrollHeight - briefBody.clientHeight;
      briefBody.scrollTo({ top: Math.max(0, max * anchor.ratio - 80), behavior: 'smooth' });
    }
  }

  function renderDownloadActions(run) {
    rbActions.innerHTML = '';
    if (run.form_report_url) {
      const a = document.createElement('a');
      a.href = run.form_report_url;
      a.className = 'ws-btn';
      a.download = 'form-check-report.docx';
      a.textContent = 'Download report';
      rbActions.appendChild(a);
    }
    if (run.marked_source_url) {
      const a = document.createElement('a');
      a.href = run.marked_source_url;
      a.className = 'ws-btn ws-btn-ghost';
      a.style.fontSize = '10px';
      a.download = `marked-source.${run.file_format}`;
      a.textContent = 'Open annotated brief';
      rbActions.appendChild(a);
    }
    // Corrected-brief button — DOCX only, only renders when at least one fix
    // is currently applied. Re-created here because we just blew away
    // rbActions.innerHTML; refreshCorrectedDownloadAffordance() decides
    // whether to show it.
    const correctedBtn = document.createElement('button');
    correctedBtn.id = 'cv-corrected-btn';
    correctedBtn.className = 'ws-btn';
    correctedBtn.style.display = 'none';
    correctedBtn.textContent = '↓ Corrected brief';
    correctedBtn.addEventListener('click', () => downloadCorrectedDocx());
    rbActions.appendChild(correctedBtn);

    const back = document.createElement('button');
    back.className = 'ws-btn ws-btn-ghost';
    back.style.fontSize = '10px';
    back.textContent = 'New run';
    back.addEventListener('click', () => location.reload());
    rbActions.appendChild(back);

    refreshCorrectedDownloadAffordance();
  }

  function escapeHtml(s) {
    return String(s || '').replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c]));
  }
</script>

<script is:inline>
(function clock() {
  const el = document.getElementById('nav-clock');
  if (!el) return;
  function tick() {
    const d = new Date();
    let h = d.getHours();
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12; if (h === 0) h = 12;
    const mm = String(d.getMinutes()).padStart(2, '0');
    el.textContent = `COCOA · ${h}:${mm} ${ampm}`;
  }
  tick();
  setInterval(tick, 1000);
})();
</script>
</body>
</html>
