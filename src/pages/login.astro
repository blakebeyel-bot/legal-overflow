---
import Consent from '../partials/consent.astro';
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Sign in — Legal Overflow</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<style>
  .auth-wrap { max-width: 460px; margin: 80px auto; padding: 0 24px; }
  .auth-kicker { font-family: var(--mono); font-size: 11px; color: var(--accent-deep); letter-spacing: .08em; text-transform: uppercase; margin-bottom: 14px; }
  .auth-title { font-family: var(--serif); font-weight: 400; font-size: clamp(40px, 6vw, 64px); line-height: 1; letter-spacing: -.02em; margin: 0 0 20px; }
  .auth-title em { color: var(--accent-deep); }
  .auth-sub { font-size: 15px; line-height: 1.55; color: var(--ink-2); margin: 0 0 28px; }
  .auth-form { display: flex; flex-direction: column; gap: 14px; }
  .auth-form label { font-family: var(--mono); font-size: 11px; color: var(--ink); letter-spacing: .04em; text-transform: uppercase; }
  .auth-form input { font-family: var(--sans); font-size: 15px; padding: 12px 14px; background: #fff; border: 1px solid var(--rule-soft); border-radius: 6px; color: var(--ink); }
  .auth-form input:focus { outline: none; border-color: var(--accent-deep); }
  .auth-submit {
    font-family: var(--mono); font-size: 12px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase;
    padding: 14px 24px; background: var(--ink); color: var(--paper); border: 1px solid var(--ink);
    border-radius: 999px; cursor: pointer; transition: background .2s ease;
  }
  .auth-submit:hover:not(:disabled) { background: var(--accent-deep); border-color: var(--accent-deep); }
  .auth-submit:disabled { opacity: .6; cursor: wait; }
  .auth-msg { margin-top: 16px; padding: 14px; border-radius: 6px; font-size: 14px; display: none; }
  .auth-msg.success { background: rgba(10, 125, 87, .08); border: 1px solid var(--accent-deep); color: var(--ink); display: block; }
  .auth-msg.error { background: rgba(179, 83, 47, .08); border: 1px solid #b3532f; color: var(--ink); display: block; }
  .auth-alt { font-size: 13px; color: var(--ink-3); margin-top: 24px; text-align: center; }
  .auth-alt a { color: var(--accent-deep); border-bottom: 1px solid var(--accent); }
</style>
  <link rel="stylesheet" href="/site-anim.css" />
  <script src="/site-anim.js" defer></script>
</head>
<body>
<div id="grain"></div>

<header class="nav">
  <a href="/" class="brand">
    <svg class="brand-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="1"/><path d="M20 6 L20 34 M8 14 L32 14 M8 26 L32 26" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="20" cy="14" r="2.5" fill="currentColor"/><circle cx="20" cy="26" r="2.5" fill="var(--accent)"/></svg>
    <span class="brand-text"><span>Legal</span><span class="brand-over">Overflow</span></span>
  </a>
  <nav class="nav-links">
    <a href="/#skills">Skills</a>
    <a href="/#articles">Resources</a>
    <a href="/agents/">Agents</a>
    <a href="/tracker/">Tracker</a>
    <a href="/#services">Services</a>
    <a href="/about/">About</a>
  </nav>
  <div class="nav-right">
    <a href="/#subscribe" class="nav-sub">Subscribe</a>
  </div>
</header>

<div class="auth-wrap">
  <div class="auth-kicker">Sign in</div>
  <h1 class="auth-title">Sign <em>in</em>.</h1>
  <p class="auth-sub">Email and password. Don't have an account yet? <a href="/signup/">Sign up here.</a></p>

  <form id="auth-form" class="auth-form">
    <label for="email">Email address</label>
    <input type="email" id="email" name="email" required placeholder="you@company.com" autocomplete="email" />
    <label for="password">Password</label>
    <input type="password" id="password" name="password" required minlength="8" autocomplete="current-password" />
    <button type="submit" class="auth-submit" id="submit-btn">Sign in</button>
  </form>

  <div id="auth-msg" class="auth-msg"></div>

  <p class="auth-alt">Forgot your password? <a href="mailto:contact@beyelbrothers.com?subject=Password%20reset">Email us to reset.</a></p>
</div>

<script>
  import { getSupabase } from '../lib/supabase';

  const supabase = getSupabase();

  // If already signed in, redirect to the agents page.
  const { data: { session } } = await supabase.auth.getSession();
  if (session) {
    const redirect = new URLSearchParams(location.search).get('redirect') || '/agents/contract-review/';
    location.href = redirect;
  }

  const form = document.getElementById('auth-form');
  const msg = document.getElementById('auth-msg');
  const btn = document.getElementById('submit-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value;
    if (!email || !password) return;
    btn.disabled = true;
    btn.textContent = 'Signing in…';
    msg.className = 'auth-msg';
    msg.textContent = '';

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    btn.disabled = false;
    btn.textContent = 'Sign in';

    if (error) {
      msg.className = 'auth-msg error';
      // Surface the most common errors in user-readable language; everything
      // else falls through to the raw Supabase message.
      const m = error.message || '';
      if (/invalid login credentials/i.test(m)) {
        msg.textContent = 'Email or password is incorrect.';
      } else if (/email not confirmed/i.test(m)) {
        msg.textContent = 'Please confirm your email address before signing in. Check your inbox for the confirmation link.';
      } else {
        msg.textContent = m;
      }
      return;
    }

    if (data?.session) {
      const redirect = new URLSearchParams(location.search).get('redirect') || '/agents/contract-review/';
      location.href = redirect;
    } else {
      msg.className = 'auth-msg error';
      msg.textContent = 'Sign-in did not produce a session. Try again.';
    }
  });
</script>

<Consent />
</body>
</html>
