// ============ skill sample-output download (back of flip card) ============
(function sampleDownload() {
  function slugify(s) {
    return (s || 'sample-output')
      .toLowerCase()
      .replace(/[^\w\s-]/g, '')
      .trim()
      .replace(/\s+/g, '-')
      .slice(0, 60);
  }
  document.querySelectorAll('.sk-back-dl').forEach(btn => {
    // Real download links (<a> with href) use the browser's native download handling. Skip synthesizing.
    if (btn.tagName === 'A' && btn.getAttribute('href') && btn.getAttribute('href') !== '#') return;
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const card = btn.closest('.skill-card');
      if (!card) return;
      const title = card.querySelector('.skill-title')?.textContent?.trim() || 'sample-output';
      const inputLabel = card.querySelector('.sk-io-label:not(.sk-io-out)')?.textContent?.trim() || 'Input';
      const outputLabel = card.querySelector('.sk-io-label.sk-io-out')?.textContent?.trim() || 'Output';
      const inputBlock = card.querySelector('.sk-io-col:not(:has(.sk-io-out)) .sk-io-block')?.textContent?.trim() || '';
      const outputBlock = card.querySelector('.sk-io-col:has(.sk-io-out) .sk-io-block')?.textContent?.trim() || '';
      const parts = [
        'LEGAL OVERFLOW — Sample output',
        '================================',
        '',
        'Skill: ' + title,
        'Generated: ' + new Date().toISOString().slice(0, 10),
        ''
      ];
      if (inputBlock) {
        parts.push('--- ' + inputLabel + ' ---', '', inputBlock, '');
      }
      parts.push('--- ' + outputLabel + ' ---', '', outputBlock || inputBlock, '');
      parts.push('', '— legaloverflow.com');
      const text = parts.join('\n');
      const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = slugify(title) + '-sample-output.txt';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(url), 100);
    });
  });
})();

// ============ count-up stats ============
(function count() {
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target;
      const target = parseInt(el.getAttribute('data-count'), 10);
      if (isNaN(target)) return;
      const dur = 1400;
      const start = performance.now();
      function tick(t) {
        const p = Math.min(1, (t - start) / dur);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = Math.round(target * eased).toLocaleString();
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
      io.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('[data-count]').forEach(el => io.observe(el));
})();

// ============ neural graph canvas ============
(function graph() {
  const canvas = document.getElementById('graph');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, DPR = Math.min(window.devicePixelRatio || 1, 2);
  const nodes = [];
  const pulses = [];
  const N = 70;
  const MAX_LINE = 220;
  const MOUSE_R = 220;
  let mouseX = -9999, mouseY = -9999;
  let t = 0;

  function resize() {
    W = canvas.clientWidth; H = canvas.clientHeight;
    canvas.width = W * DPR; canvas.height = H * DPR;
    ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
  }
  function init() {
    nodes.length = 0;
    pulses.length = 0;
    for (let i = 0; i < N; i++) {
      nodes.push({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.55,
        vy: (Math.random() - 0.5) * 0.55,
        r: Math.random() * 1.6 + 0.6,
        hub: Math.random() < 0.16,
        phase: Math.random() * Math.PI * 2,
        nextFireAt: 60 + Math.random() * 240
      });
    }
  }
  function maybeFire(idx) {
    const a = nodes[idx];
    if (!a.hub) return;
    if (t < a.nextFireAt) return;
    a.nextFireAt = t + 90 + Math.random() * 220;
    // fire to nearest neighbours
    const targets = [];
    for (let j = 0; j < nodes.length; j++) {
      if (j === idx) continue;
      const b = nodes[j];
      const dx = a.x - b.x, dy = a.y - b.y;
      const d2 = dx*dx + dy*dy;
      if (d2 < MAX_LINE * MAX_LINE) targets.push({ j, d2 });
    }
    targets.sort((p, q) => p.d2 - q.d2);
    const fan = Math.min(2 + (Math.random() * 2 | 0), targets.length);
    for (let k = 0; k < fan; k++) {
      pulses.push({
        from: idx,
        to: targets[k].j,
        p: 0,
        speed: 0.012 + Math.random() * 0.018
      });
    }
  }
  function draw() {
    t += 1;
    ctx.clearRect(0, 0, W, H);
    // motion + mouse repel
    for (let i = 0; i < nodes.length; i++) {
      const a = nodes[i];
      a.x += a.vx; a.y += a.vy;
      if (a.x < 0 || a.x > W) a.vx *= -1;
      if (a.y < 0 || a.y > H) a.vy *= -1;

      const mdx = a.x - mouseX, mdy = a.y - mouseY;
      const md2 = mdx*mdx + mdy*mdy;
      if (md2 < MOUSE_R * MOUSE_R) {
        const md = Math.sqrt(md2) || 1;
        const f = 0.9 * (1 - md / MOUSE_R);
        a.x += (mdx/md) * f;
        a.y += (mdy/md) * f;
      }
      maybeFire(i);
    }
    // lines (with breathing alpha + cursor-tinted RGB)
    for (let i = 0; i < nodes.length; i++) {
      const a = nodes[i];
      for (let j = i + 1; j < nodes.length; j++) {
        const b = nodes[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const d2 = dx*dx + dy*dy;
        if (d2 < MAX_LINE * MAX_LINE) {
          const dist = Math.sqrt(d2);
          const breath = 0.5 + 0.5 * Math.sin(t * 0.018 + a.phase + b.phase * 0.6);
          let alpha = (1 - dist / MAX_LINE) * 0.4 * (0.55 + 0.45 * breath);
          // cursor proximity tint toward accent
          const mx = (a.x + b.x) / 2 - mouseX;
          const my = (a.y + b.y) / 2 - mouseY;
          const mdist = Math.sqrt(mx*mx + my*my);
          const tint = Math.max(0, 1 - mdist / 280);
          const r = Math.round(14 + (10 - 14) * tint);
          const g = Math.round(21 + (125 - 21) * tint);
          const bl = Math.round(18 + (87 - 18) * tint);
          ctx.strokeStyle = `rgba(${r},${g},${bl},${alpha})`;
          ctx.lineWidth = 0.6 + tint * 0.4;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.stroke();
        }
      }
    }
    // travelling pulses
    for (let k = pulses.length - 1; k >= 0; k--) {
      const pu = pulses[k];
      pu.p += pu.speed;
      if (pu.p >= 1) { pulses.splice(k, 1); continue; }
      const a = nodes[pu.from], b = nodes[pu.to];
      if (!a || !b) { pulses.splice(k, 1); continue; }
      const px = a.x + (b.x - a.x) * pu.p;
      const py = a.y + (b.y - a.y) * pu.p;
      const fade = Math.sin(pu.p * Math.PI);
      ctx.beginPath();
      ctx.arc(px, py, 6, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(16,185,129,${0.12 * fade})`;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(px, py, 2, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(10,125,87,${0.95 * fade})`;
      ctx.fill();
    }
    // nodes
    for (const n of nodes) {
      const breath = n.hub ? (0.7 + 0.3 * Math.sin(t * 0.04 + n.phase)) : 1;
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r * breath, 0, Math.PI * 2);
      ctx.fillStyle = n.hub ? 'rgba(10,125,87,.92)' : 'rgba(14,21,18,.5)';
      ctx.fill();
      if (n.hub) {
        ctx.beginPath();
        ctx.arc(n.x, n.y, (n.r + 4) * breath, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(16,185,129,${0.25 + 0.2 * breath})`;
        ctx.lineWidth = 0.7;
        ctx.stroke();
      }
    }
    requestAnimationFrame(draw);
  }
  window.addEventListener('resize', () => { resize(); });
  window.addEventListener('mousemove', (e) => {
    const r = canvas.getBoundingClientRect();
    mouseX = e.clientX - r.left; mouseY = e.clientY - r.top;
  });
  window.addEventListener('mouseleave', () => { mouseX = -9999; mouseY = -9999; });
  resize(); init(); draw();
})();

