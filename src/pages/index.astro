      lineIdx++;
      stepLine();
    }, delay);
  }

  function finishSkill() {
    const s = skills[skillIdx];
    clearInterval(elapsedInt);
    status.textContent = `saved ${s.saved}`;
    status.style.color = '#d97757';
    body.innerHTML = body.innerHTML.replace(/<span class="wt-caret"[^>]*><\/span>/, '');
    setTimeout(() => {
      skillIdx = (skillIdx + 1) % skills.length;
      startSkill();
    }, 2600);
  }

  startSkill();
})();

</script>

<DownloadGate />
<Consent />
</body>
</html>
