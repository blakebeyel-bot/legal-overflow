    setTimeout(() => {
      // append this full line + caret
      const built = s.lines.slice(0, lineIdx + 1).join('\n');
      body.innerHTML = built + '\n' + caret;
      lineIdx++;
      stepLine();
    }, delay);
  }

  function finishSkill() {
    const s = skills[skillIdx];
    clearInterval(elapsedInt);
    status.textContent = `saved ${s.saved}`;
