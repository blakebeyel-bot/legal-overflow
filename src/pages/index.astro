---
import { getCollection } from 'astro:content';
import { phArt, formatDate, trackLabel, trackClass } from '../lib/phArt';
import ArticleSection from '../partials/article-section.astro';

const all = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = all.find(a => a.data.featured) ?? all[0];
const gridArticles = all.filter(a => a.slug !== featured?.slug);
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Legal Overflow — Where law meets machine intelligence</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
</head>
<body>
  <div id="grain"></div>
  <div id="cursor-dot" aria-hidden="true"></div>
  <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => { document.location.href = "/admin/"; });
        }
      });
    }
  </script>

  <!-- NAV -->
  <header class="nav">
    <a href="#" class="brand" aria-label="Legal Overflow home">
      <svg class="brand-mark" viewBox="0 0 40 40" aria-hidden="true">
        <circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="1"/>
        <path d="M20 6 L20 34 M8 14 L32 14 M8 26 L32 26" stroke="currentColor" stroke-width="1" fill="none"/>
        <circle cx="20" cy="14" r="2.5" fill="currentColor"/>
        <circle cx="20" cy="26" r="2.5" fill="var(--accent)"/>
      </svg>
      <span class="brand-text">
        <span>Legal</span><span class="brand-over">Overflow</span>
      </span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="#skills" data-nav>Skills</a>
      <a href="#articles" data-nav>Resources</a>
      <a href="#services" data-nav>Services</a>
      <a href="/about/" data-nav>About</a>
    </nav>
    <div class="nav-right">
      <div class="live-dot" aria-hidden="true"></div>
      <span class="nav-meta" id="nav-clock">—</span>
      <a href="#subscribe" class="nav-sub">Subscribe</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <canvas id="graph" aria-hidden="true"></canvas>
    <div class="hero-grid">
      <div class="hero-lede">
      <div class="hero-kicker">
        <span class="kicker-dash"></span>
        <span>Issue 024 · Spring 2026 · A field journal on AI and the legal profession</span>
      </div>
      <h1 class="hero-title">
        <span class="line">The law is</span>
        <span class="line"><em>learning</em> to</span>
        <span class="line">automate itself.</span>
      </h1>
      <p class="hero-sub">
        Custom Claude Skills, working notes, and deep reporting on how artificial intelligence is
        <em>actually</em> getting work out the door — for legal teams and the businesses they serve. Written and tested by an in-house attorney, in public.
      </p>
      <div class="hero-cta">
        <a href="#articles" class="btn-primary">
          <span>Start reading</span>
          <svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        </a>
        <a href="#subscribe" class="btn-ghost">
          <span>Weekly dispatch</span>
          <span class="btn-count">Free &middot; plain text</span>
        </a>
      </div>

      <!-- Narrow-viewport demo fallback: stacks under CTA on <1200px -->
      <figure class="hero-demo hero-demo-inline">
        <div class="hero-demo-frame" data-sound="off">
          <div class="macbook-screen">
            <div class="macbook-bezel">
              <video
                class="hero-demo-video"
                src="/assets/hero-demo.mp4"
                autoplay muted loop playsinline preload="metadata"
                aria-label="Legal Overflow demo video">
              </video>
              <button type="button" class="sound-toggle" aria-label="Toggle sound">
                <svg class="icon-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
                <svg class="icon-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                <span class="label"></span>
              </button>
            </div>
          </div>
          <div class="macbook-base" aria-hidden="true"></div>
        </div>
        <figcaption class="hero-demo-caption">
          <span class="dot"></span>
          <span>Live demo</span>
          <span class="sep">·</span>
          <span>Skills in the wild</span>
        </figcaption>
      </figure>
      </div>

      <!-- Desktop demo: fills right column on ≥1200px -->
      <figure class="hero-demo" aria-label="Product demo">
        <div class="hero-demo-frame" data-sound="off">
          <div class="macbook-screen">
            <div class="macbook-bezel">
              <video
                class="hero-demo-video"
                src="/assets/hero-demo.mp4"
                autoplay muted loop playsinline preload="metadata"
                aria-label="Legal Overflow demo video">
              </video>
              <button type="button" class="sound-toggle" aria-label="Toggle sound">
                <svg class="icon-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
                <svg class="icon-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                <span class="label"></span>
              </button>
            </div>
          </div>
          <div class="macbook-base" aria-hidden="true"></div>
        </div>
        <figcaption class="hero-demo-caption">
          <span class="dot"></span>
          <span>Live demo</span>
          <span class="sep">·</span>
          <span>Skills in the wild</span>
        </figcaption>
      </figure>

      <!-- NOW PANEL — the current state of the work, not historical traction. -->
      <div class="hero-now" aria-label="Current status">
        <div class="now-head">
          <span class="now-live"><span class="now-dot"></span>Now</span>
          <span class="now-stamp">Updated <time datetime="2026-04-18">Apr 18</time></span>
        </div>
        <div class="now-grid">
          <div class="now-cell">
            <span class="now-label">Writing</span>
            <span class="now-val"><em>The ghost in the redline</em></span>
            <span class="now-sub">essay · draft 3 of 4</span>
          </div>
          <div class="now-cell">
            <span class="now-label">Last shipped</span>
            <span class="now-val">cite-check.skill <span class="now-ver">v2</span></span>
            <span class="now-sub">Apr 14 · <a href="#skills">view Skill</a></span>
          </div>
          <div class="now-cell">
            <span class="now-label">In the lab</span>
            <span class="now-val">Deposition-prep field study</span>
            <span class="now-sub">4 firms · interviews in progress</span>
          </div>
          <div class="now-cell">
            <span class="now-label">Next up</span>
            <span class="now-val">&ldquo;Same model, both sides&rdquo;</span>
            <span class="now-sub">May · transactional case study</span>
          </div>
        </div>
      </div>

    </div>

    <!-- cinematic hero scene removed per request -->
  </section>

  <!-- MARQUEE -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span>§ 230 reform</span><span>·</span><span>LLM hallucination sanctions</span><span>·</span>
      <span>e-discovery at scale</span><span>·</span><span>Bar Rule 1.1 competence</span><span>·</span>
      <span>contract graph extraction</span><span>·</span><span>regulatory sandboxes</span><span>·</span>
      <span>Mata v. Avianca</span><span>·</span><span>privilege & retrieval</span><span>·</span>
      <span>deposition transcription</span><span>·</span><span>agentic paralegals</span><span>·</span>
      <span>§ 230 reform</span><span>·</span><span>LLM hallucination sanctions</span><span>·</span>
      <span>e-discovery at scale</span><span>·</span><span>Bar Rule 1.1 competence</span><span>·</span>
      <span>contract graph extraction</span><span>·</span><span>regulatory sandboxes</span><span>·</span>
    </div>
  </div>

  <!-- TIME-SAVED TICKER -->
  <section class="tsticker" aria-label="Time saved by Skills">
    <div class="tst-inner">
      <div class="tst-lead">
        <span class="tst-label">Time saved this month</span>
        <span class="tst-big"><span id="tst-hours" data-count="37420">0</span><span class="tst-unit">hrs</span></span>
        <span class="tst-fine">by readers running Skills published here · <a href="#skills">view Skills</a></span>
      </div>
      <ol class="tst-rows">
        <li>
          <span class="tst-skill">Contract redline <em>Tier 1</em></span>
          <span class="tst-from">4 h 20 m</span>
          <span class="tst-arrow">→</span>
          <span class="tst-to">11 min</span>
          <span class="tst-delta">−95%</span>
        </li>
        <li>
          <span class="tst-skill">Deposition prep <em>in one afternoon</em></span>
          <span class="tst-from">2 days</span>
          <span class="tst-arrow">→</span>
          <span class="tst-to">3 h</span>
          <span class="tst-delta">−81%</span>
        </li>
        <li>
          <span class="tst-skill">Citation verification <em>protocol</em></span>
          <span class="tst-from">90 min</span>
          <span class="tst-arrow">→</span>
          <span class="tst-to">4 min</span>
          <span class="tst-delta">−96%</span>
        </li>
        <li>
          <span class="tst-skill">e-Discovery triage <em>100k → 500</em></span>
          <span class="tst-from">11 days</span>
          <span class="tst-arrow">→</span>
          <span class="tst-to">6 h</span>
          <span class="tst-delta">−93%</span>
        </li>
        <li>
          <span class="tst-skill">Motion-to-dismiss <em>research + draft</em></span>
          <span class="tst-from">22 h</span>
          <span class="tst-arrow">→</span>
          <span class="tst-to">2 h 40 m</span>
          <span class="tst-delta">−88%</span>
        </li>
      </ol>
    </div>
  </section>

  <!-- THREE PILLARS -->
  <section class="pillars" id="pillars">
    <div class="pillar-intro">
      <span class="pillar-kicker"><span class="kicker-dash"></span> What's here</span>
      <h2 class="pillar-h">One in-house attorney, writing the <em>playbook</em> in public.</h2>
      <p class="pillar-p">Three ways in, all free. Pull a <strong>Skill</strong> off the shelf and run it this afternoon. Read a <strong>Resource</strong> to understand why it works and where it breaks. Book a <strong>Service</strong> engagement if you'd rather have someone do it with you. Everything here is tagged <span class="track-pill track-legal-inline">Legal</span> or <span class="track-pill track-biz-inline">Business</span> so you can filter to what fits your role.</p>
    </div>
    <div class="pillar-grid">
      <a href="#skills" class="pillar-card">
        <div class="pillar-num">P / 01</div>
        <div class="pillar-icon">
          <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <rect x="8" y="10" width="32" height="28" rx="2" stroke="currentColor" stroke-width="1.4"/>
            <path d="M14 18h20M14 24h20M14 30h12" stroke="currentColor" stroke-width="1.4"/>
            <circle cx="38" cy="34" r="5" fill="var(--accent)"/>
            <path d="M35.5 34l2 2 3-3.5" stroke="var(--ink)" stroke-width="1.4" fill="none"/>
          </svg>
        </div>
        <div class="pillar-label">Skills</div>
        <h3 class="pillar-title">Ready-to-use AI prompts &amp; workflows</h3>
        <p class="pillar-desc">Prompt packs, chained workflows, and templates — designed to plug into any agent or chat surface. Free to download, MIT-licensed.</p>
        <div class="pillar-cta"><span>View Skills</span>
          <svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        </div>
      </a>
      <a href="#articles" class="pillar-card">
        <div class="pillar-num">P / 02</div>
        <div class="pillar-icon">
          <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <path d="M10 8h20l8 8v24H10V8z" stroke="currentColor" stroke-width="1.4"/>
            <path d="M30 8v8h8" stroke="currentColor" stroke-width="1.4"/>
            <path d="M15 22h18M15 28h18M15 34h12" stroke="currentColor" stroke-width="1.4"/>
          </svg>
        </div>
        <div class="pillar-label">Resources</div>
        <h3 class="pillar-title">Guides, reports &amp; insights</h3>
        <p class="pillar-desc">Long-form essays, implementation guides, case studies, and a weekly dispatch for busy in-house counsel and operators who actually need to ship.</p>
        <div class="pillar-cta"><span>View Resources</span>
          <svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        </div>
      </a>
      <a href="#services" class="pillar-card">
        <div class="pillar-num">P / 03</div>
        <div class="pillar-icon">
          <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <circle cx="24" cy="24" r="16" stroke="currentColor" stroke-width="1.4"/>
            <path d="M24 14v10l7 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <circle cx="24" cy="24" r="2.5" fill="var(--accent)"/>
          </svg>
        </div>
        <div class="pillar-label">Services</div>
        <h3 class="pillar-title">End-to-end AI implementation</h3>
        <p class="pillar-desc">Hands-on engagements: audit your current stack, design the workflow, train the team, and handle the ethics-compliance paperwork.</p>
        <div class="pillar-cta"><span>View Services</span>
          <svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        </div>
      </a>
    </div>
  </section>

  <!-- RESOURCES (blog/articles) -->
  <section class="featured" id="articles">
    <div class="section-head">
      <span class="section-num">02</span>
      <h2 class="section-title">Resources</h2>
      <span class="section-meta">Guides, reports &amp; insights · Updated weekly</span>
      <div class="track-filter" data-filter-scope="#articles">
        <span class="tf-label">Filter by track:</span>
        <button type="button" data-track-filter="all" aria-pressed="true">All</button>
        <button type="button" data-track-filter="legal" aria-pressed="false">· Legal</button>
        <button type="button" data-track-filter="business" aria-pressed="false">· Business</button>
        <span class="tf-count" data-filter-count></span>
      </div>
    </div>

    <ArticleSection featured={featured} gridArticles={gridArticles} />
  </section>

  <!-- SKILLS & WORKFLOWS -->
  <section class="skills" id="skills">
    <div class="section-head">
      <span class="section-num">03</span>
      <h2 class="section-title">Skills &amp; workflows</h2>
      <span class="section-meta">Free downloads · Prompts, checklists, and templates I actually use</span>
      <div class="track-filter" data-filter-scope="#skills">
        <span class="tf-label">Filter by track:</span>
        <button type="button" data-track-filter="all" aria-pressed="true">All</button>
        <button type="button" data-track-filter="legal" aria-pressed="false">· Legal</button>
        <button type="button" data-track-filter="business" aria-pressed="false">· Business</button>
        <span class="tf-count" data-filter-count></span>
      </div>
    </div>

    <div class="skills-grid">
      <article class="skill-card" data-track="legal">
        <div class="sk-face sk-front">
          <div class="skill-head">
            <span class="skill-type">Prompt pack</span>
            <span class="skill-format">.md · 14 KB</span>
          <span class="track-pill track-legal">Legal</span>
          </div>
          <h3 class="skill-title">Contract redline review — Tier 1</h3>
          <p class="skill-desc">Nine chained prompts that walk a frontier model through a first-pass review of an NDA, MSA, or SaaS agreement. Includes confidence gates and an escalation prompt.</p>
          <ul class="skill-meta-list">
            <li><span class="sk-dot"></span> Tested on GPT-5, Claude 4.5, Gemini 2.5</li>
            <li><span class="sk-dot"></span> Works inside any chat surface</li>
            <li><span class="sk-dot"></span> MIT-licensed, remix as you like</li>
          </ul>
          <div class="skill-foot">
            <button class="sk-peek" type="button">Peek inside →</button>
            <a href="#" class="skill-dl" data-file="contract-redline-tier1.md">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M8 2v9m0 0l-3-3m3 3l3-3M3 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Download</span>
            </a>
            <span class="skill-count"><span class="sk-n">1,842</span> downloads</span>
          </div>
        </div>
        <div class="sk-face sk-back">
          <div class="sk-back-head"><span class="sk-back-label">Sample run</span><button class="sk-flip-back" type="button">× close</button></div>
          <div class="sk-io">
            <div class="sk-io-col">
              <span class="sk-io-label">Input · clause from draft MSA</span>
              <pre class="sk-io-block">§7.2 LIMITATION OF LIABILITY. In no event shall Vendor's aggregate liability exceed the fees paid by Customer in the twelve (12) months preceding the claim.</pre>
            </div>
            <div class="sk-io-col">
              <span class="sk-io-label sk-io-out">Output · redline memo</span>
              <pre class="sk-io-block"><span class="tok-a">▲ §7.2</span>  one-sided cap
<span class="tok-m">→</span> request mutual cap
<span class="tok-m">→</span> carve-outs: IP indemnity,
    confidentiality breach,
    gross negligence
<span class="tok-k">suggested:</span> "…except
for obligations under §11
(Indemnification) and §13
(Confidentiality)…"</pre>
            </div>
          </div>
        </div>
      </article>

      <article class="skill-card featured-skill" data-track="both">
        <div class="sk-face sk-front">
          <div class="skill-ribbon">Most downloaded</div>
          <div class="skill-head">
            <span class="skill-type">Workflow</span>
            <span class="skill-format">.zip · 218 KB</span>
          <span class="track-pill track-both">Legal + Business</span>
          </div>
          <h3 class="skill-title">Deposition prep in one afternoon</h3>
          <p class="skill-desc">A complete four-step workflow — transcript ingestion prompt, witness timeline generator, impeachment-material finder, and a single-page cross-exam outline generator. Used on real cases.</p>
          <ul class="skill-meta-list">
            <li><span class="sk-dot"></span> 4 prompts + 2 JSON schemas + sample runs</li>
            <li><span class="sk-dot"></span> Privilege-safe: runs fully local if you want</li>
            <li><span class="sk-dot"></span> Includes a 12-min walkthrough video link</li>
          </ul>
          <div class="skill-foot">
            <button class="sk-peek" type="button">Peek inside →</button>
            <a href="#" class="skill-dl primary" data-file="deposition-prep-workflow.zip">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M8 2v9m0 0l-3-3m3 3l3-3M3 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Download</span>
            </a>
            <span class="skill-count"><span class="sk-n">3,104</span> downloads</span>
          </div>
        </div>
        <div class="sk-face sk-back">
          <div class="sk-back-head"><span class="sk-back-label">Sample run</span><button class="sk-flip-back" type="button">× close</button></div>
          <div class="sk-io">
            <div class="sk-io-col">
              <span class="sk-io-label">Input · 1,842 pp discovery</span>
              <pre class="sk-io-block">Witness: R. Hsu, CFO
Topics: Q2 revenue restatement,
audit committee communications,
board deck versioning.
Run: full discovery corpus.</pre>
            </div>
            <div class="sk-io-col">
              <span class="sk-io-label sk-io-out">Output · cross-exam outline</span>
              <pre class="sk-io-block"><span class="tok-k">I. BACKGROUND</span> — 12 Q
<span class="tok-k">II. TIMELINE</span> — 34 Q
  <span class="tok-a">▲ Apr 11 email</span> contradicts
    Mar 28 board deck
<span class="tok-k">III. IMPEACHMENT</span> — 9 Q
  → Ex. 14 (email chain)
  → Ex. 22 (slide v3 → v4)
<span class="tok-m">41 exhibits linked</span></pre>
            </div>
          </div>
        </div>
      </article>

      <article class="skill-card" data-track="business">
        <div class="sk-face sk-front">
          <div class="skill-head">
            <span class="skill-type">Checklist</span>
            <span class="skill-format">.pdf · 96 KB</span>
          <span class="track-pill track-biz">Business</span>
          </div>
          <h3 class="skill-title">Citation verification protocol</h3>
          <p class="skill-desc">The one-page compliance checklist my firm uses post-<em>Avianca</em> to verify every model-generated citation before filing. Includes the Rule 11 attestation template.</p>
          <ul class="skill-meta-list">
            <li><span class="sk-dot"></span> Printable, 1-page, double-sided</li>
            <li><span class="sk-dot"></span> Annotated with case authority</li>
            <li><span class="sk-dot"></span> Updated quarterly</li>
          </ul>
          <div class="skill-foot">
            <button class="sk-peek" type="button">Peek inside →</button>
            <a href="#" class="skill-dl" data-file="citation-verification-protocol.pdf">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M8 2v9m0 0l-3-3m3 3l3-3M3 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Download</span>
            </a>
            <span class="skill-count">MIT-licensed &middot; updated Apr 2026</span>
          </div>
        </div>
        <div class="sk-face sk-back">
