// ============ hero video sound toggle ============
// Browsers block autoplay w/ audio. Start muted, let user tap the pill to
// unmute. There are TWO frames in the DOM (desktop + mobile fallback), only
// one is visible at any viewport. To guarantee no double-audio we (a) only
// unmute the visible/clicked frame, (b) pause + force-mute the OTHER frame,
// and (c) mirror playback state whenever the viewport crosses the breakpoint.
(function soundToggle() {
  const frames = Array.from(document.querySelectorAll('.hero-demo-frame'));
  if (!frames.length) return;

  function isVisible(el) {
    if (!el) return false;
    if (el.offsetParent !== null) return true;
    return getComputedStyle(el).display !== 'none';
  }

  function findVisibleFrame() {
    return frames.find(f => {
      // walk up to the figure which carries the media-query display rule
      const fig = f.closest('figure');
      return isVisible(fig);
    });
  }

  function silenceAndPauseHidden() {
    frames.forEach(frame => {
      const fig = frame.closest('figure');
      if (isVisible(fig)) return;
      const v = frame.querySelector('video');
      if (!v) return;
      v.muted = true;
      v.volume = 0;
      if (!v.paused) v.pause();
      frame.setAttribute('data-sound', 'off');
    });
  }

  function unmute(frame) {
    silenceAndPauseHidden();
    const v = frame.querySelector('video');
    if (!v) return;
    v.muted = false;
    v.volume = 1;
    frame.setAttribute('data-sound', 'on');
    const p = v.play();
    if (p && p.catch) p.catch(() => {});
  }

  function muteAll() {
    frames.forEach(frame => {
      const v = frame.querySelector('video');
      if (v) {
        v.muted = true;
        v.volume = 0;
      }
      frame.setAttribute('data-sound', 'off');
    });
  }

  // Initial: pause hidden video so it isn't silently consuming a decoder slot.
  silenceAndPauseHidden();

  frames.forEach(frame => {
    const btn = frame.querySelector('.sound-toggle');
    if (!btn) return;
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const visible = findVisibleFrame() || frame;
      const currentlyOn = visible.getAttribute('data-sound') === 'on';
      if (currentlyOn) muteAll();
      else unmute(visible);
    });
  });

  // Re-sync on viewport crossing the breakpoint.
  let lastWide = window.innerWidth >= 1200;
  window.addEventListener('resize', () => {
    const nowWide = window.innerWidth >= 1200;
    if (nowWide !== lastWide) {
      lastWide = nowWide;
      muteAll();
      silenceAndPauseHidden();
      // resume the newly-visible one (muted)
      const vis = findVisibleFrame();
      if (vis) {
        const v = vis.querySelector('video');
        if (v && v.paused) { const p = v.play(); if (p && p.catch) p.catch(()=>{}); }
      }
    }
  });
})();

