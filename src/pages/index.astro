    let h = d.getHours();
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12; if (h === 0) h = 12;
    const mm = String(d.getMinutes()).padStart(2, '0');
    el.textContent = `COCOA · ${h}:${mm} ${ampm}`;
  }
  tick();
  setInterval(tick, 1000);
})();

// ============ track filter (Legal / Business) ============
(function trackFilter() {
  const filters = document.querySelectorAll('.track-filter');
  filters.forEach(filter => {
    const scopeSel = filter.getAttribute('data-filter-scope');
    const scope = document.querySelector(scopeSel);
    if (!scope) return;
    const cards = scope.querySelectorAll('[data-track]');
    const countEl = filter.querySelector('[data-filter-count]');
    const buttons = filter.querySelectorAll('button[data-track-filter]');

    function apply(track) {
      let shown = 0;
      cards.forEach(card => {
        const cardTrack = card.getAttribute('data-track');
        const match = track === 'all' || cardTrack === track || cardTrack === 'both';
        if (match) { card.removeAttribute('data-hidden'); shown++; }
        else { card.setAttribute('data-hidden', ''); }
      });
      if (countEl) countEl.textContent = `${shown} showing`;
      buttons.forEach(b => {
        b.setAttribute('aria-pressed', b.getAttribute('data-track-filter') === track ? 'true' : 'false');
      });
      // Notify pagination (or anything else listening) that the filter changed.
      scope.dispatchEvent(new CustomEvent('filterchange'));
    }

    buttons.forEach(b => {
      b.addEventListener('click', () => apply(b.getAttribute('data-track-filter')));
    });
    apply('all');
  });
})();

// ============ skills pagination (6 per page) ============
(function skillsPagination() {
  const PAGE_SIZE = 6;
  const scope = document.getElementById('skills');
  if (!scope) return;
  const grid = scope.querySelector('.skills-grid');
  const pagination = scope.querySelector('[data-skill-pagination]');
  if (!grid || !pagination) return;
  const allCards = Array.from(grid.querySelectorAll('.skill-card'));
  let currentPage = 1;

  function render() {
    const visible = allCards.filter(c => !c.hasAttribute('data-hidden'));
    const totalPages = Math.max(1, Math.ceil(visible.length / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;
    const start = (currentPage - 1) * PAGE_SIZE;
    const end = start + PAGE_SIZE;
    // Reset then apply page-hidden only to the visible set outside the current window
    allCards.forEach(c => c.removeAttribute('data-page-hidden'));
    visible.forEach((card, i) => {
      if (i < start || i >= end) card.setAttribute('data-page-hidden', '');
    });
    // Pad the current page to a full row of 3 with empty placeholder cells so
    // partial pages match the grid rhythm of full pages.
    grid.querySelectorAll('.skill-card-placeholder').forEach(p => p.remove());
    const onPage = Math.min(PAGE_SIZE, visible.length - start);
    const remainder = onPage % 3;
    const toAdd = remainder === 0 ? 0 : 3 - remainder;
    for (let i = 0; i < toAdd; i++) {
      const ph = document.createElement('div');
      ph.className = 'skill-card skill-card-placeholder';
      ph.setAttribute('aria-hidden', 'true');
      grid.appendChild(ph);
    }
    // Rebuild UI
    pagination.innerHTML = '';
    if (visible.length <= PAGE_SIZE) { pagination.hidden = true; return; }
    pagination.hidden = false;
    const mkBtn = (label, opts) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'skills-page-btn' + (opts.nav ? ' skills-page-nav' : '') + (opts.active ? ' active' : '');
      b.textContent = label;
      if (opts.disabled) b.disabled = true;
      if (opts.active) b.setAttribute('aria-current', 'page');
      b.addEventListener('click', opts.onClick);
      return b;
    };
    pagination.appendChild(mkBtn('← Prev', { nav: true, disabled: currentPage === 1,
      onClick: () => { currentPage--; render(); scope.scrollIntoView({ behavior: 'smooth', block: 'start' }); } }));
    for (let i = 1; i <= totalPages; i++) {
      pagination.appendChild(mkBtn(String(i), { active: i === currentPage,
        onClick: () => { currentPage = i; render(); scope.scrollIntoView({ behavior: 'smooth', block: 'start' }); } }));
    }
    pagination.appendChild(mkBtn('Next →', { nav: true, disabled: currentPage === totalPages,
      onClick: () => { currentPage++; render(); scope.scrollIntoView({ behavior: 'smooth', block: 'start' }); } }));
  }

  scope.addEventListener('filterchange', () => { currentPage = 1; render(); });
  render();
})();

// ============ cursor dot ============
(function cursor() {
  const dot = document.getElementById('cursor-dot');
  if (!dot) return;
  let x = window.innerWidth / 2, y = window.innerHeight / 2, tx = x, ty = y;
  window.addEventListener('mousemove', (e) => { tx = e.clientX; ty = e.clientY; });
  function loop() {
    x += (tx - x) * 0.18;
    y += (ty - y) * 0.18;
    dot.style.left = x + 'px';
    dot.style.top = y + 'px';
    requestAnimationFrame(loop);
  }
  loop();
  document.querySelectorAll('a, button, .card, .series-card, input').forEach(el => {
    el.addEventListener('mouseenter', () => dot.classList.add('grow'));
    el.addEventListener('mouseleave', () => dot.classList.remove('grow'));
  });
})();

// ============ reveal on scroll ============
(function reveal() {
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
})();

