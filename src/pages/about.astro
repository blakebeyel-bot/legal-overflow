    </div>
    <div>
      <div class="about-portrait">
        <img src="/assets/attorney-portrait.jpg" alt="Blake Beyel, corporate counsel" />
      </div>
      <div class="portrait-meta">
        <span class="pm-rule"></span>
        <span class="pm-name">Blake Beyel</span>
        <span class="pm-role">Corporate Counsel · Beyel Brothers Inc.</span>
