---
// Account page — manage profile + BYOK API keys.
// Auth-gated client-side. Approval not strictly required to view this
// page (a pending user might still want to see their account info), but
// the BYOK save endpoint is approval-gated server-side.
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Account — Legal Overflow</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<script src="/nav-autohide.js" defer></script>
<script src="/site-dialog.js" defer></script>
<link rel="stylesheet" href="/workspace.css" />
<style>
  /* Auth-gate paint suppression. The body[data-auth-gate] attribute is
     present in the rendered HTML, so the browser sees `visibility:hidden`
     before any layout pass — eliminates the flash of gated content
     visible during the JS auth check. The auth handler below removes
     the attribute on successful session load. */
  body[data-auth-gate] { visibility: hidden; }
</style>
</head>
<body data-auth-gate>
<div id="grain"></div>

<header class="nav">
  <a href="/" class="brand">
    <svg class="brand-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="1"/><path d="M20 6 L20 34 M8 14 L32 14 M8 26 L32 26" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="20" cy="14" r="2.5" fill="currentColor"/><circle cx="20" cy="26" r="2.5" fill="var(--accent)"/></svg>
    <span class="brand-text"><span>Legal</span><span class="brand-over">Overflow</span></span>
  </a>
  <nav class="nav-links">
    <a href="/#skills">Skills</a>
    <a href="/#articles">Resources</a>
    <a href="/agents/">Agents</a>
    <a href="/workspace/">Workspace</a>
    <a href="/tracker/">Tracker</a>
    <a href="/#services">Services</a>
    <a href="/about/">About</a>
  </nav>
  <div class="nav-right">
    <button id="signout-btn" class="nav-sub" type="button">Sign out</button>
  </div>
</header>

<main class="ws-wrap">
  <header class="ws-head">
    <div>
      <div class="ws-kicker">Account</div>
      <h1 class="ws-title">Settings &amp; API keys.</h1>
      <p class="ws-sub" id="acct-email">—</p>
    </div>
  </header>

  <!-- Display name — single source of truth for the author shown on
       any document this account marks up: tracked changes in
       finalized redlines, sticky-note comments on annotated PDFs,
       Word comments embedded by the citation verifier, etc.
       Universal override across the entire platform. Falls back to
       'Legal Overflow' if the field is blank. -->
  <section class="ws-card">
    <header class="ws-card-head">
      <h2 class="ws-card-title">Display name</h2>
    </header>
    <div class="acct-displayname-intro" style="font-size:13.5px; color:var(--ink-2); margin-bottom:14px;">
      <p>The author name attributed on every redline and comment this account produces — tracked changes in compare-finalize and contract-review outputs, sticky notes on annotated PDFs, Word comments in corrected briefs. Falls back to <strong>Legal Overflow</strong> when blank.</p>
    </div>
    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <input type="text" id="acct-displayname-input" maxlength="80"
        placeholder="e.g. Blake Beyel"
        style="flex:1; min-width:220px; padding:9px 12px; border:1px solid var(--rule-soft); border-radius:4px; font-family:var(--sans); font-size:14px;" />
      <button type="button" id="acct-displayname-save" class="ws-btn">Save</button>
      <span id="acct-displayname-status" style="font-family:var(--mono); font-size:11px; letter-spacing:.06em; text-transform:uppercase; color:var(--ink-3);"></span>
    </div>
  </section>

  <section class="ws-card">
    <header class="ws-card-head">
      <h2 class="ws-card-title">Bring your own keys</h2>
    </header>
    <div class="acct-byok-intro">
      <p>By default, chat uses the keys configured by Legal Overflow. You can override per provider with your own. Stored as AES-256 ciphertext; we display only the last 4 characters back to you, never the full key.</p>
    </div>
    <div id="byok-rows" class="acct-byok-rows">Loading…</div>
  </section>

  <p class="ws-foot"><a href="/workspace/">Back to workspace →</a></p>
</main>

<footer class="foot">
  <p class="foot-bar-disclosure">
    <strong>Blake Beyel, Esq.</strong> · Florida Bar No. 1065044 · Cocoa, Florida ·
    The hiring of a lawyer is an important decision that should not be based solely on advertisements.
    Before you decide, ask for written information about the lawyer's qualifications and experience.
    No representation is made that the quality of the legal services to be performed is greater than
    the quality of legal services performed by other lawyers.
  </p>
  <div class="foot-bot"><span>© 2026 Legal Overflow</span><span class="foot-version">v2026.04<a href="/admin/users/" class="foot-admin-link" aria-label="Admin"></a></span></div>
</footer>

<script>
  import { getSupabase } from '../../lib/supabase';
  const supabase = getSupabase();

  // Body starts with [data-auth-gate] which CSS hides via
  // `visibility: hidden`. We only remove that attribute AFTER the
  // session check confirms the user is signed in — so unauthenticated
  // visitors are redirected to /login/ without ever seeing the gated
  // page render. (Replaces the prior JS-set `style.visibility='hidden'`
  // which had a race window during the brief gap between body parse
  // and script execution.)
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    location.href = '/login/?redirect=/account/';
    throw new Error('not signed in');
  }
  document.body.removeAttribute('data-auth-gate');

  const accessToken = session.access_token;
  document.getElementById('acct-email').textContent = session.user.email || '';

  document.getElementById('signout-btn').addEventListener('click', async () => {
    await supabase.auth.signOut();
    location.href = '/';
  });

  // Display name — universal author override across the site. The
  // RLS lockdown in migration 0028 deliberately leaves this column
  // unpinned, so a `supabase.from('profiles').update(...)` from the
  // browser succeeds; tier/approved_at/cap_overrides remain locked.
  const dnInput = document.getElementById('acct-displayname-input');
  const dnSave = document.getElementById('acct-displayname-save');
  const dnStatus = document.getElementById('acct-displayname-status');

  async function loadDisplayName() {
    try {
      const { data, error } = await supabase
        .from('profiles')
        .select('display_name')
        .eq('id', session.user.id)
        .maybeSingle();
      if (error) throw error;
      dnInput.value = (data?.display_name || '').trim();
    } catch (err) {
      console.warn('display_name load failed:', err?.message);
    }
  }

  async function saveDisplayName() {
    const raw = dnInput.value.trim();
    if (raw.length > 80) {
      dnStatus.textContent = 'Too long (max 80)';
      dnStatus.style.color = 'var(--accent)';
      return;
    }
    dnSave.disabled = true;
    dnStatus.textContent = 'Saving…';
    dnStatus.style.color = 'var(--ink-3)';
    try {
      const { error } = await supabase
        .from('profiles')
        .update({ display_name: raw || null })
        .eq('id', session.user.id);
      if (error) throw error;
      dnStatus.textContent = 'Saved';
      dnStatus.style.color = 'var(--ink-3)';
      setTimeout(() => { if (dnStatus.textContent === 'Saved') dnStatus.textContent = ''; }, 2400);
    } catch (err) {
      dnStatus.textContent = 'Failed';
      dnStatus.style.color = 'var(--accent)';
      console.warn('display_name save failed:', err?.message);
    } finally {
      dnSave.disabled = false;
    }
  }

  dnSave.addEventListener('click', saveDisplayName);
  dnInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); saveDisplayName(); }
  });
  loadDisplayName();

  const PROVIDERS = [
    { id: 'anthropic', label: 'Anthropic (Claude)', placeholder: 'sk-ant-…', help: 'From console.anthropic.com → Settings → API keys' },
    { id: 'openai', label: 'OpenAI (GPT)', placeholder: 'sk-proj-…', help: 'From platform.openai.com/api-keys' },
    { id: 'google', label: 'Google AI (Gemini)', placeholder: 'AIza…', help: 'From aistudio.google.com/app/apikey' },
    { id: 'xai', label: 'xAI (Grok)', placeholder: 'xai-…', help: 'From console.x.ai → API Keys' },
  ];

  function escapeHtml(s) {
    return String(s ?? '').replace(/[<>&"]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[ch]));
  }

  function renderRows(stored) {
    const byProvider = Object.fromEntries((stored || []).map((k) => [k.provider, k]));
    const html = PROVIDERS.map((p) => {
      const existing = byProvider[p.id];
      const status = existing
        ? `<span class="byok-status">Saved · ending in <code>${escapeHtml(existing.fingerprint)}</code></span>`
        : `<span class="byok-status muted">No key saved · using site default</span>`;
      const remove = existing
        ? `<button type="button" class="byok-remove" data-remove="${p.id}">Remove</button>`
        : '';
      return `<div class="byok-row" data-provider="${p.id}">
        <div class="byok-row-head">
          <div class="byok-row-title">${p.label}</div>
          ${status}
        </div>
        <p class="byok-row-help">${p.help}</p>
        <form class="byok-form" data-provider="${p.id}">
          <input type="password" name="key" autocomplete="off" placeholder="${p.placeholder}" />
          <button type="submit" class="ws-btn">Save</button>
          ${remove}
        </form>
      </div>`;
    }).join('');
    document.getElementById('byok-rows').innerHTML = html;

    document.querySelectorAll('.byok-form').forEach((f) => {
      f.addEventListener('submit', async (e) => {
        e.preventDefault();
        const provider = f.dataset.provider;
        const input = f.querySelector('input[name="key"]');
        const apiKey = input.value.trim();
        if (!apiKey) return;
        const r = await fetch('/.netlify/functions/workspace-byok-save', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ provider, api_key: apiKey }),
        });
        const j = await r.json();
        if (!r.ok) {
          alert('Failed: ' + (j.error || 'unknown'));
          return;
        }
        input.value = '';
        loadKeys();
      });
    });
    document.querySelectorAll('.byok-remove').forEach((b) => {
      b.addEventListener('click', async () => {
        const provider = b.dataset.remove;
        if (!(await window.siteConfirm(`Remove your ${provider} key? Future chats will fall back to the site key.`, { okLabel: 'Remove', danger: true }))) return;
        await fetch('/.netlify/functions/workspace-byok-delete', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ provider }),
        });
        loadKeys();
      });
    });
  }

  async function loadKeys() {
    const r = await fetch('/.netlify/functions/workspace-byok-list', {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) {
      document.getElementById('byok-rows').innerHTML = `<div class="ws-empty">Failed to load: ${escapeHtml(j.error || 'unknown')}</div>`;
      return;
    }
    renderRows(j.keys || []);
  }

  loadKeys();
</script>
</body>
</html>
