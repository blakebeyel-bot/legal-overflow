<script is:inline>
(function clock() {
  const el = document.getElementById('nav-clock');
  if (!el) return;
  function tick() {
    const d = new Date();
    let h = d.getHours();
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12; if (h === 0) h = 12;
    const mm = String(d.getMinutes()).padStart(2, '0');
    el.textContent = `COCOA · ${h}:${mm} ${ampm}`;
  }
  tick();
  setInterval(tick, 1000);
})();

// Hero stats — pull live aggregates from /api/agents-stats so the four
// values in the hero (runs, median completion, findings raised, false-
// positive rate) reflect real database numbers instead of placeholders.
// Endpoint is public, no-auth, 5-minute server-side cached.
(function loadAgentStats() {
  const fmt = (n) => Number(n).toLocaleString('en-US');
  const runs = document.getElementById('agents-stat-runs');
  const median = document.getElementById('agents-stat-median');
  const findings = document.getElementById('agents-stat-findings');
  const fp = document.getElementById('agents-stat-fp');

  fetch('/.netlify/functions/agents-stats')
    .then(r => r.ok ? r.json() : null)
    .then(data => {
      if (!data?.ok || !data.stats) return;
      const s = data.stats;
      if (runs) runs.innerHTML = `<em>${fmt(s.runs_30d || 0)}</em>`;
      if (median) {
        median.innerHTML = s.median_completion_s != null
          ? `${s.median_completion_s}<em>s</em>`
          : `—<em>s</em>`;
      }
      if (findings) findings.textContent = fmt(s.findings_raised || 0);
      if (fp) {
        if (s.false_positive_pct != null) {
          fp.innerHTML = `${s.false_positive_pct}<em>%</em>`;
        } else {
          // No feedback-tracking schema yet — hide the row's value cleanly
          // so the lawyer doesn't see a fabricated number.
          fp.textContent = '—';
        }
      }
    })
    .catch((err) => {
      console.warn('[agents stats] failed to load:', err?.message);
    });
})();
</script>

