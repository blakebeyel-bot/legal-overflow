---
// Workflows / playbooks. List view at /workspace/workflows/, editor
// at /workspace/workflows/?id=<uuid>&edit=1, single-view at
// /workspace/workflows/?id=<uuid>. Same page, JS branches on the
// query params.
//
// CSS strategy: prototype's design inlined as <style is:global>
// scoped under body.ws-workflows. Keeps the page self-contained and
// avoids leaking back into other workspace surfaces.
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Workflows — Legal Overflow</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<link rel="stylesheet" href="/workspace.css" />
<link rel="stylesheet" href="/site-anim.css" />
<script src="/nav-autohide.js" defer></script>
<script src="/site-dialog.js" defer></script>
<script src="/site-anim.js" defer></script>
<style is:global>
  /* ============================================================
     Workflows — page-local stylesheet (verbatim port of the
     prototype). is:global is required because the workflow cards
     are rendered via JS — those nodes don't get Astro's auto-scoped
     attribute, so a normal scoped style would fail to match them.
     ============================================================ */

  body.ws-workflows {
    --rule-thread: #cbc4b1;
    --motion-snap: cubic-bezier(.2,.8,.2,1);
    --hi: #b22222; --md: #c98a14; --lo: #6a7c8e; --ins: #4a8a64;
    background-image:
      radial-gradient(1100px 600px at 80% -10%, rgba(208,219,213,.18), transparent 60%),
      radial-gradient(900px 500px at -10% 20%, rgba(220,212,196,.25), transparent 70%);
  }

  /* ---------- shell wrapper ---------- */
  body.ws-workflows main.ws-wrap {
    position: relative; z-index: 2;
    max-width: 1480px;
    margin: 0 auto;
    padding: 22px 40px 40px !important;
    background: transparent;
    border: none !important;
  }
  @media (max-width: 980px) {
    body.ws-workflows main.ws-wrap { padding: 18px 16px 40px !important; }
  }

  /* ---------- ws-head with all four corner brackets ---------- */
  body.ws-workflows .ws-head {
    position: relative !important;
    display: block !important;
    padding: 14px 24px 22px !important;
    margin: 0 0 22px !important;
    border: none !important;
    background: transparent !important;
  }
  body.ws-workflows .ws-head::before, body.ws-workflows .ws-head::after,
  body.ws-workflows .ws-head > .br-bl, body.ws-workflows .ws-head > .br-br {
    content: ''; position: absolute;
    width: 14px; height: 14px;
    border: 1px solid var(--ink); pointer-events: none;
  }
  body.ws-workflows .ws-head::before { top: 0; left: 0; border-right: none; border-bottom: none; }
  body.ws-workflows .ws-head::after  { top: 0; right: 0; border-left: none; border-bottom: none; }
  body.ws-workflows .ws-head > .br-bl { bottom: 0; left: 0; border-top: none; border-right: none; }
  body.ws-workflows .ws-head > .br-br { bottom: 0; right: 0; border-top: none; border-left: none; }

  body.ws-workflows .kicker {
    display: inline-flex; gap: 12px;
    font-family: var(--mono); font-size: 10.5px;
    color: var(--accent-deep);
    letter-spacing: .14em; text-transform: uppercase;
    margin-bottom: 12px; align-items: center;
  }
  body.ws-workflows .kicker .k-tag {
    border: 1px solid var(--accent-deep);
    padding: 2px 7px; border-radius: 2px; font-size: 9.5px;
  }
  body.ws-workflows .kicker .k-coord {
    color: var(--ink-4); font-size: 9.5px;
  }
  body.ws-workflows .head-row {
    display: flex; justify-content: space-between; align-items: flex-end;
    flex-wrap: wrap; gap: 20px;
  }
  body.ws-workflows .head-title {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(40px, 5vw, 68px);
    letter-spacing: -.012em; line-height: 1;
    margin: 0; color: var(--ink);
  }
  body.ws-workflows .head-title em {
    font-style: italic; color: var(--accent-deep);
  }
  body.ws-workflows .head-sub {
    font-family: var(--serif); font-size: 19px;
    color: var(--ink-2); max-width: 64ch;
    margin-top: 12px; line-height: 1.4;
  }
  body.ws-workflows .head-actions {
    display: flex; gap: 8px; flex-wrap: wrap;
  }

  /* ws-btn redefined to match the prototype's shape */
  body.ws-workflows .ws-head .ws-btn,
  body.ws-workflows .head-actions .ws-btn,
  body.ws-workflows .ws-btn-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 18px;
    cursor: pointer;
    font-family: var(--mono); font-size: 11px;
    letter-spacing: .12em; text-transform: uppercase;
    background: var(--ink); color: var(--paper);
    border: 1px solid var(--ink); border-radius: 4px;
    text-decoration: none;
    transition: background .15s var(--motion-snap), color .15s, border-color .15s;
  }
  body.ws-workflows .ws-head .ws-btn:hover,
  body.ws-workflows .head-actions .ws-btn:hover {
    background: var(--accent-deep); border-color: var(--accent-deep);
  }
  body.ws-workflows .ws-btn-ghost,
  body.ws-workflows .head-actions .ws-btn-secondary {
    background: transparent !important; color: var(--ink) !important;
  }
  body.ws-workflows .ws-btn-ghost:hover,
  body.ws-workflows .head-actions .ws-btn-secondary:hover {
    background: var(--ink) !important; color: var(--paper) !important;
  }
  body.ws-workflows .ws-btn svg { width: 12px; height: 12px; }

  /* ---------- meta-strip (top stat row) ---------- */
  body.ws-workflows .meta-strip {
    display: grid; grid-template-columns: repeat(5, 1fr);
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    margin: 0 0 22px;
  }
  body.ws-workflows .ms-cell {
    padding: 13px 18px;
    border-right: 1px solid var(--rule-soft);
    display: flex; flex-direction: column; gap: 5px;
  }
  body.ws-workflows .ms-cell:last-child { border-right: none; }
  body.ws-workflows .ms-l {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .14em; text-transform: uppercase;
  }
  body.ws-workflows .ms-v {
    font-family: var(--serif); font-size: 24px;
    color: var(--ink); line-height: 1;
  }
  body.ws-workflows .ms-v em {
    font-style: italic; color: var(--accent-deep);
  }
  body.ws-workflows .ms-d {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-4);
    letter-spacing: .08em; text-transform: uppercase;
  }
  @media (max-width: 1100px) {
    body.ws-workflows .meta-strip { grid-template-columns: repeat(2, 1fr); }
    body.ws-workflows .ms-cell:nth-child(2n) { border-right: none; }
  }

  /* ---------- section divider ---------- */
  body.ws-workflows .sec-div {
    display: grid; grid-template-columns: auto 1fr auto;
    align-items: center; gap: 16px;
    margin: 8px 0 14px;
    font-family: var(--mono); font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: .12em; text-transform: uppercase;
  }
  body.ws-workflows .sec-num { color: var(--ink); }
  body.ws-workflows .sec-rule { height: 1px; background: var(--rule-soft); }
  body.ws-workflows .sec-meta { color: var(--ink-4); font-size: 9.5px; }

  /* ---------- filter / tab row ---------- */
  body.ws-workflows .tab-row {
    display: flex; align-items: center; gap: 0;
    border: 1px solid var(--rule-soft);
    border-radius: 4px;
    background: rgba(255,255,255,.3);
    padding: 4px 10px;
    margin-bottom: 16px;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .1em; text-transform: uppercase;
    color: var(--ink-3);
    flex-wrap: wrap;
  }
  body.ws-workflows .tab-l {
    font-size: 9px; color: var(--ink-4);
    letter-spacing: .18em;
    margin-right: 10px;
  }
  body.ws-workflows .tab-btn {
    padding: 6px 11px;
    border: none; background: transparent;
    cursor: pointer;
    color: var(--ink-3);
    transition: color .15s;
    display: inline-flex; gap: 6px; align-items: center;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .1em; text-transform: uppercase;
  }
  body.ws-workflows .tab-btn:hover { color: var(--ink); }
  body.ws-workflows .tab-btn.is-active { color: var(--accent-deep); }
  body.ws-workflows .tab-btn .pip {
    width: 5px; height: 5px; border-radius: 50%;
    border: 1px solid currentColor;
  }
  body.ws-workflows .tab-btn.is-active .pip { background: currentColor; }
  body.ws-workflows .tab-btn .cnt { opacity: .7; font-size: 9px; }
  body.ws-workflows .tab-sep {
    width: 1px; height: 12px;
    background: var(--rule-soft);
    margin: 0 1px;
  }
  body.ws-workflows .tab-spacer { flex: 1; }

  /* ---------- workflow grid ---------- */
  body.ws-workflows .wf-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px;
  }
  @media (max-width: 980px) {
    body.ws-workflows .wf-grid { grid-template-columns: 1fr; }
  }
  /* Tablet + phone: stack the workflow editor column rows so the
     prompt-name field doesn't get crushed against the textarea. */
  @media (max-width: 768px) {
    body.ws-workflows .rv-col-row {
      grid-template-columns: 1fr;
      row-gap: 6px;
    }
  }
  /* Phone-tier: full-width form inputs and tighter modal padding. */
  @media (max-width: 600px) {
    body.ws-workflows .meta-strip { grid-template-columns: 1fr; }
  }

  /* ---------- workflow card ---------- */
  body.ws-workflows .wf-card {
    position: relative;
    background: var(--paper-2);
    border: 1px solid var(--rule-soft);
    border-radius: 8px;
    padding: 18px 20px 16px;
    display: flex; flex-direction: column; gap: 14px;
    cursor: pointer;
    text-decoration: none;
    color: var(--ink);
    transition: border-color .15s var(--motion-snap), transform .15s;
  }
  body.ws-workflows .wf-card:hover {
    border-color: var(--ink); transform: translateY(-2px);
  }
  body.ws-workflows .wf-card::before, body.ws-workflows .wf-card::after {
    content: ''; position: absolute;
    width: 8px; height: 8px;
    border-color: var(--ink-4); pointer-events: none;
    transition: border-color .15s var(--motion-snap), width .15s, height .15s;
  }
  body.ws-workflows .wf-card::before { top: 5px; left: 5px; border-top: 1px solid; border-left: 1px solid; }
  body.ws-workflows .wf-card::after  { bottom: 5px; right: 5px; border-bottom: 1px solid; border-right: 1px solid; }
  body.ws-workflows .wf-card:hover::before, body.ws-workflows .wf-card:hover::after {
    border-color: var(--accent-deep); width: 12px; height: 12px;
  }

  body.ws-workflows .wf-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 14px;
  }
  body.ws-workflows .wf-h-l {
    display: flex; flex-direction: column; gap: 6px;
    flex: 1; min-width: 0;
  }
  body.ws-workflows .wf-kicker {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .14em; text-transform: uppercase;
  }
  body.ws-workflows .wf-id { color: var(--ink); }
  body.ws-workflows .wf-kind {
    display: inline-flex; align-items: center; gap: 5px;
  }
  body.ws-workflows .wf-kind .pip {
    width: 5px; height: 5px; border-radius: 50%;
  }
  body.ws-workflows .wf-kind.chat .pip { background: var(--lo); }
  body.ws-workflows .wf-kind.review .pip { background: var(--accent-deep); }
  body.ws-workflows .wf-kind.cite .pip { background: var(--md); }

  body.ws-workflows .wf-title {
    font-family: var(--serif); font-size: 24px;
    letter-spacing: -.01em; line-height: 1.15;
    color: var(--ink); margin: 0;
    font-weight: 400;
  }
  body.ws-workflows .wf-title em {
    font-style: italic; color: var(--accent-deep);
  }
  body.ws-workflows .wf-sub {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-4);
    letter-spacing: .06em; text-transform: uppercase;
  }

  body.ws-workflows .wf-h-r {
    display: flex; flex-direction: column; align-items: flex-end; gap: 6px;
    flex-shrink: 0;
  }
  body.ws-workflows .wf-runs {
    font-family: var(--serif); font-size: 24px;
    color: var(--ink); line-height: 1;
  }
  body.ws-workflows .wf-runs em {
    font-style: italic; color: var(--accent-deep);
  }
  body.ws-workflows .wf-runs-l {
    font-family: var(--mono); font-size: 9px;
    color: var(--ink-4);
    letter-spacing: .14em; text-transform: uppercase;
  }

  body.ws-workflows .wf-steps {
    display: flex; flex-direction: column; gap: 0;
    border-top: 1px dotted var(--rule-soft);
    padding-top: 10px;
    font-family: var(--mono);
  }
  body.ws-workflows .wf-step {
    display: grid;
    grid-template-columns: 24px 18px 1fr auto;
    gap: 10px; align-items: center;
    padding: 5px 0;
    font-size: 11px; color: var(--ink-2);
    letter-spacing: .02em;
  }
  body.ws-workflows .wf-step .n {
    color: var(--ink-4); font-size: 9.5px;
    letter-spacing: .14em;
  }
  body.ws-workflows .wf-step .b {
    width: 8px; height: 8px;
    border: 1px solid var(--ink-3);
    transform: rotate(45deg);
    justify-self: start;
  }
  body.ws-workflows .wf-step .t {
    color: var(--ink-2);
    font-family: var(--sans); font-size: 13px;
    letter-spacing: 0;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  body.ws-workflows .wf-step .meta {
    font-size: 9px; color: var(--ink-4);
    letter-spacing: .08em; text-transform: uppercase;
  }
  body.ws-workflows .wf-step.is-input .b {
    background: var(--accent-deep); border-color: var(--accent-deep);
  }
  body.ws-workflows .wf-step.is-tool .b { background: transparent; }
  body.ws-workflows .wf-step.is-output .b {
    background: var(--ink); border-color: var(--ink);
  }

  body.ws-workflows .wf-tags {
    display: flex; gap: 5px; flex-wrap: wrap;
  }
  body.ws-workflows .tg {
    font-family: var(--mono); font-size: 9px;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--ink-3);
    border: 1px solid var(--rule-thread);
    border-radius: 2px;
    padding: 2px 6px;
  }

  body.ws-workflows .wf-foot {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 10px;
    border-top: 1px solid var(--rule-soft);
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--ink-3);
    flex-wrap: wrap; gap: 10px;
  }
  body.ws-workflows .wf-foot .l {
    display: flex; gap: 14px; flex-wrap: wrap;
  }
  body.ws-workflows .wf-foot .actions {
    display: flex; gap: 6px;
  }
  body.ws-workflows .wf-mini {
    padding: 4px 9px;
    border: 1px solid var(--rule-soft);
    background: transparent;
    cursor: pointer;
    color: var(--ink-2);
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .12em; text-transform: uppercase;
    border-radius: 3px;
    text-decoration: none;
    display: inline-flex; align-items: center;
    transition: border-color .15s, color .15s, background .15s;
  }
  body.ws-workflows .wf-mini:hover {
    border-color: var(--ink); color: var(--ink);
  }
  body.ws-workflows .wf-mini.run {
    background: var(--ink); color: var(--paper);
    border-color: var(--ink);
  }
  body.ws-workflows .wf-mini.run:hover {
    background: var(--accent-deep); border-color: var(--accent-deep);
    color: var(--paper);
  }

  /* ---------- + new workflow (dashed card) ---------- */
  body.ws-workflows .wf-new {
    position: relative;
    background: transparent;
    border: 1px dashed var(--rule-thread);
    border-radius: 8px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 10px;
    padding: 32px 24px;
    cursor: pointer;
    color: var(--ink-3);
    text-decoration: none;
    transition: border-color .15s, background .15s, color .15s;
    min-height: 280px;
  }
  body.ws-workflows .wf-new:hover {
    border-color: var(--accent-deep); border-style: solid;
    background: rgba(215,237,224,.4);
    color: var(--accent-deep);
  }
  body.ws-workflows .wf-new-cross {
    font-size: 36px; line-height: 1;
    font-family: var(--serif);
  }
  body.ws-workflows .wf-new-l {
    font-family: var(--mono); font-size: 10.5px;
    letter-spacing: .14em; text-transform: uppercase;
  }
  body.ws-workflows .wf-new-h {
    font-family: var(--serif); font-size: 18px;
    color: var(--ink-2);
  }
  body.ws-workflows .wf-new:hover .wf-new-h { color: var(--accent-deep); }

  /* ---------- skeletons ---------- */
  body.ws-workflows .wf-skel {
    background: var(--paper-2);
    border: 1px solid var(--rule-soft);
    border-radius: 8px;
    padding: 18px 20px;
    min-height: 280px;
  }
  body.ws-workflows .sk-block {
    display: block;
    background: linear-gradient(90deg, rgba(0,0,0,.04) 0%, rgba(0,0,0,.09) 50%, rgba(0,0,0,.04) 100%);
    background-size: 200% 100%;
    animation: wfShimmer 1.4s linear infinite;
    border-radius: 2px; height: 12px;
    margin-bottom: 10px;
  }
  @keyframes wfShimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  body.ws-workflows .ws-empty {
    grid-column: 1 / -1;
    padding: 60px 20px; text-align: center;
    font-family: var(--serif); font-size: 16px; color: var(--ink-3);
    font-style: italic;
  }

  /* ---------- single-view + editor (kept structurally simple,
       restyled here so the views still match the design vocabulary) ---------- */
  body.ws-workflows .ws-card {
    background: var(--paper-2);
    border: 1px solid var(--rule-soft);
    border-radius: 8px;
    padding: 22px 24px;
    margin-bottom: 18px;
  }
  body.ws-workflows .ws-card-head {
    display: flex; align-items: baseline; gap: 12px;
    border-bottom: 1px solid var(--rule-soft);
    padding-bottom: 10px; margin-bottom: 14px;
  }
  body.ws-workflows .ws-card-title {
    font-family: var(--serif); font-weight: 400;
    font-size: 22px; letter-spacing: -.005em;
    color: var(--ink); margin: 0;
  }

  body.ws-workflows .wf-prompt {
    font-family: var(--mono); font-size: 12.5px; line-height: 1.55;
    background: var(--paper);
    border: 1px solid var(--rule-thread);
    border-radius: 4px;
    padding: 14px 16px;
    white-space: pre-wrap;
    color: var(--ink);
    margin: 0;
  }
  body.ws-workflows .wf-cols {
    border: 1px solid var(--rule-thread);
    border-radius: 4px;
    overflow: hidden;
    background: var(--paper);
  }
  body.ws-workflows .wf-col {
    padding: 12px 16px;
    border-bottom: 1px dotted var(--rule-soft);
  }
  body.ws-workflows .wf-col:last-child { border-bottom: none; }
  body.ws-workflows .wf-col-name {
    font-family: var(--serif); font-size: 16px;
    color: var(--ink); margin-bottom: 4px;
  }
  body.ws-workflows .wf-col-prompt {
    font-family: var(--mono); font-size: 11.5px;
    color: var(--ink-2); line-height: 1.5;
  }

  /* editor field row */
  body.ws-workflows .rv-field {
    display: flex; flex-direction: column; gap: 6px;
    margin-bottom: 14px;
  }
  body.ws-workflows .rv-field-label {
    font-family: var(--mono); font-size: 10px;
    color: var(--ink-3);
    letter-spacing: .12em; text-transform: uppercase;
  }
  body.ws-workflows .rv-field input[type="text"],
  body.ws-workflows .rv-field textarea {
    font-family: var(--sans); font-size: 14px;
    line-height: 1.5;
    padding: 10px 12px;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    background: var(--paper); color: var(--ink);
    outline: none;
  }
  body.ws-workflows .rv-field input[type="text"]:focus,
  body.ws-workflows .rv-field textarea:focus {
    border-color: var(--ink);
  }
  body.ws-workflows .wf-kind-picker {
    display: flex; flex-direction: column; gap: 8px;
  }
  body.ws-workflows .wf-kind-opt {
    display: flex; align-items: center; gap: 8px;
    padding: 9px 12px;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    cursor: pointer;
    font-family: var(--sans); font-size: 13px;
    transition: border-color .15s, background .15s;
  }
  body.ws-workflows .wf-kind-opt:hover { border-color: var(--ink-2); }
  body.ws-workflows .wf-kind-opt:has(input:checked) {
    border-color: var(--accent-deep);
    background: rgba(215,237,224,.4);
  }
  body.ws-workflows .rv-cols { display: flex; flex-direction: column; gap: 8px; }
  body.ws-workflows .rv-col-row {
    display: grid; grid-template-columns: 200px 1fr auto; gap: 8px;
    align-items: start;
    padding: 8px 10px;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    background: var(--paper);
  }
  body.ws-workflows .rv-col-row input,
  body.ws-workflows .rv-col-row textarea {
    font-family: var(--sans); font-size: 13px;
    border: 1px solid var(--rule-soft); border-radius: 3px;
    padding: 6px 8px;
    background: var(--paper);
  }
  body.ws-workflows .rv-col-del {
    width: 26px; height: 26px;
    background: transparent; border: 1px solid var(--rule-soft);
    border-radius: 4px;
    color: var(--ink-3); cursor: pointer;
    align-self: start;
  }
  body.ws-workflows .rv-col-del:hover { border-color: #b22222; color: #b22222; }
  body.ws-workflows .rv-add-col {
    margin-top: 6px;
    padding: 6px 12px;
    border: 1px dashed var(--rule-thread); background: transparent;
    color: var(--ink-3); cursor: pointer;
    font-family: var(--mono); font-size: 10.5px;
    letter-spacing: .1em; text-transform: uppercase;
    border-radius: 3px;
  }
  body.ws-workflows .rv-add-col:hover {
    color: var(--ink); border-color: var(--ink); border-style: solid;
  }
  body.ws-workflows .lib-back {
    font-family: var(--mono); font-size: 10.5px;
    color: var(--ink-3); letter-spacing: .12em; text-transform: uppercase;
    text-decoration: none;
  }
  body.ws-workflows .lib-back:hover { color: var(--accent-deep); }

  /* ---------- foot line ---------- */
  body.ws-workflows .ws-foot {
    margin-top: 36px; padding-top: 18px;
    border-top: 1px solid var(--rule-soft);
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--mono); font-size: 10.5px;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--ink-3);
  }
  body.ws-workflows .ws-foot a {
    color: var(--ink-3); text-decoration: none;
    border-bottom: 1px solid var(--rule-soft); padding-bottom: 1px;
  }
  body.ws-workflows .ws-foot a:hover {
    color: var(--accent-deep); border-color: var(--accent-deep);
  }
</style>
</head>
<body class="ws-workflows">
<div id="grain"></div>

<header class="nav">
  <a href="/" class="brand">
    <svg class="brand-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="1"/><path d="M20 6 L20 34 M8 14 L32 14 M8 26 L32 26" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="20" cy="14" r="2.5" fill="currentColor"/><circle cx="20" cy="26" r="2.5" fill="var(--accent)"/></svg>
    <span class="brand-text"><span>Legal</span><span class="brand-over">Overflow</span></span>
  </a>
  <nav class="nav-links">
    <a href="/#skills">Skills</a>
    <a href="/#articles">Resources</a>
    <a href="/agents/">Agents</a>
    <a href="/workspace/" class="is-active">Workspace</a>
    <a href="/tracker/">Tracker</a>
    <a href="/#services">Services</a>
    <a href="/about/">About</a>
  </nav>
  <div class="nav-right">
    <a href="/account/" class="nav-sub">Account</a>
  </div>
</header>

<main id="page-main"></main>

<footer class="foot">
  <p class="foot-bar-disclosure">
    <strong>Blake Beyel, Esq.</strong> · Florida Bar No. 1065044 · Cocoa, Florida ·
    The hiring of a lawyer is an important decision that should not be based solely on advertisements.
    Before you decide, ask for written information about the lawyer's qualifications and experience.
    No representation is made that the quality of the legal services to be performed is greater than
    the quality of legal services performed by other lawyers.
  </p>
  <div class="foot-bot"><span>© 2026 Legal Overflow</span><span class="foot-version">v2026.04<a href="/admin/users/" class="foot-admin-link" aria-label="Admin"></a></span></div>
</footer>

<script>
  import { getSupabase } from '../../../lib/supabase';
  const supabase = getSupabase();

  // Body never hidden — match the dashboard's hardened pattern.
  console.log('[workflows] Script started');
  let session;
  try {
    const { data } = await supabase.auth.getSession();
    session = data?.session;
    if (!session) {
      const here = location.pathname + location.search;
      console.info('[workflows] No session — redirecting to /login/');
      location.href = '/login/?redirect=' + encodeURIComponent(here);
      throw new Error('not signed in');
    }
    const { data: profile } = await supabase
      .from('profiles').select('approved_at').eq('id', session.user.id).maybeSingle();
    if (!profile?.approved_at) {
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Pending approval</h1><p>Your account is pending operator approval.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('pending approval');
    }
    console.log('[workflows] Auth gate passed, user', session.user?.id);
  } catch (err) {
    if (err && !['not signed in','pending approval'].includes(err.message)) {
      console.error('[workflows] Gate failed:', err);
      document.body.innerHTML = `<main style="max-width:680px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Workflows error</h1><pre style="background:#f5f5f5;padding:14px;border-radius:6px;font-size:12px;white-space:pre-wrap">${(err.message || String(err)).replace(/[<>&]/g,(c)=>({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]))}</pre><p><a href="/workspace/">← Back to workspace</a></p></main>`;
    }
    throw err;
  }

  // Mutable + auto-refreshed via auth state listener. Without this,
  // long-lived tabs hit "Invalid or expired session" 401s once the
  // JWT (default 1h TTL) lapses.
  let accessToken = session.access_token;
  try {
    supabase.auth.onAuthStateChange((event, sess) => {
      if (sess?.access_token) accessToken = sess.access_token;
    });
  } catch {}
  const userId = session.user.id;
  const main = document.getElementById('page-main');
  const params = new URL(location.href).searchParams;
  const wfId = params.get('id');
  const editMode = params.get('edit') === '1';

  function escapeHtml(s) {
    return String(s ?? '').replace(/[<>&"]/g, (c) => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
  }
  function pad2(n) { return String(n).padStart(2, '0'); }
  function fmtDateShort(iso) {
    if (!iso) return '—';
    const d = new Date(iso);
    const today = new Date();
    if (d.toDateString() === today.toDateString()) return 'TODAY';
    const yest = new Date(today); yest.setDate(today.getDate() - 1);
    if (d.toDateString() === yest.toDateString()) return 'YDA';
    return d.toLocaleDateString(undefined, { day: '2-digit', month: 'short' }).toUpperCase();
  }

  // ============================================================
  // LIST VIEW
  // ============================================================
  async function renderListView() {
    main.innerHTML = `
      <div class="ws-wrap">
        <a href="/workspace/" class="ws-back-pill" title="Back to workspace home"><span class="ws-back-arrow">←</span> Workspace home</a>
        <header class="ws-head">
          <span class="br-bl"></span><span class="br-br"></span>
          <div class="kicker">
            <span class="k-tag">WORKFLOWS</span>
            <span class="k-coord" id="wf-coord">/WS.07 · PLAYBOOKS · — SAVED</span>
          </div>
          <div class="head-row">
            <div>
              <h1 class="head-title">Saved <em>playbooks</em>.</h1>
              <p class="head-sub">Reusable chat prompts and review templates. Each workflow is a small program — inputs, tools, outputs — that you can run on a fresh document.</p>
            </div>
            <div class="head-actions">
              <a class="ws-btn ws-btn-ghost" href="/workspace/workflows/?edit=1&new=chat">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 12h8M12 8v8"/></svg>
                Chat workflow
              </a>
              <a class="ws-btn" href="/workspace/workflows/?edit=1&new=tabular">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 5v14M5 12h14"/></svg>
                New workflow
              </a>
            </div>
          </div>
        </header>

        <div class="meta-strip" id="wf-meta-strip">
          <div class="ms-cell"><span class="ms-l">SAVED</span><span class="ms-v" id="ms-saved">—</span><span class="ms-d">PLAYBOOKS</span></div>
          <div class="ms-cell"><span class="ms-l">CHAT</span><span class="ms-v" id="ms-chat">—</span><span class="ms-d">PROMPT TEMPLATES</span></div>
          <div class="ms-cell"><span class="ms-l">TABULAR</span><span class="ms-v" id="ms-tab"><em>—</em></span><span class="ms-d">CLAUSE PLAYBOOKS</span></div>
          <div class="ms-cell"><span class="ms-l">CURATED</span><span class="ms-v" id="ms-curated">—</span><span class="ms-d">SHARED · PLATFORM</span></div>
          <div class="ms-cell"><span class="ms-l">MINE</span><span class="ms-v" id="ms-mine">—</span><span class="ms-d">YOUR PRIVATE</span></div>
        </div>

        <div class="sec-div">
          <span class="sec-num">§ 07.A</span>
          <span class="sec-rule"></span>
          <span class="sec-meta">PLAYBOOKS · ALL</span>
        </div>

        <div class="tab-row" id="wf-tabs">
          <span class="tab-l">FILTER ·</span>
          <button type="button" class="tab-btn is-active" data-filter="all"><span class="pip"></span>All <span class="cnt" id="cnt-all">[—]</span></button>
          <span class="tab-sep"></span>
          <button type="button" class="tab-btn" data-filter="chat"><span class="pip"></span>Chat <span class="cnt" id="cnt-chat">[—]</span></button>
          <span class="tab-sep"></span>
          <button type="button" class="tab-btn" data-filter="tabular"><span class="pip"></span>Tabular <span class="cnt" id="cnt-tab">[—]</span></button>
          <span class="tab-sep"></span>
          <button type="button" class="tab-btn" data-filter="mine"><span class="pip"></span>Mine</button>
          <span class="tab-sep"></span>
          <button type="button" class="tab-btn" data-filter="curated"><span class="pip"></span>Curated</button>
          <span class="tab-spacer"></span>
          <span class="tab-l">SORT · MOST RECENT</span>
        </div>

        <div id="wf-grid" class="wf-grid">
          <div class="wf-skel"><div class="sk-block" style="width:30%"></div><div class="sk-block" style="width:70%"></div><div class="sk-block" style="width:60%"></div><div class="sk-block" style="width:80%"></div></div>
          <div class="wf-skel"><div class="sk-block" style="width:25%"></div><div class="sk-block" style="width:60%"></div><div class="sk-block" style="width:75%"></div><div class="sk-block" style="width:55%"></div></div>
          <div class="wf-skel"><div class="sk-block" style="width:35%"></div><div class="sk-block" style="width:80%"></div><div class="sk-block" style="width:50%"></div><div class="sk-block" style="width:65%"></div></div>
          <div class="wf-skel"><div class="sk-block" style="width:28%"></div><div class="sk-block" style="width:65%"></div><div class="sk-block" style="width:70%"></div><div class="sk-block" style="width:45%"></div></div>
        </div>

        <p class="ws-foot">
          <span><span style="color:var(--ink-4)">EOF</span> &nbsp; · &nbsp; END OF WORKFLOWS</span>
          <a href="/workspace/">← Workspace home</a>
        </p>
      </div>
    `;
    await loadWorkflows();
  }

  // Active tab + cached workflows for client-side filtering.
  let activeFilter = 'all';
  let allWorkflows = [];

  // Cache-first workflows list — paint from cache, refresh in background.
  const WF_LIST_CACHE = 'workspace.workflows-list.' + (session.user?.id || 'anon');

  function workflowKindLabel(kind) {
    if (kind === 'tabular') return 'TABULAR';
    if (kind === 'cite') return 'CITATION VERIFIER';
    return 'CHAT PROMPT';
  }
  function workflowKindClass(kind) {
    if (kind === 'tabular') return 'review';
    if (kind === 'cite') return 'cite';
    return 'chat';
  }
  function buildSteps(w) {
    // Build a minimal step list per workflow kind. Tabular workflows
    // get one step per column (capped). Chat workflows get a 3-step
    // input → tool → output sketch using their prompt size.
    const steps = [];
    if (w.kind === 'tabular') {
      const cols = (w.columns_config || []).slice(0, 4);
      steps.push({ cls: 'is-input', t: 'Input — document (DOCX or PDF)', meta: 'REQ' });
      for (const c of cols) {
        steps.push({ cls: 'is-tool', t: c.name || 'Column', meta: 'COL' });
      }
      const more = (w.columns_config || []).length - cols.length;
      if (more > 0) steps.push({ cls: 'is-tool', t: `+${more} more columns`, meta: 'COL' });
      steps.push({ cls: 'is-output', t: 'Output — N×M findings grid', meta: 'OUT' });
    } else {
      const promptLen = (w.prompt_md || '').length;
      steps.push({ cls: 'is-input', t: 'Input — fact pattern + jurisdiction', meta: 'REQ' });
      steps.push({ cls: 'is-tool', t: `System prompt (${promptLen.toLocaleString()} chars)`, meta: 'TOOL' });
      steps.push({ cls: 'is-output', t: 'Output — IRAC-style memo or draft', meta: 'OUT' });
    }
    return steps;
  }

  function renderCard(w, idx) {
    const isCurated = !w.user_id;
    const isMine = w.user_id === userId;
    const kindCls = workflowKindClass(w.kind);
    const kindLabel = workflowKindLabel(w.kind);
    const wfNum = String(idx + 1).padStart(3, '0');
    const sub = w.description
      ? escapeHtml(w.description).slice(0, 90).toUpperCase()
      : (w.kind === 'tabular'
          ? `${(w.columns_config || []).length}-COLUMN PLAYBOOK`
          : 'CHAT PROMPT TEMPLATE');
    const editedAt = fmtDateShort(w.updated_at || w.created_at);
    const ownerLabel = isCurated ? 'CURATED' : (isMine ? 'MINE' : 'SHARED · TEAM');
    const tags = [];
    if (w.practice_area) tags.push(w.practice_area.toUpperCase());
    if (w.kind === 'tabular') tags.push('TABULAR');
    if (w.kind === 'chat') tags.push('CHAT');
    if (isCurated) tags.push('OPERATOR');
    const tagsHtml = tags.slice(0, 4).map((t) => `<span class="tg">${escapeHtml(t)}</span>`).join('');

    const stepsHtml = buildSteps(w).map((s, i) => `
      <div class="wf-step ${s.cls}">
        <span class="n">${pad2(i + 1)}</span>
        <span class="b"></span>
        <span class="t">${escapeHtml(s.t)}</span>
        <span class="meta">${escapeHtml(s.meta)}</span>
      </div>`).join('');

    const runsCount = w.runs_30d != null ? w.runs_30d : '—';

    return `<article class="wf-card" data-wf-id="${w.id}" data-kind="${escapeHtml(w.kind || 'chat')}" data-owner="${isCurated ? 'curated' : (isMine ? 'mine' : 'team')}">
      <div class="wf-head">
        <div class="wf-h-l">
          <div class="wf-kicker">
            <span class="wf-id">WF · ${wfNum}</span>
            <span class="tab-sep"></span>
            <span class="wf-kind ${kindCls}"><span class="pip"></span>${kindLabel}</span>
          </div>
          <h3 class="wf-title">${escapeHtml(w.title || 'Untitled')}</h3>
          <span class="wf-sub">${sub}</span>
        </div>
        <div class="wf-h-r">
          <span class="wf-runs">${typeof runsCount === 'number' && runsCount > 0 ? `<em>${runsCount}</em>` : runsCount}</span>
          <span class="wf-runs-l">RUNS · 30D</span>
        </div>
      </div>
      <div class="wf-steps">${stepsHtml}</div>
      ${tagsHtml ? `<div class="wf-tags">${tagsHtml}</div>` : ''}
      <div class="wf-foot">
        <div class="l">
          <span>EDITED ${escapeHtml(editedAt)}</span>
          <span>${ownerLabel}</span>
        </div>
        <div class="actions">
          ${isMine ? `<a href="/workspace/workflows/?id=${w.id}&edit=1" class="wf-mini" data-stop>Edit</a>` : ''}
          <button type="button" class="wf-mini" data-stop data-action="duplicate" data-id="${w.id}">Duplicate</button>
          <button type="button" class="wf-mini run" data-stop data-action="run" data-id="${w.id}" data-kind="${escapeHtml(w.kind || 'chat')}">Run</button>
        </div>
      </div>
    </article>`;
  }

  function paintGrid() {
    const grid = document.getElementById('wf-grid');
    if (!grid) return;
    let filtered = allWorkflows;
    if (activeFilter === 'chat') filtered = allWorkflows.filter((w) => (w.kind || 'chat') === 'chat');
    else if (activeFilter === 'tabular') filtered = allWorkflows.filter((w) => w.kind === 'tabular');
    else if (activeFilter === 'mine') filtered = allWorkflows.filter((w) => w.user_id === userId);
    else if (activeFilter === 'curated') filtered = allWorkflows.filter((w) => !w.user_id);

    if (!filtered.length) {
      grid.innerHTML = `
        <div class="ws-empty">${activeFilter === 'all' ? 'No workflows yet. Create one with the buttons above.' : 'No workflows in this filter.'}</div>
        <a href="/workspace/workflows/?edit=1&new=chat" class="wf-new">
          <span class="wf-new-l">+ NEW WORKFLOW</span>
          <span class="wf-new-cross">+</span>
          <span class="wf-new-h">Compose a playbook</span>
          <span class="wf-new-l" style="opacity:.6">CHAT · TABULAR</span>
        </a>`;
      return;
    }
    grid.innerHTML = filtered.map((w, i) => renderCard(w, i)).join('') + `
      <a href="/workspace/workflows/?edit=1&new=chat" class="wf-new">
        <span class="wf-new-l">+ NEW WORKFLOW</span>
        <span class="wf-new-cross">+</span>
        <span class="wf-new-h">Compose a playbook</span>
        <span class="wf-new-l" style="opacity:.6">CHAT · TABULAR</span>
      </a>`;

    // Card click → view; inner buttons stop propagation.
    grid.querySelectorAll('.wf-card[data-wf-id]').forEach((card) => {
      card.addEventListener('click', (e) => {
        if (e.target.closest('[data-stop]')) return;
        location.href = `/workspace/workflows/?id=${card.dataset.wfId}`;
      });
    });
    grid.querySelectorAll('[data-action="run"]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        const kind = btn.dataset.kind;
        if (kind === 'tabular') {
          location.href = `/workspace/reviews/?prefill=${id}`;
          return;
        }
        // Chat workflow → create a new chat tied to it. Pass the
        // user's preferred model from the universal pref key so the
        // conversation starts on the model they actually want to
        // use, not the server default.
        let preferredModel = '';
        try { preferredModel = localStorage.getItem('workspace.dash.model') || ''; } catch {}
        const r = await fetch('/.netlify/functions/workspace-chats-create', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({
            workflow_id: id,
            ...(preferredModel ? { model: preferredModel } : {}),
          }),
        });
        const j = await r.json();
        if (!r.ok) { alert('Run failed: ' + (j.error || 'unknown')); return; }
        location.href = `/workspace/chat/?id=${j.id}`;
      });
    });
    grid.querySelectorAll('[data-action="duplicate"]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        const src = allWorkflows.find((w) => w.id === id);
        if (!src) return;
        btn.disabled = true; btn.textContent = '…';
        const payload = {
          title: (src.title || 'Untitled') + ' (copy)',
          description: src.description || '',
          kind: src.kind || 'chat',
          practice_area: src.practice_area || '',
        };
        if (payload.kind === 'chat') payload.prompt_md = src.prompt_md || '';
        else payload.columns_config = src.columns_config || [];
        const r = await fetch('/.netlify/functions/workspace-workflows-save', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const j = await r.json();
        if (!r.ok) { alert('Duplicate failed: ' + (j.error || 'unknown')); btn.disabled = false; btn.textContent = 'Duplicate'; return; }
        location.href = `/workspace/workflows/?id=${j.workflow.id}&edit=1`;
      });
    });
  }

  function paintMetaStrip() {
    const total = allWorkflows.length;
    const chat = allWorkflows.filter((w) => (w.kind || 'chat') === 'chat').length;
    const tab = allWorkflows.filter((w) => w.kind === 'tabular').length;
    const curated = allWorkflows.filter((w) => !w.user_id).length;
    const mine = allWorkflows.filter((w) => w.user_id === userId).length;
    const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
    set('ms-saved', total);
    set('ms-chat', chat);
    set('wf-coord', `/WS.07 · PLAYBOOKS · ${total} SAVED`);
    set('ms-curated', curated);
    set('ms-mine', mine);
    // Tabular cell uses italic accent — set inner HTML
    const tabEl = document.getElementById('ms-tab');
    if (tabEl) tabEl.innerHTML = `<em>${pad2(tab)}</em>`;
    set('cnt-all', `[${total}]`);
    set('cnt-chat', `[${chat}]`);
    set('cnt-tab', `[${tab}]`);
  }

  function renderWorkflowsFromData(j) {
    allWorkflows = j.workflows || [];
    paintMetaStrip();
    paintGrid();
    // Wire tab filter (idempotent — only attach once)
    const tabsEl = document.getElementById('wf-tabs');
    if (tabsEl && !tabsEl.dataset.wired) {
      tabsEl.dataset.wired = '1';
      tabsEl.addEventListener('click', (e) => {
        const btn = e.target.closest('.tab-btn');
        if (!btn) return;
        activeFilter = btn.dataset.filter || 'all';
        tabsEl.querySelectorAll('.tab-btn').forEach((b) => b.classList.toggle('is-active', b === btn));
        paintGrid();
      });
    }
  }
  async function loadWorkflows() {
    let renderedSomething = false;
    try {
      const cached = JSON.parse(localStorage.getItem(WF_LIST_CACHE) || 'null');
      if (cached) { renderWorkflowsFromData(cached); renderedSomething = true; }
    } catch {}
    try {
      console.log('[workflows] loadWorkflows() — fetching');
      const r = await fetch('/.netlify/functions/workspace-workflows-list', {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Failed to load');
      console.log('[workflows] got', (j.workflows || []).length, 'workflows');
      renderWorkflowsFromData(j);
      try { localStorage.setItem(WF_LIST_CACHE, JSON.stringify(j)); } catch {}
    } catch (e) {
      console.error('[workflows] loadWorkflows() failed:', e);
      const grid = document.getElementById('wf-grid');
      if (!renderedSomething && grid) {
        grid.innerHTML = `<div class="ws-empty">Failed to load: ${escapeHtml(e.message || 'unknown')}</div>`;
      }
    }
  }

  // ============================================================
  // SINGLE WORKFLOW VIEW
  // ============================================================
  async function renderViewMode(id) {
    const r = await fetch(`/.netlify/functions/workspace-workflows-get?id=${encodeURIComponent(id)}`, {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) {
      main.innerHTML = `<div class="ws-wrap"><div class="ws-empty">${escapeHtml(j.error || 'Failed to load')}</div></div>`;
      return;
    }
    const w = j.workflow;
    const isOwn = w.user_id === userId;
    const isCurated = !w.user_id;
    const kindLabel = workflowKindLabel(w.kind);
    const kindCls = workflowKindClass(w.kind);

    main.innerHTML = `
      <div class="ws-wrap">
        <header class="ws-head">
          <span class="br-bl"></span><span class="br-br"></span>
          <div class="kicker">
            <a href="/workspace/workflows/" class="lib-back">← Workflows</a>
            <span class="k-coord" style="margin-left:8px">/WS.07 · WF · ${escapeHtml((w.id || '').slice(0,4).toUpperCase())}</span>
          </div>
          <div class="head-row">
            <div>
              <h1 class="head-title">${escapeHtml(w.title || 'Untitled')}</h1>
              <div class="wf-kicker" style="margin-top:10px">
                <span class="wf-kind ${kindCls}"><span class="pip"></span>${kindLabel}</span>
                ${isCurated ? '<span class="tab-sep"></span><span>CURATED</span>' : ''}
                ${w.practice_area ? `<span class="tab-sep"></span><span>${escapeHtml(w.practice_area.toUpperCase())}</span>` : ''}
              </div>
              ${w.description ? `<p class="head-sub">${escapeHtml(w.description)}</p>` : ''}
            </div>
            <div class="head-actions">
              ${w.kind === 'chat' ? `<button id="wf-use-chat" class="ws-btn">Use in chat</button>` : `<button id="wf-use-tabular" class="ws-btn">Use in review</button>`}
              ${isOwn ? `<a href="/workspace/workflows/?id=${w.id}&edit=1" class="ws-btn ws-btn-ghost">Edit</a>` : ''}
              ${isOwn ? `<button id="wf-delete" class="ws-btn ws-btn-ghost">Delete</button>` : ''}
            </div>
          </div>
        </header>

        ${w.kind === 'chat' ? `
          <section class="ws-card">
            <header class="ws-card-head"><h2 class="ws-card-title">System prompt</h2></header>
            <pre class="wf-prompt">${escapeHtml(w.prompt_md || '')}</pre>
          </section>` : `
          <section class="ws-card">
            <header class="ws-card-head"><h2 class="ws-card-title">Columns (${(w.columns_config || []).length})</h2></header>
            <div class="wf-cols">
              ${(w.columns_config || []).map((c) => `
                <div class="wf-col">
                  <div class="wf-col-name">${escapeHtml(c.name || '?')}</div>
                  <div class="wf-col-prompt">${escapeHtml(c.prompt || '')}</div>
                </div>`).join('')}
            </div>
          </section>`}

        <p class="ws-foot">
          <span><span style="color:var(--ink-4)">EOF</span> &nbsp; · &nbsp; END OF WORKFLOW</span>
          <a href="/workspace/workflows/">← All workflows</a>
        </p>
      </div>
    `;

    document.getElementById('wf-use-chat')?.addEventListener('click', async () => {
      const r2 = await fetch('/.netlify/functions/workspace-chats-create', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ workflow_id: w.id }),
      });
      const j2 = await r2.json();
      if (!r2.ok) { alert('Failed: ' + (j2.error || 'unknown')); return; }
      location.href = `/workspace/chat/?id=${j2.id}`;
    });
    document.getElementById('wf-use-tabular')?.addEventListener('click', () => {
      location.href = `/workspace/reviews/?prefill=${w.id}`;
    });
    document.getElementById('wf-delete')?.addEventListener('click', async () => {
      if (!(await window.siteConfirm(`Delete "${w.title}"? This cannot be undone.`, { okLabel: 'Delete', danger: true }))) return;
      await fetch('/.netlify/functions/workspace-workflows-delete', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: w.id }),
      });
      location.href = '/workspace/workflows/';
    });
  }

  // ============================================================
  // EDITOR
  // ============================================================
  async function renderEditor(id) {
    let initial = { title: '', description: '', kind: 'chat', prompt_md: '', columns_config: [], practice_area: '' };
    const newKind = params.get('new');
    if (newKind === 'tabular') initial.kind = 'tabular';
    if (id) {
      const r = await fetch(`/.netlify/functions/workspace-workflows-get?id=${encodeURIComponent(id)}`, {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok) { main.innerHTML = `<div class="ws-wrap"><div class="ws-empty">${escapeHtml(j.error || 'Failed')}</div></div>`; return; }
      if (j.workflow.user_id !== userId) {
        main.innerHTML = '<div class="ws-wrap"><div class="ws-empty">You can\'t edit a curated workflow. Make a copy instead.</div></div>';
        return;
      }
      initial = j.workflow;
    }

    main.innerHTML = `
      <div class="ws-wrap">
        <header class="ws-head">
          <span class="br-bl"></span><span class="br-br"></span>
          <div class="kicker">
            <a href="/workspace/workflows/" class="lib-back">← Workflows</a>
            <span class="k-coord" style="margin-left:8px">/WS.07 · ${id ? 'EDIT' : 'NEW'}</span>
          </div>
          <h1 class="head-title">${id ? 'Edit <em>workflow</em>' : 'New <em>workflow</em>'}</h1>
        </header>
        <section class="ws-card">
          <label class="rv-field">
            <span class="rv-field-label">Title</span>
            <input type="text" id="wf-title" maxlength="200" value="${escapeHtml(initial.title || '')}" placeholder="e.g. FL MSA review checklist" />
          </label>
          <label class="rv-field">
            <span class="rv-field-label">Description (optional)</span>
            <textarea id="wf-desc" rows="2" placeholder="What this workflow is for, when to use it…">${escapeHtml(initial.description || '')}</textarea>
          </label>
          <label class="rv-field">
            <span class="rv-field-label">Practice area (optional tag)</span>
            <input type="text" id="wf-practice" maxlength="100" value="${escapeHtml(initial.practice_area || '')}" placeholder="e.g. NDA review, FL real estate" />
          </label>
          <div class="rv-field">
            <span class="rv-field-label">Kind</span>
            <div class="wf-kind-picker">
              <label class="wf-kind-opt"><input type="radio" name="wf-kind" value="chat" ${initial.kind === 'chat' ? 'checked' : ''} /> Chat — sets a system prompt for new chats</label>
              <label class="wf-kind-opt"><input type="radio" name="wf-kind" value="tabular" ${initial.kind === 'tabular' ? 'checked' : ''} /> Tabular — saves a column config for tabular reviews</label>
            </div>
          </div>

          <div id="wf-chat-fields" class="rv-field" ${initial.kind === 'chat' ? '' : 'hidden'}>
            <span class="rv-field-label">System prompt body (markdown)</span>
            <textarea id="wf-prompt" rows="14" placeholder="You are a senior associate reviewing this MSA. Walk through these checks one by one: governing law, IP assignment, indemnification scope, liability cap, termination triggers…">${escapeHtml(initial.prompt_md || '')}</textarea>
          </div>

          <div id="wf-tabular-fields" class="rv-field" ${initial.kind === 'tabular' ? '' : 'hidden'}>
            <span class="rv-field-label">Columns</span>
            <div id="wf-cols-edit" class="rv-cols"></div>
            <button type="button" id="wf-add-col" class="rv-add-col">+ Add column</button>
          </div>

          <div class="head-actions" style="margin-top:18px">
            <button id="wf-save" class="ws-btn">${id ? 'Save changes' : 'Create'}</button>
            <a href="/workspace/workflows/" class="ws-btn ws-btn-ghost">Cancel</a>
          </div>
        </section>

        <p class="ws-foot">
          <span><span style="color:var(--ink-4)">EOF</span> &nbsp; · &nbsp; ${id ? 'EDIT WORKFLOW' : 'NEW WORKFLOW'}</span>
          <a href="/workspace/workflows/">← All workflows</a>
        </p>
      </div>
    `;

    const colsEl = document.getElementById('wf-cols-edit');
    let colIdx = 0;
    function addCol(c) {
      const id2 = colIdx++;
      colsEl.insertAdjacentHTML('beforeend', `
        <div class="rv-col-row" data-col="${id2}">
          <input type="text" class="rv-col-name" placeholder="Column name" value="${escapeHtml(c?.name || '')}" />
          <textarea class="rv-col-prompt" rows="2" placeholder="Prompt for this column">${escapeHtml(c?.prompt || '')}</textarea>
          <button type="button" class="rv-col-del" aria-label="Remove">×</button>
        </div>`);
    }
    if (initial.columns_config && initial.columns_config.length) {
      for (const c of initial.columns_config) addCol(c);
    } else if (initial.kind === 'tabular') {
      addCol();
    }
    document.getElementById('wf-add-col').addEventListener('click', () => addCol());
    colsEl.addEventListener('click', (e) => {
      if (e.target.classList.contains('rv-col-del')) {
        e.target.closest('.rv-col-row')?.remove();
      }
    });

    document.querySelectorAll('input[name="wf-kind"]').forEach((r) => {
      r.addEventListener('change', () => {
        const k = document.querySelector('input[name="wf-kind"]:checked').value;
        document.getElementById('wf-chat-fields').hidden = (k !== 'chat');
        document.getElementById('wf-tabular-fields').hidden = (k !== 'tabular');
        if (k === 'tabular' && colsEl.children.length === 0) addCol();
      });
    });

    document.getElementById('wf-save').addEventListener('click', async () => {
      const title = document.getElementById('wf-title').value.trim();
      const description = document.getElementById('wf-desc').value.trim();
      const practice = document.getElementById('wf-practice').value.trim();
      const kind = document.querySelector('input[name="wf-kind"]:checked').value;
      const prompt_md = document.getElementById('wf-prompt').value;
      const columns_config = Array.from(colsEl.querySelectorAll('.rv-col-row')).map((r) => ({
        name: r.querySelector('.rv-col-name').value.trim(),
        prompt: r.querySelector('.rv-col-prompt').value.trim(),
      })).filter((c) => c.prompt);

      if (!title) { alert('Title required'); return; }

      const btn = document.getElementById('wf-save');
      btn.disabled = true; btn.textContent = 'Saving…';

      const payload = { id: id || undefined, title, description, kind, practice_area: practice };
      if (kind === 'chat') payload.prompt_md = prompt_md;
      else payload.columns_config = columns_config;

      const r = await fetch('/.netlify/functions/workspace-workflows-save', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const j = await r.json();
      if (!r.ok) { alert('Failed: ' + (j.error || 'unknown')); btn.disabled = false; btn.textContent = id ? 'Save changes' : 'Create'; return; }
      try { localStorage.removeItem(WF_LIST_CACHE); } catch {}
      location.href = `/workspace/workflows/?id=${j.workflow.id}`;
    });
  }

  // ============================================================
  if (editMode) renderEditor(wfId);
  else if (wfId) renderViewMode(wfId);
  else renderListView();
</script>
</body>
</html>
