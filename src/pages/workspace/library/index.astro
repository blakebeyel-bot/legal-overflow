---
// Workspace document library — uploads persist here, can be re-attached
// to multiple chats, and the chat reads their extracted text directly.
// Verbatim port of Library.html prototype with all existing JS handlers
// (upload, redline modal, edit-review modal, save-to-vault) preserved.
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Library — Legal Overflow</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<link rel="stylesheet" href="/workspace.css" />
<link rel="stylesheet" href="/site-anim.css" />
<script src="/nav-autohide.js" defer></script>
<script src="/site-dialog.js" defer></script>
<script src="/site-anim.js" defer></script>
<style is:global>
  /* ============================================================
     Library — page-local stylesheet (verbatim port of the prototype).
     is:global because document cards + upload rows are rendered via
     JS — those nodes don't get Astro auto-scoped attributes.
     Page-local-ness enforced by body.ws-library ancestor selector.
     ============================================================ */

  body.ws-library {
    --doc-paper: #fafaf6;
    --rule-thread: #cbc4b1;
    --motion-snap: cubic-bezier(.2,.8,.2,1);
    --hi: #b22222; --md: #c98a14; --lo: #6a7c8e;
    background-image:
      radial-gradient(1100px 600px at 80% -10%, rgba(208,219,213,.18), transparent 60%),
      radial-gradient(900px 500px at -10% 20%, rgba(220,212,196,.25), transparent 70%);
  }

  /* ---------- shell ---------- */
  body.ws-library main.ws-wrap {
    position: relative; z-index: 2;
    max-width: 1480px; width: 100%;
    margin: 0 auto;
    padding: 22px 40px 40px !important;
    background: transparent;
    border: none !important;
  }
  @media (max-width: 980px) {
    body.ws-library main.ws-wrap { padding: 18px 16px 40px !important; }
  }

  /* ---------- ws-head with all four corner brackets ---------- */
  body.ws-library .ws-head {
    position: relative !important;
    display: block !important;
    padding: 14px 24px 22px !important;
    margin: 0 0 22px !important;
    border: none !important;
    background: transparent !important;
  }
  body.ws-library .ws-head::before, body.ws-library .ws-head::after,
  body.ws-library .ws-head > .br-bl, body.ws-library .ws-head > .br-br {
    content: ''; position: absolute;
    width: 14px; height: 14px;
    border: 1px solid var(--ink); pointer-events: none;
  }
  body.ws-library .ws-head::before { top: 0; left: 0; border-right: none; border-bottom: none; }
  body.ws-library .ws-head::after  { top: 0; right: 0; border-left: none; border-bottom: none; }
  body.ws-library .ws-head > .br-bl { bottom: 0; left: 0; border-top: none; border-right: none; }
  body.ws-library .ws-head > .br-br { bottom: 0; right: 0; border-top: none; border-left: none; }

  body.ws-library .kicker {
    display: inline-flex; align-items: center; gap: 12px;
    font-family: var(--mono); font-size: 10.5px;
    color: var(--accent-deep);
    letter-spacing: .14em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  body.ws-library .kicker .k-tag {
    border: 1px solid var(--accent-deep);
    padding: 2px 7px; border-radius: 2px; font-size: 9.5px;
  }
  body.ws-library .kicker .k-coord { color: var(--ink-4); font-size: 9.5px; }

  body.ws-library .head-row {
    display: flex; gap: 20px; justify-content: space-between;
    align-items: flex-end; flex-wrap: wrap;
  }
  body.ws-library .head-title {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(40px, 5vw, 68px);
    letter-spacing: -.012em; line-height: 1; margin: 0;
    color: var(--ink);
  }
  body.ws-library .head-title em { font-style: italic; color: var(--accent-deep); }
  body.ws-library .head-sub {
    font-family: var(--serif); font-size: 19px;
    color: var(--ink-2); max-width: 64ch;
    margin-top: 12px; line-height: 1.4;
  }
  body.ws-library .head-actions {
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
  }
  body.ws-library .head-actions .ws-btn,
  body.ws-library .head-actions .ws-btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 18px; cursor: pointer;
    font-family: var(--mono); font-size: 11px;
    letter-spacing: .12em; text-transform: uppercase;
    background: var(--ink); color: var(--paper);
    border: 1px solid var(--ink); border-radius: 4px;
    text-decoration: none;
    transition: background .15s var(--motion-snap), border-color .15s, color .15s;
  }
  body.ws-library .head-actions .ws-btn:hover {
    background: var(--accent-deep); border-color: var(--accent-deep);
  }
  body.ws-library .head-actions .ws-btn-ghost {
    background: transparent !important; color: var(--ink) !important;
  }
  body.ws-library .head-actions .ws-btn-ghost:hover {
    background: var(--ink) !important; color: var(--paper) !important;
  }
  body.ws-library .head-actions .ws-btn svg { width: 12px; height: 12px; }

  /* ---------- drop zone ---------- */
  body.ws-library .dropzone {
    position: relative;
    border: 1px dashed var(--rule-thread); border-radius: 8px;
    background: rgba(255,255,255,.3);
    padding: 32px 32px;
    display: grid; grid-template-columns: 1fr auto;
    gap: 24px; align-items: center;
    transition: border-color .25s, background .25s;
  }
  body.ws-library .dropzone:hover,
  body.ws-library .dropzone.is-drag {
    border-color: var(--accent-deep);
    background: rgba(215,237,224,.5);
    border-style: solid;
  }
  body.ws-library .dropzone::before, body.ws-library .dropzone::after,
  body.ws-library .dropzone .dz-bl, body.ws-library .dropzone .dz-br {
    content: ''; position: absolute;
    width: 12px; height: 12px;
    border-color: var(--accent-deep);
    pointer-events: none;
    opacity: 0;
    transition: opacity .25s;
  }
  body.ws-library .dropzone::before { top: 8px; left: 8px; border-top: 1px solid; border-left: 1px solid; }
  body.ws-library .dropzone::after  { top: 8px; right: 8px; border-top: 1px solid; border-right: 1px solid; }
  body.ws-library .dropzone .dz-bl { bottom: 8px; left: 8px; border-bottom: 1px solid; border-left: 1px solid; }
  body.ws-library .dropzone .dz-br { bottom: 8px; right: 8px; border-bottom: 1px solid; border-right: 1px solid; }
  body.ws-library .dropzone:hover::before, body.ws-library .dropzone:hover::after,
  body.ws-library .dropzone:hover .dz-bl, body.ws-library .dropzone:hover .dz-br,
  body.ws-library .dropzone.is-drag::before, body.ws-library .dropzone.is-drag::after,
  body.ws-library .dropzone.is-drag .dz-bl, body.ws-library .dropzone.is-drag .dz-br {
    opacity: 1;
  }
  body.ws-library .dz-l { display: flex; flex-direction: column; gap: 8px; }
  body.ws-library .dz-kick {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--accent-deep);
    letter-spacing: .14em; text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 8px;
  }
  body.ws-library .dz-kick .pip {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent-deep);
    animation: libPulse 2s ease-in-out infinite;
  }
  @keyframes libPulse { 0%,100% { opacity: 1; } 50% { opacity: .35; } }
  body.ws-library .dz-title {
    font-family: var(--serif); font-size: 32px;
    letter-spacing: -.01em; color: var(--ink);
    margin: 0; line-height: 1.1;
    font-weight: 400;
  }
  body.ws-library .dz-title em { font-style: italic; color: var(--accent-deep); }
  body.ws-library .dz-sub {
    font-family: var(--mono); font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: .08em; text-transform: uppercase;
    display: flex; gap: 18px; flex-wrap: wrap;
  }
  body.ws-library .dz-r { display: flex; flex-direction: column; gap: 8px; }
  body.ws-library .dz-r .ws-btn,
  body.ws-library .dz-r .ws-btn-ghost {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 11px 18px; cursor: pointer;
    font-family: var(--mono); font-size: 11px;
    letter-spacing: .12em; text-transform: uppercase;
    background: var(--ink); color: var(--paper);
    border: 1px solid var(--ink); border-radius: 4px;
    text-decoration: none;
    transition: background .15s, border-color .15s, color .15s;
  }
  body.ws-library .dz-r .ws-btn:hover { background: var(--accent-deep); border-color: var(--accent-deep); }
  body.ws-library .dz-r .ws-btn-ghost { background: transparent; color: var(--ink); font-size: 10px; }
  body.ws-library .dz-r .ws-btn-ghost:hover { background: var(--ink); color: var(--paper); }
  @media (max-width: 980px) {
    body.ws-library .dropzone { grid-template-columns: 1fr; padding: 22px; }
  }

  /* ---------- meta strip ---------- */
  body.ws-library .meta-strip {
    display: grid; grid-template-columns: repeat(5, 1fr);
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    margin: 22px 0;
  }
  body.ws-library .ms-cell {
    padding: 13px 18px;
    border-right: 1px solid var(--rule-soft);
    display: flex; flex-direction: column; gap: 5px;
  }
  body.ws-library .ms-cell:last-child { border-right: none; }
  body.ws-library .ms-l {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .14em; text-transform: uppercase;
  }
  body.ws-library .ms-v {
    font-family: var(--serif); font-size: 24px;
    color: var(--ink); line-height: 1;
  }
  body.ws-library .ms-v em { font-style: italic; color: var(--accent-deep); }
  body.ws-library .ms-d {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-4);
    letter-spacing: .08em; text-transform: uppercase;
  }
  @media (max-width: 1100px) {
    body.ws-library .meta-strip { grid-template-columns: repeat(2, 1fr); }
    body.ws-library .ms-cell:nth-child(2n) { border-right: none; }
  }

  /* ---------- sec-div ---------- */
  body.ws-library .sec-div {
    display: grid; grid-template-columns: auto 1fr auto;
    align-items: center; gap: 16px;
    margin: 8px 0 14px;
    font-family: var(--mono); font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: .12em; text-transform: uppercase;
  }
  body.ws-library .sec-div .sec-num { color: var(--ink); }
  body.ws-library .sec-div .sec-rule { height: 1px; background: var(--rule-soft); }
  body.ws-library .sec-div .sec-meta { color: var(--ink-4); font-size: 9.5px; }

  /* ---------- filter row ---------- */
  body.ws-library .filter-row {
    display: flex; gap: 0; align-items: center; flex-wrap: wrap;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    background: rgba(255,255,255,.3);
    padding: 4px 10px;
    margin-bottom: 16px;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--ink-3);
  }
  body.ws-library .filter-row .fl-l {
    font-size: 9px; color: var(--ink-4);
    letter-spacing: .14em;
    margin-right: 10px; padding: 4px 0;
  }
  body.ws-library .fl-toggle {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 11px;
    background: transparent; border: none; cursor: pointer;
    color: var(--ink-3);
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase;
    transition: color .15s;
  }
  body.ws-library .fl-toggle:hover { color: var(--ink); }
  body.ws-library .fl-toggle.is-on { color: var(--accent-deep); }
  body.ws-library .fl-toggle .fl-pip {
    width: 5px; height: 5px; border-radius: 50%;
    border: 1px solid currentColor; transition: background .15s;
  }
  body.ws-library .fl-toggle.is-on .fl-pip { background: currentColor; }
  body.ws-library .fl-toggle .fl-cnt { font-size: 9px; opacity: .7; }
  body.ws-library .fl-sep {
    width: 1px; height: 12px; background: var(--rule-soft);
    margin: 0 1px;
  }
  body.ws-library .fl-spacer { flex: 1; }
  body.ws-library .fl-search {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; border: 1px solid var(--rule-soft); border-radius: 4px;
    background: rgba(255,255,255,.4);
    margin-right: 6px;
  }
  body.ws-library .fl-search input {
    border: none; outline: none; background: transparent;
    font-family: var(--sans); font-size: 12.5px;
    color: var(--ink); width: 200px;
  }
  body.ws-library .fl-search input::placeholder { color: var(--ink-4); }
  body.ws-library .fl-sort {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; cursor: pointer;
    color: var(--ink-3);
    background: transparent; border: none;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase;
    transition: color .15s;
  }
  body.ws-library .fl-sort:hover { color: var(--ink); }
  body.ws-library .fl-sort .v {
    font-family: var(--sans); text-transform: none; letter-spacing: 0;
    font-size: 11.5px;
    color: var(--ink); border-bottom: 1px dotted var(--ink-3);
  }
  body.ws-library .layout-seg {
    display: inline-flex;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    overflow: hidden;
    margin-left: 6px;
  }
  body.ws-library .layout-seg-btn {
    padding: 4px 10px;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--ink-3);
    background: transparent; border: none; cursor: pointer;
    border-right: 1px solid var(--rule-soft);
    transition: color .15s, background .15s;
  }
  body.ws-library .layout-seg-btn:last-child { border-right: none; }
  body.ws-library .layout-seg-btn:hover { color: var(--ink); }
  body.ws-library .layout-seg-btn.is-active {
    background: var(--ink); color: var(--paper);
  }

  /* ---------- grid of doc cards ---------- */
  body.ws-library .lib-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;
  }
  @media (max-width: 1280px) { body.ws-library .lib-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 980px)  { body.ws-library .lib-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { body.ws-library .lib-grid { grid-template-columns: 1fr; } }

  /* List layout — flips the grid to 1-col with horizontal cards */
  body.ws-library .lib-grid.is-list { grid-template-columns: 1fr; }
  body.ws-library .lib-grid.is-list .lib-card {
    flex-direction: row;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
  }
  body.ws-library .lib-grid.is-list .lc-thumb {
    width: 56px; height: 56px;
    flex-shrink: 0;
    padding: 6px 8px; gap: 2px;
  }
  body.ws-library .lib-grid.is-list .lc-thumb-h { font-size: 7px; margin-bottom: 1px; }
  body.ws-library .lib-grid.is-list .lc-thumb-line { height: 2px; }
  body.ws-library .lib-grid.is-list .lc-mid { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
  body.ws-library .lib-grid.is-list .lc-title { font-size: 14px; -webkit-line-clamp: 1; }
  body.ws-library .lib-grid.is-list .lc-meta { border-top: none; padding-top: 0; }
  body.ws-library .lib-grid.is-list .lc-kicker { padding: 0; }

  body.ws-library .lib-card {
    position: relative;
    border: 1px solid var(--rule-soft); border-radius: 6px;
    background: var(--paper-2);
    padding: 14px 14px 12px;
    cursor: pointer;
    display: flex; flex-direction: column; gap: 10px;
    color: var(--ink); text-decoration: none;
    transition: border-color .15s var(--motion-snap),
                transform .15s, background .15s;
  }
  body.ws-library .lib-card:hover {
    border-color: var(--ink); transform: translateY(-2px);
  }
  body.ws-library .lib-card::before, body.ws-library .lib-card::after {
    content: ''; position: absolute;
    width: 8px; height: 8px;
    border-color: var(--ink-4);
    pointer-events: none;
    transition: border-color .15s var(--motion-snap), width .15s var(--motion-snap), height .15s var(--motion-snap);
  }
  body.ws-library .lib-card::before { top: 4px; left: 4px; border-top: 1px solid; border-left: 1px solid; }
  body.ws-library .lib-card::after  { bottom: 4px; right: 4px; border-bottom: 1px solid; border-right: 1px solid; }
  body.ws-library .lib-card:hover::before, body.ws-library .lib-card:hover::after {
    border-color: var(--accent-deep); width: 12px; height: 12px;
  }
  body.ws-library .lib-card.is-pending { border-color: var(--md); }
  body.ws-library .lib-card.is-failed { border-color: var(--hi); }

  /* Thumbnail */
  body.ws-library .lc-thumb {
    position: relative;
    height: 118px;
    background: var(--doc-paper);
    border: 1px solid var(--rule-soft); border-radius: 4px;
    overflow: hidden;
    display: flex; flex-direction: column;
    padding: 14px 12px; gap: 5px;
    font-family: var(--serif); color: var(--ink-3);
  }
  body.ws-library .lc-thumb::before {
    content: ''; position: absolute;
    top: 0; right: 0;
    width: 14px; height: 14px;
    border-left: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    background: var(--paper-2);
  }
  body.ws-library .lc-thumb-line {
    height: 4px; background: var(--rule-soft); border-radius: 1px;
  }
  body.ws-library .lc-thumb-line.short { width: 60%; }
  body.ws-library .lc-thumb-line.tiny  { width: 35%; }
  body.ws-library .lc-thumb-h {
    font-family: var(--mono); font-size: 8px;
    color: var(--ink-4);
    letter-spacing: .12em; text-transform: uppercase;
    margin-bottom: 5px;
  }
  body.ws-library .lib-card.is-pending .lc-thumb {
    background: linear-gradient(180deg, var(--doc-paper) 60%, var(--paper-2) 60%);
  }
  body.ws-library .lib-card.is-pending .lc-thumb-h { color: var(--md); }

  /* Card kicker line (kind + status) */
  body.ws-library .lc-kicker {
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .12em; text-transform: uppercase;
  }
  body.ws-library .lc-kind {
    display: inline-flex; align-items: center; gap: 5px;
  }
  body.ws-library .lc-kind .pip {
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--accent-deep);
  }
  body.ws-library .lc-kind.is-pdf .pip { background: var(--hi); }
  body.ws-library .lc-kind.is-doc .pip { background: var(--ink-2); }
  body.ws-library .lc-kind.is-mail .pip { background: var(--lo); }
  body.ws-library .lc-kind.is-img .pip { background: var(--md); }
  body.ws-library .lc-kind.is-txt .pip { background: var(--ink-3); }

  body.ws-library .lc-status { color: var(--accent-deep); }
  body.ws-library .lc-status.pending { color: var(--md); }
  body.ws-library .lc-status.failed { color: var(--hi); }

  body.ws-library .lc-title {
    font-family: var(--serif); font-size: 16px;
    line-height: 1.25; color: var(--ink);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    margin: 0;
  }
  body.ws-library .lc-title em { font-style: italic; }

  body.ws-library .lc-meta {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .04em;
    display: flex; gap: 8px; flex-wrap: wrap;
    margin-top: auto;
    padding-top: 6px;
    border-top: 1px dotted var(--rule-soft);
  }
  body.ws-library .lc-meta .dot { color: var(--rule-thread); }

  /* Card delete button — top-right, fades in on hover */
  body.ws-library .lc-del {
    position: absolute; top: 6px; right: 6px;
    width: 22px; height: 22px;
    background: transparent; border: 1px solid transparent;
    color: var(--ink-4);
    font-size: 14px; line-height: 1;
    border-radius: 4px; cursor: pointer;
    opacity: 0; z-index: 2;
    transition: opacity .15s, background .15s, color .15s, border-color .15s;
  }
  body.ws-library .lib-card:hover .lc-del { opacity: 1; }
  body.ws-library .lc-del:hover {
    background: var(--hi); color: white; border-color: var(--hi);
  }

  /* Skeleton */
  body.ws-library .lib-skel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--rule-soft); border-radius: 6px;
    background: var(--paper-2);
    padding: 14px 14px 12px;
    display: flex; flex-direction: column; gap: 10px;
  }
  body.ws-library .lib-skel::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.5), transparent);
    animation: libShim 1.4s linear infinite;
  }
  @keyframes libShim {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  body.ws-library .skel-thumb {
    height: 118px;
    background: var(--rule-soft);
    border-radius: 4px;
    opacity: .4;
  }
  body.ws-library .skel-line {
    height: 11px;
    background: var(--rule-soft); border-radius: 2px;
    opacity: .4;
  }
  body.ws-library .skel-line.short { width: 60%; }
  body.ws-library .skel-line.tiny  { width: 35%; }

  /* ---------- upload progress strip (rows appended below grid) ---------- */
  body.ws-library .lib-uploads {
    margin-top: 18px;
