<script>
  import { getSupabase } from '../../../lib/supabase';
  const supabase = getSupabase();

  // Body never hidden — match the dashboard's hardened pattern.
  console.log('[library] Script started');
  let session = null;
  try {
    const { data, error } = await supabase.auth.getSession();
    if (error) throw error;
    session = data?.session;
    if (!session) {
      console.info('[library] No session — redirecting to /login/');
      location.href = '/login/?redirect=/workspace/library/';
      throw new Error('not signed in');
    }
    const { data: profile } = await supabase
      .from('profiles').select('approved_at').eq('id', session.user.id).maybeSingle();
    if (!profile?.approved_at) {
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Pending approval</h1><p>Your account is pending operator approval.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('pending approval');
    }
    console.log('[library] Auth gate passed, user', session.user?.id);
  } catch (err) {
    if (err && !['not signed in', 'pending approval'].includes(err.message)) {
      console.error('[library] Gate failed:', err);
      document.body.innerHTML = `<main style="max-width:680px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Library error</h1><pre style="background:#f5f5f5;padding:14px;border-radius:6px;font-size:12px;white-space:pre-wrap">${(err && err.message ? err.message : String(err)).replace(/[<>&]/g,(c)=>({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]))}</pre><p><a href="/workspace/">← Back to workspace</a></p></main>`;
    }
    throw err;
  }

  let accessToken = session.access_token;
  try { supabase.auth.onAuthStateChange((_e, s) => { if (s?.access_token) accessToken = s.access_token; }); } catch {}
  const userId = session.user.id;
  const els = {
    grid: document.getElementById('lib-grid'),
    search: document.getElementById('lib-search'),
    uploadBtn: document.getElementById('upload-btn'),
    uploadInput: document.getElementById('upload-input'),
    uploadProgress: document.getElementById('upload-progress'),
    dropzone: document.getElementById('dropzone'),
    dzPick: document.getElementById('dz-pick'),
  };

  // State for client-side filtering / sorting / layout
  let allDocs = [];
  let activeFilter = 'all';
  let activeLayout = 'grid';
  const SORT_VALUES = ['Updated · newest', 'Updated · oldest', 'Title · A–Z', 'Size · large', 'Size · small'];
  let sortIdx = 0;

  function escapeHtml(s) {
    return String(s ?? '').replace(/[<>&"]/g, (c) => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
  }
  function formatBytes(n) {
    if (!n) return '—';
    const u = ['B','KB','MB','GB'];
    let i = 0; let v = n;
    while (v >= 1024 && i < u.length - 1) { v /= 1024; i++; }
    return `${v.toFixed(v < 10 ? 1 : 0)} ${u[i]}`;
  }
  function fileTypeBadge(mime, name) {
    const ext = (name || '').split('.').pop().toLowerCase();
    if (ext === 'pdf' || /pdf/i.test(mime)) return 'PDF';
    if (ext === 'docx' || /wordprocessing/i.test(mime)) return 'DOCX';
    if (ext === 'doc') return 'DOC';
    if (ext === 'txt' || /^text\/plain/.test(mime)) return 'TXT';
    if (ext === 'md' || /markdown/.test(mime)) return 'MD';
    return ext ? ext.toUpperCase() : '?';
  }
  function kindClass(badge) {
    if (badge === 'PDF') return 'is-pdf';
    if (badge === 'DOCX' || badge === 'DOC') return 'is-doc';
    if (badge === 'EML' || badge === 'MSG') return 'is-mail';
    if (badge === 'PNG' || badge === 'JPG' || badge === 'JPEG' || badge === 'IMG' || badge === 'TIFF') return 'is-img';
    return 'is-txt';
  }
  function relTime(iso) {
    if (!iso) return '—';
    const d = new Date(iso);
    const today = new Date();
    if (d.toDateString() === today.toDateString()) {
      const pad = (n) => String(n).padStart(2, '0');
      return pad(d.getHours()) + ':' + pad(d.getMinutes());
    }
    const yest = new Date(today); yest.setDate(today.getDate() - 1);
    if (d.toDateString() === yest.toDateString()) {
      const pad = (n) => String(n).padStart(2, '0');
      return 'YDA ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
    }
    return d.toLocaleDateString(undefined, { day: '2-digit', month: 'short' }).toUpperCase();
  }

  function applySort(arr) {
    const v = SORT_VALUES[sortIdx];
    const sorted = [...arr];
    if (v === 'Updated · newest') sorted.sort((a, b) => (b.updated_at || '').localeCompare(a.updated_at || ''));
    else if (v === 'Updated · oldest') sorted.sort((a, b) => (a.updated_at || '').localeCompare(b.updated_at || ''));
    else if (v === 'Title · A–Z') sorted.sort((a, b) => (a.filename || '').localeCompare(b.filename || ''));
    else if (v === 'Size · large') sorted.sort((a, b) => (b.size_bytes || 0) - (a.size_bytes || 0));
    else if (v === 'Size · small') sorted.sort((a, b) => (a.size_bytes || 0) - (b.size_bytes || 0));
    return sorted;
  }
  function applyFilter(arr) {
    if (activeFilter === 'all') return arr;
    return arr.filter((d) => {
      const status = d.current_version?.extraction_status || 'unknown';
      const badge = fileTypeBadge(d.file_type, d.original_filename);
      if (activeFilter === 'pdf') return badge === 'PDF';
      if (activeFilter === 'doc') return badge === 'DOCX' || badge === 'DOC';
      if (activeFilter === 'txt') return badge === 'TXT' || badge === 'MD';
      if (activeFilter === 'processing') return status === 'pending' || status === 'running';
      return true;
    });
  }

  function renderGrid() {
    const filtered = applyFilter(allDocs);
    const sorted = applySort(filtered);

    // Update counts + meta strip + coord
    updateMetaStrip();
    updateFilterCounts();

    if (!sorted.length) {
      els.grid.innerHTML = '<div class="ws-empty"><strong>No documents yet.</strong><br/>Drop files into the zone above, or click "Add document".</div>';
      return;
    }

    els.grid.innerHTML = sorted.map((d) => {
      const badge = fileTypeBadge(d.file_type, d.original_filename);
      const kCls = kindClass(badge);
      const status = d.current_version?.extraction_status || 'unknown';
      const chars = d.current_version?.extracted_chars || 0;
      const isPending = status === 'pending' || status === 'running';
      const isFailed = status === 'failed';
      const cardCls = 'lib-card' + (isPending ? ' is-pending' : '') + (isFailed ? ' is-failed' : '');
      const statusLabel =
        status === 'done' ? '● VERIFIED' :
        isPending ? '● PROCESSING' :
        status === 'failed' ? '● FAILED' :
        status === 'skipped' ? '● NO PREVIEW' :
        '—';
      const statusCls = status === 'done' ? '' : (isPending ? 'pending' : (isFailed ? 'failed' : 'pending'));

      // Thumbnail header text — kind + page-ish hint
      const thumbH = isPending ? 'EXTRACTING…' : (badge + ' DOCUMENT');

      const charLabel = status === 'done' ? `${chars.toLocaleString()} chars` :
                        isPending ? 'extracting…' :
                        status === 'failed' ? 'preview unavailable' :
                        status === 'skipped' ? 'no preview' : '—';

      return `<a href="/workspace/library/?id=${d.id}" class="${cardCls}" data-id="${d.id}">
        <button type="button" class="lc-del" data-del="${d.id}" data-name="${escapeHtml(d.filename)}" aria-label="Delete" title="Delete">×</button>
        <div class="lc-thumb">
          <div class="lc-thumb-h">${escapeHtml(thumbH)}</div>
          <div class="lc-thumb-line"></div>
          <div class="lc-thumb-line short"></div>
          <div class="lc-thumb-line"></div>
          <div class="lc-thumb-line tiny"></div>
          <div class="lc-thumb-line short"></div>
        </div>
        <div class="lc-mid">
          <div class="lc-kicker">
            <span class="lc-kind ${kCls}"><span class="pip"></span>${badge}</span>
            <span class="lc-status ${statusCls}">${statusLabel}</span>
          </div>
          <div class="lc-title">${escapeHtml(d.filename || '')}</div>
          <div class="lc-meta">
            <span>${formatBytes(d.size_bytes)}</span>
            <span class="dot">·</span>
            <span>${escapeHtml(relTime(d.updated_at))}</span>
            <span class="dot">·</span>
            <span>${escapeHtml(charLabel)}</span>
          </div>
        </div>
        <button type="button" class="save-to-vault-btn" data-save-vault="${d.id}" data-name="${escapeHtml(d.filename)}" aria-label="Save to Vault">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
          </svg>
          <span>Save to Vault</span>
        </button>
      </a>`;
    }).join('');

    // Wire buttons (delete + save-to-vault)
    els.grid.querySelectorAll('[data-save-vault]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault(); e.stopPropagation();
        if (btn.classList.contains('is-saved')) return;
        const id = btn.dataset.saveVault;
        const name = btn.dataset.name;
        btn.disabled = true;
        btn.querySelector('span').textContent = 'Saving…';
        try {
          const meta = await fetch(`/.netlify/functions/workspace-library-get?id=${encodeURIComponent(id)}&include_text=1`, {
            headers: { Authorization: `Bearer ${accessToken}` },
          });
          const mj = await meta.json();
          if (!meta.ok) throw new Error(mj.error || 'Could not load document');
          const text = mj.current_version_text || '';
          if (!text.trim()) throw new Error('Document text is not available yet (extraction still running?). Try again in a minute.');
          const r = await fetch('/.netlify/functions/workspace-vault-add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${accessToken}` },
            body: JSON.stringify({ source_kind: 'document', source_doc_id: id, title: name, content: text }),
          });
          const j = await r.json();
          if (!r.ok) throw new Error(j.error || 'Save failed');
          btn.classList.add('is-saved');
          btn.querySelector('span').textContent = 'Saved to Vault';
          if (typeof window.siteToast === 'function') window.siteToast('Added to your Vault', { kind: 'success' });
        } catch (err) {
          btn.disabled = false;
          btn.querySelector('span').textContent = 'Save to Vault';
          alert('Could not save: ' + err.message);
        }
      });
    });

    els.grid.querySelectorAll('[data-del]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault(); e.stopPropagation();
        const id = btn.dataset.del;
        const name = btn.dataset.name;
        const ok = await window.siteConfirm(`Delete "${name}"? This cannot be undone.`, { okLabel: 'Delete', danger: true });
        if (!ok) return;
        // Optimistic remove
        const row = btn.closest('.ws-row-wrap, [data-doc-id], li, .lib-card') || btn.parentElement;
        const removedHTML = row?.outerHTML;
        const removedNext = row?.nextSibling;
        const removedParent = row?.parentNode;
        if (row) row.remove();
        const r = await fetch('/.netlify/functions/workspace-library-delete', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          window.siteToast('Delete failed: ' + (j.error || 'unknown'), { kind: 'error' });
          if (removedParent && removedHTML) {
            const tmp = document.createElement('div'); tmp.innerHTML = removedHTML;
            const restored = tmp.firstElementChild;
            if (restored) {
              if (removedNext) removedParent.insertBefore(restored, removedNext);
              else removedParent.appendChild(restored);
            }
          }
          return;
        }
        try { localStorage.removeItem(LIB_CACHE_KEY); } catch {}
        window.siteToast(`"${name}" deleted`, { kind: 'success', duration: 2400 });
        loadDocs();
      });
    });
  }

  function updateMetaStrip() {
    const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
    const total = allDocs.length;
    set('ms-doc-count', total);
    set('ms-doc-recent', total === 1 ? '1 indexed' : total + ' indexed');
    const processing = allDocs.filter((d) => {
      const s = d.current_version?.extraction_status;
      return s === 'pending' || s === 'running';
    }).length;
    const verified = allDocs.filter((d) => d.current_version?.extraction_status === 'done').length;
    set('ms-processing', processing || '0');
    set('ms-processing-d', processing ? 'extracting…' : 'queue empty');
    set('ms-verified', verified || '0');
    const pdfs = allDocs.filter((d) => fileTypeBadge(d.file_type, d.original_filename) === 'PDF').length;
    const docs = allDocs.filter((d) => {
      const b = fileTypeBadge(d.file_type, d.original_filename);
      return b === 'DOCX' || b === 'DOC';
    }).length;
    set('ms-formats', pdfs + ' / ' + docs);
    const totalBytes = allDocs.reduce((s, d) => s + (d.size_bytes || 0), 0);
    set('ms-storage', formatBytes(totalBytes));
    const coord = document.getElementById('lib-coord');
    if (coord) coord.textContent = '/WS.01 · WORKING SET · ' + total + ' ITEM' + (total === 1 ? '' : 'S');
  }
  function updateFilterCounts() {
    const set = (id, n) => { const el = document.getElementById(id); if (el) el.textContent = '[' + n + ']'; };
    set('fl-cnt-all', allDocs.length);
    set('fl-cnt-pdf', allDocs.filter((d) => fileTypeBadge(d.file_type, d.original_filename) === 'PDF').length);
    set('fl-cnt-doc', allDocs.filter((d) => {
      const b = fileTypeBadge(d.file_type, d.original_filename);
      return b === 'DOCX' || b === 'DOC';
    }).length);
    set('fl-cnt-txt', allDocs.filter((d) => {
      const b = fileTypeBadge(d.file_type, d.original_filename);
      return b === 'TXT' || b === 'MD';
    }).length);
    set('fl-cnt-processing', allDocs.filter((d) => {
      const s = d.current_version?.extraction_status;
      return s === 'pending' || s === 'running';
    }).length);
  }

  // Cache-first library load
  const LIB_CACHE_KEY = 'workspace.library.' + (userId || 'anon');
  async function loadDocs() {
    const q = els.search.value.trim();
    let renderedSomething = false;
    if (!q) {
      try {
        const cached = JSON.parse(localStorage.getItem(LIB_CACHE_KEY) || 'null');
        if (cached?.documents) {
          allDocs = cached.documents || [];
          renderGrid();
          renderedSomething = true;
        }
      } catch {}
    }
    try {
      const r = await fetch('/.netlify/functions/workspace-library-list' + (q ? `?q=${encodeURIComponent(q)}` : ''), {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'unknown');
      allDocs = j.documents || [];
      renderGrid();
      if (!q) {
        try { localStorage.setItem(LIB_CACHE_KEY, JSON.stringify(j)); } catch {}
      }
    } catch (e) {
      if (!renderedSomething) {
        els.grid.innerHTML = `<div class="ws-empty">Failed to load: ${escapeHtml(e.message || 'unknown')}</div>`;
      }
    }
  }

  // ---- Upload flow: direct-to-Storage then register ----
  async function uploadOne(file) {
    const docId = crypto.randomUUID();
    const versionId = crypto.randomUUID();
    const ext = file.name.split('.').pop().toLowerCase().replace(/[^a-z0-9]/g, '') || 'bin';
    const storagePath = `${userId}/${docId}/${versionId}.${ext}`;

    const tempId = 'up-' + Date.now() + '-' + Math.random().toString(36).slice(2, 6);
    els.uploadProgress.insertAdjacentHTML('beforeend', `
      <div class="lib-upload" data-temp="${tempId}">
        <span class="lib-upload-name">${escapeHtml(file.name)}</span>
        <span class="lib-upload-status">Uploading…</span>
      </div>`);
    const row = els.uploadProgress.querySelector(`[data-temp="${tempId}"]`);

    try {
      const { error: upErr } = await supabase.storage
        .from('library')
        .upload(storagePath, file, { contentType: file.type, upsert: false });
      if (upErr) throw new Error(`Storage upload: ${upErr.message}`);

      row.querySelector('.lib-upload-status').textContent = 'Extracting text…';

      const r = await fetch('/.netlify/functions/workspace-library-register', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          filename: file.name,
          original_filename: file.name,
          file_type: file.type || 'application/octet-stream',
          size_bytes: file.size,
          storage_path: storagePath,
        }),
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || `HTTP ${r.status}`);

      row.classList.add('is-done');
      row.querySelector('.lib-upload-status').textContent =
        j.extraction.status === 'done' ? `Ready · ${(j.extraction.chars || 0).toLocaleString()} chars` :
        j.extraction.status === 'skipped' ? 'Ready · no text preview' :
        j.extraction.status === 'pending_ocr' ? 'OCR queued — running in background…' :
        'Ready · text extraction failed';
      setTimeout(() => row.remove(), 4000);
      try { localStorage.removeItem(LIB_CACHE_KEY); } catch {}
      loadDocs();
    } catch (err) {
      row.classList.add('is-error');
      row.querySelector('.lib-upload-status').textContent = `Failed: ${err.message}`;
    }
  }

  // ---- Wire UI ----
  // Filter row
  document.querySelectorAll('.fl-toggle').forEach((b) => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.fl-toggle').forEach((x) => x.classList.remove('is-on'));
      b.classList.add('is-on');
      activeFilter = b.dataset.filter || 'all';
      renderGrid();
    });
  });
  // Sort cycle
  document.getElementById('lib-sort').addEventListener('click', () => {
    sortIdx = (sortIdx + 1) % SORT_VALUES.length;
    document.getElementById('sort-v').textContent = SORT_VALUES[sortIdx];
    renderGrid();
  });
  // Layout segments
  document.querySelectorAll('.layout-seg-btn').forEach((b) => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.layout-seg-btn').forEach((x) => x.classList.remove('is-active'));
      b.classList.add('is-active');
      activeLayout = b.dataset.layout || 'grid';
      els.grid.classList.toggle('is-list', activeLayout === 'list');
    });
  });

  // Upload buttons
  els.uploadBtn.addEventListener('click', () => els.uploadInput.click());
  els.dzPick.addEventListener('click', () => els.uploadInput.click());
  document.getElementById('bulk-btn')?.addEventListener('click', () => els.uploadInput.click());
  els.uploadInput.addEventListener('change', async (e) => {
    const files = Array.from(e.target.files || []);
    e.target.value = '';
    for (const f of files) await uploadOne(f);
  });

  // Drag-and-drop on the dropzone
  ['dragenter', 'dragover'].forEach((evt) => {
    els.dropzone.addEventListener(evt, (e) => { e.preventDefault(); els.dropzone.classList.add('is-drag'); });
  });
  ['dragleave', 'drop'].forEach((evt) => {
    els.dropzone.addEventListener(evt, (e) => { e.preventDefault(); els.dropzone.classList.remove('is-drag'); });
  });
  els.dropzone.addEventListener('drop', async (e) => {
    e.preventDefault();
    const files = Array.from(e.dataTransfer?.files || []);
    if (!files.length) return;
    for (const f of files) await uploadOne(f);
  });

  // Page-level drag-and-drop (so user can drop anywhere) — also adds is-drag to the zone
  ['dragenter', 'dragover'].forEach((evt) => {
    document.addEventListener(evt, (e) => {
      if (e.dataTransfer?.types?.includes?.('Files')) {
        e.preventDefault();
        els.dropzone.classList.add('is-drag');
      }
    });
  });
  document.addEventListener('dragleave', (e) => {
    if (!e.relatedTarget) els.dropzone.classList.remove('is-drag');
  });

  // Search
  let searchTimer = null;
  els.search.addEventListener('input', () => {
    if (searchTimer) clearTimeout(searchTimer);
    searchTimer = setTimeout(loadDocs, 200);
  });

  // ⌘K focuses search
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      els.search.focus(); els.search.select();
    }
  });

  loadDocs();
</script>
</body>
</html>
