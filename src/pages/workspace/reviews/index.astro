---
// Tabular reviews. List view at /workspace/reviews/, grid view at
// /workspace/reviews/?id=<uuid>. Same page, the JS branches on the
// query param.
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Reviews — Legal Overflow</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<link rel="stylesheet" href="/site-anim.css" />
<script src="/nav-autohide.js" defer></script>
<script src="/site-dialog.js" defer></script>
<script src="/site-notify.js" defer></script>
<script src="/site-anim.js" defer></script>
<link rel="stylesheet" href="/workspace.css" />
<link rel="stylesheet" href="/futuristic.css" />
<!-- mammoth.js for in-doc redline preview (renders .docx → HTML
     client-side so we can highlight where each edit lands) -->
<script src="https://cdn.jsdelivr.net/npm/mammoth@1.9.0/mammoth.browser.min.js"></script>
</head>
<body class="review-page">
<div id="grain"></div>

<header class="nav">
  <a href="/" class="brand">
    <svg class="brand-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="1"/><path d="M20 6 L20 34 M8 14 L32 14 M8 26 L32 26" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="20" cy="14" r="2.5" fill="currentColor"/><circle cx="20" cy="26" r="2.5" fill="var(--accent)"/></svg>
    <span class="brand-text"><span>Legal</span><span class="brand-over">Overflow</span></span>
  </a>
  <nav class="nav-links">
    <a href="/#skills">Skills</a>
    <a href="/#articles">Resources</a>
    <a href="/agents/">Agents</a>
    <a href="/workspace/" class="is-active">Workspace</a>
    <a href="/tracker/">Tracker</a>
    <a href="/#services">Services</a>
    <a href="/about/">About</a>
  </nav>
  <div class="nav-right">
    <a href="/account/" class="nav-sub">Account</a>
  </div>
</header>

<main id="page-main"></main>

<!-- Modal templates rendered into the page via JS so we don't carry
     non-React conditional Astro logic. -->

<footer class="foot">
  <p class="foot-bar-disclosure">
    <strong>Blake Beyel, Esq.</strong> · Florida Bar No. 1065044 · Cocoa, Florida ·
    The hiring of a lawyer is an important decision that should not be based solely on advertisements.
    Before you decide, ask for written information about the lawyer's qualifications and experience.
    No representation is made that the quality of the legal services to be performed is greater than
    the quality of legal services performed by other lawyers.
  </p>
  <div class="foot-bot"><span>© 2026 Legal Overflow</span><span class="foot-version">v2026.04<a href="/admin/users/" class="foot-admin-link" aria-label="Admin"></a></span></div>
</footer>

<script>
  import { getSupabase } from '../../../lib/supabase';
  const supabase = getSupabase();

  document.body.style.visibility = 'hidden';
  let session;
  try {
    const { data, error } = await supabase.auth.getSession();
    if (error) throw error;
    session = data?.session;
    if (!session) {
      const here = location.pathname + location.search;
      location.href = '/login/?redirect=' + encodeURIComponent(here);
      throw new Error('not signed in');
    }
    const { data: profile } = await supabase
      .from('profiles').select('approved_at').eq('id', session.user.id).maybeSingle();
    if (!profile?.approved_at) {
      document.body.style.visibility = '';
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Pending approval</h1><p>Your account is pending operator approval.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('pending approval');
    }
    document.body.style.visibility = '';
  } catch (err) {
    if (err && !['not signed in','pending approval'].includes(err.message)) {
      document.body.style.visibility = '';
      document.body.innerHTML = `<main style="max-width:680px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Reviews error</h1><pre style="background:#f5f5f5;padding:14px;border-radius:6px;font-size:12px;white-space:pre-wrap">${(err.message || String(err)).replace(/[<>&]/g,(c)=>({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]))}</pre><p><a href="/workspace/">← Back to workspace</a></p></main>`;
    }
    throw err;
  }

  let accessToken = session.access_token;
  try { supabase.auth.onAuthStateChange((_e, s) => { if (s?.access_token) accessToken = s.access_token; }); } catch {}
  const main = document.getElementById('page-main');
  const url = new URL(location.href);
  const reviewId = url.searchParams.get('id');
  const initialView = url.searchParams.get('view');     // 'doc' | 'grid' | null
  const initialDocId = url.searchParams.get('doc');     // selected doc in doc view

  function escapeHtml(s) {
    return String(s ?? '').replace(/[<>&"]/g, (c) => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
  }

  // ---- Resizable docview sidebar ----
  // Same UX pattern as the chat page: drag the slim handle between
  // the findings/analysis sidebar and the document preview to widen
  // or shrink the sidebar. Persisted across reloads via localStorage.
  // The width is applied as a CSS variable on .rv-docview each time
  // it renders, so it survives doc-tab switches.
  const RV_RAIL_KEY = 'workspace.rv-rail.width';
  const RV_RAIL_MIN = 220;
  const RV_RAIL_MAX = 640;
  const RV_RAIL_DEFAULT = 360;
  let rvRailWidth = (() => {
    try {
      const stored = parseInt(localStorage.getItem(RV_RAIL_KEY) || '', 10);
      if (Number.isFinite(stored) && stored >= RV_RAIL_MIN && stored <= RV_RAIL_MAX) return stored;
    } catch {}
    return RV_RAIL_DEFAULT;
  })();
  function clampRvRail(px) {
    return Math.min(RV_RAIL_MAX, Math.max(RV_RAIL_MIN, Math.round(px)));
  }
  // Delegated drag handler — works across re-renders because the
  // .rv-docview element is rebuilt every time the user switches doc
  // tabs. Hooks onto document-level mousedown/move/up.
  let rvDragging = false;
  let rvDragShell = null;
  document.addEventListener('mousedown', (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    if (!t.classList.contains('rv-rail-resize')) return;
    e.preventDefault();
    rvDragging = true;
    rvDragShell = t.closest('.rv-docview');
    document.body.style.cursor = 'col-resize';
    document.body.style.userSelect = 'none';
  });
  window.addEventListener('mousemove', (e) => {
    if (!rvDragging || !rvDragShell) return;
    const rect = rvDragShell.getBoundingClientRect();
    const desired = e.clientX - rect.left;
    rvRailWidth = clampRvRail(desired);
    rvDragShell.style.setProperty('--rv-rail-width', rvRailWidth + 'px');
  });
  window.addEventListener('mouseup', () => {
    if (!rvDragging) return;
    rvDragging = false;
    rvDragShell = null;
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
    try { localStorage.setItem(RV_RAIL_KEY, String(rvRailWidth)); } catch {}
  });
  // Keyboard nudge when the handle is focused.
  document.addEventListener('keydown', (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    if (!t.classList.contains('rv-rail-resize')) return;
    if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
    e.preventDefault();
    const delta = e.key === 'ArrowRight' ? 16 : -16;
    rvRailWidth = clampRvRail(rvRailWidth + delta);
    const shell = t.closest('.rv-docview');
    if (shell) shell.style.setProperty('--rv-rail-width', rvRailWidth + 'px');
    try { localStorage.setItem(RV_RAIL_KEY, String(rvRailWidth)); } catch {}
  });

  // ---- Document zoom (doc-view main pane) ----
  // Three-button toolbar (− % +) floats top-right inside the doc
  // pane. Adjusts the font-size of .rv-live-doc-body so text reflows
  // naturally and stays sharp at any zoom level. Persists in
  // localStorage as a percentage (default 100, range 60-220).
  const RV_ZOOM_KEY = 'workspace.rv-doc-zoom';
  const RV_ZOOM_MIN = 60;
  const RV_ZOOM_MAX = 220;
  const RV_ZOOM_STEP = 10;
  const RV_ZOOM_DEFAULT = 100;
  let rvDocZoom = (() => {
    try {
      const stored = parseInt(localStorage.getItem(RV_ZOOM_KEY) || '', 10);
      if (Number.isFinite(stored) && stored >= RV_ZOOM_MIN && stored <= RV_ZOOM_MAX) return stored;
    } catch {}
    return RV_ZOOM_DEFAULT;
  })();
  function clampZoom(p) {
    return Math.min(RV_ZOOM_MAX, Math.max(RV_ZOOM_MIN, Math.round(p / RV_ZOOM_STEP) * RV_ZOOM_STEP));
  }
  function applyDocZoom() {
    // Base font-size is 14px (matches .rv-live-doc-body default).
    // Multiply by zoom percentage / 100 to scale.
    const docBody = document.getElementById('rv-live-doc-body');
    if (docBody) docBody.style.fontSize = (rvDocZoom * 0.14).toFixed(2) + 'px';
    const levelEl = document.querySelector('.rv-doc-zoom-level');
    if (levelEl) levelEl.textContent = rvDocZoom + '%';
    try { localStorage.setItem(RV_ZOOM_KEY, String(rvDocZoom)); } catch {}
  }
  function setZoom(next) {
    rvDocZoom = clampZoom(next);
    applyDocZoom();
  }
  // Click handlers (delegated — toolbar is rebuilt every doc-tab switch)
  document.addEventListener('click', (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    const btn = t.closest('[data-zoom]');
    if (!btn) return;
    e.preventDefault();
    const action = btn.getAttribute('data-zoom');
    if (action === 'in')        setZoom(rvDocZoom + RV_ZOOM_STEP);
    else if (action === 'out')  setZoom(rvDocZoom - RV_ZOOM_STEP);
    else if (action === 'reset') setZoom(RV_ZOOM_DEFAULT);
  });
  // Keyboard shortcuts when focus is inside the doc-view (Ctrl/Cmd
  // +/-/0). Don't hijack global browser zoom — only fire when the
  // user is interacting with the review's doc pane.
  document.addEventListener('keydown', (e) => {
    if (!(e.ctrlKey || e.metaKey)) return;
    // Only act when the doc pane is in the page — otherwise let
    // the browser handle Cmd+/Cmd-/Cmd0 normally.
    if (!document.querySelector('.rv-doc-zoom-bar')) return;
    if (e.key === '=' || e.key === '+') {
      e.preventDefault();
      setZoom(rvDocZoom + RV_ZOOM_STEP);
    } else if (e.key === '-') {
      e.preventDefault();
      setZoom(rvDocZoom - RV_ZOOM_STEP);
    } else if (e.key === '0') {
      e.preventDefault();
      setZoom(RV_ZOOM_DEFAULT);
    }
  });
  // Mouse-wheel zoom while holding Ctrl/Cmd over the doc pane.
  // (Browsers natively do this for page zoom; we capture inside the
  // doc area to scope it to the document only.)
  document.addEventListener('wheel', (e) => {
    if (!(e.ctrlKey || e.metaKey)) return;
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;
    if (!target.closest('.rv-docview-main')) return;
    e.preventDefault();
    const dir = e.deltaY > 0 ? -1 : 1;
    setZoom(rvDocZoom + dir * RV_ZOOM_STEP);
  }, { passive: false });

  // ============================================================
  // LIST VIEW
  // ============================================================
  async function renderListView() {
    main.innerHTML = `
      <div class="ws-wrap">
        <a href="/workspace/" class="ws-back-pill" title="Back to workspace home"><span class="ws-back-arrow">←</span> Workspace home</a>
        <header class="ws-head fm-frame">
          <span class="br-tr"></span><span class="br-br"></span>
          <div>
            <div class="ws-kicker">
              <span class="k-tag">Reviews</span>
              <span class="k-coord">PG / 04 · TABULAR-REVIEWS</span>
            </div>
            <h1 class="ws-title">Document <em>review</em> grids.</h1>
            <p class="ws-sub">Pick documents, define columns, get a grid of LLM-extracted answers with verbatim citations.</p>
          </div>
          <div class="ws-head-actions">
            <button id="new-review-btn" class="ws-btn">New review</button>
          </div>
        </header>
        <div class="sec-div">
          <span><span class="sec-num">§ 01</span> &nbsp;Reviews</span>
          <span class="sec-rule"></span>
          <span class="sec-meta">EXTRACT &nbsp;·&nbsp; SUMMARIZE &nbsp;·&nbsp; REDLINE</span>
        </div>
        <section class="ws-card fm-card">
          <header class="ws-card-head">
            <span class="ws-card-num">01·1</span>
            <h2 class="ws-card-title">Recent reviews <span class="ws-card-count" id="rv-count-pill"></span></h2>
            <div class="ws-card-tabs" id="rv-tabs">
              <button type="button" class="ws-card-tab is-active" data-rvtab="all">All</button>
              <button type="button" class="ws-card-tab" data-rvtab="extraction">Extraction</button>
              <button type="button" class="ws-card-tab" data-rvtab="redline">Redline</button>
              <button type="button" class="ws-card-tab" data-rvtab="summary">Summary</button>
            </div>
            <span class="ws-card-count" id="rv-updated-stamp"></span>
          </header>
          <div id="reviews-list" class="ws-list ws-list-tabular ws-list-rv">
            <div class="ws-list-head">
              <span></span>
              <span class="h-title">Title</span>
              <span class="h-model">Status</span>
              <span class="h-time" style="text-align:right; padding-right:14px;">Updated</span>
              <span></span>
            </div>
            <div class="ws-row-wrap"><div class="ws-rc ws-rc-handle"></div><div class="ws-rc ws-rc-title"><span class="sk-block sk-block-title" style="width:60%"></span></div><div class="ws-rc ws-rc-model"><span class="sk-block sk-block-meta" style="width:60%"></span></div><div class="ws-rc ws-rc-time"><span class="sk-block sk-block-meta" style="width:60%"></span></div><div class="ws-rc ws-rc-action"></div></div>
            <div class="ws-row-wrap"><div class="ws-rc ws-rc-handle"></div><div class="ws-rc ws-rc-title"><span class="sk-block sk-block-title" style="width:72%"></span></div><div class="ws-rc ws-rc-model"><span class="sk-block sk-block-meta" style="width:60%"></span></div><div class="ws-rc ws-rc-time"><span class="sk-block sk-block-meta" style="width:60%"></span></div><div class="ws-rc ws-rc-action"></div></div>
            <div class="ws-row-wrap"><div class="ws-rc ws-rc-handle"></div><div class="ws-rc ws-rc-title"><span class="sk-block sk-block-title" style="width:50%"></span></div><div class="ws-rc ws-rc-model"><span class="sk-block sk-block-meta" style="width:60%"></span></div><div class="ws-rc ws-rc-time"><span class="sk-block sk-block-meta" style="width:60%"></span></div><div class="ws-rc ws-rc-action"></div></div>
          </div>
        </section>
        <p class="ws-foot">
          <span><span style="color:var(--ink-4)">EOF</span> &nbsp; · &nbsp; END OF REVIEWS</span>
          <a href="/workspace/">← Workspace home</a>
        </p>
      </div>
    `;
    document.getElementById('new-review-btn').addEventListener('click', openNewReviewModal);
    await loadReviewsList();
  }

  // Cache-first: render previously-seen reviews from localStorage
  // instantly so the user never sees a "Loading…" flash. Then refresh
  // from the server in the background and re-render.
  const REVIEWS_LIST_CACHE = 'workspace.reviews-list.' + (session.user?.id || 'anon');
  let rvAllReviews = [];
  let rvActiveTab = 'all';

  function rvHeadHtml() {
    return `<div class="ws-list-head">
      <span></span>
      <span class="h-title">Title</span>
      <span class="h-model">Status</span>
      <span class="h-time" style="text-align:right; padding-right:14px;">Updated</span>
      <span></span>
    </div>`;
  }

  function paintReviewsList() {
    const listEl = document.getElementById('reviews-list');
    if (!listEl) return;
    const filtered = rvAllReviews.filter((rv) => {
      if (rvActiveTab === 'all') return true;
      // Reviews carry a `kind` field — extraction | summary | redline
      return (rv.kind || 'extraction') === rvActiveTab;
    });
    const countEl = document.getElementById('rv-count-pill');
    const stamp = document.getElementById('rv-updated-stamp');
    if (countEl) countEl.textContent = `${filtered.length}/${rvAllReviews.length}`;
    if (stamp) {
      const newest = rvAllReviews[0]?.updated_at;
      stamp.textContent = newest ? `Latest · ${rvRelTime(newest)}` : '';
    }
    if (!filtered.length) {
      const empty = !rvAllReviews.length
        ? 'No reviews yet. Click "New review" to start one.'
        : `No ${rvActiveTab} reviews. Switch tabs or start a new one.`;
      listEl.innerHTML = rvHeadHtml() +
        `<div class="ws-empty" style="grid-column:1/-1;padding:28px 14px;color:var(--ink-3);font-size:13px;">${empty}</div>`;
      return;
    }
    listEl.innerHTML = rvHeadHtml() + filtered.map((rv) => {
      const colCount = (rv.columns_config || []).length;
      const date = new Date(rv.updated_at).toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' });
      const statusClass = rv.status === 'complete' ? 'rv-status-done' :
                         rv.status === 'running' ? 'rv-status-run' :
                         rv.status === 'error' ? 'rv-status-err' :
                         rv.status === 'partial' ? 'rv-status-part' : 'rv-status-pen';
      const kindLabel = (rv.kind || 'extraction').toString().toUpperCase();
      return `<div class="ws-row-wrap">
        <div class="ws-rc ws-rc-handle"><span class="rv-kind-tag" data-kind="${escapeHtml(rv.kind || 'extraction')}">${escapeHtml(kindLabel.slice(0,1))}</span></div>
        <div class="ws-rc ws-rc-title"><a href="/workspace/reviews/?id=${rv.id}">${escapeHtml(rv.title)}<span class="ws-rc-sub">${colCount} ${colCount === 1 ? 'col' : 'cols'} · ${escapeHtml(kindLabel.toLowerCase())}</span></a></div>
        <div class="ws-rc ws-rc-model"><span class="rv-status-pill ${statusClass}">${escapeHtml(rv.status)}</span></div>
        <div class="ws-rc ws-rc-time">${date}</div>
        <div class="ws-rc ws-rc-action"><button type="button" data-del="${rv.id}" data-title="${escapeHtml(rv.title)}" aria-label="Delete">×</button></div>
      </div>`;
    }).join('');
    listEl.querySelectorAll('[data-del]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault(); e.stopPropagation();
        const id = btn.dataset.del; const title = btn.dataset.title;
        if (!(await window.siteConfirm(`Delete review "${title}"? This cannot be undone.`, { okLabel: 'Delete', danger: true }))) return;
        btn.disabled = true;
        await fetch('/.netlify/functions/workspace-tr-delete', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        try { localStorage.removeItem(REVIEWS_LIST_CACHE); } catch {}
        loadReviewsList();
      });
    });
  }
  function rvRelTime(iso) {
    if (!iso) return '';
    const ms = Date.now() - new Date(iso).getTime();
    if (ms < 60_000) return 'just now';
    if (ms < 3_600_000) return `${Math.floor(ms / 60_000)}m ago`;
    if (ms < 86_400_000) return `${Math.floor(ms / 3_600_000)}h ago`;
    if (ms < 7 * 86_400_000) return `${Math.floor(ms / 86_400_000)}d ago`;
    return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  }
  function renderReviewsListFromData(j) {
    rvAllReviews = j.reviews || [];
    paintReviewsList();
    // Wire tab filter once after first paint.
    const tabsEl = document.getElementById('rv-tabs');
    if (tabsEl && !tabsEl.dataset.wired) {
      tabsEl.dataset.wired = '1';
      tabsEl.addEventListener('click', (e) => {
        const btn = e.target.closest('.ws-card-tab');
        if (!btn) return;
        rvActiveTab = btn.dataset.rvtab || 'all';
        tabsEl.querySelectorAll('.ws-card-tab').forEach((b) => b.classList.toggle('is-active', b === btn));
        paintReviewsList();
      });
    }
  }
  async function loadReviewsList() {
    const listEl = document.getElementById('reviews-list');
    let renderedSomething = false;
    // 1. Render from cache instantly if present
    try {
      const cached = JSON.parse(localStorage.getItem(REVIEWS_LIST_CACHE) || 'null');
      if (cached) { renderReviewsListFromData(cached); renderedSomething = true; }
    } catch {}
    // 2. Fetch fresh in background
    try {
      const r = await fetch('/.netlify/functions/workspace-tr-list', {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Failed to load');
      renderReviewsListFromData(j);
      try { localStorage.setItem(REVIEWS_LIST_CACHE, JSON.stringify(j)); } catch {}
    } catch (e) {
      // If we already painted from cache, leave that visible. Otherwise show the error.
      if (!renderedSomething && listEl) {
        listEl.innerHTML = `<div class="ws-empty">${escapeHtml(e.message || 'Failed to load')}</div>`;
      }
    }
  }

  // ============================================================
  // NEW REVIEW MODAL
  // ============================================================
  async function openNewReviewModal(opts = {}) {
    const overlay = document.createElement('div');
    overlay.className = 'attach-modal';
    const initialKind = opts.prefillKind || 'extraction';
    overlay.innerHTML = `
      <div class="attach-modal-inner rv-modal">
        <header class="attach-modal-head">
          <h2 class="attach-modal-title">New tabular review</h2>
          <button type="button" class="attach-modal-close" data-close>×</button>
        </header>
        <div class="attach-modal-body">
          <div class="rv-field">
            <span class="rv-field-label">Kind</span>
            <div class="rv-kind-picker">
              <label class="rv-kind-opt"><input type="radio" name="rv-kind" value="extraction" ${initialKind === 'extraction' ? 'checked' : ''} />
                <div class="rv-kind-title">Extraction</div>
                <div class="rv-kind-desc">Each cell answers "what does this say?" with a verbatim quote. Good for due diligence summaries.</div>
              </label>
              <label class="rv-kind-opt"><input type="radio" name="rv-kind" value="redline" ${initialKind === 'redline' ? 'checked' : ''} />
                <div class="rv-kind-title">Redline</div>
                <div class="rv-kind-desc">Each cell proposes a tracked-changes edit. Accept/reject per cell, finalize per doc as a clean .docx. <strong>Requires .docx files.</strong></div>
              </label>
            </div>
          </div>

          <label class="rv-field">
            <span class="rv-field-label">Title</span>
            <input type="text" id="rv-title" maxlength="200" placeholder="e.g. NDA portfolio scan — 2026 Q1" />
          </label>

          <div class="rv-field">
            <span class="rv-field-label">Whose side are you on?</span>
            <input type="text" id="rv-client-role" maxlength="200" placeholder="e.g. Buyer, Tenant, Licensee, Employee, Disclosing Party" />
            <div id="rv-detect-banner" class="rv-detect-banner" hidden></div>
            <div class="rv-role-chips" id="rv-role-chips">
              <button type="button" class="rv-role-chip" data-role="Buyer">Buyer</button>
              <button type="button" class="rv-role-chip" data-role="Seller">Seller</button>
              <button type="button" class="rv-role-chip" data-role="Tenant">Tenant</button>
              <button type="button" class="rv-role-chip" data-role="Landlord">Landlord</button>
              <button type="button" class="rv-role-chip" data-role="Vendor">Vendor</button>
              <button type="button" class="rv-role-chip" data-role="Customer">Customer</button>
              <button type="button" class="rv-role-chip" data-role="Employer">Employer</button>
              <button type="button" class="rv-role-chip" data-role="Employee">Employee</button>
              <button type="button" class="rv-role-chip" data-role="Licensor">Licensor</button>
              <button type="button" class="rv-role-chip" data-role="Licensee">Licensee</button>
              <button type="button" class="rv-role-chip" data-role="Disclosing Party">Disclosing Party</button>
              <button type="button" class="rv-role-chip" data-role="Receiving Party">Receiving Party</button>
            </div>
          </div>

          <label class="rv-field">
            <span class="rv-field-label">Additional context for the AI <span class="rv-field-hint">(optional)</span></span>
            <textarea id="rv-additional-context" rows="3" maxlength="4000" placeholder="Anything else the AI should keep in mind. e.g. 'we've already signed an LOI at $1.2M', 'this is a renewal — counterparty wants new terms', 'we're racing a closing on Friday'."></textarea>
          </label>

          <div class="rv-field">
            <span class="rv-field-label" id="rv-docs-label">Documents</span>
            <div id="rv-doc-list" class="rv-doc-list"><div class="ws-empty">Loading library…</div></div>
          </div>

          <div class="rv-field">
            <span class="rv-field-label" id="rv-cols-label">Columns</span>
            <div id="rv-cols" class="rv-cols"></div>
            <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin-top:6px;">
              <button type="button" id="rv-add-col" class="rv-add-col">+ Add column</button>
              <button type="button" id="rv-load-presets" class="rv-add-col" style="border-style:dashed;" title="Replace your columns with the suggested defaults for the selected kind">Use suggested presets</button>
            </div>
          </div>

          <label class="rv-field">
            <span class="rv-field-label">Model</span>
            <select id="rv-model"></select>
          </label>
        </div>
        <footer class="attach-modal-foot">
          <span class="rv-foot-hint" id="rv-cost-hint"></span>
          <button type="button" class="ws-btn" id="rv-run">Run review</button>
        </footer>
      </div>`;
    document.body.appendChild(overlay);

    const close = () => overlay.remove();
    overlay.querySelector('[data-close]').addEventListener('click', close);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

    // Load library + models in parallel
    const [libRes, mdlRes] = await Promise.all([
      fetch('/.netlify/functions/workspace-library-list', { headers: { Authorization: `Bearer ${accessToken}` } }),
      fetch('/.netlify/functions/workspace-models-list', { headers: { Authorization: `Bearer ${accessToken}` } }),
    ]);
    const libJson = await libRes.json();
    const mdlJson = await mdlRes.json();

    const allDocs = libJson.documents || [];
    function getCurrentKind() {
      return overlay.querySelector('input[name="rv-kind"]:checked')?.value || 'extraction';
    }
    function visibleDocs() {
      const kind = getCurrentKind();
      if (kind !== 'redline') return allDocs;
      return allDocs.filter((d) => (d.original_filename || '').toLowerCase().endsWith('.docx'));
    }
    function renderDocList() {
      const docList = overlay.querySelector('#rv-doc-list');
      const docs = visibleDocs();
      const kind = getCurrentKind();
      if (!docs.length) {
        docList.innerHTML = kind === 'redline'
          ? '<div class="ws-empty">No .docx files in your library. Redlining requires Word documents — <a href="/workspace/library/">upload one →</a></div>'
          : '<div class="ws-empty">No documents in your library. <a href="/workspace/library/">Upload some →</a></div>';
        return;
      }
      docList.innerHTML = docs.map((d) => `
        <label class="rv-doc-item">
          <input type="checkbox" data-doc="${d.id}" />
          <span class="rv-doc-name">${escapeHtml(d.filename)}</span>
          <span class="rv-doc-meta">${(d.current_version?.extracted_chars || 0).toLocaleString()} chars</span>
        </label>`).join('');
    }
    renderDocList();

    const models = mdlJson.models || [];
    const sel = overlay.querySelector('#rv-model');
    // Pick the default model with a 3-step fallback so BYOK users
    // who don't have an Anthropic key still get a working default:
    //   1. The user's universal model preference (set on the dashboard
    //      / chat header model picker, mirrored to localStorage)
    //   2. claude-sonnet-4-5 if it's still in the available list
    //   3. The first available model
    // workspace-models-list only returns models the user has a key
    // for (BYOK or server fallback), so step 1 + 2 are guaranteed
    // viable; step 3 is a safety net.
    let preferredModel = '';
    try { preferredModel = localStorage.getItem('workspace.dash.model') || ''; } catch {}
    const ids = models.map((m) => m.id);
    const defaultId =
      (preferredModel && ids.includes(preferredModel)) ? preferredModel
      : ids.includes('claude-sonnet-4-5') ? 'claude-sonnet-4-5'
      : ids[0] || '';
    sel.innerHTML = models.map((m) => `<option value="${escapeHtml(m.id)}"${m.id === defaultId ? ' selected' : ''}>${escapeHtml(m.label)}</option>`).join('');

    // Initial column row. Presets vary by kind. For extraction we
    // pre-fill with NDA-review-style questions; for redline we
    // pre-fill with concern descriptions that produce edits.
    const colsEl = overlay.querySelector('#rv-cols');
    const extractionPresets = [
      { name: 'Term length', prompt: 'What is the term length of this agreement? Quote the relevant clause.' },
      { name: 'Governing law', prompt: 'What is the governing law / choice of law clause? State the jurisdiction.' },
      { name: 'Liability cap', prompt: 'Is there a cap on liability? If so, state the cap (amount or formula). Quote the clause.' },
    ];
    // Redline presets are "what the user wants changed in the
    // contract" — phrased as concrete drafting goals, not extraction
    // questions. The user can edit values in-place (cap amount, cure
    // length, etc.). Broad coverage of the most common asks; user can
    // add more or delete what they don't need.
    const redlinePresets = [
      { name: 'Cap aggregate liability', prompt: 'Cap aggregate liability at the greater of 12 months of fees paid or $1,000,000. If the contract has no cap, add one. If a cap exists but is unlimited, mutual-uncapped, or disproportionately high, tighten it. Carve out the usual exceptions (gross negligence, willful misconduct, breach of confidentiality, IP infringement) only if they appear in the original.' },
      { name: 'Mutual indemnification', prompt: 'Make any one-sided indemnification mutual. If only one party indemnifies the other, mirror the obligation so both parties owe equivalent indemnity for their own breaches/negligence. Cap any unlimited indemnity at the same amount as the liability cap.' },
      { name: 'Termination cure period', prompt: 'Require at least 30 days written notice and a 30-day right to cure before termination for cause is permitted. If the existing notice or cure period is shorter, lengthen it. Do not weaken any termination-for-convenience right the user already has.' },
      { name: 'Limit auto-renewal', prompt: 'Ensure either party can opt out of any auto-renewal with at least 30 days written notice before the renewal date. Reject silent renewal or any one-sided opt-out. If the contract has no auto-renewal, leave it alone.' },
      { name: 'IP ownership / work for hire', prompt: 'Confirm the user owns all deliverables, work product, and derivative works created under this agreement. If the contract is silent or assigns IP to the other side, add or strengthen a "work made for hire" provision with a backstop assignment of all right, title, and interest. Preserve the other side\'s pre-existing IP and any open-source they incorporate.' },
      { name: 'Confidentiality term', prompt: 'Set the confidentiality obligation to survive at least 5 years after termination (perpetual for trade secrets). If the existing term is shorter, extend it. Ensure standard carve-outs (already known, independently developed, lawfully received from a third party, required by law) are present and not over-broad.' },
      { name: 'Assignment restrictions', prompt: 'Prohibit either party from assigning the agreement without the other\'s prior written consent, with a carve-out for assignment to an affiliate or in connection with a merger, sale of substantially all assets, or change of control. Make the restriction mutual if it isn\'t already.' },
      { name: 'Governing law and venue', prompt: 'Set governing law to the state most favorable to the user (default: the user\'s home state). Set exclusive venue to the same jurisdiction\'s state and federal courts. Waive any objection to venue. Strike any one-sided forum-selection that requires the user to litigate in the counterparty\'s backyard.' },
      { name: 'Payment terms / late fees', prompt: 'Require payment within 30 days of an undisputed invoice. Permit the user to suspend services or charge a late fee of 1.5% per month (or the maximum permitted by law) on past-due amounts. Add a right to recover collection costs and reasonable attorneys\' fees on any successful collection action.' },
    ];
    const presets = (opts.prefillCols && opts.prefillCols.length) ? opts.prefillCols
      : (initialKind === 'redline' ? redlinePresets : extractionPresets);
    if (opts.prefillTitle) {
      overlay.querySelector('#rv-title').value = opts.prefillTitle + ' — ' + new Date().toLocaleDateString();
    }
    let colIdx = 0;
    function placeholderForKind() {
      // Kind-aware placeholder — the prompt the user writes here is
      // *very* different between extraction (a question to answer) and
      // redline (a drafting goal to achieve).
      return getCurrentKind() === 'redline'
        ? "Concern: what change should the AI propose? e.g. 'cap the indemnity at $1M', 'add a 30-day cure period', 'strike the auto-renewal'."
        : 'Prompt: what should the AI extract or answer for this column?';
    }
    function namePlaceholderForKind() {
      return getCurrentKind() === 'redline' ? 'Concern name (e.g. Liability cap)' : 'Column name';
    }
    function addColumn(preset) {
      const id = colIdx++;
      colsEl.insertAdjacentHTML('beforeend', `
        <div class="rv-col-row" data-col="${id}">
          <input type="text" class="rv-col-name" placeholder="${escapeHtml(namePlaceholderForKind())}" value="${escapeHtml(preset?.name || '')}" />
          <textarea class="rv-col-prompt" rows="2" placeholder="${escapeHtml(placeholderForKind())}">${escapeHtml(preset?.prompt || '')}</textarea>
          <button type="button" class="rv-col-del" data-del-col="${id}" aria-label="Remove">×</button>
        </div>`);
    }
    function refreshPlaceholders() {
      // Update ALL existing rows' placeholders when kind toggles —
      // value attribute on input + textContent on textarea are
      // preserved (only the placeholder string changes).
      const namePh = namePlaceholderForKind();
      const promptPh = placeholderForKind();
      colsEl.querySelectorAll('.rv-col-name').forEach((el) => { el.placeholder = namePh; });
      colsEl.querySelectorAll('.rv-col-prompt').forEach((el) => { el.placeholder = promptPh; });
    }
    for (const p of presets) addColumn(p);
    overlay.querySelector('#rv-add-col').addEventListener('click', () => addColumn());
    // Explicit "Use suggested presets" — replaces all rows with the
    // current-kind defaults. Confirms first if the user has any
    // non-default content so they don't accidentally lose work.
    overlay.querySelector('#rv-load-presets').addEventListener('click', async () => {
      const k = getCurrentKind();
      const targetPresets = k === 'redline' ? redlinePresets : extractionPresets;
      const knownDefaults = new Set([
        ...extractionPresets.map((p) => `${p.name}\n${p.prompt}`),
        ...redlinePresets.map((p) => `${p.name}\n${p.prompt}`),
        '\n', // empty rows count as pristine
      ]);
      const rows = Array.from(colsEl.querySelectorAll('.rv-col-row'));
      const hasCustom = rows.some((row) => {
        const n = (row.querySelector('.rv-col-name')?.value || '').trim();
        const p = (row.querySelector('.rv-col-prompt')?.value || '').trim();
        return !knownDefaults.has(`${n}\n${p}`);
      });
      if (hasCustom && !(await window.siteConfirm(`Replace your ${rows.length} column${rows.length === 1 ? '' : 's'} with the ${k} presets? Any custom edits will be lost.`, { okLabel: 'Replace' }))) return;
      colsEl.innerHTML = '';
      colIdx = 0;
      for (const p of targetPresets) addColumn(p);
      updateCost();
    });
    colsEl.addEventListener('click', (e) => {
      const t = e.target;
      if (t && t.dataset && t.dataset.delCol != null) {
        const row = t.closest('.rv-col-row');
        row?.remove();
      }
    });

    // Cost hint updates as user toggles checkboxes / adds cols.
    // Also relabels columns -> "Concerns" for redline mode and the
    // run button to "Run redline review".
    const costHint = overlay.querySelector('#rv-cost-hint');
    const colsLabel = overlay.querySelector('#rv-cols-label');
    const docsLabel = overlay.querySelector('#rv-docs-label');
    const runBtn = overlay.querySelector('#rv-run');
    function updateCost() {
      const kind = getCurrentKind();
      const docCount = overlay.querySelectorAll('input[data-doc]:checked').length;
      const colCount = overlay.querySelectorAll('.rv-col-row').length;
      const cells = docCount * colCount;
      costHint.textContent = `${docCount} docs × ${colCount} ${kind === 'redline' ? 'concerns' : 'columns'} = ${cells} cells`;
      colsLabel.textContent = kind === 'redline' ? 'Concerns (one per column)' : 'Columns';
      docsLabel.textContent = kind === 'redline' ? 'Documents (.docx only)' : 'Documents';
      runBtn.textContent = kind === 'redline' ? 'Run redline review' : 'Run review';
      const loadBtn = overlay.querySelector('#rv-load-presets');
      if (loadBtn) loadBtn.textContent = kind === 'redline' ? 'Use redline presets' : 'Use extraction presets';
    }
    // Re-render doc list and presets when kind toggles
    overlay.querySelectorAll('input[name="rv-kind"]').forEach((r) => {
      r.addEventListener('change', () => {
        renderDocList();
        // Replace presets when toggling kinds, UNLESS the user has
        // customized them. A row is "untouched" if its name+prompt
        // exactly match one of the known defaults from either preset
        // pool — those are pristine and safe to replace. Any row that
        // doesn't match a default is treated as user-edited and kept.
        const allKnownDefaults = [
          ...extractionPresets.map((p) => `${p.name}\n${p.prompt}`),
          ...redlinePresets.map((p) => `${p.name}\n${p.prompt}`),
        ];
        const rows = Array.from(colsEl.querySelectorAll('.rv-col-row'));
        const allUntouched = rows.length === 0 || rows.every((row) => {
          const n = row.querySelector('.rv-col-name')?.value || '';
          const p = row.querySelector('.rv-col-prompt')?.value || '';
          return !n.trim() && !p.trim() || allKnownDefaults.includes(`${n}\n${p}`);
        });
        if (allUntouched) {
          colsEl.innerHTML = '';
          colIdx = 0;
          const k = getCurrentKind();
          for (const p of (k === 'redline' ? redlinePresets : extractionPresets)) addColumn(p);
        } else {
          // User has customized rows — preserve their content but
          // freshen the placeholder strings so any empty fields
          // reflect the new kind's wording.
          refreshPlaceholders();
        }
        updateCost();
      });
    });
    overlay.addEventListener('input', updateCost);
    overlay.addEventListener('change', updateCost);
    updateCost();

    // Role chip → fill the input. Click again to toggle off.
    function wireRoleChips() {
      overlay.querySelectorAll('[data-role]').forEach((chip) => {
        if (chip.dataset.wired) return;
        chip.dataset.wired = '1';
        chip.addEventListener('click', () => {
          const input = overlay.querySelector('#rv-client-role');
          if (input.value === chip.dataset.role) input.value = '';
          else input.value = chip.dataset.role;
          overlay.querySelectorAll('[data-role]').forEach((c) => c.classList.toggle('is-active', c.dataset.role === input.value));
        });
      });
    }
    wireRoleChips();

    // ---- Auto-detect parties + role on single-doc selection ----
    // When the user has selected exactly ONE document, fire a quick
    // LLM call to identify the parties and suggest two likely roles.
    // Results are shown above the role chips with "Looks like a
    // [Mutual NDA] between Acme and Beyel — pick which side you're
    // on:" + the suggested roles as new accent-colored chips.
    let detectController = null;
    let lastDetectedDocId = null;
    async function maybeDetectRole() {
      const checked = overlay.querySelectorAll('input[data-doc]:checked');
      const banner = overlay.querySelector('#rv-detect-banner');
      // Cancel any in-flight detection
      if (detectController) { detectController.abort(); detectController = null; }
      if (checked.length !== 1) {
        banner.hidden = true;
        // Reset role chips back to defaults if more or fewer selected
        const chipsEl = overlay.querySelector('#rv-role-chips');
        chipsEl.querySelectorAll('.rv-role-chip-suggested').forEach((c) => c.remove());
        return;
      }
      const docId = checked[0].dataset.doc;
      if (docId === lastDetectedDocId) return;   // already detected this doc
      lastDetectedDocId = docId;

      banner.hidden = false;
      banner.className = 'rv-detect-banner is-loading';
      banner.innerHTML = '<span class="rv-spin"></span> Scanning document for parties…';

      detectController = new AbortController();
      try {
        const r = await fetch('/.netlify/functions/workspace-tr-detect-role', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ document_id: docId }),
          signal: detectController.signal,
        });
        const j = await r.json();
        if (!r.ok) {
          banner.className = 'rv-detect-banner is-error';
          banner.textContent = `Could not auto-detect: ${j.error || 'unknown'}`;
          return;
        }
        const partyNames = (j.parties || []).map((p) => p.name).filter(Boolean);
        const partyLine = partyNames.length === 2
          ? ` between <strong>${escapeHtml(partyNames[0])}</strong> and <strong>${escapeHtml(partyNames[1])}</strong>`
          : partyNames.length ? ` involving <strong>${partyNames.map(escapeHtml).join(', ')}</strong>` : '';
        banner.className = 'rv-detect-banner is-done';
        banner.innerHTML = `Looks like a <strong>${escapeHtml(j.doc_type || 'document')}</strong>${partyLine}. Which side are you on?`;
        // Inject suggested roles as priority chips at the FRONT of
        // the chip strip (mark them so the next detection can clear).
        const chipsEl = overlay.querySelector('#rv-role-chips');
        chipsEl.querySelectorAll('.rv-role-chip-suggested').forEach((c) => c.remove());
        const suggested = (j.suggested_roles || []).filter(Boolean);
        for (let i = suggested.length - 1; i >= 0; i--) {
          const chip = document.createElement('button');
          chip.type = 'button';
          chip.className = 'rv-role-chip rv-role-chip-suggested';
          chip.dataset.role = suggested[i];
          chip.textContent = '★ ' + suggested[i];
          chipsEl.insertBefore(chip, chipsEl.firstChild);
        }
        wireRoleChips();
      } catch (err) {
        if (err.name === 'AbortError') return;
        banner.className = 'rv-detect-banner is-error';
        banner.textContent = `Could not auto-detect: ${err.message}`;
      }
    }
    overlay.addEventListener('change', (e) => {
      if (e.target.matches('input[data-doc]')) maybeDetectRole();
    });

    // Run
    overlay.querySelector('#rv-run').addEventListener('click', async () => {
      const title = overlay.querySelector('#rv-title').value.trim();
      if (!title) { alert('Title required'); return; }
      const docIds = Array.from(overlay.querySelectorAll('input[data-doc]:checked')).map((i) => i.dataset.doc);
      if (!docIds.length) { alert('Pick at least one document'); return; }
      const cols = Array.from(overlay.querySelectorAll('.rv-col-row')).map((row) => ({
        name: row.querySelector('.rv-col-name').value.trim(),
        prompt: row.querySelector('.rv-col-prompt').value.trim(),
      })).filter((c) => c.prompt);
      if (!cols.length) { alert('Add at least one column with a prompt'); return; }
      const model = sel.value;

      const btn = overlay.querySelector('#rv-run');
      btn.disabled = true;
      btn.textContent = 'Creating…';

      // Walk-away mode — ask for browser-notification permission so
      // we can ping the user when the review is done. Must be
      // requested in response to a user gesture; fire-and-forget.
      if (window.siteNotify && window.siteNotify.permission() === 'default') {
        window.siteNotify.requestPermission();
      }

      const kind = getCurrentKind();
      const clientRole = overlay.querySelector('#rv-client-role').value.trim();
      const additionalContext = overlay.querySelector('#rv-additional-context').value.trim();
      const r = await fetch('/.netlify/functions/workspace-tr-create', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title, columns: cols, document_ids: docIds, model, kind,
          client_role: clientRole || null,
          additional_context: additionalContext || null,
        }),
      });
      const j = await r.json();
      if (!r.ok) {
        alert('Failed: ' + (j.error || 'unknown'));
        btn.disabled = false;
        btn.textContent = 'Run review';
        return;
      }
      // For redline reviews, drop straight into the live document view
      // (it auto-streams findings as cells complete). For extraction
      // reviews, the grid is more useful.
      const viewParam = kind === 'redline' ? `&view=doc&doc=${docIds[0]}` : '';
      location.href = `/workspace/reviews/?id=${j.review_id}${viewParam}`;
    });
  }

  // ============================================================
  // GRID VIEW (single review) — also handles the document view
  // ============================================================
  let gridState = null;   // { review, cells, documents, finalizations }
  let currentView = 'grid';      // 'grid' | 'doc'
  let currentDocId = null;       // for doc view

  async function renderGridView(id) {
    main.innerHTML = `
      <div class="rv-shell">
        <header class="rv-head">
          <a href="/workspace/reviews/" class="rv-back">← All reviews</a>
          <h1 class="rv-title" id="rv-grid-title">Loading…</h1>
          <div class="rv-head-meta">
            <span id="rv-status-pill" class="rv-status-pill rv-status-pen">…</span>
            <span id="rv-counter" class="rv-counter"></span>
            <button id="rv-export" type="button" class="ws-btn-secondary" title="Download as CSV (opens in Excel)">Export CSV</button>
          </div>
        </header>
        <div id="rv-view-tabs" class="rv-view-tabs"></div>
        <div id="rv-view-body"></div>
      </div>
      <div id="rv-cell-detail" class="attach-modal" hidden></div>
    `;
    await loadGrid(id);
    pollLoop(id);

    document.getElementById('rv-export')?.addEventListener('click', async () => {
      const r = await fetch(`/.netlify/functions/workspace-tr-export?id=${encodeURIComponent(id)}`, {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      if (!r.ok) {
        const j = await r.json().catch(() => ({}));
        alert('Export failed: ' + (j.error || 'unknown'));
        return;
      }
      const blob = await r.blob();
      const filename = (r.headers.get('Content-Disposition') || '').match(/filename="?([^"]+)"?/)?.[1] || 'review.csv';
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(a.href), 5000);
    });
  }

  async function loadGrid(id) {
    const r = await fetch(`/.netlify/functions/workspace-tr-get?id=${encodeURIComponent(id)}`, {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) {
      main.innerHTML = `<div class="ws-wrap"><div class="ws-empty">${escapeHtml(j.error || 'Failed to load')}</div></div>`;
      return;
    }
    gridState = j;
    drawGrid();
  }

  function drawGrid() {
    if (!gridState) return;
    const { review, cells, documents } = gridState;
    const isRedline = review.kind === 'redline';
    document.getElementById('rv-grid-title').textContent = review.title;

    // Decide initial view: explicit ?view= wins, else default to
    // Document view for both kinds. The grid is now the alternate
    // "compact summary" view; the doc-and-findings layout is the
    // primary experience.
    // Document view is the only view (grid retired in Phase 8).
    // Both extraction and redline reviews share the same
    // doc-with-sidebar layout.
    currentView = 'doc';
    if (!currentDocId) {
      currentDocId = initialDocId || (documents[0]?.id || null);
    }
    drawViewTabs();
    document.body.classList.remove('is-locked');
    drawDocView();
    drawStatusHead();
  }

  function drawStatusHead() {
    const { review, cells } = gridState;
    const isRedline = review.kind === 'redline';
    const pill = document.getElementById('rv-status-pill');
    pill.className = 'rv-status-pill ' + (
      review.status === 'complete' ? 'rv-status-done' :
      review.status === 'running' ? 'rv-status-run' :
      review.status === 'error' ? 'rv-status-err' :
      review.status === 'partial' ? 'rv-status-part' : 'rv-status-pen'
    );
    pill.textContent = (isRedline ? 'redline · ' : '') + review.status;

    const total = cells.length;
    const done = cells.filter((c) => c.status === 'complete').length;
    const errs = cells.filter((c) => c.status === 'error').length;
    let counter = `${done}/${total} cells${errs ? ` · ${errs} failed` : ''}`;
    if (isRedline) {
      const accepted = cells.filter((c) => c.redline_status === 'accepted').length;
      const rejected = cells.filter((c) => c.redline_status === 'rejected').length;
      counter += ` · ${accepted} accepted · ${rejected} rejected`;
    }
    document.getElementById('rv-counter').textContent = counter;
  }

  function drawViewTabs() {
    const { documents } = gridState;
    const tabsEl = document.getElementById('rv-view-tabs');
    if (!tabsEl) return;
    if (documents.length <= 1) {
      // Single-doc reviews don't need a tab strip
      tabsEl.innerHTML = '';
      tabsEl.style.display = 'none';
      return;
    }
    tabsEl.style.display = '';
    tabsEl.innerHTML = `
      <div class="rv-viewbar">
        <div class="rv-doctabs">${documents.map((d) => `
          <button type="button" class="rv-doctab${d.id === currentDocId ? ' is-active' : ''}" data-doctab="${d.id}">${escapeHtml(d.filename)}</button>
        `).join('')}</div>
      </div>`;
    tabsEl.querySelectorAll('[data-doctab]').forEach((b) => {
      b.addEventListener('click', () => switchDoc(b.dataset.doctab));
    });
  }

  function switchView(v) {
    if (v === currentView) return;
    currentView = v;
    // Update URL without reload
    const u = new URL(location.href);
    u.searchParams.set('view', v);
    if (v === 'doc' && currentDocId) u.searchParams.set('doc', currentDocId); else u.searchParams.delete('doc');
    history.replaceState(null, '', u.toString());
    drawGrid();
  }
  function switchDoc(docId) {
    if (docId === currentDocId) return;
    currentDocId = docId;
    const u = new URL(location.href);
    u.searchParams.set('doc', docId);
    history.replaceState(null, '', u.toString());
    drawGrid();
  }

  // ---- Inline document view (only view in Phase 8+) ----
  // Refresh just the counter + finalize button label/state in place,
  // without rebuilding the findings list. Used after accept/reject
  // clicks so the user's scroll position in the sidebar is preserved.
  function updateRedlineSummary() {
    if (!gridState) return;
    const { cells } = gridState;
    const docId = currentDocId;
    if (!docId) return;
    const cellsForDoc = cells.filter((c) => c.document_id === docId);
    const accepted = cellsForDoc.filter((c) => c.redline_status === 'accepted').length;
    const finBtn = document.getElementById('rv-docview-finalize');
    if (finBtn) {
      finBtn.disabled = accepted === 0;
      finBtn.textContent = accepted
        ? `Download with ${accepted} tracked change${accepted === 1 ? '' : 's'}`
        : 'Download with tracked changes';
    }
  }

  function drawDocView() {
    const { review, cells, documents, finalizations, overviews } = gridState;
    const isRedline = review.kind === 'redline';
    const docId = currentDocId || documents[0]?.id;
    if (!docId) return;
    const doc = documents.find((d) => d.id === docId);
    const cellsForDoc = cells.filter((c) => c.document_id === docId);
    const cols = review.columns_config || [];
    const fin = (finalizations || []).find((f) => f.document_id === docId);
    const overview = (overviews || []).find((o) => o.document_id === docId);

    const total = cellsForDoc.length;
    const done = cellsForDoc.filter((c) => c.status === 'complete').length;
    const accepted = cellsForDoc.filter((c) => c.redline_status === 'accepted').length;
    const pending = cellsForDoc.filter((c) => c.status === 'pending' || c.status === 'running').length;

    const body = document.getElementById('rv-view-body');
    body.innerHTML = `
      <div class="rv-docview" style="--rv-rail-width: ${rvRailWidth}px">
        <aside class="rv-docview-side">
          <div class="rv-docview-side-head">
            <span>${isRedline ? 'Findings' : 'Analysis'}</span>
            <span class="rv-docview-counter">${done}/${total}${pending > 0 ? ' · scanning' : ''}</span>
          </div>
          <div class="rv-docview-side-scroll">
            <div id="rv-docview-overview" class="rv-overview"></div>
            ${isRedline ? `
            <div class="rv-docview-bulkbar">
              <button type="button" class="rv-bulk-acc" data-bulk="accepted">Accept all</button>
              <button type="button" class="rv-bulk-rej" data-bulk="rejected">Reject all</button>
              <button type="button" class="rv-bulk-pen" data-bulk="pending">Reset</button>
            </div>` : ''}
            <div id="rv-docview-findings" class="rv-live-findings"></div>
          </div>
          ${isRedline ? `
          <div class="rv-docview-side-foot">
            <button type="button" id="rv-docview-finalize" class="ws-btn"${accepted === 0 ? ' disabled' : ''}>
              ${accepted ? `Download with ${accepted} tracked changes` : 'Download with tracked changes'}
            </button>
            ${fin ? `<a class="rv-finalized-link" data-final-version="${fin.version_id}" data-storage-path="${escapeHtml(fin.version?.storage_path || '')}" data-doc-name="${escapeHtml(doc.filename)}">v${fin.version?.version_number || ''} ↓</a>` : ''}
          </div>` : ''}
        </aside>
        <div class="rv-rail-resize" role="separator" aria-label="Resize sidebar" aria-orientation="vertical" tabindex="0"></div>
        <main class="rv-docview-main">
          <div id="rv-live-scanner" class="rv-live-scanner${pending > 0 ? ' is-active' : ''}"></div>
          <div class="rv-doc-zoom-bar" role="toolbar" aria-label="Document zoom">
            <button type="button" class="rv-doc-zoom-btn" data-zoom="out" aria-label="Zoom out" title="Zoom out (Ctrl/Cmd+-)">−</button>
            <button type="button" class="rv-doc-zoom-level" data-zoom="reset" aria-label="Reset zoom" title="Reset zoom (Ctrl/Cmd+0)">${rvDocZoom}%</button>
            <button type="button" class="rv-doc-zoom-btn" data-zoom="in" aria-label="Zoom in" title="Zoom in (Ctrl/Cmd+=)">+</button>
          </div>
          <div id="rv-live-doc-body" class="rv-doc-preview rv-live-doc-body" style="font-size: ${(rvDocZoom * 0.14).toFixed(2)}px"><div class="ws-empty">Loading document…</div></div>
        </main>
      </div>`;

    // Wire bulk-action buttons
    body.querySelectorAll('[data-bulk]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const status = btn.dataset.bulk;
        const label = status === 'accepted' ? 'Accept' : status === 'rejected' ? 'Reject' : 'Reset';
        if (!(await window.siteConfirm(`${label} all findings on this document?`, { okLabel: label }))) return;
        await fetch('/.netlify/functions/workspace-tr-cell-update', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ review_id: review.id, document_id: docId, redline_status: status, scope: 'all' }),
        });
        for (const c of gridState.cells) {
          if (c.document_id === docId && c.redline_find) c.redline_status = status;
        }
        drawGrid();
      });
    });

    // Render the doc body once per doc switch (cache hit on repeat).
    renderDocViewBody(docId);
    refreshDocViewFindings();

    document.getElementById('rv-docview-finalize')?.addEventListener('click', async () => {
      const r = await fetch('/.netlify/functions/workspace-tr-finalize-doc', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ review_id: review.id, document_id: docId }),
      });
      const j = await r.json();
      if (!r.ok) { alert('Failed: ' + (j.error || 'unknown')); return; }
      const sb = (await import('../../../lib/supabase')).getSupabase();
      const { data: signed } = await sb.storage.from('library').createSignedUrl(j.version.storage_path, 600);
      if (signed?.signedUrl) {
        const link = document.createElement('a');
        link.href = signed.signedUrl;
        link.download = `${doc.filename.replace(/\.docx$/i, '')} (final).docx`;
        link.click();
      }
      await loadGrid(review.id);
    });

    body.querySelectorAll('[data-final-version]').forEach((a) => {
      a.addEventListener('click', async (e) => {
        e.preventDefault();
        const path = a.dataset.storagePath; if (!path) return;
        const sb = (await import('../../../lib/supabase')).getSupabase();
        const { data } = await sb.storage.from('library').createSignedUrl(path, 600);
        if (data?.signedUrl) {
          const link = document.createElement('a');
          link.href = data.signedUrl;
          link.download = `${a.dataset.docName.replace(/\.docx$/i, '')} (final).docx`;
          link.click();
        }
      });
    });
  }

  // Cache mammoth-rendered HTML per doc; track which cells we've
  // already pulse-highlighted so re-renders don't re-pulse.
  const _seenCellPulses = new Set();
  async function renderDocViewBody(docId) {
    const target = document.getElementById('rv-live-doc-body');
    if (!target) return;
    try {
      let html = _docPreviewCache[docId];
      if (!html) {
        const supa = (await import('../../../lib/supabase')).getSupabase();
        const { data: versions } = await supa
          .from('workspace_document_versions')
          .select('storage_path')
          .eq('document_id', docId)
          .eq('source', 'upload')
          .order('version_number', { ascending: true })
          .limit(1);
        const path = versions?.[0]?.storage_path;
        if (!path) throw new Error('Original version not found');
        const { data: signed } = await supa.storage.from('library').createSignedUrl(path, 600);
        const res = await fetch(signed.signedUrl);
        const ab = await res.arrayBuffer();
        const result = await window.mammoth.convertToHtml({ arrayBuffer: ab });
        html = result.value || '';
        _docPreviewCache[docId] = html;
      }
      target.innerHTML = `<div class="rv-doc-preview-page">${html}</div>`;
      refreshDocViewFindings();
    } catch (err) {
      target.innerHTML = `<div class="ws-empty">Preview failed: ${escapeHtml(err.message || String(err))}</div>`;
    }
  }

  function refreshDocViewFindings() {
    if (!gridState || currentView !== 'doc') return;
    const { review, cells, overviews } = gridState;
    const isRedline = review.kind === 'redline';
    const docId = currentDocId;
    if (!docId) return;
    const cellsForDoc = cells.filter((c) => c.document_id === docId);
    const cols = review.columns_config || [];

    // Reveal-everything-at-once gate. The user wants user-column
    // findings AND red flags to appear simultaneously, not stream
    // (cells finish faster than the overview, so without this gate the
    // user sees columns appear, then the red flags trickle in later).
    // We hold the entire findings panel in a loading state until all
    // cells have reached a terminal status (complete or error) AND the
    // overview row exists with a terminal status too. Once that's
    // true, the whole list reveals together.
    const overview = (overviews || []).find((o) => o.document_id === docId);
    const allCellsTerminal = cellsForDoc.length === 0 || cellsForDoc.every((c) => c.status === 'complete' || c.status === 'error');
    const overviewTerminal = !!overview && (overview.status === 'complete' || overview.status === 'error');
    const allDone = allCellsTerminal && overviewTerminal;

    // Per-doc overview card — summary only. Red flags used to render
    // here as their own list, but they're now folded into the unified
    // findings list below so the user works through one stream of
    // cards instead of two parallel ones.
    const overviewEl = document.getElementById('rv-docview-overview');
    if (overviewEl) {
      if (!allDone) {
        // While anything is still working, show one unified progress
        // line. We deliberately don't render the partial summary or
        // partial findings — they reveal together when everything's
        // done so the user sees a single coherent result, not a
        // staggered drip.
        const total = cellsForDoc.length;
        const done = cellsForDoc.filter((c) => c.status === 'complete' || c.status === 'error').length;
        const ovBit = overviewTerminal ? '' : (overview ? ' · summary in progress' : ' · queued');
        overviewEl.innerHTML = `<div class="rv-overview-loading"><span class="rv-spin"></span>Reviewing… ${done}/${total} clauses${ovBit}</div>`;
      } else if (overview.status === 'error') {
        const detail = overview.status_detail || 'unknown error';
        overviewEl.innerHTML = `
          <div class="rv-overview-card">
            <div class="rv-overview-error">
              <div class="rv-overview-label">Summary generation failed</div>
              <div class="rv-overview-summary-text">${escapeHtml(detail)}</div>
            </div>
          </div>`;
      } else {
        // status === 'complete'. If summary is missing the parser
        // probably bailed on a truncated response — show what came
        // back from status_detail so the user knows what happened.
        const summaryText = overview.summary && overview.summary.trim()
          ? overview.summary
          : (overview.status_detail
              ? `(no summary — ${overview.status_detail})`
              : '(no summary returned — try re-running the review)');
        overviewEl.innerHTML = `
          <div class="rv-overview-card">
            <div class="rv-overview-summary">
              <div class="rv-overview-label">Summary</div>
              <div class="rv-overview-summary-text">${escapeHtml(summaryText)}</div>
            </div>
          </div>`;
      }
    }

    // Compute the deduped, severity-sorted red-flag list. A red flag
    // is dropped if its quote text overlaps any user-defined cell's
    // redline_find on the same doc — those are the same clause and
    // would render as duplicate cards.
    const allRisks = (overview && overview.status === 'complete' && Array.isArray(overview.risks))
      ? overview.risks : [];
    const userFinds = cellsForDoc
      .filter((c) => c.redline_find)
      .map((c) => c.redline_find.trim().toLowerCase());
    function risksOverlapsUserFind(quote) {
      if (!quote) return false;
      const q = quote.trim().toLowerCase();
      for (const u of userFinds) {
        if (q === u) return true;
        // Only dedup when the spans are NEARLY the same passage —
        // strict substring containment with a high length floor. Topic-
        // level overlap is fine; we want red flags to act as the
        // industry baseline, not get filtered out because the user
        // mentioned the same area in a column.
        if (q.length >= 60 && u.length >= 60 && (q.includes(u) || u.includes(q))) return true;
      }
      return false;
    }
    // Keep risks that don't overlap with any user-defined cell.
    // Structural risks (no quote) always pass through — they describe
    // missing clauses, not duplicates of anything the user has listed.
    const sortedRisks = [...allRisks]
      .filter((r) => !r.quote || !risksOverlapsUserFind(r.quote))
      .sort((a, b) => {
        const sev = { high: 0, medium: 1, low: 2 };
        return (sev[a.severity] ?? 1) - (sev[b.severity] ?? 1);
      });

    // (Risk card wiring is built inside the findings list block below.)

    function escapeAttr(s) {
      return String(s ?? '').replace(/[<>&"'\n\r]/g, (c) => ({
        '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;', "'": '&#39;',
        '\n': '&#10;', '\r': '&#13;',
      }[c]));
    }

    // Sidebar list — unified: risks render alongside user-defined
    // column findings, sharing the same .rv-live-finding chrome and
    // accept/reject/refine actions. Risks come from the doc overview;
    // they're cards that the AI flagged on its own (i.e. things the
    // user didn't list), each pre-populated with a recommended rewrite
    // so the user can accept/reject without an extra step.
    const findingsEl = document.getElementById('rv-docview-findings');

    // Build the risk-card HTML. Mirrors the regular finding card
    // template; the only structural difference is data-risk-idx (no
    // cell id yet, since accepting is what creates a cell + column).
    function renderRiskCard(r, ri) {
      const sev = r.severity || 'medium';
      const sevLabel = sev.toUpperCase();
      const hasQuote = !!r.quote;
      const hasRewrite = hasQuote && !!r.suggested_replace;
      const titleHtml = `
        <div class="rv-live-finding-head">
          <div class="rv-live-finding-col rv-risk-col">
            <span class="rv-risk-sev-pill rv-risk-sev-${sev}">${sevLabel}</span>
            <span class="rv-risk-flag-label">RED FLAG</span>
            <span class="rv-risk-title-text">${escapeHtml(r.title || '')}</span>
          </div>
          <button type="button" class="rv-card-toggle" data-card-toggle title="Minimize / expand">▾</button>
        </div>`;
      // Show the rewrite rationale primarily (matches how regular
      // finding cards explain WHY the change is being proposed). Fall
      // back to the risk detail when there's no rewrite (structural
      // risks). No italic / em wrap — keep the line visually flush
      // with regular finding rationales.
      const rationaleHtml = `<div class="rv-live-finding-rationale">${escapeHtml(r.suggested_rationale || r.detail || '')}</div>`;
      // Structural risk (no quotable clause) → simple Dismiss card
      if (!hasQuote) {
        return `<div class="rv-live-finding rv-live-finding-risk rv-live-finding-risk-${sev}" data-risk-idx="${ri}" data-risk-no-quote="1">
          ${titleHtml}
          ${rationaleHtml}
          <div class="rv-live-finding-na-text" style="font-style:italic;">Structural concern — no specific clause to redline.</div>
          <div class="rv-live-finding-actions">
            <button type="button" class="rv-cell-rej" data-risk-action="rejected" data-risk-idx="${ri}">× Dismiss</button>
          </div>
        </div>`;
      }
      // Quotable risk with auto-generated rewrite proposal
      const fromText = r.quote || '';
      const toText = r.suggested_replace || '';
      return `<div class="rv-live-finding rv-live-finding-risk rv-live-finding-risk-${sev}" data-risk-idx="${ri}" data-find="${escapeHtml(fromText)}">
        ${titleHtml}
        ${rationaleHtml}
        <div class="rv-live-finding-diff">
          <div class="rv-live-finding-from">${escapeHtml(fromText.slice(0, 200))}${fromText.length > 200 ? '…' : ''}</div>
          <div class="rv-live-finding-arrow">→</div>
          <div class="rv-live-finding-to">${hasRewrite ? escapeHtml(toText.slice(0, 200)) + (toText.length > 200 ? '…' : '') : '<em style="color:var(--ink-3)">(no rewrite — accept to mark for deletion, or refine for a proposal)</em>'}</div>
        </div>
        <div class="rv-live-finding-actions">
          <button type="button" class="rv-cell-acc" data-risk-action="accepted" data-risk-idx="${ri}">✓ Accept</button>
          <button type="button" class="rv-cell-rej" data-risk-action="rejected" data-risk-idx="${ri}">× Reject</button>
          <button type="button" class="rv-cell-refine-btn" data-risk-action="refine" data-risk-idx="${ri}" title="Ask AI to revise this proposal">Refine</button>
        </div>
        <div class="rv-cell-refine-form rv-risk-suggest-form" data-risk-form="${ri}" hidden>
          <textarea class="rv-cell-refine-input rv-risk-suggest-input" placeholder="Tell the AI how to revise this. e.g. 'make it stronger', 'use the phrase work made for hire', 'add a 60-day cure period'."></textarea>
          <div class="rv-cell-refine-actions rv-risk-suggest-actions">
            <button type="button" class="rv-cell-refine-cancel" data-risk-action="cancel" data-risk-idx="${ri}">Cancel</button>
            <button type="button" class="rv-cell-refine-go ws-btn" data-risk-action="go" data-risk-idx="${ri}">Revise with AI</button>
          </div>
          <div class="rv-cell-refine-status rv-risk-suggest-status" data-risk-status="${ri}" hidden></div>
        </div>
      </div>`;
    }

    if (findingsEl && !allDone) {
      // Hold the findings list in a loading state until the overview
      // AND all cells finish. Reveals everything together so the
      // user sees one coherent result, not a staggered drip.
      const total = cellsForDoc.length;
      const done = cellsForDoc.filter((c) => c.status === 'complete' || c.status === 'error').length;
      const ovBit = overviewTerminal ? '' : (overview ? ' · summary' : ' · queued');
      findingsEl.innerHTML = `
        <div class="rv-live-finding rv-live-finding-pending">
          <div class="rv-live-finding-na-text">
            <span class="rv-spin"></span>
            Reviewing the document — ${done}/${total} clauses${ovBit}. Findings will appear together when the scan completes.
          </div>
        </div>`;
      // Keep the scanner sweep animating across the document until
      // EVERYTHING the user is waiting on has finished. The reveal-
      // everything-at-once gate would otherwise return here without
      // touching the scanner state.
      const scannerEl = document.getElementById('rv-live-scanner');
      if (scannerEl) scannerEl.classList.add('is-active');
      return;
    }

    if (findingsEl) {
      const findings = cellsForDoc.sort((a, b) => a.column_index - b.column_index);
      const riskHtml = isRedline ? sortedRisks.map((r, ri) => renderRiskCard(r, ri)).join('') : '';
      const findingsHtml = findings.map((c) => {
        const col = cols[c.column_index];
        if (c.status === 'pending' || c.status === 'running') {
          return `<div class="rv-live-finding rv-live-finding-pending">
            <div class="rv-live-finding-col">${escapeHtml(col?.name || '?')}</div>
            <div class="rv-live-finding-na-text"><span class="rv-spin"></span>Analyzing…</div>
          </div>`;
        }
        if (c.status === 'error') {
          return `<div class="rv-live-finding rv-live-finding-na" title="${escapeHtml(c.status_detail || '')}">
            <div class="rv-live-finding-col">${escapeHtml(col?.name || '?')}</div>
            <div class="rv-live-finding-na-text">Error</div>
          </div>`;
        }

        if (isRedline) {
          const status = c.redline_status || 'pending';
          const stClass = status === 'accepted' ? ' is-accepted' : status === 'rejected' ? ' is-rejected' : '';
          // Cards start collapsed if already resolved (saved between
          // sessions) — keeps the list scannable. The minimize chevron
          // can re-collapse a card at any time, regardless of status.
          const collapsed = (status === 'accepted' || status === 'rejected') ? ' is-collapsed' : '';
          const resolvedLabel = status === 'accepted' ? '✓ Accepted' : status === 'rejected' ? '× Rejected' : '';
          if (!c.redline_find) {
            return `<div class="rv-live-finding rv-live-finding-na" data-cell="${c.id}">
              <div class="rv-live-finding-head">
                <div class="rv-live-finding-col">${escapeHtml(col?.name || '?')}</div>
                <button type="button" class="rv-card-toggle" data-card-toggle title="Minimize / expand">▾</button>
              </div>
              <div class="rv-live-finding-na-text">Not present in document</div>
            </div>`;
          }
          return `<div class="rv-live-finding${stClass}${collapsed}" data-cell="${c.id}" data-find="${escapeHtml(c.redline_find)}">
            <div class="rv-live-finding-head">
              <div class="rv-live-finding-col">${escapeHtml(col?.name || '?')}</div>
              <button type="button" class="rv-card-toggle" data-card-toggle title="Minimize / expand">▾</button>
            </div>
            <div class="rv-live-finding-resolved-bar">
              <span class="rv-live-finding-resolved-label">${resolvedLabel}</span>
              <span class="rv-live-finding-resolved-actions">
                <button type="button" class="rv-cell-undo" data-cell-action="pending" data-cell="${c.id}" title="Undo this decision">Undo</button>
              </span>
            </div>
            <div class="rv-live-finding-rationale">${escapeHtml(c.redline_rationale || c.content || '')}</div>
            <div class="rv-live-finding-diff">
              <div class="rv-live-finding-from">${escapeHtml(c.redline_find.slice(0, 200))}${c.redline_find.length > 200 ? '…' : ''}</div>
              <div class="rv-live-finding-arrow">→</div>
              <div class="rv-live-finding-to">${c.redline_replace ? escapeHtml(c.redline_replace.slice(0, 200)) + (c.redline_replace.length > 200 ? '…' : '') : '<em>(delete)</em>'}</div>
            </div>
            <div class="rv-live-finding-actions">
              <button type="button" class="rv-cell-acc${status === 'accepted' ? ' is-on' : ''}" data-cell-action="accepted" data-cell="${c.id}">✓ Accept</button>
              <button type="button" class="rv-cell-rej${status === 'rejected' ? ' is-on' : ''}" data-cell-action="rejected" data-cell="${c.id}">× Reject</button>
              <button type="button" class="rv-cell-refine-btn" data-refine-cell="${c.id}" title="Ask AI to revise this proposal">Refine</button>
              <button type="button" class="save-to-vault-btn rv-cell-save-vault" data-vault-save-cell="${c.id}" title="Save this finding to your Vault"><span>Save</span></button>
            </div>
            <div class="rv-cell-refine-form" data-refine-form="${c.id}" hidden>
              <textarea class="rv-cell-refine-input" placeholder="Tell the AI how to revise this. e.g. 'make it stronger', 'use the phrase work made for hire', 'add a 60-day cure period'."></textarea>
              <div class="rv-cell-refine-actions">
                <button type="button" class="rv-cell-refine-cancel">Cancel</button>
                <button type="button" class="rv-cell-refine-go ws-btn">Revise with AI</button>
              </div>
              <div class="rv-cell-refine-status" hidden></div>
            </div>
          </div>`;
        }

        // Extraction mode: answer + verbatim quote (citation) highlighted in the doc.
        const cite = (c.citations || [])[0];
        if (!cite || !cite.quote) {
          return `<div class="rv-live-finding rv-live-finding-na" data-cell="${c.id}">
            <div class="rv-live-finding-head">
              <div class="rv-live-finding-col">${escapeHtml(col?.name || '?')}</div>
              <button type="button" class="rv-card-toggle" data-card-toggle title="Minimize / expand">▾</button>
            </div>
            <div class="rv-live-finding-rationale">${escapeHtml(c.content || '')}</div>
          </div>`;
        }
        return `<div class="rv-live-finding" data-cell="${c.id}" data-find="${escapeHtml(cite.quote)}">
          <div class="rv-live-finding-head">
            <div class="rv-live-finding-col">${escapeHtml(col?.name || '?')}</div>
            <button type="button" class="rv-card-toggle" data-card-toggle title="Minimize / expand">▾</button>
          </div>
          <div class="rv-live-finding-rationale">${escapeHtml(c.content || '')}</div>
          <div class="rv-live-finding-diff" style="grid-template-columns: 1fr">
            <div class="rv-live-finding-from">${escapeHtml(cite.quote.slice(0, 240))}${cite.quote.length > 240 ? '…' : ''}${cite.page ? ` <span style="color:var(--ink-3);font-style:italic">(p. ${cite.page})</span>` : ''}</div>
          </div>
        </div>`;
      }).join('');
      findingsEl.innerHTML = riskHtml + findingsHtml;

      // Apply the visual state of an accept/reject change to a single
      // finding row + its action buttons + the matching inline tracked-
      // changes spans inside the document preview. Pure DOM manipulation,
      // no network. Used for both optimistic updates and rollback.
      function applyFindingState(findingEl, status) {
        if (!findingEl) return;
        // 1. Sidebar finding card — accept/reject classes + auto-collapse
        findingEl.classList.remove('is-accepted', 'is-rejected', 'is-collapsed');
        if (status === 'accepted') findingEl.classList.add('is-accepted', 'is-collapsed');
        else if (status === 'rejected') findingEl.classList.add('is-rejected', 'is-collapsed');
        findingEl.querySelectorAll('.rv-cell-acc, .rv-cell-rej').forEach((b) => b.classList.remove('is-on'));
        const targetBtn = findingEl.querySelector(`[data-cell-action="${status}"]`);
        if (targetBtn) targetBtn.classList.add('is-on');
        // Update the collapsed-bar label so the right verb shows
        const lbl = findingEl.querySelector('.rv-live-finding-resolved-label');
        if (lbl) lbl.textContent = status === 'accepted' ? '✓ Accepted' : status === 'rejected' ? '× Rejected' : '';

        // 2. In-doc tracked-changes preview spans for THIS cell —
        //    swap is-pending / is-accepted / is-rejected on both the
        //    strikethrough "find" span and the green "insert" span so
        //    the doc preview reflects what the final tracked-changes
        //    Word file will look like the moment the user clicks.
        const cellId = findingEl.getAttribute('data-cell');
        if (cellId) {
          const docBody = document.getElementById('rv-live-doc-body');
          if (docBody) {
            const spans = docBody.querySelectorAll(`[data-cell="${cellId}"]`);
            spans.forEach((span) => {
              const baseCls = span.classList.contains('rv-rdln-ins') ? 'rv-rdln-ins' : 'rv-rdln-find';
              span.className = `${baseCls} is-${status}`;
            });
          }
        }
      }

      // Manual minimize/expand toggle — lives on every card (pending,
      // accepted, rejected). Independent of status; lets the user
      // shrink any card to free up space while reviewing.
      findingsEl.querySelectorAll('[data-card-toggle]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const card = btn.closest('.rv-live-finding');
          if (!card) return;
          card.classList.toggle('is-collapsed');
        });
      });

      findingsEl.querySelectorAll('[data-cell-action]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const cellId = btn.dataset.cell;
          const status = btn.dataset.cellAction;
          const cell = gridState.cells.find((x) => x.id === cellId);
          const prevStatus = cell?.redline_status || 'pending';
          const findingEl = btn.closest('.rv-live-finding');

          // Optimistic update — apply the visual change INSTANTLY so
          // the user sees feedback the moment they click. No await
          // before the DOM reacts. Server call runs in background;
          // we revert if it fails.
          if (cell) cell.redline_status = status;
          applyFindingState(findingEl, status);
          updateRedlineSummary();

          // Fire-and-forget the persistence call. Revert on failure.
          fetch('/.netlify/functions/workspace-tr-cell-update', {
            method: 'POST',
            headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: cellId, redline_status: status }),
          })
          .then((r) => {
            if (!r.ok) throw new Error(`HTTP ${r.status}`);
          })
          .catch((err) => {
            // Revert local state and DOM
            if (cell) cell.redline_status = prevStatus;
            applyFindingState(findingEl, prevStatus);
            updateRedlineSummary();
            if (typeof siteToast === 'function') {
              siteToast('Could not save change — reverted', { kind: 'error' });
            } else {
              console.error('Cell update failed, reverted:', err?.message || err);
            }
          });
        });
      });
      findingsEl.querySelectorAll('[data-find]').forEach((row) => {
        row.addEventListener('click', (e) => {
          // Don't navigate if user clicked an inner button or
          // typed in the refine textarea
          if (e.target.closest('button, textarea, input, [data-refine-form], [data-risk-form]')) return;
          const find = row.dataset.find;
          const span = document.querySelector(`#rv-live-doc-body [data-finding-find="${cssEscape(find)}"]`);
          if (span) {
            span.scrollIntoView({ block: 'center', behavior: 'smooth' });
            span.classList.remove('is-flash');
            void span.offsetWidth;
            span.classList.add('is-flash');
            setTimeout(() => span.classList.remove('is-flash'), 1800);
          } else {
            // Risk cards' quotes may not yet be registered as finding
            // spans — fall back to a one-off scroll+flash in the doc.
            flashTextInDoc(find);
          }
        });
      });

      // ---- Save finding to Vault ----
      // Each redline finding card has a 💾 Save button that POSTs the
      // finding (column name + rationale + verbatim find text + the
      // accepted-or-proposed replace text) into the user's vault.
      findingsEl.querySelectorAll('[data-vault-save-cell]').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          if (btn.classList.contains('is-saved')) return;
          const cellId = btn.dataset.vaultSaveCell;
          const cell = gridState.cells.find((c) => c.id === cellId);
          if (!cell) return;
          const col = (gridState.review.columns_config || [])[cell.column_index];
          const colName = col?.name || 'Finding';
          const rationale = cell.redline_rationale || cell.content || '';
          const findText = cell.redline_find || '';
          const replaceText = cell.redline_replace || '';
          const docName = (gridState.documents || []).find((d) => d.id === cell.document_id)?.filename || '';
          const titleParts = [colName];
          if (docName) titleParts.push('· ' + docName);
          const title = titleParts.join(' ').slice(0, 200);
          const content = [
            rationale ? `Rationale: ${rationale}` : '',
            findText ? `\nOriginal:\n${findText}` : '',
            replaceText ? `\nProposed replacement:\n${replaceText}` : '',
            cell.redline_status ? `\nStatus: ${cell.redline_status}` : '',
          ].filter(Boolean).join('\n').trim();
          if (!content) {
            alert('Nothing to save on this finding.');
            return;
          }
          btn.disabled = true;
          btn.querySelector('span').textContent = 'Saving…';
          try {
            const r = await fetch('/.netlify/functions/workspace-vault-add', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${accessToken}` },
              body: JSON.stringify({
                source_kind: 'review_finding',
                source_review_id: gridState.review.id,
                source_doc_id: cell.document_id,
                title,
                content,
                tags: ['finding', cell.redline_status || 'pending'],
              }),
            });
            const j = await r.json();
            if (!r.ok) throw new Error(j.error || 'Save failed');
            btn.classList.add('is-saved');
            btn.querySelector('span').textContent = 'Saved';
            if (typeof window.siteToast === 'function') {
              window.siteToast('Finding saved to your Vault', { kind: 'success' });
            }
          } catch (err) {
            btn.disabled = false;
            btn.querySelector('span').textContent = 'Save';
            alert('Could not save: ' + err.message);
          }
        });
      });

      // ---- Risk-card action wiring ----
      // Risk cards live in the same findings list as user-defined
      // findings, but use data-risk-action / data-risk-idx so we can
      // route them through workspace-tr-risk-accept (which creates a
      // new column + cell from the risk) instead of the existing cell-
      // update endpoint. Optimistic UI mirrors the regular flow.
      findingsEl.querySelectorAll('[data-risk-action]').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const action = btn.dataset.riskAction;
          const ri = parseInt(btn.dataset.riskIdx, 10);
          const risk = sortedRisks[ri];
          if (!risk) return;
          const card = btn.closest('.rv-live-finding-risk');
          const formEl = card?.querySelector(`[data-risk-form="${ri}"]`);
          const statusEl = card?.querySelector(`[data-risk-status="${ri}"]`);

          // ----- Refine: open the textarea form -----
          if (action === 'refine') {
            if (formEl) {
              formEl.hidden = !formEl.hidden;
              if (!formEl.hidden) formEl.querySelector('textarea')?.focus();
            }
            return;
          }
          if (action === 'cancel') {
            if (formEl) formEl.hidden = true;
            if (statusEl) statusEl.hidden = true;
            return;
          }

          // ----- Generate (regenerate the rewrite with new direction) -----
          if (action === 'go') {
            const ta = formEl?.querySelector('.rv-risk-suggest-input');
            const direction = (ta?.value || '').trim();
            btn.disabled = true;
            if (statusEl) {
              statusEl.hidden = false;
              statusEl.className = 'rv-risk-suggest-status is-running';
              statusEl.textContent = '✨ Generating revised rewrite…';
            }
            try {
              const r = await fetch('/.netlify/functions/workspace-tr-risk-suggest', {
                method: 'POST',
                headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  review_id: gridState.review.id,
                  document_id: currentDocId,
                  risk: { title: risk.title, detail: risk.detail, quote: risk.quote, severity: risk.severity },
                  user_direction: direction || null,
                }),
              });
              const j = await r.json();
              if (!r.ok) throw new Error(j.error || 'Suggest failed');
              // Mutate the risk in place, then re-render the list so
              // the refreshed find/replace/rationale shows in the diff.
              risk.quote = j.find || risk.quote;
              risk.suggested_replace = j.replace || '';
              risk.suggested_rationale = j.rationale || '';
              if (formEl) formEl.hidden = true;
              if (statusEl) statusEl.hidden = true;
              refreshDocViewFindings();
            } catch (err) {
              if (statusEl) {
                statusEl.className = 'rv-risk-suggest-status is-error';
                statusEl.textContent = `Failed: ${err.message || err}`;
              }
            } finally {
              btn.disabled = false;
            }
            return;
          }

          // ----- Accept / Reject -----
          // Both persist as a real redline cell (status accepted or
          // rejected) so the dedup logic catches them on next render
          // and the user's decision survives a reload. Optimistic.
          if (action !== 'accepted' && action !== 'rejected') return;
          const newStatus = action;
          const findText = risk.quote || '';
          const replaceText = risk.suggested_replace || '';
          const rationaleText = risk.suggested_rationale || risk.detail || '';

          // For structural risks (no quote), reject is the only valid
          // path — just dismiss locally so the card disappears.
          if (!findText) {
            const ovIdx = (gridState.overviews || []).findIndex((o) => o.document_id === currentDocId);
            if (ovIdx !== -1) {
              const ov = gridState.overviews[ovIdx];
              ov.risks = (ov.risks || []).filter((rr) => rr !== risk);
            }
            refreshDocViewFindings();
            if (typeof siteToast === 'function') siteToast('Dismissed', { kind: 'info' });
            return;
          }

          // Optimistic temp cell + column → instant render
          const tempId = `temp_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
          const newColIndex = (gridState.review.columns_config || []).length;
          const tempColumn = {
            index: newColIndex,
            name: `[Red flag] ${String(risk.title || '').slice(0, 80)}`,
            prompt: `(Auto-generated from red flag: ${String(risk.title || '').slice(0, 200)})`,
            from_risk: true,
          };
          const tempCell = {
            id: tempId,
            review_id: gridState.review.id,
            document_id: currentDocId,
            column_index: newColIndex,
            status: 'complete',
            content: rationaleText,
            redline_find: findText,
            redline_replace: replaceText,
            redline_rationale: rationaleText,
            redline_status: newStatus,
            citations: [],
          };
          gridState.review.columns_config = [...(gridState.review.columns_config || []), tempColumn];
          gridState.cells.push(tempCell);
          // Remove the risk from the local overview so it doesn't
          // render twice (the new cell will dedup it next render too).
          const ovIdx = (gridState.overviews || []).findIndex((o) => o.document_id === currentDocId);
          if (ovIdx !== -1) {
            const ov = gridState.overviews[ovIdx];
            ov.risks = (ov.risks || []).filter((rr) => rr !== risk);
          }
          refreshDocViewFindings();
          updateRedlineSummary();
          if (typeof siteToast === 'function') {
            siteToast(newStatus === 'accepted' ? 'Accepted — added to findings' : 'Rejected', { kind: 'success' });
          }

          fetch('/.netlify/functions/workspace-tr-risk-accept', {
            method: 'POST',
            headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({
              review_id: gridState.review.id,
              document_id: currentDocId,
              risk: { title: risk.title, severity: risk.severity, detail: risk.detail, quote: risk.quote },
              find: findText,
              replace: replaceText,
              rationale: rationaleText,
              status: newStatus,
            }),
          })
            .then(async (ar) => {
              const aj = await ar.json().catch(() => ({}));
              if (!ar.ok) throw new Error(aj.error || `HTTP ${ar.status}`);
              const tIdx = gridState.cells.findIndex((c) => c.id === tempId);
              if (tIdx !== -1 && aj.cell) {
                gridState.cells[tIdx] = aj.cell;
                document.querySelectorAll(`[data-cell="${tempId}"]`).forEach((el) => {
                  el.setAttribute('data-cell', aj.cell.id);
                });
              }
              if (aj.columns_config) gridState.review.columns_config = aj.columns_config;
            })
            .catch((err) => {
              gridState.cells = gridState.cells.filter((c) => c.id !== tempId);
              gridState.review.columns_config = (gridState.review.columns_config || []).filter((c) => c !== tempColumn);
              // Restore the risk so the user can try again
              if (ovIdx !== -1) {
                const ov = gridState.overviews[ovIdx];
                ov.risks = [risk, ...(ov.risks || [])];
              }
              refreshDocViewFindings();
              if (typeof siteToast === 'function') siteToast(`Could not save: ${err.message || err}`, { kind: 'error' });
            });
        });
      });

      // Wire Refine flow: open form, run revise, update cell
      findingsEl.querySelectorAll('[data-refine-cell]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const cellId = btn.dataset.refineCell;
          const form = findingsEl.querySelector(`[data-refine-form="${cellId}"]`);
          if (!form) return;
          const isOpen = !form.hidden;
          form.hidden = isOpen;
          if (!isOpen) form.querySelector('textarea')?.focus();
        });
      });
      findingsEl.querySelectorAll('.rv-cell-refine-cancel').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          btn.closest('.rv-cell-refine-form').hidden = true;
        });
      });
      findingsEl.querySelectorAll('.rv-cell-refine-go').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const form = btn.closest('.rv-cell-refine-form');
          const cellId = form.dataset.refineForm;
          const instruction = form.querySelector('textarea').value.trim();
          if (!instruction) return;
          const status = form.querySelector('.rv-cell-refine-status');
          status.hidden = false;
          status.textContent = 'Revising…';
          status.className = 'rv-cell-refine-status is-running';
          btn.disabled = true;
          const r = await fetch('/.netlify/functions/workspace-tr-cell-refine', {
            method: 'POST',
            headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ cell_id: cellId, instruction }),
          });
          const j = await r.json();
          btn.disabled = false;
          if (!r.ok) {
            status.textContent = 'Failed: ' + (j.error || 'unknown');
            status.className = 'rv-cell-refine-status is-error';
            return;
          }
          // Replace the cell in gridState and re-render. Also remove
          // the doc-body span so it gets re-inserted with the new
          // (possibly different) replace text.
          const updated = j.cell;
          const idx = gridState.cells.findIndex((c) => c.id === cellId);
          if (idx !== -1) gridState.cells[idx] = { ...gridState.cells[idx], ...updated };
          _seenCellPulses.delete(cellId);
          const oldFind = document.querySelector(`#rv-live-doc-body .rv-rdln-find[data-cell="${cellId}"]`);
          const oldIns = document.querySelector(`#rv-live-doc-body .rv-rdln-ins[data-cell="${cellId}"]`);
          if (oldFind) oldFind.replaceWith(document.createTextNode(oldFind.textContent));
          if (oldIns) oldIns.remove();
          drawGrid();
        });
      });
    }

    // Update doc body highlights. For redline mode, highlight
    // c.redline_find. For extraction mode, highlight the quote from
    // citations[0]. The find + insertion span pair updates its
    // classes together when the user accepts/rejects.
    const body = document.getElementById('rv-live-doc-body');
    if (body && body.querySelector('.rv-doc-preview-page')) {
      for (const c of cellsForDoc) {
        if (c.status !== 'complete') continue;
        const findText = isRedline ? c.redline_find : (c.citations || [])[0]?.quote;
        if (!findText) continue;
        const status = isRedline ? (c.redline_status || 'pending') : 'extraction';
        const existingFind = body.querySelector(`.rv-rdln-find[data-cell="${c.id}"]`);
        const existingIns = body.querySelector(`.rv-rdln-ins[data-cell="${c.id}"]`);
        if (existingFind) {
          existingFind.className = `rv-rdln-find is-${status}`;
          if (existingIns) existingIns.className = `rv-rdln-ins is-${status}`;
          continue;
        }
        const isPulse = !_seenCellPulses.has(c.id);
        _seenCellPulses.add(c.id);
        const cellWrap = isRedline ? c : { id: c.id, redline_find: findText, redline_status: 'extraction', redline_replace: '', redline_rationale: c.content || '' };
        highlightLiveFinding(body, cellWrap, isPulse);
      }
    }

    // Scanner stays active until EVERYTHING the user is waiting on
    // has finished — both the user-column cells and the overview
    // (summary + red flags). This matches the reveal-everything-at-
    // once gate above so the scan-line keeps animating across the
    // doc preview right up until the findings panel reveals its
    // results in one shot.
    const scanner = document.getElementById('rv-live-scanner');
    if (scanner) {
      scanner.classList.toggle('is-active', !allDone);
    }
  }

  function drawGridTable() {
    const { review, cells, documents, finalizations } = gridState;
    const isRedline = review.kind === 'redline';
    const cols = review.columns_config || [];
    const cellMap = {};
    for (const c of cells) cellMap[`${c.document_id}|${c.column_index}`] = c;

    // Index per-doc finalizations for the row buttons
    const finalByDoc = {};
    for (const f of (finalizations || [])) finalByDoc[f.document_id] = f;

    const headLabel = isRedline ? 'Concerns' : 'Columns';
    const head = `<thead><tr>
      <th class="rv-th rv-th-doc">Document</th>
      ${cols.map((c) => `<th class="rv-th"><div class="rv-th-name">${escapeHtml(c.name || `Column ${c.index + 1}`)}</div><div class="rv-th-prompt">${escapeHtml((c.prompt || '').slice(0, 120))}${(c.prompt || '').length > 120 ? '…' : ''}</div></th>`).join('')}
      ${isRedline ? '<th class="rv-th rv-th-actions">Apply</th>' : ''}
    </tr></thead>`;

    const rows = documents.map((d) => {
      const docCells = cells.filter((c) => c.document_id === d.id);
      const accepted = docCells.filter((c) => c.redline_status === 'accepted').length;
      const fin = finalByDoc[d.id];
      const finalCol = isRedline ? `
        <td class="rv-td-actions">
          <button type="button" class="rv-watch-btn" data-watch-doc="${d.id}" data-doc-name="${escapeHtml(d.filename)}">Live preview</button>
          <button type="button" class="rv-finalize-btn" data-finalize-doc="${d.id}" ${accepted === 0 ? 'disabled' : ''}>
            Apply ${accepted}
          </button>
          ${fin ? `<a class="rv-finalized-link" data-final-version="${fin.version_id}" data-storage-path="${escapeHtml(fin.version?.storage_path || '')}" data-doc-name="${escapeHtml(d.filename)}">v${fin.version?.version_number || ''} ↓</a>` : ''}
        </td>` : '';
      return `<tr data-doc-row="${d.id}">
        <td class="rv-td-doc"><div class="rv-doc-row-name">${escapeHtml(d.filename)}</div></td>
        ${cols.map((c) => renderCell(cellMap[`${d.id}|${c.index}`], isRedline)).join('')}
        ${finalCol}
      </tr>`;
    }).join('');

    document.getElementById('rv-view-body').innerHTML = `<div class="rv-grid-wrap"><table class="rv-grid${isRedline ? ' rv-grid-redline' : ''}">${head}<tbody>${rows}</tbody></table></div>`;

    // Wire cell click → detail modal
    document.querySelectorAll('.rv-cell[data-cell]').forEach((td) => {
      td.addEventListener('click', (e) => {
        if (e.target.closest('.rv-cell-actions')) return;   // ignore clicks on accept/reject buttons
        openCellDetail(td.dataset.cell);
      });
    });

    // Wire per-cell accept/reject (redline only)
    if (isRedline) {
      document.querySelectorAll('[data-cell-action]').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const td = btn.closest('[data-cell]');
          const cellId = td?.dataset.cell;
          const status = btn.dataset.cellAction;
          if (!cellId) return;
          const r = await fetch('/.netlify/functions/workspace-tr-cell-update', {
            method: 'POST',
            headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: cellId, redline_status: status }),
          });
          if (!r.ok) { alert('Failed'); return; }
          const cell = gridState.cells.find((c) => c.id === cellId);
          if (cell) cell.redline_status = status;
          drawGrid();
        });
      });

      document.querySelectorAll('[data-finalize-doc]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const docId = btn.dataset.finalizeDoc;
          btn.disabled = true; btn.textContent = '…';
          const r = await fetch('/.netlify/functions/workspace-tr-finalize-doc', {
            method: 'POST',
            headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ review_id: review.id, document_id: docId }),
          });
          const j = await r.json();
          if (!r.ok) { alert('Finalize failed: ' + (j.error || 'unknown')); btn.disabled = false; return; }
          await loadGrid(review.id);
        });
      });

      document.querySelectorAll('[data-final-version]').forEach((a) => {
        a.addEventListener('click', async (e) => {
          e.preventDefault();
          const path = a.dataset.storagePath;
          if (!path) return;
          const sb = (await import('../../../lib/supabase')).getSupabase();
          const { data } = await sb.storage.from('library').createSignedUrl(path, 600);
          if (data?.signedUrl) {
            const link = document.createElement('a');
            link.href = data.signedUrl;
            link.download = `${a.dataset.docName.replace(/\.docx$/i, '')} (final).docx`;
            link.click();
          }
        });
      });

      // Wire "Live preview" buttons
      document.querySelectorAll('[data-watch-doc]').forEach((btn) => {
        btn.addEventListener('click', () => {
          openLivePreview(btn.dataset.watchDoc, btn.dataset.docName);
        });
      });
    }
  }

  function renderCell(cell, isRedline) {
    if (!cell) return '<td class="rv-cell rv-cell-pending">—</td>';
    if (cell.status === 'pending') return '<td class="rv-cell rv-cell-pending">queued</td>';
    if (cell.status === 'running') return '<td class="rv-cell rv-cell-running"><span class="rv-spin"></span>thinking…</td>';
    if (cell.status === 'error') return `<td class="rv-cell rv-cell-error" data-cell="${cell.id}" title="${escapeHtml(cell.status_detail || 'failed')}">error</td>`;

    if (isRedline) {
      const find = cell.redline_find || '';
      const replace = cell.redline_replace || '';
      const rationale = cell.redline_rationale || cell.content || '';
      const status = cell.redline_status || 'pending';
      if (!find) {
        return `<td class="rv-cell rv-cell-na" data-cell="${cell.id}" title="${escapeHtml(cell.status_detail || '')}"><em>not in document</em></td>`;
      }
      const stClass = status === 'accepted' ? ' is-accepted' : status === 'rejected' ? ' is-rejected' : '';
      return `<td class="rv-cell rv-cell-redline${stClass}" data-cell="${cell.id}">
        <div class="rv-cell-rationale">${escapeHtml(rationale)}</div>
        <div class="rv-cell-mini-diff">
          <div class="rv-cell-find">${escapeHtml(find.slice(0, 140))}${find.length > 140 ? '…' : ''}</div>
          <div class="rv-cell-arrow">→</div>
          <div class="rv-cell-replace">${replace ? escapeHtml(replace.slice(0, 140)) + (replace.length > 140 ? '…' : '') : '<em>(delete)</em>'}</div>
        </div>
        <div class="rv-cell-actions">
          <button type="button" class="rv-cell-acc${status === 'accepted' ? ' is-on' : ''}" data-cell-action="accepted">✓</button>
          <button type="button" class="rv-cell-rej${status === 'rejected' ? ' is-on' : ''}" data-cell-action="rejected">×</button>
        </div>
      </td>`;
    }

    const ans = cell.content || '';
    const hasQuote = Array.isArray(cell.citations) && cell.citations.length > 0;
    return `<td class="rv-cell rv-cell-done" data-cell="${cell.id}">
      <div class="rv-cell-answer">${escapeHtml(ans)}</div>
      ${hasQuote ? '<div class="rv-cell-cite">▸ source</div>' : ''}
    </td>`;
  }

  function openCellDetail(cellId) {
    const cell = (gridState?.cells || []).find((c) => c.id === cellId);
    if (!cell) return;
    const doc = (gridState?.documents || []).find((d) => d.id === cell.document_id);
    const col = (gridState?.review?.columns_config || [])[cell.column_index];
    const isRedline = gridState?.review?.kind === 'redline';
    const detail = document.getElementById('rv-cell-detail');
    detail.hidden = false;

    if (isRedline) {
      detail.innerHTML = `
        <div class="attach-modal-inner rv-redline-detail">
          <header class="attach-modal-head">
            <h2 class="attach-modal-title">${escapeHtml(doc?.filename || '?')} · ${escapeHtml(col?.name || '?')}</h2>
            <button type="button" class="attach-modal-close" data-close>×</button>
          </header>
          <div class="attach-modal-body rv-redline-detail-body">
            <div class="rv-redline-side">
              <div class="rv-redline-rationale">
                <span class="rv-detail-label">Concern</span>
                <p>${escapeHtml(col?.prompt || '')}</p>
                <span class="rv-detail-label">Rationale</span>
                <p>${escapeHtml(cell.redline_rationale || cell.content || '')}</p>
              </div>
              <div class="rv-redline-diff">
                <span class="rv-detail-label">From</span>
                <blockquote class="rv-redline-from">${escapeHtml(cell.redline_find || '')}</blockquote>
                <span class="rv-detail-label">To</span>
                <blockquote class="rv-redline-to">${cell.redline_replace ? escapeHtml(cell.redline_replace) : '<em>(deletion)</em>'}</blockquote>
              </div>
              <div class="rv-redline-actions">
                <button type="button" class="rv-cell-acc${cell.redline_status === 'accepted' ? ' is-on' : ''}" data-cell-action="accepted" data-cell="${cell.id}">✓ Accept</button>
                <button type="button" class="rv-cell-rej${cell.redline_status === 'rejected' ? ' is-on' : ''}" data-cell-action="rejected" data-cell="${cell.id}">× Reject</button>
              </div>
            </div>
            <div class="rv-redline-preview">
              <span class="rv-detail-label">In-document preview</span>
              <div id="rv-doc-preview" class="rv-doc-preview"><div class="ws-empty">Loading document…</div></div>
            </div>
          </div>
        </div>`;
      detail.querySelector('[data-close]').addEventListener('click', () => detail.hidden = true);
      detail.addEventListener('click', (e) => { if (e.target === detail) detail.hidden = true; });

      // Wire accept/reject from inside the modal
      detail.querySelectorAll('[data-cell-action]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const status = btn.dataset.cellAction;
          await fetch('/.netlify/functions/workspace-tr-cell-update', {
            method: 'POST',
            headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: cell.id, redline_status: status }),
          });
          cell.redline_status = status;
          // Toggle visual state
          detail.querySelector('.rv-cell-acc').classList.toggle('is-on', status === 'accepted');
          detail.querySelector('.rv-cell-rej').classList.toggle('is-on', status === 'rejected');
          drawGrid();
        });
      });

      // Render the document preview with the edit highlighted
      renderDocPreview(doc, cell);
      return;
    }

    // Extraction mode (unchanged)
    const cite = (cell.citations || [])[0];
    detail.innerHTML = `
      <div class="attach-modal-inner">
        <header class="attach-modal-head">
          <h2 class="attach-modal-title">Cell detail</h2>
          <button type="button" class="attach-modal-close" data-close>×</button>
        </header>
        <div class="attach-modal-body rv-detail-body">
          <div class="rv-detail-meta">
            <strong>${escapeHtml(doc?.filename || '?')}</strong> · ${escapeHtml(col?.name || '?')}
          </div>
          <div class="rv-detail-q"><span class="rv-detail-label">Question</span><div>${escapeHtml(col?.prompt || '')}</div></div>
          <div class="rv-detail-a"><span class="rv-detail-label">Answer</span><div>${escapeHtml(cell.content || '')}</div></div>
          ${cite ? `<div class="rv-detail-quote"><span class="rv-detail-label">Source quote ${cite.page ? `(p. ${cite.page})` : ''}</span><blockquote>${escapeHtml(cite.quote || '')}</blockquote></div>` : ''}
          ${cell.status === 'error' && cell.status_detail ? `<div class="rv-detail-err"><span class="rv-detail-label">Error</span><pre>${escapeHtml(cell.status_detail)}</pre></div>` : ''}
        </div>
      </div>`;
    detail.querySelector('[data-close]').addEventListener('click', () => detail.hidden = true);
    detail.addEventListener('click', (e) => { if (e.target === detail) detail.hidden = true; });
  }

  // ---- In-doc preview ----
  // Fetch the original .docx for this document, run mammoth.js
  // (loaded via CDN in the head) to convert it to HTML, then locate
  // the cell's redline_find string in the rendered HTML and wrap it
  // in a highlight span so the user sees exactly where the edit
  // lands. Scrolls the container so the highlight is centered.
  const _docPreviewCache = {};
  async function renderDocPreview(doc, cell) {
    const target = document.getElementById('rv-doc-preview');
    if (!target) return;
    try {
      let html = _docPreviewCache[doc.id];
      if (!html) {
        const supa = (await import('../../../lib/supabase')).getSupabase();
        // Get the ORIGINAL upload version (we want the unmodified
        // text so the find string matches verbatim).
        const { data: versions } = await supa
          .from('workspace_document_versions')
          .select('storage_path, source')
          .eq('document_id', doc.id)
          .eq('source', 'upload')
          .order('version_number', { ascending: true })
          .limit(1);
        const path = versions?.[0]?.storage_path;
        if (!path) { target.innerHTML = '<div class="ws-empty">Original version not found.</div>'; return; }
        const { data: signed } = await supa.storage.from('library').createSignedUrl(path, 600);
        if (!signed?.signedUrl) { target.innerHTML = '<div class="ws-empty">Could not load document.</div>'; return; }
        const res = await fetch(signed.signedUrl);
        const ab = await res.arrayBuffer();
        if (typeof window.mammoth === 'undefined') {
          target.innerHTML = '<div class="ws-empty">Preview engine failed to load.</div>';
          return;
        }
        const result = await window.mammoth.convertToHtml({ arrayBuffer: ab });
        html = result.value || '';
        _docPreviewCache[doc.id] = html;
      }
      target.innerHTML = `<div class="rv-doc-preview-page">${html}</div>`;

      // Highlight the find_text in the rendered HTML
      const findText = cell.redline_find;
      if (findText) {
        highlightFindIn(target, findText, cell.redline_replace || '');
      }
    } catch (err) {
      target.innerHTML = `<div class="ws-empty">Preview failed: ${escapeHtml(err.message || String(err))}</div>`;
    }
  }

  function highlightFindIn(container, find, replace) {
    // Walk text nodes, locate the first occurrence of the find
    // string, wrap it in a highlight span with the replacement
    // shown as a tooltip.
    const treeWalker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT);
    const candidates = [];
    let node;
    while ((node = treeWalker.nextNode())) {
      candidates.push(node);
    }
    // Try exact match first; if not found, normalize whitespace.
    const tryMatch = (haystackFn) => {
      for (const t of candidates) {
        const idx = haystackFn(t.nodeValue || '').indexOf(haystackFn(find));
        if (idx !== -1) {
          // Found in this text node — split and wrap
          const text = t.nodeValue;
          const realIdx = (t.nodeValue.indexOf(find) !== -1) ? t.nodeValue.indexOf(find) : idx;
          const before = text.slice(0, realIdx);
          const matched = text.slice(realIdx, realIdx + find.length);
          const after = text.slice(realIdx + find.length);
          const span = document.createElement('span');
          span.className = 'rv-doc-highlight';
          span.title = replace ? `→ ${replace.slice(0, 240)}` : '(delete)';
          span.textContent = matched;
          const parent = t.parentNode;
          parent.insertBefore(document.createTextNode(before), t);
          parent.insertBefore(span, t);
          parent.insertBefore(document.createTextNode(after), t);
          parent.removeChild(t);
          // Scroll into view
          setTimeout(() => span.scrollIntoView({ block: 'center', behavior: 'smooth' }), 50);
          return true;
        }
      }
      return false;
    };
    if (tryMatch((s) => s)) return;
    // Whitespace-normalized fallback
    if (tryMatch((s) => s.replace(/\s+/g, ' '))) return;
    // Couldn't find — show a banner
    const banner = document.createElement('div');
    banner.className = 'rv-doc-nofind';
    banner.textContent = `Could not locate "${find.slice(0, 100)}${find.length > 100 ? '…' : ''}" in the rendered preview. The redline engine may still find it in the .docx.`;
    container.prepend(banner);
  }

  let pollTimer = null;
  // Tracks whether the current poll cycle has already notified the
  // user. Without this we'd fire on every refresh after completion.
  let _notifiedReviewId = null;
  async function pollLoop(id) {
    if (pollTimer) clearTimeout(pollTimer);
    if (!gridState) return;
    const status = gridState.review?.status;
    if (status === 'complete' || status === 'error' || status === 'partial') {
      // One last refresh in case the inline doc view is open.
      if (livePreviewState) refreshLivePreview();
      if (currentView === 'doc') refreshDocViewFindings();
      // Walk-away ping — fire a browser notification ONCE per review
      // when it transitions to a terminal state. Permission must have
      // been granted earlier (we ask when the run starts). No-op if
      // not granted.
      if (_notifiedReviewId !== id && window.siteNotify && document.visibilityState !== 'visible') {
        _notifiedReviewId = id;
        const r = gridState.review || {};
        const cellsForReview = (gridState.cells || []).filter((c) => c.review_id === id);
        const accepted = cellsForReview.filter((c) => c.redline_status === 'accepted').length;
        const isOk = status !== 'error';
        const titleText = isOk ? 'Review complete' : 'Review failed';
        const body = isOk
          ? `${r.title || 'Your review'} — ${cellsForReview.length} finding${cellsForReview.length === 1 ? '' : 's'}${accepted ? ` · ${accepted} ready to apply` : ''}. Click to open.`
          : `${r.title || 'Your review'} — ${r.status_detail || 'something went wrong'}. Click to open.`;
        window.siteNotify.fire(titleText, {
          body,
          tag: `tr-review-${id}`,
          urgency: !isOk,
          onClick: () => {
            try { window.focus(); } catch {}
            const main = document.getElementById('rv-main');
            if (main) main.scrollIntoView({ behavior: 'smooth', block: 'start' });
          },
        });
      }
      return;
    }
    pollTimer = setTimeout(async () => {
      await loadGrid(id);
      if (livePreviewState) refreshLivePreview();
      if (currentView === 'doc') refreshDocViewFindings();
      pollLoop(id);
    }, 2500);
  }

  // ---- Live preview ----
  // Full-screen view of one document with findings streaming in as
  // the LLM completes each cell. The doc renders once via mammoth,
  // and each new finding gets a pulse animation when it arrives.
  // Sidebar lists findings; click to scroll, accept/reject inline.
  let livePreviewState = null;   // { docId, overlay, seenCellIds: Set }

  function openLivePreview(docId, docName) {
    const overlay = document.createElement('div');
    overlay.className = 'attach-modal rv-live-modal';
    overlay.innerHTML = `
      <div class="rv-live-inner">
        <header class="rv-live-head">
          <button type="button" class="rv-live-close" data-close>← Back to grid</button>
          <h2 class="rv-live-title">${escapeHtml(docName)}</h2>
          <div class="rv-live-progress" id="rv-live-progress">…</div>
          <button type="button" id="rv-live-finalize" class="ws-btn">Apply accepted</button>
        </header>
        <div class="rv-live-body">
          <aside class="rv-live-side">
            <div class="rv-live-side-head">Findings</div>
            <div id="rv-live-findings" class="rv-live-findings"></div>
          </aside>
          <main class="rv-live-doc">
            <div id="rv-live-scanner" class="rv-live-scanner"></div>
            <div id="rv-live-doc-body" class="rv-doc-preview rv-live-doc-body"><div class="ws-empty">Loading document…</div></div>
          </main>
        </div>
      </div>`;
    document.body.appendChild(overlay);
    overlay.querySelector('[data-close]').addEventListener('click', closeLivePreview);

    livePreviewState = { docId, docName, overlay, seenCellIds: new Set() };

    // Fetch + render the document body once
    renderLiveDocBody(docId);
    refreshLivePreview();

    overlay.querySelector('#rv-live-finalize').addEventListener('click', async () => {
      const review = gridState?.review;
      const acceptedCount = (gridState?.cells || []).filter(
        (c) => c.document_id === docId && c.redline_status === 'accepted',
      ).length;
      if (!acceptedCount) { alert('Mark at least one finding as accepted first.'); return; }
      const btn = overlay.querySelector('#rv-live-finalize');
      btn.disabled = true; btn.textContent = 'Applying…';
      const r = await fetch('/.netlify/functions/workspace-tr-finalize-doc', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ review_id: review.id, document_id: docId }),
      });
      const j = await r.json();
      if (!r.ok) { alert('Failed: ' + (j.error || 'unknown')); btn.disabled = false; btn.textContent = 'Apply accepted'; return; }
      // Trigger download
      const sb = (await import('../../../lib/supabase')).getSupabase();
      const { data: signed } = await sb.storage.from('library').createSignedUrl(j.version.storage_path, 600);
      if (signed?.signedUrl) {
        const link = document.createElement('a');
        link.href = signed.signedUrl;
        link.download = `${docName.replace(/\.docx$/i, '')} (final).docx`;
        link.click();
      }
      btn.textContent = '✓ Applied';
      await loadGrid(review.id);
      refreshLivePreview();
    });
  }

  function closeLivePreview() {
    livePreviewState?.overlay?.remove();
    livePreviewState = null;
  }

  async function renderLiveDocBody(docId) {
    const target = document.getElementById('rv-live-doc-body');
    if (!target) return;
    try {
      let html = _docPreviewCache[docId];
      if (!html) {
        const supa = (await import('../../../lib/supabase')).getSupabase();
        const { data: versions } = await supa
          .from('workspace_document_versions')
          .select('storage_path')
          .eq('document_id', docId)
          .eq('source', 'upload')
          .order('version_number', { ascending: true })
          .limit(1);
        const path = versions?.[0]?.storage_path;
        if (!path) throw new Error('Original version not found');
        const { data: signed } = await supa.storage.from('library').createSignedUrl(path, 600);
        const res = await fetch(signed.signedUrl);
        const ab = await res.arrayBuffer();
        const result = await window.mammoth.convertToHtml({ arrayBuffer: ab });
        html = result.value || '';
        _docPreviewCache[docId] = html;
      }
      target.innerHTML = `<div class="rv-doc-preview-page">${html}</div>`;
      // Now apply highlights for every existing complete redline cell
      // for this doc.
      refreshLivePreview();
    } catch (err) {
      target.innerHTML = `<div class="ws-empty">Preview failed: ${escapeHtml(err.message || String(err))}</div>`;
    }
  }

  function refreshLivePreview() {
    if (!livePreviewState || !gridState) return;
    const { docId } = livePreviewState;
    const review = gridState.review;
    const cellsForDoc = gridState.cells.filter((c) => c.document_id === docId);
    const cols = review.columns_config || [];

    // Update progress bar
    const total = cellsForDoc.length;
    const done = cellsForDoc.filter((c) => c.status === 'complete').length;
    const pendingDocCells = cellsForDoc.filter((c) => c.status === 'pending' || c.status === 'running').length;
    const progressEl = document.getElementById('rv-live-progress');
    if (progressEl) {
      progressEl.textContent = pendingDocCells > 0
        ? `Analyzing… ${done}/${total} concerns checked`
        : `${done}/${total} concerns checked · ${cellsForDoc.filter((c) => c.redline_find).length} findings`;
    }
    const scanner = document.getElementById('rv-live-scanner');
    if (scanner) scanner.classList.toggle('is-active', pendingDocCells > 0);

    // Render findings sidebar
    const findingsEl = document.getElementById('rv-live-findings');
    if (findingsEl) {
      const findings = cellsForDoc
        .filter((c) => c.status === 'complete')
        .sort((a, b) => a.column_index - b.column_index);
      if (findings.length === 0 && pendingDocCells > 0) {
        findingsEl.innerHTML = '<div class="ws-empty">Scanning the document…</div>';
      } else if (findings.length === 0) {
        findingsEl.innerHTML = '<div class="ws-empty">No findings.</div>';
      } else {
        findingsEl.innerHTML = findings.map((c) => {
          const col = cols[c.column_index];
          const status = c.redline_status || 'pending';
          const stClass = status === 'accepted' ? ' is-accepted' : status === 'rejected' ? ' is-rejected' : '';
          if (!c.redline_find) {
            return `<div class="rv-live-finding rv-live-finding-na" data-cell="${c.id}">
              <div class="rv-live-finding-col">${escapeHtml(col?.name || '?')}</div>
              <div class="rv-live-finding-na-text">Not present in document</div>
            </div>`;
          }
          return `<div class="rv-live-finding${stClass}" data-cell="${c.id}" data-find="${escapeHtml(c.redline_find)}">
            <div class="rv-live-finding-col">${escapeHtml(col?.name || '?')}</div>
            <div class="rv-live-finding-rationale">${escapeHtml(c.redline_rationale || c.content || '')}</div>
            <div class="rv-live-finding-diff">
              <div class="rv-live-finding-from">${escapeHtml(c.redline_find.slice(0, 200))}${c.redline_find.length > 200 ? '…' : ''}</div>
              <div class="rv-live-finding-arrow">→</div>
              <div class="rv-live-finding-to">${c.redline_replace ? escapeHtml(c.redline_replace.slice(0, 200)) + (c.redline_replace.length > 200 ? '…' : '') : '<em>(delete)</em>'}</div>
            </div>
            <div class="rv-live-finding-actions">
              <button type="button" class="rv-cell-acc${status === 'accepted' ? ' is-on' : ''}" data-cell-action="accepted" data-cell="${c.id}">✓ Accept</button>
              <button type="button" class="rv-cell-rej${status === 'rejected' ? ' is-on' : ''}" data-cell-action="rejected" data-cell="${c.id}">× Reject</button>
              <button type="button" class="rv-cell-refine-btn" data-refine-cell="${c.id}" title="Ask AI to revise this proposal">Refine</button>
              <button type="button" class="save-to-vault-btn rv-cell-save-vault" data-vault-save-cell="${c.id}" title="Save this finding to your Vault"><span>Save</span></button>
            </div>
            <div class="rv-cell-refine-form" data-refine-form="${c.id}" hidden>
              <textarea class="rv-cell-refine-input" placeholder="Tell the AI how to revise this. e.g. 'make it stronger', 'use the phrase work made for hire', 'add a 60-day cure period'."></textarea>
              <div class="rv-cell-refine-actions">
                <button type="button" class="rv-cell-refine-cancel">Cancel</button>
                <button type="button" class="rv-cell-refine-go ws-btn">Revise with AI</button>
              </div>
              <div class="rv-cell-refine-status" hidden></div>
            </div>
          </div>`;
        }).join('');

        findingsEl.querySelectorAll('[data-cell-action]').forEach((btn) => {
          btn.addEventListener('click', async (e) => {
            e.stopPropagation();
            const cellId = btn.dataset.cell;
            const status = btn.dataset.cellAction;
            await fetch('/.netlify/functions/workspace-tr-cell-update', {
              method: 'POST',
              headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: cellId, redline_status: status }),
            });
            const cell = gridState.cells.find((x) => x.id === cellId);
            if (cell) cell.redline_status = status;
            refreshLivePreview();
          });
        });

        // Click finding → scroll to highlight in doc
        findingsEl.querySelectorAll('[data-find]').forEach((row) => {
          row.addEventListener('click', () => {
            const find = row.dataset.find;
            const span = document.querySelector(`#rv-live-doc-body [data-finding-find="${cssEscape(find)}"]`);
            span?.scrollIntoView({ block: 'center', behavior: 'smooth' });
          });
        });
      }
    }

    // Highlight new findings on the doc body. Each cell that just
    // completed and has a find_text gets wrapped in a span; existing
    // ones stay highlighted with their accepted/rejected class.
    const body = document.getElementById('rv-live-doc-body');
    if (body && body.querySelector('.rv-doc-preview-page')) {
      for (const c of cellsForDoc) {
        if (!c.redline_find || c.status !== 'complete') continue;
        const existing = body.querySelector(`[data-cell="${c.id}"]`);
        if (existing) {
          // Update class to reflect current redline_status
          existing.className = `rv-doc-finding-highlight is-${c.redline_status || 'pending'}`;
          continue;
        }
        // New finding — try to highlight in the doc with a pulse
        const isPulse = !livePreviewState.seenCellIds.has(c.id);
        livePreviewState.seenCellIds.add(c.id);
        highlightLiveFinding(body, c, isPulse);
      }
    }

    // Apply button counter
    const accepted = cellsForDoc.filter((c) => c.redline_status === 'accepted').length;
    const finalBtn = document.getElementById('rv-live-finalize');
    if (finalBtn) {
      finalBtn.textContent = accepted ? `Apply ${accepted} accepted` : 'Apply accepted';
      finalBtn.disabled = accepted === 0;
    }
  }

  function highlightLiveFinding(container, cell, pulse) {
    // Inserts TWO sibling spans wrapping the find text + an
    // insertion of the replacement text right after it. CSS controls
    // visibility/styling per status:
    //   pending  — find: yellow highlight,        insert: hidden
    //   accepted — find: red strikethrough,       insert: green underline (Word track-changes look)
    //   rejected — find: plain (no markup),       insert: hidden
    //   extraction (read-only) — find: blue, insert: hidden
    const find = cell.redline_find;
    if (!find) return;
    const treeWalker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT);
    const candidates = [];
    let node;
    while ((node = treeWalker.nextNode())) candidates.push(node);
    for (const t of candidates) {
      const text = t.nodeValue || '';
      const idx = text.indexOf(find);
      if (idx === -1) continue;
      const before = text.slice(0, idx);
      const matched = text.slice(idx, idx + find.length);
      const after = text.slice(idx + find.length);

      const status = cell.redline_status || 'pending';
      const findSpan = document.createElement('span');
      findSpan.className = `rv-rdln-find is-${status}${pulse ? ' is-pulse' : ''}`;
      findSpan.dataset.cell = cell.id;
      findSpan.dataset.findingFind = find;
      findSpan.textContent = matched;
      findSpan.title = cell.redline_rationale || '';

      const insSpan = document.createElement('span');
      insSpan.className = `rv-rdln-ins is-${status}`;
      insSpan.dataset.cell = cell.id;
      insSpan.textContent = cell.redline_replace || '';

      const parent = t.parentNode;
      parent.insertBefore(document.createTextNode(before), t);
      parent.insertBefore(findSpan, t);
      parent.insertBefore(insSpan, t);
      parent.insertBefore(document.createTextNode(after), t);
      parent.removeChild(t);

      if (pulse) {
        setTimeout(() => findSpan.scrollIntoView({ block: 'center', behavior: 'smooth' }), 80);
        setTimeout(() => findSpan.classList.remove('is-pulse'), 2200);
      }
      return;
    }
  }

  // CSS.escape polyfill for older browsers
  function cssEscape(s) {
    if (window.CSS && CSS.escape) return CSS.escape(s);
    return String(s).replace(/["\\]/g, '\\$&');
  }

  // Used when a risk quote isn't already a registered finding
  // highlight — locates the text in the rendered doc and scrolls +
  // flashes a one-off temporary span so the eye finds it.
  function flashTextInDoc(quote) {
    if (!quote) return;
    const container = document.getElementById('rv-live-doc-body');
    if (!container) return;
    const treeWalker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT);
    const candidates = [];
    let node;
    while ((node = treeWalker.nextNode())) candidates.push(node);
    for (const t of candidates) {
      const text = t.nodeValue || '';
      const idx = text.indexOf(quote);
      if (idx === -1) continue;
      const before = text.slice(0, idx);
      const matched = text.slice(idx, idx + quote.length);
      const after = text.slice(idx + quote.length);
      const span = document.createElement('span');
      span.className = 'rv-rdln-find is-extraction is-flash';
      span.textContent = matched;
      const parent = t.parentNode;
      parent.insertBefore(document.createTextNode(before), t);
      parent.insertBefore(span, t);
      parent.insertBefore(document.createTextNode(after), t);
      parent.removeChild(t);
      setTimeout(() => span.scrollIntoView({ block: 'center', behavior: 'smooth' }), 50);
      // Remove the temporary highlight after the flash
      setTimeout(() => {
        span.replaceWith(document.createTextNode(span.textContent || ''));
      }, 2200);
      return;
    }
  }

  // ============================================================
  // ROUTE
  // ============================================================
  if (reviewId) renderGridView(reviewId);
  else {
    await renderListView();
    // If we arrived from a "Use in review" workflow link, open the
    // new-review modal pre-filled with the workflow's columns.
    const prefillId = new URL(location.href).searchParams.get('prefill');
    if (prefillId) {
      const r = await fetch(`/.netlify/functions/workspace-workflows-get?id=${encodeURIComponent(prefillId)}`, {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (r.ok && j.workflow?.kind === 'tabular') {
        await openNewReviewModal({ prefillCols: j.workflow.columns_config || [], prefillTitle: j.workflow.title });
      }
    }
  }
</script>
</body>
</html>
