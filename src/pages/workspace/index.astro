---
// Workspace landing — chat list + new chat button.
// Auth + approval gated client-side; the page shell ships static and
// the gate runs in the script tag below before revealing the page.
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Workspace — Legal Overflow</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<script src="/nav-autohide.js" defer></script>
<script src="/site-dialog.js" defer></script>
<link rel="stylesheet" href="/workspace.css" />
</head>
<body>
<div id="grain"></div>

<header class="nav">
  <a href="/" class="brand">
    <svg class="brand-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="1"/><path d="M20 6 L20 34 M8 14 L32 14 M8 26 L32 26" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="20" cy="14" r="2.5" fill="currentColor"/><circle cx="20" cy="26" r="2.5" fill="var(--accent)"/></svg>
    <span class="brand-text"><span>Legal</span><span class="brand-over">Overflow</span></span>
  </a>
  <nav class="nav-links">
    <a href="/#skills">Skills</a>
    <a href="/#articles">Resources</a>
    <a href="/agents/">Agents</a>
    <a href="/workspace/" class="is-active">Workspace</a>
    <a href="/tracker/">Tracker</a>
    <a href="/#services">Services</a>
    <a href="/about/">About</a>
  </nav>
  <div class="nav-right">
    <a href="/account/" class="nav-sub">Account</a>
  </div>
</header>

<main class="ws-wrap">
  <header class="ws-head">
    <div>
      <div class="ws-kicker">Workspace</div>
      <h1 class="ws-title">Your research desk.</h1>
      <p class="ws-sub">Persistent multi-turn chats. Three model providers. Bring your own key if you want.</p>
    </div>
    <button id="new-chat" class="ws-btn">New chat</button>
  </header>

  <!-- Section nav — primary entry points. Sits above the chat list so
       the user can jump straight into the heavy tools. -->
  <nav class="ws-nav-tiles" aria-label="Workspace sections">
    <a href="/workspace/projects/" class="ws-nav-tile">
      <span class="ws-nav-tile-name">Projects</span>
      <span class="ws-nav-tile-desc">Folders for chats &amp; docs</span>
    </a>
    <a href="/workspace/library/" class="ws-nav-tile">
      <span class="ws-nav-tile-name">Library</span>
      <span class="ws-nav-tile-desc">Uploaded contracts &amp; PDFs</span>
    </a>
    <a href="/workspace/reviews/" class="ws-nav-tile">
      <span class="ws-nav-tile-name">Reviews</span>
      <span class="ws-nav-tile-desc">Extract, summarize, redline</span>
    </a>
    <a href="/workspace/compare/" class="ws-nav-tile">
      <span class="ws-nav-tile-name">Compare</span>
      <span class="ws-nav-tile-desc">Two-document side-by-side diff</span>
    </a>
    <a href="/workspace/workflows/" class="ws-nav-tile">
      <span class="ws-nav-tile-name">Workflows</span>
      <span class="ws-nav-tile-desc">Saved chat playbooks</span>
    </a>
  </nav>

  <!-- Pending-work strip — only visible when reviews/comparisons are
       running so the user knows something's in flight. Polls every 8s. -->
  <section id="dash-pending" class="ws-dash-pending" hidden>
    <span class="rv-spin"></span>
    <span id="dash-pending-text"></span>
  </section>

  <!-- Activity dashboard — last 4 of each: reviews, comparisons,
       uploads. Each row links to the section page. -->
  <section class="ws-dash-grid">
    <article class="ws-dash-card">
      <header class="ws-dash-card-head">
        <h2 class="ws-dash-card-title">Recent reviews</h2>
        <a href="/workspace/reviews/" class="ws-dash-link">View all →</a>
      </header>
      <ul id="dash-reviews" class="ws-dash-list"><li class="ws-dash-empty">Loading…</li></ul>
    </article>
    <article class="ws-dash-card">
      <header class="ws-dash-card-head">
        <h2 class="ws-dash-card-title">Recent comparisons</h2>
        <a href="/workspace/compare/" class="ws-dash-link">View all →</a>
      </header>
      <ul id="dash-compares" class="ws-dash-list"><li class="ws-dash-empty">Loading…</li></ul>
    </article>
    <article class="ws-dash-card">
      <header class="ws-dash-card-head">
        <h2 class="ws-dash-card-title">Recent uploads</h2>
        <a href="/workspace/library/" class="ws-dash-link">View all →</a>
      </header>
      <ul id="dash-library" class="ws-dash-list"><li class="ws-dash-empty">Loading…</li></ul>
    </article>
  </section>

  <!-- Projects strip — drop a chat row onto any chip to move that chat
       into the project. Click "+ New project" to create one inline. -->
  <section id="proj-strip" class="proj-strip" hidden>
    <span class="proj-strip-label">Drop a chat to move it →</span>
    <div id="proj-strip-chips" class="proj-strip-chips"></div>
  </section>

  <section class="ws-card">
    <header class="ws-card-head">
      <h2 class="ws-card-title">Recent chats</h2>
    </header>
    <div id="chat-list" class="ws-list">
      <!-- Skeleton placeholder shown until cache renders or first
           fetch completes. Replaces the old "Loading…" text. -->
      <div class="ws-row-wrap"><div class="ws-row"><span class="ws-row-title"><span class="sk-block sk-block-title" style="width:65%"></span></span><span class="ws-row-meta"><span class="sk-block sk-block-meta" style="width:40%"></span></span></div></div>
      <div class="ws-row-wrap"><div class="ws-row"><span class="ws-row-title"><span class="sk-block sk-block-title" style="width:75%"></span></span><span class="ws-row-meta"><span class="sk-block sk-block-meta" style="width:35%"></span></span></div></div>
      <div class="ws-row-wrap"><div class="ws-row"><span class="ws-row-title"><span class="sk-block sk-block-title" style="width:55%"></span></span><span class="ws-row-meta"><span class="sk-block sk-block-meta" style="width:45%"></span></span></div></div>
    </div>
  </section>

  <p class="ws-foot">
    <a href="/account/">API keys →</a>
  </p>
</main>

<footer class="foot">
  <p class="foot-bar-disclosure">
    <strong>Blake Beyel, Esq.</strong> · Florida Bar No. 1065044 · Cocoa, Florida ·
    The hiring of a lawyer is an important decision that should not be based solely on advertisements.
    Before you decide, ask for written information about the lawyer's qualifications and experience.
    No representation is made that the quality of the legal services to be performed is greater than
    the quality of legal services performed by other lawyers.
  </p>
  <div class="foot-bot"><span>© 2026 Legal Overflow</span><span class="foot-version">v2026.04<a href="/admin/users/" class="foot-admin-link" aria-label="Admin"></a></span></div>
</footer>

<script>
  import { getSupabase } from '../../lib/supabase';

  const supabase = getSupabase();

  // Auth gate: signed-in + approved. We hide the body upfront so a
  // non-approved user never glimpses the workspace UI shell. Anything
  // that throws below MUST land in the catch and reveal an error
  // panel — otherwise the page sits blank forever and the user has no
  // idea why.
  document.body.style.visibility = 'hidden';
  let session = null;
  try {
    const { data, error } = await supabase.auth.getSession();
    if (error) throw error;
    session = data?.session || null;
    if (!session) {
      location.href = '/login/?redirect=/workspace/';
      throw new Error('not signed in — redirecting');
    }
    const { data: profile, error: profileErr } = await supabase
      .from('profiles').select('tier, approved_at').eq('id', session.user.id).maybeSingle();
    if (profileErr) throw profileErr;
    if (!profile) {
      document.body.style.visibility = '';
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">No profile</h1><p>We could not find a profile for your account. This usually means signup did not finish. Try signing out and creating the account again, or contact the operator.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('no profile');
    }
    if (!profile.approved_at) {
      document.body.style.visibility = '';
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Pending approval</h1><p>Your account is pending operator approval. We review every signup before granting workspace access.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('pending approval');
    }
    document.body.style.visibility = '';
  } catch (err) {
    // If something unexpected blew up, surface it instead of leaving
    // a blank page. Re-throw at the end so dev tools still see it.
    if (err && err.message && !['pending approval','no profile','not signed in — redirecting'].includes(err.message)) {
      console.error('Workspace gate failed:', err);
      document.body.style.visibility = '';
      document.body.innerHTML = `<main style="max-width:680px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Workspace error</h1><p>The workspace failed to load. Open your browser console for full details.</p><pre style="background:#f5f5f5;padding:14px;border-radius:6px;font-size:12px;white-space:pre-wrap;word-break:break-word">${(err && err.message ? err.message : String(err)).replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]))}</pre><p><a href="/">Back to homepage</a></p></main>`;
    }
    throw err;
  }

  const chatList = document.getElementById('chat-list');
  const newChatBtn = document.getElementById('new-chat');
  const accessToken = session.access_token;

  // Same localStorage cache key as the chat page. Renders immediately
  // on reload so the chat list is never visibly empty during the
  // network round-trip; the fresh fetch overwrites it.
  const RAIL_CACHE_KEY = 'workspace.rail.' + (session.user?.id || 'anon');

  function renderChats(chats) {
    if (!chats?.length) {
      chatList.innerHTML = '<div class="ws-empty">No chats yet. Click "New chat" above to start one.</div>';
      return;
    }
    chatList.innerHTML = chats.map((c) => {
      const title = (c.title || 'Untitled chat').replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]));
      const date = new Date(c.updated_at).toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' });
      const projBadge = c.project_id ? `<span class="ws-row-proj-badge" title="In a project">●</span>` : '';
      // Each row is draggable for the project strip drop-zones above.
      // The anchor inside is kept clickable for navigation; the drag
      // handler lives on the wrap so the user can grab any part.
      return `<div class="ws-row-wrap" draggable="true" data-chat-id="${c.id}">
        <a href="/workspace/chat/?id=${c.id}" class="ws-row">
          <span class="ws-row-title">${projBadge}${title}</span>
          <span class="ws-row-meta">${c.model || ''} · ${date}</span>
        </a>
        <button type="button" class="ws-row-del" data-del="${c.id}" data-title="${title}" aria-label="Delete chat" title="Delete chat">×</button>
      </div>`;
    }).join('');

    // Wire drag handlers
    chatList.querySelectorAll('[data-chat-id]').forEach((row) => {
      row.addEventListener('dragstart', (e) => {
        e.dataTransfer.setData('text/chat-id', row.dataset.chatId);
        e.dataTransfer.effectAllowed = 'move';
        row.classList.add('is-dragging');
      });
      row.addEventListener('dragend', () => row.classList.remove('is-dragging'));
    });

    // Wire delete handlers
    chatList.querySelectorAll('[data-del]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.dataset.del;
        const title = btn.dataset.title;
        if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;
        btn.disabled = true;
        const r = await fetch('/.netlify/functions/workspace-chats-delete', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          alert('Delete failed: ' + (j.error || 'unknown'));
          btn.disabled = false;
          return;
        }
        // Invalidate cache and refetch
        try { localStorage.removeItem(RAIL_CACHE_KEY); } catch {}
        loadChats();
      });
    });
  }
  function renderFromCache() {
    try {
      const raw = localStorage.getItem(RAIL_CACHE_KEY);
      if (!raw) return false;
      const cached = JSON.parse(raw);
      if (!Array.isArray(cached) || cached.length === 0) return false;
      renderChats(cached);
      return true;
    } catch { return false; }
  }
  async function loadChats() {
    const r = await fetch('/.netlify/functions/workspace-chats-list', {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) {
      chatList.innerHTML = `<div class="ws-empty">Failed to load chats: ${j.error || 'unknown'}</div>`;
      return;
    }
    const chats = j.chats || [];
    renderChats(chats);
    try { localStorage.setItem(RAIL_CACHE_KEY, JSON.stringify(chats)); } catch {}
  }

  async function createChat() {
    newChatBtn.disabled = true;
    const r = await fetch('/.netlify/functions/workspace-chats-create', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({}),
    });
    const j = await r.json();
    newChatBtn.disabled = false;
    if (!r.ok) {
      alert('Failed to create chat: ' + (j.error || 'unknown'));
      return;
    }
    location.href = `/workspace/chat/?id=${j.id}`;
  }

  newChatBtn.addEventListener('click', createChat);

  // ---- Project strip (drag chats onto a project to move them) ----
  const stripEl = document.getElementById('proj-strip');
  const stripChips = document.getElementById('proj-strip-chips');
  async function loadProjectStrip() {
    const r = await fetch('/.netlify/functions/workspace-projects-list', {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) return;
    const projects = j.projects || [];
    if (!projects.length) {
      stripEl.hidden = false;
      stripChips.innerHTML = `<button type="button" class="proj-strip-new">+ New project</button>`;
      stripChips.querySelector('.proj-strip-new').addEventListener('click', createInlineProject);
      return;
    }
    stripEl.hidden = false;
    stripChips.innerHTML = projects.map((p) => {
      const c = p.counts || {};
      return `<a href="/workspace/projects/?id=${p.id}" class="proj-strip-chip" data-proj-drop="${p.id}" title="${(c.chats || 0) + ' chats · ' + (c.documents || 0) + ' docs'}">${(p.name || '').replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]))}</a>`;
    }).join('') + `<button type="button" class="proj-strip-new">+ New</button>`;
    stripChips.querySelector('.proj-strip-new').addEventListener('click', createInlineProject);
    // Wire drop targets
    stripChips.querySelectorAll('[data-proj-drop]').forEach((chip) => {
      chip.addEventListener('dragover', (e) => {
        if (e.dataTransfer.types.includes('text/chat-id')) {
          e.preventDefault();
          chip.classList.add('is-drop-target');
        }
      });
      chip.addEventListener('dragleave', () => chip.classList.remove('is-drop-target'));
      chip.addEventListener('drop', async (e) => {
        e.preventDefault();
        chip.classList.remove('is-drop-target');
        const chatId = e.dataTransfer.getData('text/chat-id');
        const projectId = chip.dataset.projDrop;
        if (!chatId) return;
        await fetch('/.netlify/functions/workspace-chats-update', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: chatId, project_id: projectId }),
        });
        try { localStorage.removeItem(RAIL_CACHE_KEY); } catch {}
        loadChats();
      });
    });
  }
  // Inline-edit project creation. Swaps the "+ New" button for a
  // small input field; Enter creates, Esc cancels. Avoids the
  // native browser prompt() dialog which feels disconnected from
  // the page.
  function createInlineProject() {
    const newBtn = stripChips.querySelector('.proj-strip-new');
    if (!newBtn) return;
    if (newBtn.classList.contains('is-editing')) return;   // already open
    const wrap = document.createElement('span');
    wrap.className = 'proj-strip-newform';
    wrap.innerHTML = `<input type="text" class="proj-strip-newinput" placeholder="Project name" maxlength="200" />`;
    newBtn.replaceWith(wrap);
    const input = wrap.querySelector('input');
    input.focus();

    const cancel = () => {
      const restore = document.createElement('button');
      restore.type = 'button';
      restore.className = 'proj-strip-new';
      restore.textContent = '+ New';
      restore.addEventListener('click', createInlineProject);
      wrap.replaceWith(restore);
    };
    const create = async () => {
      const name = input.value.trim();
      if (!name) { cancel(); return; }
      input.disabled = true;
      const r = await fetch('/.netlify/functions/workspace-projects-create', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      const j = await r.json();
      if (!r.ok) { input.disabled = false; input.classList.add('is-error'); input.title = j.error || 'failed'; return; }
      loadProjectStrip();
    };
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); create(); }
      else if (e.key === 'Escape') cancel();
    });
    input.addEventListener('blur', () => {
      // small delay so click on a sibling element doesn't double-fire
      setTimeout(() => { if (document.contains(input) && !input.disabled) cancel(); }, 120);
    });
  }

  // ---- Dashboard tiles: reviews / comparisons / uploads ----
  // All three list endpoints fire in parallel — the grid populates
  // independently. If any one fails the others still render.
  const STATUS_CLASS = {
    complete: 'rv-status-done',
    running: 'rv-status-run',
    error: 'rv-status-err',
    pending: 'rv-status-pen',
  };
  function statusPill(status) {
    const cls = STATUS_CLASS[status] || 'rv-status-pen';
    return `<span class="rv-status-pill ${cls}">${escapeAttr(status)}</span>`;
  }
  function escapeAttr(s) {
    return String(s ?? '').replace(/[<>&"]/g, (c) => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
  }
  function relTime(iso) {
    if (!iso) return '';
    const ms = Date.now() - new Date(iso).getTime();
    if (ms < 60_000) return 'just now';
    if (ms < 3_600_000) return `${Math.floor(ms / 60_000)}m ago`;
    if (ms < 86_400_000) return `${Math.floor(ms / 3_600_000)}h ago`;
    if (ms < 7 * 86_400_000) return `${Math.floor(ms / 86_400_000)}d ago`;
    return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  }
  function fmtBytes(n) {
    if (!n) return '';
    if (n < 1024) return n + ' B';
    if (n < 1024 * 1024) return (n / 1024).toFixed(0) + ' KB';
    return (n / (1024 * 1024)).toFixed(1) + ' MB';
  }

  let reviewsCache = [];
  let comparesCache = [];

  // ---- Cache-first fetch helper ----
  // Renders the cached data instantly (no "Loading…" flash), then
  // refreshes from the server in the background and re-renders. If
  // there's no cache yet, renders a skeleton placeholder. The
  // cache key is user-scoped so multi-account testing doesn't bleed.
  const USER_TAG = '.' + (session.user?.id || 'anon');
  function dashSkeletonRows(n) {
    return Array.from({length: n}, () => `<li class="ws-dash-row">
      <div class="sk-block sk-block-title" style="width:78%"></div>
      <div class="sk-block sk-block-meta" style="width:42%"></div>
    </li>`).join('');
  }
  async function cachedListLoad({ cacheKey, fetchUrl, renderData, skeleton, errorEl }) {
    let renderedSomething = false;
    try {
      const raw = localStorage.getItem(cacheKey);
      if (raw) {
        const cached = JSON.parse(raw);
        if (cached) { renderData(cached); renderedSomething = true; }
      }
    } catch {}
    if (!renderedSomething && typeof skeleton === 'function') skeleton();
    try {
      const r = await fetch(fetchUrl, { headers: { Authorization: `Bearer ${accessToken}` } });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'failed');
      renderData(j);
      try { localStorage.setItem(cacheKey, JSON.stringify(j)); } catch {}
    } catch (e) {
      // Don't blow away cached content if we already had something visible.
      if (!renderedSomething && errorEl) {
        errorEl.innerHTML = `<li class="ws-dash-empty">Failed: ${escapeAttr(e.message)}</li>`;
      }
    }
  }

  async function loadDashReviews() {
    const el = document.getElementById('dash-reviews');
    return cachedListLoad({
      cacheKey: 'workspace.dash.reviews' + USER_TAG,
      fetchUrl: '/.netlify/functions/workspace-tr-list',
      skeleton: () => { el.innerHTML = dashSkeletonRows(3); },
      errorEl: el,
      renderData: (j) => {
        const items = (j.reviews || []).slice(0, 4);
        reviewsCache = j.reviews || [];
        if (!items.length) {
          el.innerHTML = '<li class="ws-dash-empty">No reviews yet. <a href="/workspace/reviews/">Start one →</a></li>';
        } else {
          el.innerHTML = items.map((rv) => `<li class="ws-dash-row">
            <a href="/workspace/reviews/?id=${rv.id}" class="ws-dash-row-link">
              <span class="ws-dash-row-title">${escapeAttr(rv.title)}</span>
              <span class="ws-dash-row-meta">${statusPill(rv.status)}<span class="ws-dash-row-time">${relTime(rv.updated_at)}</span></span>
            </a>
          </li>`).join('');
        }
        updatePendingStrip();
      },
    });
  }

  async function loadDashCompares() {
    const el = document.getElementById('dash-compares');
    return cachedListLoad({
      cacheKey: 'workspace.dash.compares' + USER_TAG,
      fetchUrl: '/.netlify/functions/workspace-compare-list',
      skeleton: () => { el.innerHTML = dashSkeletonRows(3); },
      errorEl: el,
      renderData: (j) => {
        const items = (j.runs || []).slice(0, 4);
        comparesCache = j.runs || [];
        if (!items.length) {
          el.innerHTML = '<li class="ws-dash-empty">No comparisons yet. <a href="/workspace/compare/">Run one →</a></li>';
        } else {
          el.innerHTML = items.map((rv) => `<li class="ws-dash-row">
            <a href="/workspace/compare/?id=${rv.id}" class="ws-dash-row-link">
              <span class="ws-dash-row-title">${escapeAttr(rv.title)}</span>
              <span class="ws-dash-row-meta">${statusPill(rv.status)}${rv.diffs_count ? `<span class="ws-dash-row-time">${rv.diffs_count} diffs</span>` : ''}<span class="ws-dash-row-time">${relTime(rv.updated_at)}</span></span>
            </a>
          </li>`).join('');
        }
        updatePendingStrip();
      },
    });
  }

  async function loadDashLibrary() {
    const el = document.getElementById('dash-library');
    return cachedListLoad({
      cacheKey: 'workspace.dash.library' + USER_TAG,
      fetchUrl: '/.netlify/functions/workspace-library-list?limit=4',
      skeleton: () => { el.innerHTML = dashSkeletonRows(3); },
      errorEl: el,
      renderData: (j) => {
        const items = (j.documents || []).slice(0, 4);
        if (!items.length) {
          el.innerHTML = '<li class="ws-dash-empty">No documents yet. <a href="/workspace/library/">Upload →</a></li>';
        } else {
          el.innerHTML = items.map((d) => `<li class="ws-dash-row">
            <a href="/workspace/library/?id=${d.id}" class="ws-dash-row-link">
              <span class="ws-dash-row-title">${escapeAttr(d.filename)}</span>
              <span class="ws-dash-row-meta">${d.size_bytes ? `<span class="ws-dash-row-time">${fmtBytes(d.size_bytes)}</span>` : ''}<span class="ws-dash-row-time">${relTime(d.updated_at)}</span></span>
            </a>
          </li>`).join('');
        }
      },
    });
  }

  // Pending-work strip — surfaces in-flight background work so the
  // user can see at a glance "something's running, come back in a
  // minute." Only shown if at least one review or comparison is
  // pending or running.
  function updatePendingStrip() {
    const strip = document.getElementById('dash-pending');
    const txt = document.getElementById('dash-pending-text');
    const inflight = [
      ...reviewsCache.filter((r) => r.status === 'pending' || r.status === 'running').map((r) => ({ kind: 'review', id: r.id, title: r.title, status: r.status })),
      ...comparesCache.filter((r) => r.status === 'pending' || r.status === 'running').map((r) => ({ kind: 'comparison', id: r.id, title: r.title, status: r.status })),
    ];
    if (!inflight.length) { strip.hidden = true; return; }
    strip.hidden = false;
    const pieces = inflight.slice(0, 3).map((it) => {
      const href = it.kind === 'review' ? `/workspace/reviews/?id=${it.id}` : `/workspace/compare/?id=${it.id}`;
      return `<a href="${href}" class="ws-dash-pending-chip">${escapeAttr(it.title)} — ${it.status}</a>`;
    });
    const more = inflight.length > 3 ? ` <span class="ws-dash-row-time">+${inflight.length - 3} more</span>` : '';
    txt.innerHTML = `${inflight.length} in flight: ${pieces.join(' · ')}${more}`;
  }

  // Re-poll dashboard every 12s so running items eventually flip to
  // complete without a page refresh. Stops when nothing's pending.
  let dashTimer = null;
  function scheduleDashRefresh() {
    if (dashTimer) clearTimeout(dashTimer);
    const anyInflight = [...reviewsCache, ...comparesCache].some((r) => r.status === 'pending' || r.status === 'running');
    if (!anyInflight) return;
    dashTimer = setTimeout(async () => {
      await Promise.all([loadDashReviews(), loadDashCompares()]);
      scheduleDashRefresh();
    }, 12_000);
  }

  Promise.all([loadDashReviews(), loadDashCompares(), loadDashLibrary()])
    .then(scheduleDashRefresh);

  // Show cached list instantly, then refresh from server.
  renderFromCache();
  loadChats();
  loadProjectStrip();
</script>
</body>
</html>
