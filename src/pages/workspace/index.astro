<script>
  import { getSupabase } from '../../lib/supabase';

  const supabase = getSupabase();

  // Auth gate: signed-in + approved. Body is never hidden — better
  // for a signed-out user to briefly glimpse the shell than for a
  // signed-in user to see a blank page when the gate has any hiccup.
  console.log('[workspace] Script started');
  let session = null;
  try {
    const { data, error } = await supabase.auth.getSession();
    if (error) throw error;
    session = data?.session || null;
    if (!session) {
      console.info('[workspace] No session — redirecting to /login/');
      location.href = '/login/?redirect=/workspace/';
      throw new Error('not signed in — redirecting');
    }
    const { data: profile, error: profileErr } = await supabase
      .from('profiles').select('tier, approved_at').eq('id', session.user.id).maybeSingle();
    if (profileErr) throw profileErr;
    if (!profile) {
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">No profile</h1><p>We could not find a profile for your account. This usually means signup did not finish. Try signing out and creating the account again, or contact the operator.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('no profile');
    }
    if (!profile.approved_at) {
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Pending approval</h1><p>Your account is pending operator approval. We review every signup before granting workspace access.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('pending approval');
    }
    console.log('[workspace] Auth gate passed, user', session.user?.id);
  } catch (err) {
    if (err && err.message && !['pending approval','no profile','not signed in — redirecting'].includes(err.message)) {
      console.error('[workspace] Gate failed:', err);
      document.body.innerHTML = `<main style="max-width:680px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Workspace error</h1><p>The workspace failed to load. Open your browser console for full details.</p><pre style="background:#f5f5f5;padding:14px;border-radius:6px;font-size:12px;white-space:pre-wrap;word-break:break-word">${(err && err.message ? err.message : String(err)).replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]))}</pre><p><a href="/">Back to homepage</a></p></main>`;
    }
    throw err;
  }

  const chatList = document.getElementById('chat-list');
  const newChatBtn = document.getElementById('new-chat');
  let accessToken = session.access_token;
  try { supabase.auth.onAuthStateChange((_e, s) => { if (s?.access_token) accessToken = s.access_token; }); } catch {}

  const RAIL_CACHE_KEY = 'workspace.rail.' + (session.user?.id || 'anon');

  // Active tab filter held in module scope so re-renders preserve it.
  let activeTab = 'all';
  let allChats = [];
  // Whether the chats list is fully expanded ("Show all" clicked).
  // Default false — capped to INITIAL_CHATS_LIMIT in renderChatList()
  // so the dashboard doesn't grow unbounded as the user accumulates
  // conversations.
  let chatsExpanded = false;

  function rebuildHeadKeepBody() {
    return `<div class="ws-list-head">
      <span></span>
      <span class="h-title">Title</span>
      <span class="h-model">Model</span>
      <span class="h-time" style="text-align:right; padding-right:14px;">Updated</span>
      <span></span>
    </div>`;
  }

  function renderChats(chats) {
    allChats = Array.isArray(chats) ? chats : [];
    paintChats();
  }

  function paintChats() {
    const filtered = allChats.filter((c) => {
      if (activeTab === 'proj') return !!c.project_id;
      if (activeTab === 'solo') return !c.project_id;
      return true;
    });
    const countPill = document.getElementById('chat-count-pill');
    const stamp = document.getElementById('chat-updated-stamp');
    if (countPill) countPill.textContent = `· ${filtered.length} of ${allChats.length}`;
    if (stamp) {
      const newest = allChats[0]?.updated_at;
      stamp.textContent = newest ? `UPDATED ${relTimeShort(newest)}` : '';
    }

    if (!filtered.length) {
      const empty = !allChats.length
        ? 'No chats yet. Type a question above and press Begin →'
        : (activeTab === 'proj'
            ? 'No project-scoped chats. Drop a row onto a project chip.'
            : 'No loose chats. Every thread is filed.');
      chatList.innerHTML = rebuildHeadKeepBody() + `<div class="ws-empty">${empty}</div>`;
      return;
    }

    // Cap the initial render to keep the dashboard from growing
    // unbounded as users accumulate chats. "Show all" button below
    // toggles `chatsExpanded` and re-renders. Default cap is 8 —
    // covers most users' "what was I just doing?" needs without
    // pushing other dashboard sections off-screen.
    const INITIAL_CHATS_LIMIT = 8;
    const visible = chatsExpanded ? filtered : filtered.slice(0, INITIAL_CHATS_LIMIT);
    const hiddenCount = filtered.length - visible.length;

    chatList.innerHTML = rebuildHeadKeepBody() + visible.map((c) => {
      const title = (c.title || 'Untitled chat').replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]));
      const date = relTimeFull(c.updated_at);
      const projBadge = c.project_id ? `<span class="ws-row-proj-badge" title="In a project">●</span>` : '';
      const tab = c.project_id ? 'proj' : 'solo';
      const model = (c.model || '').replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]));
      return `<div class="ws-row-wrap" draggable="true" data-chat-id="${c.id}" data-tab="${tab}">
        <div class="ws-rc ws-rc-handle" aria-hidden="true"></div>
        <div class="ws-rc ws-rc-title">${projBadge}<a href="/workspace/chat/?id=${c.id}">${title}</a></div>
        <div class="ws-rc ws-rc-model">${shortModel(model) || '—'}</div>
        <div class="ws-rc ws-rc-time">${date}</div>
        <div class="ws-rc ws-rc-action"><button type="button" data-del="${c.id}" data-title="${title}" aria-label="Delete chat" title="Delete chat">×</button></div>
      </div>`;
    }).join('');

    // Show-all / collapse toggle. Visible only when there's more
    // than INITIAL_CHATS_LIMIT chats in the filtered set, OR when
    // we're currently expanded (so the user can collapse back).
    if (hiddenCount > 0 || chatsExpanded) {
      const label = chatsExpanded
        ? `Show fewer chats`
        : `Show all ${filtered.length} chats (${hiddenCount} more)`;
      chatList.insertAdjacentHTML('beforeend',
        `<button type="button" id="chats-toggle-all" class="chats-toggle-all">${label}</button>`,
      );
      const tgl = document.getElementById('chats-toggle-all');
      tgl?.addEventListener('click', () => {
        chatsExpanded = !chatsExpanded;
        renderChatList();
      });
    }

    chatList.querySelectorAll('.ws-row-wrap[data-chat-id]').forEach((row) => {
      row.addEventListener('dragstart', (e) => {
        e.dataTransfer.setData('text/chat-id', row.dataset.chatId);
        e.dataTransfer.effectAllowed = 'move';
        row.classList.add('is-dragging');
      });
      row.addEventListener('dragend', () => row.classList.remove('is-dragging'));
    });

    chatList.querySelectorAll('[data-del]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.dataset.del;
        const title = btn.dataset.title;
        const ok = await window.siteConfirm(`Delete "${title}"? This cannot be undone.`, {
          okLabel: 'Delete', danger: true,
        });
        if (!ok) return;
        // Optimistic remove — drop the row instantly. Restore on
        // server error.
        const row = btn.closest('.ws-row-wrap, [data-chat-id], li') || btn.parentElement;
        const removedHTML = row?.outerHTML;
        const removedNext = row?.nextSibling;
        const removedParent = row?.parentNode;
        if (row) row.remove();
        try {
          const cached = JSON.parse(localStorage.getItem(RAIL_CACHE_KEY) || '[]');
          if (Array.isArray(cached)) {
            localStorage.setItem(RAIL_CACHE_KEY, JSON.stringify(cached.filter((c) => c.id !== id)));
          }
        } catch {}
        const r = await fetch('/.netlify/functions/workspace-chats-delete', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          window.siteToast('Delete failed: ' + (j.error || 'unknown'), { kind: 'error' });
          if (removedParent && removedHTML) {
            const tmp = document.createElement('div');
            tmp.innerHTML = removedHTML;
            const restored = tmp.firstElementChild;
            if (restored) {
              if (removedNext) removedParent.insertBefore(restored, removedNext);
              else removedParent.appendChild(restored);
            }
          }
          return;
        }
        window.siteToast(`"${title}" deleted`, { kind: 'success', duration: 2400 });
        // Soft refresh in the background to pick up any reordering;
        // user already sees the row gone.
        loadChats();
      });
    });
  }

  // Compact model-name renderer so the model column doesn't overflow.
  function shortModel(m) {
    if (!m) return '';
    const s = String(m).toLowerCase();
    if (s.includes('claude')) return 'claude';
    if (s.includes('gpt'))    return 'gpt-4o';
    if (s.includes('gemini')) return 'gemini';
    if (s.includes('grok'))   return 'grok';
    return s;
  }

  function renderFromCache() {
    try {
      const raw = localStorage.getItem(RAIL_CACHE_KEY);
      if (!raw) return false;
      const cached = JSON.parse(raw);
      if (!Array.isArray(cached) || cached.length === 0) return false;
      renderChats(cached);
      return true;
    } catch { return false; }
  }
  async function loadChats() {
    console.log('[workspace] loadChats() — fetching');
    try {
      const r = await fetch('/.netlify/functions/workspace-chats-list', {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      console.log('[workspace] loadChats() response status', r.status);
      const j = await r.json();
      if (!r.ok) {
        console.error('[workspace] loadChats() failed:', j);
        chatList.innerHTML = rebuildHeadKeepBody() +
          `<div class="ws-empty" style="grid-column:1/-1;padding:28px 14px;color:#b22222;">
            Failed to load chats: ${(j.error || 'unknown')} (HTTP ${r.status})
          </div>`;
        return;
      }
      const chats = j.chats || [];
      console.log('[workspace] loadChats() got', chats.length, 'chats');
      renderChats(chats);
      try { localStorage.setItem(RAIL_CACHE_KEY, JSON.stringify(chats)); } catch {}
    } catch (e) {
      console.error('[workspace] loadChats() threw:', e);
      chatList.innerHTML = rebuildHeadKeepBody() +
        `<div class="ws-empty" style="grid-column:1/-1;padding:28px 14px;color:#b22222;">
          Network error loading chats: ${e?.message || String(e)}
        </div>`;
    }
  }

  async function createChat() {
    newChatBtn.disabled = true;
    const r = await fetch('/.netlify/functions/workspace-chats-create', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({}),
    });
    const j = await r.json();
    newChatBtn.disabled = false;
    if (!r.ok) {
      alert('Failed to create chat: ' + (j.error || 'unknown'));
      return;
    }
    location.href = `/workspace/chat/?id=${j.id}`;
  }

  newChatBtn.addEventListener('click', createChat);

  // ---- Command bar — workspace-wide search-as-you-type + create-thread ----
  // Searches across SIX sources at once: chats, projects, library
  // documents, vault items, tabular reviews, and workflows. All sources
  // are lazy-loaded on first focus / keystroke and cached in memory for
  // the rest of the page lifetime — keystrokes filter client-side, no
  // round-trips per character.
  //
  // Submit behaviors:
  //   - Empty input + Enter → fall through to "begin new thread"
  //   - Typed query, result highlighted → open that result
  //   - Typed query, no result → create new thread with typed text as seed
  const cmdBar = document.getElementById('cmd-bar');
  const cmdInput = document.getElementById('cmd-input');
  const cmdGo = document.getElementById('cmd-go');
  const cmdResults = document.getElementById('cmd-results');
  let cmdActiveIdx = -1;
  let cmdMatches = [];

  // Index of every workspace item the bar can search. Loaded once on
  // first focus; refreshed if the user opens the bar after a long idle.
  let wsIndex = null;
  let wsIndexLoadedAt = 0;
  const WS_INDEX_TTL_MS = 60 * 1000; // 1 minute; cheap to refresh

  // Each entry: { kind, id, title, meta, href, time }
  const KIND_LABEL = {
    chat: 'CHAT',
    project: 'PROJECT',
    document: 'LIBRARY',
    vault: 'VAULT',
    review: 'REVIEW',
    workflow: 'WORKFLOW',
  };

  function cmdRelTime(iso) {
    if (!iso) return '';
    const ms = Date.now() - new Date(iso).getTime();
    const m = Math.floor(ms / 60000);
    if (m < 1) return 'just now';
    if (m < 60) return `${m}m ago`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ago`;
    const d = Math.floor(h / 24);
    return `${d}d ago`;
  }

  async function loadWorkspaceIndex() {
    // Stale-while-revalidate: if we have an index younger than TTL, use
    // it immediately. Past TTL we still return what we have synchronously
    // but kick off a refetch in the background.
    const now = Date.now();
    const fresh = wsIndex && (now - wsIndexLoadedAt < WS_INDEX_TTL_MS);
    if (fresh) return wsIndex;

    const headers = { Authorization: `Bearer ${accessToken}` };
    const safe = (p) => p.then((r) => r.ok ? r.json() : null).catch(() => null);
    const [chatsR, projsR, docsR, vaultR, reviewsR, wfR] = await Promise.all([
      safe(fetch('/.netlify/functions/workspace-chats-list',     { headers })),
      safe(fetch('/.netlify/functions/workspace-projects-list',  { headers })),
      safe(fetch('/.netlify/functions/workspace-library-list',   { headers })),
      safe(fetch('/.netlify/functions/workspace-vault-list',     { headers })),
      safe(fetch('/.netlify/functions/workspace-tr-list',        { headers })),
      safe(fetch('/.netlify/functions/workspace-workflows-list', { headers })),
    ]);

    const out = [];
    for (const c of (chatsR?.chats || allChats || [])) {
      out.push({
        kind: 'chat', id: c.id,
        title: c.title || 'Untitled chat',
        meta: c.model || '',
        href: `/workspace/chat/?id=${c.id}`,
        time: c.updated_at || c.created_at,
      });
    }
    for (const p of (projsR?.projects || [])) {
      const ct = p.counts || {};
      out.push({
        kind: 'project', id: p.id,
        title: p.name || 'Untitled project',
        meta: `${ct.chats || 0} chats · ${ct.documents || 0} docs`,
        href: `/workspace/projects/?id=${p.id}`,
        time: p.updated_at || p.created_at,
      });
    }
    for (const d of (docsR?.documents || [])) {
      out.push({
        kind: 'document', id: d.id,
        title: d.filename || d.original_filename || 'Untitled document',
        meta: (d.file_type || '').toUpperCase(),
        href: `/workspace/library/?id=${d.id}`,
        time: d.updated_at || d.created_at,
      });
    }
    for (const v of (vaultR?.items || vaultR?.vault || [])) {
      out.push({
        kind: 'vault', id: v.id,
        title: v.title || v.name || 'Untitled vault item',
        meta: (v.source_kind || 'note').toUpperCase(),
        href: `/workspace/vault/?id=${v.id}`,
        time: v.updated_at || v.created_at,
      });
    }
    for (const r of (reviewsR?.reviews || [])) {
      out.push({
        kind: 'review', id: r.id,
        title: r.title || 'Untitled review',
        meta: (r.status || '').toUpperCase(),
        href: `/workspace/reviews/?id=${r.id}`,
        time: r.updated_at || r.created_at,
      });
    }
    for (const w of (wfR?.workflows || [])) {
      out.push({
        kind: 'workflow', id: w.id,
        title: w.name || w.title || 'Untitled workflow',
        meta: (w.kind || 'workflow').toUpperCase(),
        href: `/workspace/workflows/?id=${w.id}`,
        time: w.updated_at || w.created_at,
      });
    }

    wsIndex = out;
    wsIndexLoadedAt = now;
    return wsIndex;
  }

  // Kick off the load in the background as soon as the page is interactive,
  // so the first keystroke already has data.
  loadWorkspaceIndex().catch((e) => console.warn('[cmd] index load failed:', e?.message));

  function renderCmdResults(query) {
    if (!cmdResults) return;
    const q = (query || '').trim().toLowerCase();
    if (!q) {
      cmdResults.hidden = true;
      cmdResults.innerHTML = '';
      cmdMatches = [];
      cmdActiveIdx = -1;
      return;
    }
    const idx = wsIndex || [];
    // Score: title.startsWith > title.includes > meta.includes; recency
    // boost on tied scores.
    const scored = idx
      .map((it) => {
        const title = (it.title || '').toLowerCase();
        const meta = (it.meta || '').toLowerCase();
        let s = 0;
        if (title.startsWith(q)) s = 100;
        else if (title.includes(q)) s = 60;
        else if (meta.includes(q)) s = 30;
        if (s === 0) return null;
        const recency = it.time ? -(Date.now() - new Date(it.time).getTime()) / 1e10 : 0;
        return { it, s: s + recency };
      })
      .filter(Boolean)
      .sort((a, b) => b.s - a.s)
      .slice(0, 10)
      .map((x) => x.it);
    cmdMatches = scored;
    cmdActiveIdx = scored.length ? 0 : -1;
    const esc = (s) => String(s || '').replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]));
    if (!scored.length) {
      cmdResults.innerHTML = `
        <div class="cmd-results-empty">Nothing matches across the workspace — press Enter to begin a new thread.</div>
        <div class="cmd-result cmd-result-create" data-idx="-1" data-create="1">
          <span class="cmd-result-num">+</span>
          <span class="cmd-result-title">Begin new thread with this prompt</span>
          <span class="cmd-result-meta">Enter ↵</span>
        </div>
      `;
    } else {
      cmdResults.innerHTML = scored.map((it, i) => `
        <div class="cmd-result${i === 0 ? ' is-active' : ''}" data-idx="${i}">
          <span class="cmd-result-num">${KIND_LABEL[it.kind] || it.kind.toUpperCase()}</span>
          <span class="cmd-result-title">${esc(it.title)}</span>
          <span class="cmd-result-meta">${esc(it.meta || '')}${it.meta && it.time ? ' · ' : ''}${cmdRelTime(it.time)}</span>
        </div>
      `).join('') + `
        <div class="cmd-result cmd-result-create" data-idx="-1" data-create="1">
          <span class="cmd-result-num">+</span>
          <span class="cmd-result-title">Begin new thread with this prompt</span>
          <span class="cmd-result-meta">Enter ↵</span>
        </div>
      `;
    }
    cmdResults.querySelectorAll('.cmd-result').forEach((row) => {
      row.addEventListener('mouseenter', () => {
        cmdResults.querySelectorAll('.cmd-result').forEach((r) => r.classList.remove('is-active'));
        row.classList.add('is-active');
        cmdActiveIdx = parseInt(row.dataset.idx, 10);
      });
      row.addEventListener('mousedown', (e) => {
        // mousedown fires before blur, so the popover doesn't close out
        // from under our click on a result row.
        e.preventDefault();
      });
      row.addEventListener('click', () => {
        if (row.dataset.create === '1') {
          cmdBar.dispatchEvent(new Event('submit', { cancelable: true }));
          return;
        }
        const idxNum = parseInt(row.dataset.idx, 10);
        const target = cmdMatches[idxNum];
        if (target?.href) location.href = target.href;
      });
    });
    cmdResults.hidden = false;
  }

  async function createThreadWithSeed(seed) {
    cmdInput.disabled = true;
    cmdGo.disabled = true;
    cmdGo.textContent = 'Opening…';
    try {
      // Pass the chosen model so the new chat opens with it preselected.
      const createRes = await fetch('/.netlify/functions/workspace-chats-create', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ model: currentModelId }),
      });
      const j = await createRes.json();
      if (!createRes.ok) throw new Error(j.error || `HTTP ${createRes.status}`);

      // If privacy is toggled on, propagate it onto the chat's law_settings
      // BEFORE redirecting so the chat page's law_settings hydration sees
      // privacy_enabled=true on first paint (no privacy-off flash).
      if (privOn) {
        try {
          await fetch('/.netlify/functions/workspace-chats-update', {
            method: 'POST',
            headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: j.id, law_settings: { privacy_enabled: true } }),
          });
        } catch (e) {
          // Don't block chat-creation if the privacy update fails — user
          // can still flip the toggle inside the chat view.
          console.warn('[dash] privacy propagate failed:', e?.message);
        }
      }
      const params = new URLSearchParams();
      if (seed) params.set('seed', seed);
      const qs = params.toString();
      location.href = `/workspace/chat/?id=${j.id}${qs ? '&' + qs : ''}`;
    } catch (err) {
      alert('Failed to create chat: ' + (err?.message || 'unknown'));
      cmdInput.disabled = false; cmdGo.disabled = false; cmdGo.textContent = 'Begin →';
    }
  }

  if (cmdBar && cmdInput) {
    cmdInput.addEventListener('input', () => renderCmdResults(cmdInput.value));
    cmdInput.addEventListener('focus', () => {
      if (cmdInput.value.trim()) renderCmdResults(cmdInput.value);
    });
    cmdInput.addEventListener('blur', () => {
      // Delay so click on a result-row fires before the popover closes.
      setTimeout(() => { if (cmdResults) cmdResults.hidden = true; }, 150);
    });
    cmdInput.addEventListener('keydown', (e) => {
      if (!cmdResults || cmdResults.hidden || !cmdMatches.length) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        cmdActiveIdx = Math.min(cmdActiveIdx + 1, cmdMatches.length - 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        cmdActiveIdx = Math.max(cmdActiveIdx - 1, 0);
      } else if (e.key === 'Escape') {
        cmdResults.hidden = true;
        return;
      } else { return; }
      cmdResults.querySelectorAll('.cmd-result').forEach((r, i) => {
        r.classList.toggle('is-active', i === cmdActiveIdx);
      });
      const el = cmdResults.querySelector(`.cmd-result[data-idx="${cmdActiveIdx}"]`);
      el?.scrollIntoView({ block: 'nearest' });
    });

    cmdBar.addEventListener('submit', async (e) => {
      e.preventDefault();
      const seed = cmdInput.value.trim();
      // If a search-result is highlighted, navigate to its kind-aware href
      // (chat, project, library doc, vault item, review, or workflow).
      if (cmdActiveIdx >= 0 && cmdMatches[cmdActiveIdx]?.href) {
        location.href = cmdMatches[cmdActiveIdx].href;
        return;
      }
      await createThreadWithSeed(seed);
    });

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        cmdInput.focus();
        cmdInput.select();
      }
    });
  }

  // ---- Tab filter on Recent chats ----
  const chatTabs = document.getElementById('chat-tabs');
  if (chatTabs) {
    chatTabs.addEventListener('click', (e) => {
      const btn = e.target.closest('.ws-card-tab');
      if (!btn) return;
      activeTab = btn.dataset.tab || 'all';
      chatTabs.querySelectorAll('.ws-card-tab').forEach((b) => {
        b.classList.toggle('is-active', b === btn);
      });
      paintChats();
    });
  }

  // ---- Model picker — universal model switch ----
  // Pulls the same live catalog the chat page uses (/api/workspace-models-list,
  // grouped by provider). The selected model id is the user's universal
  // preference: it's persisted to localStorage and threaded into every
  // chat created from the dashboard, AND the chat page reads the same
  // localStorage cache (workspace.models.v4) so the dropdown options
  // stay in sync between dashboard and chat.
  const MODEL_KEY = 'workspace.dash.model';
  const MODEL_CACHE_KEY = 'workspace.models.v4';   // shared with chat page
  const MODEL_CACHE_TTL = 24 * 60 * 60 * 1000;
  // Conservative fallback if the API is unreachable on first load.
  const FALLBACK_MODELS = [
    { id: 'claude-sonnet-4-5', label: 'Claude Sonnet 4.5', provider: 'anthropic' },
    { id: 'gpt-5-mini',        label: 'GPT-5 mini',        provider: 'openai' },
    { id: 'gemini-2.5-flash',  label: 'Gemini 2.5 Flash',  provider: 'google' },
  ];
  const PROVIDER_LABEL = {
    anthropic: 'Anthropic', openai: 'OpenAI', google: 'Google', xai: 'xAI',
  };

  const modelPick = document.getElementById('dash-model-pick');
  const modelCurrent = document.getElementById('dash-model-current');

  let modelCatalog = (function loadCachedModels() {
    try {
      const raw = localStorage.getItem(MODEL_CACHE_KEY);
      if (!raw) return null;
      const { models, ts } = JSON.parse(raw);
      if (!Array.isArray(models) || Date.now() - ts > MODEL_CACHE_TTL) return null;
      return models;
    } catch { return null; }
  })() || FALLBACK_MODELS;

  let currentModelId = '';
  try { currentModelId = localStorage.getItem(MODEL_KEY) || ''; } catch {}
  if (!currentModelId || !modelCatalog.some((m) => m.id === currentModelId)) {
    currentModelId = modelCatalog[0]?.id || 'claude-sonnet-4-5';
  }
  let modelMenu = null;

  function labelFor(id) {
    return modelCatalog.find((m) => m.id === id)?.label || id;
  }
  function applyModel(id) {
    const m = modelCatalog.find((o) => o.id === id);
    if (!m) return;
    currentModelId = m.id;
    if (modelCurrent) modelCurrent.textContent = m.label;
    try { localStorage.setItem(MODEL_KEY, m.id); } catch {}
  }
  applyModel(currentModelId);

  // Background refresh of the live catalog so the dropdown reflects new
  // models the moment a provider ships them. Result is cached to
  // localStorage under the same key the chat page reads, so the two
  // dropdowns never drift.
  (async function refreshModelCatalog() {
    try {
      const r = await fetch('/.netlify/functions/workspace-models-list', {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok || !Array.isArray(j.models) || !j.models.length) return;
      modelCatalog = j.models;
      try { localStorage.setItem(MODEL_CACHE_KEY, JSON.stringify({ models: j.models, ts: Date.now() })); } catch {}
      // Re-apply current selection in case the label text changed (e.g.,
      // provider relabeled "Sonnet 4.5" to "Sonnet 4.5 (latest)").
      if (!modelCatalog.some((m) => m.id === currentModelId)) {
        applyModel(modelCatalog[0]?.id || currentModelId);
      } else {
        applyModel(currentModelId);
      }
    } catch (err) {
      console.warn('[dash] model catalog refresh failed:', err?.message);
    }
  })();

  function closeModelMenu() {
    if (modelMenu) { modelMenu.remove(); modelMenu = null; }
    document.removeEventListener('click', onDocClickModel, true);
  }
  function onDocClickModel(e) {
    if (modelMenu && !modelMenu.contains(e.target) && !modelPick.contains(e.target)) {
      closeModelMenu();
    }
  }
  function openModelMenu() {
    if (modelMenu) { closeModelMenu(); return; }
    modelMenu = document.createElement('div');
    modelMenu.className = 'model-menu';
    modelMenu.setAttribute('role', 'listbox');

    // Group by provider — same shape the chat page renders.
    const order = ['anthropic', 'openai', 'google', 'xai'];
    const grouped = {};
    for (const m of modelCatalog) {
      const prov = m.provider || 'other';
      (grouped[prov] = grouped[prov] || []).push(m);
    }
    const groupKeys = order.filter((p) => grouped[p]?.length).concat(
      Object.keys(grouped).filter((p) => !order.includes(p) && grouped[p]?.length)
    );

    const sections = groupKeys.map((p) => `
      <div class="model-menu-group">
        <div class="model-menu-group-l">${PROVIDER_LABEL[p] || p.toUpperCase()}</div>
        ${grouped[p].map((m) => `
          <div class="model-menu-opt${m.id === currentModelId ? ' is-current' : ''}" role="option" data-id="${m.id}">
            <span class="mm-check">${m.id === currentModelId ? '●' : ''}</span>
            <span>${(m.label || m.id).replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]))}</span>
          </div>
        `).join('')}
      </div>
    `).join('');
    modelMenu.innerHTML = sections;

    const rect = modelPick.getBoundingClientRect();
    document.body.appendChild(modelMenu);
    modelMenu.style.left = `${rect.left + window.scrollX}px`;
    modelMenu.style.top  = `${rect.bottom + window.scrollY + 6}px`;
    modelMenu.querySelectorAll('.model-menu-opt').forEach((row) => {
      row.addEventListener('click', () => {
        applyModel(row.dataset.id);
        closeModelMenu();
      });
    });
    setTimeout(() => document.addEventListener('click', onDocClickModel, true), 0);
  }

  if (modelPick) {
    modelPick.addEventListener('click', openModelMenu);
    modelPick.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModelMenu(); }
    });
  }

  // ---- Privacy toggle (persisted, off by default) ----
  const PRIV_KEY = 'workspace.dash.privacy';
  const privToggle = document.getElementById('dash-privacy-toggle');
  const privLabel = document.getElementById('dash-priv-label');
  function applyPrivacy(on) {
    if (!privToggle || !privLabel) return;
    privToggle.classList.toggle('is-on', on);
    privToggle.setAttribute('aria-checked', on ? 'true' : 'false');
    privLabel.textContent = on ? 'on' : 'off';
    try { localStorage.setItem(PRIV_KEY, on ? '1' : '0'); } catch {}
  }
  let privOn = false;
  try { privOn = localStorage.getItem(PRIV_KEY) === '1'; } catch {}
  applyPrivacy(privOn);
  if (privToggle) {
    const flip = () => { privOn = !privOn; applyPrivacy(privOn); };
    privToggle.addEventListener('click', flip);
    privToggle.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); flip(); }
    });
  }

  // ---- Project strip (drag chats onto a project to move them) ----
  const stripEl = document.getElementById('proj-strip');
  const stripChips = document.getElementById('proj-strip-chips');
  async function loadProjectStrip() {
    const r = await fetch('/.netlify/functions/workspace-projects-list', {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) return;
    const projects = j.projects || [];
    if (!projects.length) {
      stripEl.hidden = false;
      stripChips.innerHTML = `<button type="button" class="proj-strip-new">+ New project</button>`;
      stripChips.querySelector('.proj-strip-new').addEventListener('click', createInlineProject);
      return;
    }
    stripEl.hidden = false;
    stripChips.innerHTML = projects.map((p) => {
      const c = p.counts || {};
      return `<a href="/workspace/projects/?id=${p.id}" class="proj-strip-chip" data-proj-drop="${p.id}" title="${(c.chats || 0) + ' chats · ' + (c.documents || 0) + ' docs'}">${(p.name || '').replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]))}</a>`;
    }).join('') + `<button type="button" class="proj-strip-new">+ New</button>`;
    stripChips.querySelector('.proj-strip-new').addEventListener('click', createInlineProject);
    stripChips.querySelectorAll('[data-proj-drop]').forEach((chip) => {
      chip.addEventListener('dragover', (e) => {
        if (e.dataTransfer.types.includes('text/chat-id')) {
          e.preventDefault();
          chip.classList.add('is-drop-target');
        }
      });
      chip.addEventListener('dragleave', () => chip.classList.remove('is-drop-target'));
      chip.addEventListener('drop', async (e) => {
        e.preventDefault();
        chip.classList.remove('is-drop-target');
        const chatId = e.dataTransfer.getData('text/chat-id');
        const projectId = chip.dataset.projDrop;
        if (!chatId) return;
        await fetch('/.netlify/functions/workspace-chats-update', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: chatId, project_id: projectId }),
        });
        try { localStorage.removeItem(RAIL_CACHE_KEY); } catch {}
        loadChats();
      });
    });
  }

  function createInlineProject() {
    const newBtn = stripChips.querySelector('.proj-strip-new');
    if (!newBtn) return;
    if (newBtn.classList.contains('is-editing')) return;
    const wrap = document.createElement('span');
    wrap.className = 'proj-strip-newform';
    wrap.innerHTML = `<input type="text" class="proj-strip-newinput" placeholder="Project name" maxlength="200" />`;
    newBtn.replaceWith(wrap);
    const input = wrap.querySelector('input');
    input.focus();

    const cancel = () => {
      const restore = document.createElement('button');
      restore.type = 'button';
      restore.className = 'proj-strip-new';
      restore.textContent = '+ New';
      restore.addEventListener('click', createInlineProject);
      wrap.replaceWith(restore);
    };
    const create = async () => {
      const name = input.value.trim();
      if (!name) { cancel(); return; }
      input.disabled = true;
      const r = await fetch('/.netlify/functions/workspace-projects-create', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      const j = await r.json();
      if (!r.ok) { input.disabled = false; input.classList.add('is-error'); input.title = j.error || 'failed'; return; }
      loadProjectStrip();
    };
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); create(); }
      else if (e.key === 'Escape') cancel();
    });
    input.addEventListener('blur', () => {
      setTimeout(() => { if (document.contains(input) && !input.disabled) cancel(); }, 120);
    });
  }

  // ---- Activity grid (cache-first, parallel loads) ----
  const STATUS_CLASS = {
    complete: 'rv-status-done',
    running: 'rv-status-run',
    error: 'rv-status-err',
    pending: 'rv-status-pen',
    partial: 'rv-status-part',
  };
  function statusPill(status) {
    const cls = STATUS_CLASS[status] || 'rv-status-pen';
    return `<span class="rv-status-pill ${cls}">${escapeAttr(status)}</span>`;
  }
  function escapeAttr(s) {
    return String(s ?? '').replace(/[<>&"]/g, (c) => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
  }
  function relTimeShort(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    const pad = (n) => String(n).padStart(2,'0');
    return pad(d.getHours()) + ':' + pad(d.getMinutes());
  }
  function relTimeFull(iso) {
    if (!iso) return '';
    const ms = Date.now() - new Date(iso).getTime();
    if (ms < 60_000) return 'just now';
    if (ms < 3_600_000) return `${Math.floor(ms / 60_000)} min ago`;
    if (ms < 86_400_000) return `${Math.floor(ms / 3_600_000)} hr ago`;
    if (ms < 7 * 86_400_000) return `${Math.floor(ms / 86_400_000)} days ago`;
    return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  }
  function relTime(iso) { return relTimeFull(iso); }
  function fmtBytes(n) {
    if (!n) return '';
    if (n < 1024) return n + ' B';
    if (n < 1024 * 1024) return (n / 1024).toFixed(0) + ' KB';
    return (n / (1024 * 1024)).toFixed(1) + ' MB';
  }

  let reviewsCache = [];
  let comparesCache = [];

  const USER_TAG = '.' + (session.user?.id || 'anon');
  function dashSkeletonRows(n) {
    return Array.from({length: n}, () => `<li class="ws-dash-row">
      <div style="padding:9px 0; display:grid; grid-template-columns:1fr auto; gap:14px;">
        <span class="sk-block" style="width:78%"></span>
        <span class="sk-block" style="width:42px"></span>
      </div>
    </li>`).join('');
  }
  async function cachedListLoad({ cacheKey, fetchUrl, renderData, skeleton, errorEl }) {
    let renderedSomething = false;
    try {
      const raw = localStorage.getItem(cacheKey);
      if (raw) {
        const cached = JSON.parse(raw);
        if (cached) { renderData(cached); renderedSomething = true; }
      }
    } catch {}
    if (!renderedSomething && typeof skeleton === 'function') skeleton();
    try {
      const r = await fetch(fetchUrl, { headers: { Authorization: `Bearer ${accessToken}` } });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'failed');
      renderData(j);
      try { localStorage.setItem(cacheKey, JSON.stringify(j)); } catch {}
    } catch (e) {
      if (!renderedSomething && errorEl) {
        errorEl.innerHTML = `<li class="ws-dash-empty">Failed: ${escapeAttr(e.message)}</li>`;
      }
    }
  }

  async function loadDashReviews() {
    const el = document.getElementById('dash-reviews');
    return cachedListLoad({
      cacheKey: 'workspace.dash.reviews' + USER_TAG,
      fetchUrl: '/.netlify/functions/workspace-tr-list',
      skeleton: () => { el.innerHTML = dashSkeletonRows(3); },
      errorEl: el,
      renderData: (j) => {
        const items = (j.reviews || []).slice(0, 4);
        reviewsCache = j.reviews || [];
        if (!items.length) {
          el.innerHTML = '<li class="ws-dash-empty">No reviews yet. <a href="/workspace/reviews/" style="color:var(--accent-deep)">Start one →</a></li>';
        } else {
          el.innerHTML = items.map((rv) => `<li class="ws-dash-row">
            <a href="/workspace/reviews/?id=${rv.id}" class="ws-dash-row-link">
              <span class="ws-dash-row-title">${escapeAttr(rv.title)}</span>
              <span class="ws-dash-row-meta">${statusPill(rv.status)}<span class="sep">·</span>${relTime(rv.updated_at)}</span>
            </a>
          </li>`).join('');
        }
        updatePendingStrip();
      },
    });
  }

  async function loadDashCompares() {
    const el = document.getElementById('dash-compares');
    return cachedListLoad({
      cacheKey: 'workspace.dash.compares' + USER_TAG,
      fetchUrl: '/.netlify/functions/workspace-compare-list',
      skeleton: () => { el.innerHTML = dashSkeletonRows(3); },
      errorEl: el,
      renderData: (j) => {
        const items = (j.runs || []).slice(0, 4);
        comparesCache = j.runs || [];
        if (!items.length) {
          el.innerHTML = '<li class="ws-dash-empty">No comparisons yet. <a href="/workspace/compare/" style="color:var(--accent-deep)">Run one →</a></li>';
        } else {
          el.innerHTML = items.map((rv) => `<li class="ws-dash-row">
            <a href="/workspace/compare/?id=${rv.id}" class="ws-dash-row-link">
              <span class="ws-dash-row-title">${escapeAttr(rv.title)}</span>
              <span class="ws-dash-row-meta">${statusPill(rv.status)}${rv.diffs_count ? `<span class="sep">·</span>${rv.diffs_count} diffs` : ''}<span class="sep">·</span>${relTime(rv.updated_at)}</span>
            </a>
          </li>`).join('');
        }
        updatePendingStrip();
      },
    });
  }

  async function loadDashLibrary() {
    const el = document.getElementById('dash-library');
    return cachedListLoad({
      cacheKey: 'workspace.dash.library' + USER_TAG,
      fetchUrl: '/.netlify/functions/workspace-library-list?limit=4',
      skeleton: () => { el.innerHTML = dashSkeletonRows(3); },
      errorEl: el,
      renderData: (j) => {
        const items = (j.documents || []).slice(0, 4);
        if (!items.length) {
          el.innerHTML = '<li class="ws-dash-empty">No documents yet. <a href="/workspace/library/" style="color:var(--accent-deep)">Upload →</a></li>';
        } else {
          el.innerHTML = items.map((d) => `<li class="ws-dash-row">
            <a href="/workspace/library/?id=${d.id}" class="ws-dash-row-link">
              <span class="ws-dash-row-title">${escapeAttr(d.filename)}</span>
              <span class="ws-dash-row-meta">${d.size_bytes ? `${fmtBytes(d.size_bytes)}<span class="sep">·</span>` : ''}${relTime(d.updated_at)}</span>
            </a>
          </li>`).join('');
        }
      },
    });
  }

  async function loadDashVault() {
    const el = document.getElementById('dash-vault');
    return cachedListLoad({
      cacheKey: 'workspace.dash.vault' + USER_TAG,
      fetchUrl: '/.netlify/functions/workspace-vault-list?limit=4',
      skeleton: () => { el.innerHTML = dashSkeletonRows(3); },
      errorEl: el,
      renderData: (j) => {
        const items = (j.items || []).slice(0, 4);
        if (!items.length) {
          el.innerHTML = '<li class="ws-dash-empty">Vault is empty. <a href="/workspace/vault/" style="color:var(--accent-deep)">Add your first item →</a></li>';
        } else {
          el.innerHTML = items.map((it) => {
            const kind = (it.source_kind || '').replace(/_/g, ' ');
            return `<li class="ws-dash-row">
              <a href="/workspace/vault/?id=${it.id}" class="ws-dash-row-link">
                <span class="ws-dash-row-title">${escapeAttr(it.title || 'Untitled')}</span>
                <span class="ws-dash-row-meta">${escapeAttr(kind)}<span class="sep">·</span>${relTime(it.updated_at || it.created_at)}</span>
              </a>
            </li>`;
          }).join('');
        }
      },
    });
  }

  function updatePendingStrip() {
    const strip = document.getElementById('dash-pending');
    const txt = document.getElementById('dash-pending-text');
    const inflight = [
      ...reviewsCache.filter((r) => r.status === 'pending' || r.status === 'running').map((r) => ({ kind: 'review', id: r.id, title: r.title, status: r.status })),
      ...comparesCache.filter((r) => r.status === 'pending' || r.status === 'running').map((r) => ({ kind: 'comparison', id: r.id, title: r.title, status: r.status })),
    ];
    if (!inflight.length) { strip.hidden = true; return; }
    strip.hidden = false;
    const pieces = inflight.slice(0, 3).map((it) => {
      const href = it.kind === 'review' ? `/workspace/reviews/?id=${it.id}` : `/workspace/compare/?id=${it.id}`;
      return `<a href="${href}" class="ws-dash-pending-chip">${escapeAttr(it.title)} — ${it.status}</a>`;
    });
    const more = inflight.length > 3 ? ` <span style="color:var(--ink-3);">+${inflight.length - 3} more</span>` : '';
    txt.innerHTML = `<b>${inflight.length} in flight:</b> ${pieces.join(' · ')}${more}`;
  }

  let dashTimer = null;
  function scheduleDashRefresh() {
    if (dashTimer) clearTimeout(dashTimer);
    const anyInflight = [...reviewsCache, ...comparesCache].some((r) => r.status === 'pending' || r.status === 'running');
    if (!anyInflight) return;
    dashTimer = setTimeout(async () => {
      await Promise.all([loadDashReviews(), loadDashCompares()]);
      scheduleDashRefresh();
    }, 12_000);
  }

  Promise.all([loadDashReviews(), loadDashCompares(), loadDashLibrary(), loadDashVault()])
    .then(scheduleDashRefresh);

  renderFromCache();
  loadChats();
  loadProjectStrip();
</script>
</body>
</html>
