---
// Workspace landing — chat list + new chat button.
// Auth + approval gated client-side; the page shell ships static and
// the gate runs in the script tag below before revealing the page.
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Workspace — Legal Overflow</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<link rel="stylesheet" href="/workspace.css" />
</head>
<body>
<div id="grain"></div>

<header class="nav">
  <a href="/" class="brand">
    <svg class="brand-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="1"/><path d="M20 6 L20 34 M8 14 L32 14 M8 26 L32 26" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="20" cy="14" r="2.5" fill="currentColor"/><circle cx="20" cy="26" r="2.5" fill="var(--accent)"/></svg>
    <span class="brand-text"><span>Legal</span><span class="brand-over">Overflow</span></span>
  </a>
  <nav class="nav-links">
    <a href="/#skills">Skills</a>
    <a href="/#articles">Resources</a>
    <a href="/agents/">Agents</a>
    <a href="/workspace/" class="is-active">Workspace</a>
    <a href="/tracker/">Tracker</a>
    <a href="/#services">Services</a>
    <a href="/about/">About</a>
  </nav>
  <div class="nav-right">
    <a href="/account/" class="nav-sub">Account</a>
  </div>
</header>

<main class="ws-wrap">
  <header class="ws-head">
    <div>
      <div class="ws-kicker">Workspace</div>
      <h1 class="ws-title">Your research desk.</h1>
      <p class="ws-sub">Persistent multi-turn chats. Three model providers. Bring your own key if you want.</p>
    </div>
    <button id="new-chat" class="ws-btn">New chat</button>
  </header>

  <section class="ws-card">
    <header class="ws-card-head">
      <h2 class="ws-card-title">Recent chats</h2>
    </header>
    <div id="chat-list" class="ws-list">
      <div class="ws-empty">Loading…</div>
    </div>
  </section>

  <p class="ws-foot">
    <a href="/workspace/library/">Document library →</a> &nbsp;·&nbsp;
    <a href="/account/">Manage your API keys →</a>
  </p>
</main>

<footer class="foot">
  <p class="foot-bar-disclosure">
    <strong>Blake Beyel, Esq.</strong> · Florida Bar No. 1065044 · Cocoa, Florida ·
    The hiring of a lawyer is an important decision that should not be based solely on advertisements.
    Before you decide, ask for written information about the lawyer's qualifications and experience.
    No representation is made that the quality of the legal services to be performed is greater than
    the quality of legal services performed by other lawyers.
  </p>
  <div class="foot-bot"><span>© 2026 Legal Overflow</span><span class="foot-version">v2026.04<a href="/admin/users/" class="foot-admin-link" aria-label="Admin"></a></span></div>
</footer>

<script>
  import { getSupabase } from '../../lib/supabase';

  const supabase = getSupabase();

  // Auth gate: signed-in + approved. We hide the body upfront so a
  // non-approved user never glimpses the workspace UI shell. Anything
  // that throws below MUST land in the catch and reveal an error
  // panel — otherwise the page sits blank forever and the user has no
  // idea why.
  document.body.style.visibility = 'hidden';
  let session = null;
  try {
    const { data, error } = await supabase.auth.getSession();
    if (error) throw error;
    session = data?.session || null;
    if (!session) {
      location.href = '/login/?redirect=/workspace/';
      throw new Error('not signed in — redirecting');
    }
    const { data: profile, error: profileErr } = await supabase
      .from('profiles').select('tier, approved_at').eq('id', session.user.id).maybeSingle();
    if (profileErr) throw profileErr;
    if (!profile) {
      document.body.style.visibility = '';
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">No profile</h1><p>We could not find a profile for your account. This usually means signup did not finish. Try signing out and creating the account again, or contact the operator.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('no profile');
    }
    if (!profile.approved_at) {
      document.body.style.visibility = '';
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Pending approval</h1><p>Your account is pending operator approval. We review every signup before granting workspace access.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('pending approval');
    }
    document.body.style.visibility = '';
  } catch (err) {
    // If something unexpected blew up, surface it instead of leaving
    // a blank page. Re-throw at the end so dev tools still see it.
    if (err && err.message && !['pending approval','no profile','not signed in — redirecting'].includes(err.message)) {
      console.error('Workspace gate failed:', err);
      document.body.style.visibility = '';
      document.body.innerHTML = `<main style="max-width:680px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Workspace error</h1><p>The workspace failed to load. Open your browser console for full details.</p><pre style="background:#f5f5f5;padding:14px;border-radius:6px;font-size:12px;white-space:pre-wrap;word-break:break-word">${(err && err.message ? err.message : String(err)).replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]))}</pre><p><a href="/">Back to homepage</a></p></main>`;
    }
    throw err;
  }

  const chatList = document.getElementById('chat-list');
  const newChatBtn = document.getElementById('new-chat');
  const accessToken = session.access_token;

  // Same localStorage cache key as the chat page. Renders immediately
  // on reload so the chat list is never visibly empty during the
  // network round-trip; the fresh fetch overwrites it.
  const RAIL_CACHE_KEY = 'workspace.rail.' + (session.user?.id || 'anon');

  function renderChats(chats) {
    if (!chats?.length) {
      chatList.innerHTML = '<div class="ws-empty">No chats yet. Click "New chat" above to start one.</div>';
      return;
    }
    chatList.innerHTML = chats.map((c) => {
      const title = (c.title || 'Untitled chat').replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]));
      const date = new Date(c.updated_at).toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' });
      // Delete button is a sibling button (not nested inside the
      // anchor) so clicking it doesn't trigger row navigation.
      return `<div class="ws-row-wrap">
        <a href="/workspace/chat/?id=${c.id}" class="ws-row">
          <span class="ws-row-title">${title}</span>
          <span class="ws-row-meta">${c.model || ''} · ${date}</span>
        </a>
        <button type="button" class="ws-row-del" data-del="${c.id}" data-title="${title}" aria-label="Delete chat" title="Delete chat">×</button>
      </div>`;
    }).join('');

    // Wire delete handlers
    chatList.querySelectorAll('[data-del]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.dataset.del;
        const title = btn.dataset.title;
        if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;
        btn.disabled = true;
        const r = await fetch('/.netlify/functions/workspace-chats-delete', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          alert('Delete failed: ' + (j.error || 'unknown'));
          btn.disabled = false;
          return;
        }
        // Invalidate cache and refetch
        try { localStorage.removeItem(RAIL_CACHE_KEY); } catch {}
        loadChats();
      });
    });
  }
  function renderFromCache() {
    try {
      const raw = localStorage.getItem(RAIL_CACHE_KEY);
      if (!raw) return false;
      const cached = JSON.parse(raw);
      if (!Array.isArray(cached) || cached.length === 0) return false;
      renderChats(cached);
      return true;
    } catch { return false; }
  }
  async function loadChats() {
    const r = await fetch('/.netlify/functions/workspace-chats-list', {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) {
      chatList.innerHTML = `<div class="ws-empty">Failed to load chats: ${j.error || 'unknown'}</div>`;
      return;
    }
    const chats = j.chats || [];
    renderChats(chats);
    try { localStorage.setItem(RAIL_CACHE_KEY, JSON.stringify(chats)); } catch {}
  }

  async function createChat() {
    newChatBtn.disabled = true;
    const r = await fetch('/.netlify/functions/workspace-chats-create', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({}),
    });
    const j = await r.json();
    newChatBtn.disabled = false;
    if (!r.ok) {
      alert('Failed to create chat: ' + (j.error || 'unknown'));
      return;
    }
    location.href = `/workspace/chat/?id=${j.id}`;
  }

  newChatBtn.addEventListener('click', createChat);
  // Show cached list instantly, then refresh from server.
  renderFromCache();
  loadChats();
</script>
</body>
</html>
