<script>
  import { getSupabase } from '../../../lib/supabase';
  const supabase = getSupabase();

  // Body never hidden — match the dashboard's hardened pattern.
  console.log('[projects] Script started');
  let session;
  try {
    const { data } = await supabase.auth.getSession();
    session = data?.session;
    if (!session) {
      const here = location.pathname + location.search;
      console.info('[projects] No session — redirecting to /login/');
      location.href = '/login/?redirect=' + encodeURIComponent(here);
      throw new Error('not signed in');
    }
    const { data: profile } = await supabase
      .from('profiles').select('approved_at').eq('id', session.user.id).maybeSingle();
    if (!profile?.approved_at) {
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Pending approval</h1><p>Your account is pending operator approval.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('pending approval');
    }
    console.log('[projects] Auth gate passed, user', session.user?.id);
  } catch (err) {
    if (err && !['not signed in', 'pending approval'].includes(err.message)) {
      console.error('[projects] Gate failed:', err);
      document.body.innerHTML = `<main style="max-width:680px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Projects error</h1><pre style="background:#f5f5f5;padding:14px;border-radius:6px;font-size:12px;white-space:pre-wrap">${(err.message || String(err)).replace(/[<>&]/g,(c)=>({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]))}</pre><p><a href="/workspace/">← Back to workspace</a></p></main>`;
    }
    throw err;
  }

  const accessToken = session.access_token;
  const main = document.getElementById('page-main');
  const projectId = new URL(location.href).searchParams.get('id');

  function escapeHtml(s) {
    return String(s ?? '').replace(/[<>&"]/g, (c) => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
  }
  function pad2(n) { return String(n).padStart(2, '0'); }
  function relTime(iso) {
    if (!iso) return '—';
    const d = new Date(iso);
    const today = new Date();
    if (d.toDateString() === today.toDateString()) {
      return pad2(d.getHours()) + ':' + pad2(d.getMinutes());
    }
    const yest = new Date(today); yest.setDate(today.getDate() - 1);
    if (d.toDateString() === yest.toDateString()) {
      return 'YDA ' + pad2(d.getHours()) + ':' + pad2(d.getMinutes());
    }
    const ms = Date.now() - d.getTime();
    const days = Math.floor(ms / 86400_000);
    if (days < 7) return days + 'D AGO';
    return d.toLocaleDateString(undefined, { day: '2-digit', month: 'short' }).toUpperCase();
  }
  function ageBucket(iso) {
    if (!iso) return 'dormant';
    const ms = Date.now() - new Date(iso).getTime();
    if (ms < 24 * 60 * 60 * 1000) return 'active';
    if (ms > 14 * 24 * 60 * 60 * 1000) return 'dormant';
    return 'idle';
  }
  function projShortId(id) {
    return 'M-' + (id || '').slice(0, 4).toUpperCase();
  }

  // ============================================================
  // LIST VIEW
  // ============================================================
  let allProjects = [];
  let activeFilter = 'all';
  const SORT_VALUES = ['Activity · recent', 'Activity · oldest', 'Name · A–Z', 'Docs · most', 'Reviews · most'];
  let sortIdx = 0;

  async function renderListView() {
    main.innerHTML = `
      <div class="ws-wrap">
        <header class="ws-head">
          <span class="br-bl"></span><span class="br-br"></span>
          <div class="kicker">
            <span class="k-tag">PROJECTS</span>
            <span class="k-coord" id="proj-coord">/WS.06 · MATTERS · — OPEN</span>
          </div>
          <div class="head-row">
            <div>
              <h1 class="head-title">Matters &amp; <em>projects</em>.</h1>
              <p class="head-sub">A folder per matter. Group related documents, chats, reviews, and comparisons under one roof. Items not in a project sit in the global workspace.</p>
            </div>
            <div class="head-actions">
              <button class="ws-btn" id="new-project-btn" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 5v14M5 12h14"/></svg>
                New project
              </button>
            </div>
          </div>
        </header>

        <div class="meta-strip">
          <div class="ms-cell">
            <span class="ms-l">OPEN</span>
            <span class="ms-v" id="ms-open">—</span>
            <span class="ms-d">PROJECTS</span>
          </div>
          <div class="ms-cell">
            <span class="ms-l">ACTIVE NOW</span>
            <span class="ms-v" id="ms-active" style="color:var(--accent-deep)">—</span>
            <span class="ms-d">EDITED &lt; 24H</span>
          </div>
          <div class="ms-cell">
            <span class="ms-l">DORMANT</span>
            <span class="ms-v" id="ms-dormant" style="color:var(--ink-4)">—</span>
            <span class="ms-d">&gt; 14D STALE</span>
          </div>
          <div class="ms-cell">
            <span class="ms-l">DOCUMENTS</span>
            <span class="ms-v" id="ms-docs">—</span>
            <span class="ms-d">ACROSS ALL</span>
          </div>
          <div class="ms-cell">
            <span class="ms-l">REVIEWS</span>
            <span class="ms-v" id="ms-reviews">—</span>
            <span class="ms-d">ACROSS ALL</span>
          </div>
        </div>

        <div class="sec-div">
          <span class="sec-num">§ 06.A</span>
          <span class="sec-rule"></span>
          <span class="sec-meta">MATTERS · MOST RECENT</span>
        </div>

        <div class="filter-row" id="proj-filters">
          <span class="fl-l">FILTER ·</span>
          <button type="button" class="fl-toggle is-on" data-filter="all"><span class="fl-pip"></span>All <span class="fl-cnt" id="cnt-all">[—]</span></button>
          <span class="fl-sep"></span>
          <button type="button" class="fl-toggle" data-filter="active"><span class="fl-pip"></span>Active <span class="fl-cnt" id="cnt-active">[—]</span></button>
          <span class="fl-sep"></span>
          <button type="button" class="fl-toggle" data-filter="idle"><span class="fl-pip"></span>Idle <span class="fl-cnt" id="cnt-idle">[—]</span></button>
          <span class="fl-sep"></span>
          <button type="button" class="fl-toggle" data-filter="dormant"><span class="fl-pip"></span>Dormant <span class="fl-cnt" id="cnt-dormant">[—]</span></button>
          <span class="fl-spacer"></span>
          <button type="button" class="fl-sort" id="proj-sort"><span>Sort</span><span class="v" id="sort-v">Activity · recent</span></button>
        </div>

        <div class="proj-grid" id="projects-grid">
          <div class="proj-skel"><div class="skel-block tiny"></div><div class="skel-block"></div><div class="skel-block short"></div><div class="skel-block tiny"></div></div>
          <div class="proj-skel"><div class="skel-block tiny"></div><div class="skel-block"></div><div class="skel-block short"></div><div class="skel-block tiny"></div></div>
          <div class="proj-skel"><div class="skel-block tiny"></div><div class="skel-block"></div><div class="skel-block short"></div><div class="skel-block tiny"></div></div>
        </div>

        <p class="ws-foot">
          <span><span style="color:var(--ink-4)">EOF</span> &nbsp; · &nbsp; END OF PROJECTS</span>
          <a href="/workspace/">← Workspace home</a>
        </p>
      </div>
    `;
    document.getElementById('new-project-btn').addEventListener('click', openNewProjectModal);
    document.querySelectorAll('#proj-filters .fl-toggle').forEach((b) => {
      b.addEventListener('click', () => {
        document.querySelectorAll('#proj-filters .fl-toggle').forEach((x) => x.classList.remove('is-on'));
        b.classList.add('is-on');
        activeFilter = b.dataset.filter || 'all';
        paintGrid();
      });
    });
    document.getElementById('proj-sort').addEventListener('click', () => {
      sortIdx = (sortIdx + 1) % SORT_VALUES.length;
      document.getElementById('sort-v').textContent = SORT_VALUES[sortIdx];
      paintGrid();
    });
    await loadProjects();
  }

  // Cache-first
  const PROJ_LIST_CACHE = 'workspace.projects-list.' + (session.user?.id || 'anon');

  function applySort(arr) {
    const v = SORT_VALUES[sortIdx];
    const sorted = [...arr];
    if (v === 'Activity · recent') sorted.sort((a, b) => (b.updated_at || '').localeCompare(a.updated_at || ''));
    else if (v === 'Activity · oldest') sorted.sort((a, b) => (a.updated_at || '').localeCompare(b.updated_at || ''));
    else if (v === 'Name · A–Z') sorted.sort((a, b) => (a.name || '').localeCompare(b.name || ''));
    else if (v === 'Docs · most') sorted.sort((a, b) => ((b.counts?.documents) || 0) - ((a.counts?.documents) || 0));
    else if (v === 'Reviews · most') sorted.sort((a, b) => ((b.counts?.reviews) || 0) - ((a.counts?.reviews) || 0));
    return sorted;
  }
  function applyFilter(arr) {
    if (activeFilter === 'all') return arr;
    return arr.filter((p) => ageBucket(p.updated_at || p.created_at) === activeFilter);
  }

  function paintGrid() {
    const grid = document.getElementById('projects-grid');
    if (!grid) return;
    const sorted = applySort(applyFilter(allProjects));
    const newTile = `<button type="button" class="proj-new" id="proj-new-tile">
      <span class="proj-new-l">+ NEW PROJECT</span>
      <span class="proj-new-cross">+</span>
      <span class="proj-new-h">Open a matter</span>
      <span class="proj-new-l" style="opacity:.6">DOCS · CHATS · REVIEWS · COMPARES</span>
    </button>`;
    if (!sorted.length) {
      grid.innerHTML = `<div class="ws-empty">${activeFilter === 'all' ? 'No projects yet. Click "New project" above to start one.' : 'No projects in this filter.'}</div>` + newTile;
      const newBtn = grid.querySelector('#proj-new-tile');
      if (newBtn) newBtn.addEventListener('click', openNewProjectModal);
      return;
    }
    grid.innerHTML = sorted.map((p) => {
      const c = p.counts || {};
      const age = ageBucket(p.updated_at || p.created_at);
      const stateLabel = age === 'active' ? 'ACTIVE' : age === 'dormant' ? 'DORMANT' : 'IDLE';
      const stateCls = age === 'active' ? '' : age === 'dormant' ? 'dormant' : 'review';
      // Pick a "client" line from the description (first sentence, ≤ 60 chars)
      const desc = (p.description || '').trim();
      const clientLine = desc ? desc.split(/[.\n]/)[0].slice(0, 60).toUpperCase() : 'INTERNAL · MATTER';
      const tags = [];
      if ((c.documents || 0) > 0) tags.push((c.documents) + ' DOCS');
      if ((c.reviews || 0) > 0) tags.push((c.reviews) + ' REVIEWS');
      if ((c.chats || 0) > 0) tags.push((c.chats) + ' CHATS');
      const tagsHtml = tags.length
        ? `<div class="proj-tags">${tags.slice(0, 4).map((t) => `<span class="tg">${escapeHtml(t)}</span>`).join('')}</div>`
        : '';
      return `<a href="/workspace/projects/?id=${p.id}" class="proj-card" data-id="${p.id}">
        <div class="proj-head">
          <div class="proj-h-row">
            <span class="proj-h-id">${escapeHtml(projShortId(p.id))}</span>
            <span class="proj-h-state ${stateCls}"><span class="pip"></span>${stateLabel}</span>
          </div>
          <h3 class="proj-title">${escapeHtml(p.name || 'Untitled')}</h3>
          <div class="proj-client">${escapeHtml(clientLine)}</div>
          ${tagsHtml}
        </div>
        <div class="proj-body">
          <div class="proj-counts">
            <div class="pc"><span class="pc-l">DOCS</span><span class="pc-v">${pad2(c.documents || 0)}</span></div>
            <div class="pc"><span class="pc-l">CHATS</span><span class="pc-v">${(c.chats || 0) > 0 ? `<em>${pad2(c.chats)}</em>` : pad2(0)}</span></div>
            <div class="pc"><span class="pc-l">REVIEWS</span><span class="pc-v">${(c.reviews || 0) > 0 ? `<em>${pad2(c.reviews)}</em>` : pad2(0)}</span></div>
          </div>
          ${desc ? `<div class="proj-recent" style="font-family:var(--serif); font-size:13.5px; color:var(--ink-2); letter-spacing:0;">${escapeHtml(desc.slice(0, 220))}${desc.length > 220 ? '…' : ''}</div>` : ''}
        </div>
        <div class="proj-foot">
          <span>UPDATED ${escapeHtml(relTime(p.updated_at || p.created_at))}</span>
          <span class="open">Open <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </div>
      </a>`;
    }).join('') + newTile;

    const newBtn = grid.querySelector('#proj-new-tile');
    if (newBtn) newBtn.addEventListener('click', openNewProjectModal);
  }

  function paintMetaStrip() {
    const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
    const total = allProjects.length;
    const active = allProjects.filter((p) => ageBucket(p.updated_at || p.created_at) === 'active').length;
    const dormant = allProjects.filter((p) => ageBucket(p.updated_at || p.created_at) === 'dormant').length;
    const idle = allProjects.filter((p) => ageBucket(p.updated_at || p.created_at) === 'idle').length;
    const docs = allProjects.reduce((s, p) => s + ((p.counts?.documents) || 0), 0);
    const reviews = allProjects.reduce((s, p) => s + ((p.counts?.reviews) || 0), 0);
    set('ms-open', total);
    set('ms-active', active || '0');
    set('ms-dormant', dormant || '0');
    set('ms-docs', docs);
    set('ms-reviews', reviews);
    set('cnt-all', '[' + total + ']');
    set('cnt-active', '[' + active + ']');
    set('cnt-idle', '[' + idle + ']');
    set('cnt-dormant', '[' + dormant + ']');
    const coord = document.getElementById('proj-coord');
    if (coord) coord.textContent = '/WS.06 · MATTERS · ' + total + ' OPEN';
  }

  function renderProjectsFromData(j) {
    allProjects = j.projects || [];
    paintMetaStrip();
    paintGrid();
  }
  async function loadProjects() {
    let renderedSomething = false;
    try {
      const cached = JSON.parse(localStorage.getItem(PROJ_LIST_CACHE) || 'null');
      if (cached) { renderProjectsFromData(cached); renderedSomething = true; }
    } catch {}
    try {
      console.log('[projects] loadProjects() fetching');
      const r = await fetch('/.netlify/functions/workspace-projects-list', {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Failed to load');
      console.log('[projects] got', (j.projects || []).length, 'projects');
      renderProjectsFromData(j);
      try { localStorage.setItem(PROJ_LIST_CACHE, JSON.stringify(j)); } catch {}
    } catch (e) {
      console.error('[projects] loadProjects() failed:', e);
      const grid = document.getElementById('projects-grid');
      if (!renderedSomething && grid) {
        grid.innerHTML = `<div class="ws-empty">${escapeHtml(e.message || 'Failed to load')}</div>`;
      }
    }
  }

  function openNewProjectModal() {
    const overlay = document.createElement('div');
    overlay.className = 'attach-modal';
    overlay.innerHTML = `
      <div class="attach-modal-inner">
        <header class="attach-modal-head">
          <h2 class="attach-modal-title">New project</h2>
          <button type="button" class="attach-modal-close" data-close>×</button>
        </header>
        <div class="attach-modal-body">
          <label class="rv-field">
            <span class="rv-field-label">Name</span>
            <input type="text" id="proj-name" maxlength="200" placeholder="e.g. Acme Corp acquisition" />
          </label>
          <label class="rv-field">
            <span class="rv-field-label">Description (optional)</span>
            <textarea id="proj-desc" rows="3" placeholder="Notes about this matter — client, jurisdiction, key dates…"></textarea>
          </label>
        </div>
        <footer class="attach-modal-foot">
          <button type="button" class="ws-btn" id="proj-create">Create</button>
        </footer>
      </div>`;
    document.body.appendChild(overlay);
    const close = () => overlay.remove();
    overlay.querySelector('[data-close]').addEventListener('click', close);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

    overlay.querySelector('#proj-create').addEventListener('click', async () => {
      const name = overlay.querySelector('#proj-name').value.trim();
      const description = overlay.querySelector('#proj-desc').value.trim();
      if (!name) { alert('Name required'); return; }
      const btn = overlay.querySelector('#proj-create');
      btn.disabled = true; btn.textContent = 'Creating…';
      const r = await fetch('/.netlify/functions/workspace-projects-create', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, description }),
      });
      const j = await r.json();
      if (!r.ok) { alert('Failed: ' + (j.error || 'unknown')); btn.disabled = false; btn.textContent = 'Create'; return; }
      try { localStorage.removeItem(PROJ_LIST_CACHE); } catch {}
      location.href = `/workspace/projects/?id=${j.project.id}`;
    });
    overlay.querySelector('#proj-name').focus();
  }

  // ============================================================
  // SINGLE PROJECT VIEW
  // ============================================================
  async function renderProjectView(id) {
    const r = await fetch(`/.netlify/functions/workspace-projects-get?id=${encodeURIComponent(id)}`, {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) {
      main.innerHTML = `<div class="ws-wrap"><div class="ws-empty">${escapeHtml(j.error || 'Failed to load')}</div></div>`;
      return;
    }
    const { project, chats, documents, reviews } = j;
    const age = ageBucket(project.updated_at || project.created_at);
    const stateLabel = age === 'active' ? 'ACTIVE' : age === 'dormant' ? 'DORMANT' : 'IDLE';
    const stateCls = age === 'active' ? '' : age === 'dormant' ? 'dormant' : 'review';

    main.innerHTML = `
      <div class="ws-wrap">
        <header class="ws-head">
          <span class="br-bl"></span><span class="br-br"></span>
          <div class="kicker">
            <a href="/workspace/projects/" class="lib-back">← Projects</a>
            <span class="k-coord" style="margin-left:8px">/WS.06 · ${escapeHtml(projShortId(project.id))}</span>
            <span class="proj-h-state ${stateCls}" style="margin-left:8px"><span class="pip"></span>${stateLabel}</span>
          </div>
          <div class="head-row">
            <div>
              <h1 class="ws-title" id="proj-title">${escapeHtml(project.name)}</h1>
              ${project.description ? `<p class="ws-sub">${escapeHtml(project.description)}</p>` : ''}
            </div>
            <div class="ws-head-actions">
              <button id="proj-rename" class="ws-btn-secondary" type="button">Rename</button>
              <button id="proj-new-chat" class="ws-btn" type="button">+ New chat</button>
              <button id="proj-delete" class="ws-btn-secondary" type="button">Delete</button>
            </div>
          </div>
        </header>

        <div class="meta-strip">
          <div class="ms-cell">
            <span class="ms-l">DOCUMENTS</span>
            <span class="ms-v">${pad2(documents.length)}</span>
            <span class="ms-d">IN PROJECT</span>
          </div>
          <div class="ms-cell">
            <span class="ms-l">CHATS</span>
            <span class="ms-v">${(chats.length > 0 ? `<em>${pad2(chats.length)}</em>` : pad2(0))}</span>
            <span class="ms-d">CONVERSATIONS</span>
          </div>
          <div class="ms-cell">
            <span class="ms-l">REVIEWS</span>
            <span class="ms-v">${(reviews.length > 0 ? `<em>${pad2(reviews.length)}</em>` : pad2(0))}</span>
            <span class="ms-d">TABULAR</span>
          </div>
          <div class="ms-cell">
            <span class="ms-l">CREATED</span>
            <span class="ms-v" style="font-family:var(--mono); font-size:14px">${escapeHtml(relTime(project.created_at))}</span>
            <span class="ms-d">FIRST OPENED</span>
          </div>
          <div class="ms-cell">
            <span class="ms-l">UPDATED</span>
            <span class="ms-v" style="font-family:var(--mono); font-size:14px">${escapeHtml(relTime(project.updated_at || project.created_at))}</span>
            <span class="ms-d">LAST ACTIVITY</span>
          </div>
        </div>

        <section class="proj-section">
          <header class="proj-section-head">
            <h2 class="proj-section-title">Documents <span class="proj-count">[${pad2(documents.length)}]</span></h2>
            <a href="/workspace/library/" class="lib-back">Library →</a>
          </header>
          ${documents.length ? `<div class="lib-grid">${documents.map((d) => `
            <a href="/workspace/library/?id=${d.id}" class="lib-card-link">
              <div class="lib-card-name">${escapeHtml(d.filename)}</div>
              <div class="lib-card-meta">${(d.current_version?.extracted_chars || 0).toLocaleString()} chars</div>
            </a>`).join('')}</div>` : '<div class="ws-empty">No documents in this project. <a href="/workspace/library/">Upload some →</a></div>'}
        </section>

        <section class="proj-section">
          <header class="proj-section-head">
            <h2 class="proj-section-title">Chats <span class="proj-count">[${pad2(chats.length)}]</span></h2>
            <a href="/workspace/" class="lib-back">All chats →</a>
          </header>
          ${chats.length ? chats.map((c) => `
            <a href="/workspace/chat/?id=${c.id}" class="ws-row">
              <span class="ws-row-title">${escapeHtml(c.title || 'Untitled chat')}</span>
              <span class="ws-row-meta">${escapeHtml(c.model || '')} · ${escapeHtml(relTime(c.updated_at))}</span>
            </a>`).join('') : '<div class="ws-empty">No chats yet. Click "+ New chat" above to start one in this project.</div>'}
        </section>

        <section class="proj-section">
          <header class="proj-section-head">
            <h2 class="proj-section-title">Tabular reviews <span class="proj-count">[${pad2(reviews.length)}]</span></h2>
            <a href="/workspace/reviews/" class="lib-back">All reviews →</a>
          </header>
          ${reviews.length ? reviews.map((rv) => `
            <a href="/workspace/reviews/?id=${rv.id}" class="ws-row">
              <span class="ws-row-title">${escapeHtml(rv.title)}</span>
              <span class="ws-row-meta">${(rv.columns_config || []).length} cols · ${escapeHtml(rv.status)}</span>
            </a>`).join('') : '<div class="ws-empty">No reviews yet.</div>'}
        </section>

        <p class="ws-foot">
          <span><span style="color:var(--ink-4)">EOF</span> &nbsp; · &nbsp; END OF MATTER</span>
          <a href="/workspace/projects/">← All projects</a>
        </p>
      </div>
    `;

    document.getElementById('proj-rename').addEventListener('click', () => {
      const titleEl = document.getElementById('proj-title');
      if (!titleEl || titleEl.dataset.editing) return;
      titleEl.dataset.editing = '1';
      const original = project.name;
      const input = document.createElement('input');
      input.type = 'text';
      input.value = original;
      input.maxLength = 200;
      input.className = 'proj-title-input';
      titleEl.replaceWith(input);
      input.focus();
      input.select();

      const restore = (newName) => {
        const h1 = document.createElement('h1');
        h1.id = 'proj-title';
        h1.className = 'ws-title';
        h1.textContent = newName;
        input.replaceWith(h1);
      };
      const save = async () => {
        const next = input.value.trim();
        if (!next || next === original) { restore(original); return; }
        input.disabled = true;
        const r = await fetch('/.netlify/functions/workspace-projects-update', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: project.id, name: next }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          input.disabled = false;
          input.classList.add('is-error');
          input.title = j.error || 'failed';
          return;
        }
        try { localStorage.removeItem(PROJ_LIST_CACHE); } catch {}
        project.name = next;
        restore(next);
      };
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); save(); }
        else if (e.key === 'Escape') restore(original);
      });
      input.addEventListener('blur', () => { if (!input.disabled) save(); });
    });

    document.getElementById('proj-delete').addEventListener('click', async () => {
      if (!confirm(`Delete project "${project.name}"? Contained items will move back to the global workspace (chats, docs, reviews are kept).`)) return;
      const r = await fetch('/.netlify/functions/workspace-projects-delete', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: project.id }),
      });
      if (!r.ok) { const j = await r.json().catch(() => ({})); alert('Failed: ' + (j.error || 'unknown')); return; }
      try { localStorage.removeItem(PROJ_LIST_CACHE); } catch {}
      location.href = '/workspace/projects/';
    });

    document.getElementById('proj-new-chat').addEventListener('click', async () => {
      const r = await fetch('/.netlify/functions/workspace-chats-create', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ project_id: project.id }),
      });
      const j = await r.json();
      if (!r.ok) { alert('Failed: ' + (j.error || 'unknown')); return; }
      location.href = `/workspace/chat/?id=${j.id}`;
    });
  }

  // ============================================================
  if (projectId) renderProjectView(projectId);
  else renderListView();
</script>
</body>
</html>
