<script>
  import { getSupabase } from '../../../lib/supabase';
  const supabase = getSupabase();

  // Body never hidden — match the dashboard's hardened pattern.
  console.log('[vault] Script started');
  let session = null;
  try {
    const { data, error } = await supabase.auth.getSession();
    if (error) throw error;
    session = data?.session;
    if (!session) {
      console.info('[vault] No session — redirecting to /login/');
      location.href = '/login/?redirect=/workspace/vault/';
      throw new Error('not signed in');
    }
    const { data: profile } = await supabase
      .from('profiles').select('approved_at').eq('id', session.user.id).maybeSingle();
    if (!profile?.approved_at) {
      location.href = '/account/?status=pending';
      throw new Error('not approved');
    }
    console.log('[vault] Auth gate passed, user', session.user?.id);
  } catch (err) {
    if (err && !['not signed in','not approved'].includes(err.message)) {
      console.error('[vault] Gate failed:', err);
    }
  }

  if (!session) {
    // Stop here — gate already redirected.
    throw new Error('halted: no session');
  }

  const accessToken = session.access_token;
  const userId = session.user.id;

  // ---- State ----
  let items = [];
  let selected = new Set();
  let isSearchMode = false;
  let activeKindFilter = '';
  let activeSearchMode = 'hybrid';
  const SORT_VALUES = ['Updated · newest', 'Updated · oldest', 'Title · A–Z', 'Chars · most', 'Kind'];
  let sortIdx = 0;

  function escapeAttr(s) {
    return String(s ?? '').replace(/[<>&"']/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;', "'": '&#39;' }[c]));
  }
  function relTime(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    const diff = Date.now() - d.getTime();
    const m = Math.floor(diff / 60_000);
    if (m < 1) return 'just now';
    if (m < 60) return m + 'm';
    const h = Math.floor(m / 60);
    if (h < 24) return h + 'h';
    const days = Math.floor(h / 24);
    if (days < 30) return days + 'd';
    return d.toLocaleDateString();
  }
  function fmtChars(n) {
    if (!n) return '—';
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
    if (n >= 1000) return Math.round(n / 1000) + 'k';
    return String(n);
  }
  function humanizeKind(kind) {
    return ({ document: 'Document', chat: 'Chat', review_finding: 'Finding', manual_note: 'Note' }[kind] || kind || '').replace(/_/g, ' ');
  }
  function shortKindBadge(kind) {
    if (kind === 'document') return 'DOC';
    if (kind === 'chat') return 'CHAT';
    if (kind === 'review_finding') return 'FIND';
    if (kind === 'manual_note') return 'NOTE';
    return (kind || '?').toUpperCase().slice(0, 4);
  }
  function kindBadgeClass(kind) {
    if (kind === 'document') return 'is-pdf';   // most documents are PDFs visually
    if (kind === 'chat') return 'is-mail';
    if (kind === 'review_finding') return 'is-img';
    if (kind === 'manual_note') return 'is-txt';
    return 'is-doc';
  }

  function applySort(arr) {
    const sorted = [...arr];
    const v = SORT_VALUES[sortIdx];
    if (v === 'Updated · newest') sorted.sort((a, b) => (b.updated_at || b.created_at || '').localeCompare(a.updated_at || a.created_at || ''));
    else if (v === 'Updated · oldest') sorted.sort((a, b) => (a.updated_at || a.created_at || '').localeCompare(b.updated_at || b.created_at || ''));
    else if (v === 'Title · A–Z') sorted.sort((a, b) => (a.title || '').localeCompare(b.title || ''));
    else if (v === 'Chars · most') sorted.sort((a, b) => (b.content_chars || 0) - (a.content_chars || 0));
    else if (v === 'Kind') sorted.sort((a, b) => (a.source_kind || '').localeCompare(b.source_kind || ''));
    return sorted;
  }

  // ---- Load list ----
  async function loadList() {
    const list = document.getElementById('vault-list');
    const url = new URL('/.netlify/functions/workspace-vault-list', location.origin);
    if (activeKindFilter) url.searchParams.set('kind', activeKindFilter);
    url.searchParams.set('limit', '200');
    try {
      const r = await fetch(url, { headers: { Authorization: 'Bearer ' + accessToken } });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Failed to load');
      items = j.items || [];
      isSearchMode = false;
      selected.clear();
      renderList();
      updateBulkBar();
      updateMetaStrip();
      updateFilterCounts();
    } catch (err) {
      list.innerHTML = '<div class="vault-empty">Failed to load: ' + escapeAttr(err.message) + '</div>';
    }
  }

  function renderList() {
    const list = document.getElementById('vault-list');
    const sorted = applySort(items);
    if (!sorted.length) {
      list.innerHTML =
        '<div class="vault-empty">' +
        '<p><strong>Your Vault is empty.</strong></p>' +
        '<p>Add a note above (paste text or upload a file), bulk-import existing files, ' +
        'or save a chat or review finding from elsewhere in the workspace.</p>' +
        '</div>';
      return;
    }
    list.innerHTML = sorted.map((it) => {
      const tags = (it.tags || []).slice(0, 3).map((t) => '<span class="tag-chip">' + escapeAttr(t) + '</span>').join('');
      const kindBadge = '<span class="vr-kind ' + kindBadgeClass(it.source_kind) + '">' + escapeAttr(shortKindBadge(it.source_kind)) + '</span>';
      const pinned = it.pinned ? '<span class="vault-pin-dot" title="Pinned">📌</span>' : '';
      const archived = it.archived_at ? '<span class="vault-arch-chip">archived</span>' : '';
      const score = (typeof it.score === 'number') ? '<span class="vault-score" title="Similarity">' + Math.round(it.score * 100) + '%</span>' : '';
      const checked = selected.has(it.id) ? ' checked' : '';
      const sub = (it.summary || (humanizeKind(it.source_kind) || '').toUpperCase());
      return (
        '<div class="vault-row" data-id="' + it.id + '">' +
          '<label class="vault-row-check" data-stop-row-click>' +
            '<input type="checkbox" data-vault-row-check="' + it.id + '"' + checked + ' />' +
          '</label>' +
          kindBadge +
          '<div class="vr-title-wrap">' +
            '<span class="vr-title">' + escapeAttr(it.title || 'Untitled') + '</span>' +
            '<span class="vr-sub">' + escapeAttr(sub) + (pinned ? ' ' + pinned : '') + (archived ? ' ' + archived : '') + '</span>' +
          '</div>' +
          '<div class="vr-tags">' + (tags || '<span style="opacity:.4">—</span>') + '</div>' +
          '<span class="vr-size">' + (it.content_chars ? fmtChars(it.content_chars) : '—') + '</span>' +
          '<span class="vr-updated">' + relTime(it.updated_at || it.created_at) + score + '</span>' +
        '</div>'
      );
    }).join('');

    list.querySelectorAll('.vault-row[data-id]').forEach((row) => {
      row.addEventListener('click', (e) => {
        if (e.target.closest('[data-stop-row-click]') || e.target.closest('input')) return;
        // Mark active row
        list.querySelectorAll('.vault-row').forEach((r) => r.classList.remove('is-active'));
        row.classList.add('is-active');
        openDetail(row.dataset.id);
      });
    });
    list.querySelectorAll('[data-vault-row-check]').forEach((cb) => {
      cb.addEventListener('change', (e) => {
        e.stopPropagation();
        const id = cb.dataset.vaultRowCheck;
        if (cb.checked) selected.add(id); else selected.delete(id);
        cb.closest('.vault-row')?.classList.toggle('is-selected', cb.checked);
        updateBulkBar();
      });
    });
  }

  function updateMetaStrip() {
    const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
    set('ms-doc-count', items.length || '0');
    set('ms-doc-recent', items.length === 1 ? '1 indexed' : items.length + ' indexed');
    set('ms-chars', fmtChars(items.reduce((s, it) => s + (it.content_chars || 0), 0)));
    set('ms-pinned', items.filter((it) => it.pinned).length || '0');
    const newest = items.reduce((acc, it) => {
      const d = new Date(it.updated_at || it.created_at || 0);
      return (!acc || d > acc) ? d : acc;
    }, null);
    if (newest) {
      const pad = (n) => String(n).padStart(2, '0');
      set('ms-last-updated', pad(newest.getHours()) + ':' + pad(newest.getMinutes()) + ':' + pad(newest.getSeconds()));
      set('ms-last-updated-date', newest.toLocaleDateString(undefined, { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase());
    } else {
      set('ms-last-updated', '—');
      set('ms-last-updated-date', '—');
    }
    const sec = document.getElementById('sec-index-meta');
    if (sec) sec.textContent = 'INDEX · ' + items.length + ' ITEM' + (items.length === 1 ? '' : 'S') + ' · ALL DESTINATIONS';
  }

  function updateFilterCounts() {
    const set = (id, n) => { const el = document.getElementById(id); if (el) el.textContent = '[' + n + ']'; };
    set('fl-cnt-all', items.length);
    set('fl-cnt-document', items.filter((it) => it.source_kind === 'document').length);
    set('fl-cnt-chat', items.filter((it) => it.source_kind === 'chat').length);
    set('fl-cnt-review_finding', items.filter((it) => it.source_kind === 'review_finding').length);
    set('fl-cnt-manual_note', items.filter((it) => it.source_kind === 'manual_note').length);
  }

