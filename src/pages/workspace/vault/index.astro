    try {
      const r = await fetch('/.netlify/functions/workspace-vault-get?id=' + encodeURIComponent(id), {
        headers: { Authorization: 'Bearer ' + accessToken },
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Failed to load');
      renderDetail(j.item, j.chunk_count);
