---
// Personal Vault — per-user RAG knowledge base.
// Verbatim port of the Vault.html prototype design with all
// existing JS handlers preserved (auth gate, cache-first list,
// semantic search, bulk import + ops, OCR pipeline, modals).
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Vault — Legal Overflow</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<link rel="stylesheet" href="/workspace.css" />
<link rel="stylesheet" href="/site-anim.css" />
<script src="/nav-autohide.js" defer></script>
<script src="/site-dialog.js" defer></script>
<script src="/site-anim.js" defer></script>
<style is:global>
  /* ============================================================
     Vault — page-local stylesheet (verbatim port of the prototype).
     is:global because rows + detail panel + upload strip are all
     rendered via JS — those nodes don't get Astro's auto-scoped
     attribute, so a normal scoped <style> would fail to match.
     Page-local-ness enforced by body.ws-vault ancestor selector.
     ============================================================ */

  body.ws-vault {
    --rule-thread: #cbc4b1;
    --motion-snap: cubic-bezier(.2,.8,.2,1);
    --hi: #b22222; --md: #c98a14; --lo: #6a7c8e;
    background-image:
      radial-gradient(1100px 600px at 80% -10%, rgba(208,219,213,.18), transparent 60%),
      radial-gradient(900px 500px at -10% 20%, rgba(220,212,196,.25), transparent 70%);
  }

  /* ---------- shell ---------- */
  body.ws-vault main.ws-wrap {
    position: relative; z-index: 2;
    max-width: 1480px; width: 100%;
    margin: 0 auto;
    padding: 22px 40px 40px !important;
    background: transparent;
    border: none !important;
  }
  @media (max-width: 980px) {
    body.ws-vault main.ws-wrap { padding: 18px 16px 40px !important; }
  }

  /* ---------- ws-head with all four corner brackets ---------- */
  body.ws-vault .ws-head {
    position: relative !important;
    display: block !important;
    padding: 14px 24px 22px !important;
    margin: 0 0 22px !important;
    border: none !important;
    background: transparent !important;
  }
  body.ws-vault .ws-head::before, body.ws-vault .ws-head::after,
  body.ws-vault .ws-head > .br-bl, body.ws-vault .ws-head > .br-br {
    content: ''; position: absolute;
    width: 14px; height: 14px;
    border: 1px solid var(--ink); pointer-events: none;
  }
  body.ws-vault .ws-head::before { top: 0; left: 0; border-right: none; border-bottom: none; }
  body.ws-vault .ws-head::after  { top: 0; right: 0; border-left: none; border-bottom: none; }
  body.ws-vault .ws-head > .br-bl { bottom: 0; left: 0; border-top: none; border-right: none; }
  body.ws-vault .ws-head > .br-br { bottom: 0; right: 0; border-top: none; border-left: none; }

  body.ws-vault .kicker {
    display: inline-flex; align-items: center; gap: 12px;
    font-family: var(--mono); font-size: 10.5px;
    color: var(--accent-deep);
    letter-spacing: .14em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  body.ws-vault .kicker .k-tag {
    border: 1px solid var(--accent-deep);
    padding: 2px 7px; border-radius: 2px; font-size: 9.5px;
  }
  body.ws-vault .kicker .k-coord { color: var(--ink-4); font-size: 9.5px; }

  body.ws-vault .head-row {
    display: flex; gap: 20px; justify-content: space-between;
    align-items: flex-end; flex-wrap: wrap;
  }
  body.ws-vault .head-title {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(40px, 5vw, 68px);
    letter-spacing: -.012em; line-height: 1; margin: 0;
    color: var(--ink);
  }
  body.ws-vault .head-title em { font-style: italic; color: var(--accent-deep); }
  body.ws-vault .head-sub {
    font-family: var(--serif); font-size: 19px;
    color: var(--ink-2); max-width: 64ch;
    margin-top: 12px; line-height: 1.4;
  }
  body.ws-vault .head-actions {
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
  }

  body.ws-vault .head-actions .ws-btn,
  body.ws-vault .head-actions .ws-btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 18px; cursor: pointer;
    font-family: var(--mono); font-size: 11px;
    letter-spacing: .12em; text-transform: uppercase;
    background: var(--ink); color: var(--paper);
    border: 1px solid var(--ink); border-radius: 4px;
    text-decoration: none;
    transition: background .15s var(--motion-snap), border-color .15s, color .15s;
  }
  body.ws-vault .head-actions .ws-btn:hover {
    background: var(--accent-deep); border-color: var(--accent-deep);
  }
  body.ws-vault .head-actions .ws-btn-ghost {
    background: transparent !important; color: var(--ink) !important;
  }
  body.ws-vault .head-actions .ws-btn-ghost:hover {
    background: var(--ink) !important; color: var(--paper) !important;
  }
  body.ws-vault .head-actions .ws-btn svg { width: 12px; height: 12px; }

  /* ---------- meta strip (top stats row) ---------- */
  body.ws-vault .meta-strip {
    display: grid; grid-template-columns: repeat(5, 1fr);
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    margin-bottom: 24px;
  }
  body.ws-vault .ms-cell {
    padding: 14px 18px;
    border-right: 1px solid var(--rule-soft);
    display: flex; flex-direction: column; gap: 5px;
  }
  body.ws-vault .ms-cell:last-child { border-right: none; }
  body.ws-vault .ms-l {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .14em; text-transform: uppercase;
  }
  body.ws-vault .ms-v {
    font-family: var(--serif); font-size: 26px;
    color: var(--ink); line-height: 1;
  }
  body.ws-vault .ms-v em { font-style: italic; color: var(--accent-deep); }
  body.ws-vault .ms-d {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-4);
    letter-spacing: .08em; text-transform: uppercase;
  }
  @media (max-width: 1100px) {
    body.ws-vault .meta-strip { grid-template-columns: repeat(2, 1fr); }
    body.ws-vault .ms-cell:nth-child(2n) { border-right: none; }
  }

  /* ---------- sec-div ---------- */
  body.ws-vault .sec-div {
    display: grid; grid-template-columns: auto 1fr auto;
    align-items: center; gap: 16px;
    margin: 8px 0 14px;
    font-family: var(--mono); font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: .12em; text-transform: uppercase;
  }
  body.ws-vault .sec-div .sec-num { color: var(--ink); }
  body.ws-vault .sec-div .sec-rule { height: 1px; background: var(--rule-soft); }
  body.ws-vault .sec-div .sec-meta { color: var(--ink-4); font-size: 9.5px; }

  /* ---------- search bar ---------- */
  body.ws-vault .vault-search {
    display: grid; grid-template-columns: 1fr auto;
    gap: 10px;
    margin-bottom: 14px;
    align-items: stretch;
  }
  body.ws-vault .search-input-wrap {
    display: flex; align-items: center; gap: 10px;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    padding: 10px 14px;
    background: rgba(255,255,255,.4);
    transition: border-color .15s, box-shadow .25s;
  }
  body.ws-vault .search-input-wrap:focus-within {
    border-color: var(--ink);
    box-shadow: 0 0 0 1px var(--ink);
  }
  body.ws-vault .search-input-wrap svg {
    width: 13px; height: 13px;
    color: var(--ink-3); flex-shrink: 0;
  }
  body.ws-vault .search-input-wrap input {
    border: none; outline: none; background: transparent;
    font-family: var(--sans); font-size: 14px;
    color: var(--ink); width: 100%;
  }
  body.ws-vault .search-input-wrap input::placeholder {
    color: var(--ink-4); font-style: italic;
    font-family: var(--serif); font-size: 16px;
  }
  body.ws-vault .search-input-wrap .pre {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--accent-deep);
    letter-spacing: .14em; text-transform: uppercase;
    border-right: 1px solid var(--rule-soft); padding-right: 10px;
  }
  body.ws-vault .search-input-wrap .kbd {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    border: 1px solid var(--rule-thread); border-radius: 2px;
    padding: 1px 5px;
  }
  body.ws-vault .search-mode {
    display: inline-flex;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    background: rgba(255,255,255,.4);
    overflow: hidden;
  }
  body.ws-vault .search-mode-btn {
    padding: 0 14px;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--ink-3); background: transparent;
    border: none; cursor: pointer;
    border-right: 1px solid var(--rule-soft);
    transition: color .15s, background .15s;
    display: inline-flex; align-items: center; gap: 6px;
  }
  body.ws-vault .search-mode-btn:last-child { border-right: none; }
  body.ws-vault .search-mode-btn:hover {
    color: var(--ink); background: rgba(255,255,255,.6);
  }
  body.ws-vault .search-mode-btn.is-active {
    color: var(--paper); background: var(--ink);
  }

  /* ---------- filter row ---------- */
  body.ws-vault .filter-row {
    display: flex; gap: 0; align-items: center; flex-wrap: wrap;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    background: rgba(255,255,255,.3);
    padding: 4px 10px;
    margin-bottom: 16px;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--ink-3);
  }
  body.ws-vault .filter-row .fl-l {
    font-size: 9px; color: var(--ink-4);
    letter-spacing: .14em;
    margin-right: 10px; padding: 4px 0;
  }
  body.ws-vault .fl-toggle {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 11px;
    background: transparent; border: none; cursor: pointer;
    color: var(--ink-3);
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase;
    transition: color .15s;
  }
  body.ws-vault .fl-toggle:hover { color: var(--ink); }
  body.ws-vault .fl-toggle.is-on { color: var(--accent-deep); }
  body.ws-vault .fl-toggle .fl-pip {
    width: 5px; height: 5px; border-radius: 50%;
    border: 1px solid currentColor; transition: background .15s;
  }
  body.ws-vault .fl-toggle.is-on .fl-pip { background: currentColor; }
  body.ws-vault .fl-toggle .fl-cnt { font-size: 9px; opacity: .7; }
  body.ws-vault .fl-sep {
    width: 1px; height: 12px; background: var(--rule-soft);
    margin: 0 1px;
  }
  body.ws-vault .fl-spacer { flex: 1; }
  body.ws-vault .fl-sort {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; cursor: pointer;
    color: var(--ink-3);
    background: transparent; border: none;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase;
    transition: color .15s;
  }
  body.ws-vault .fl-sort:hover { color: var(--ink); }
  body.ws-vault .fl-sort .v {
    font-family: var(--sans); text-transform: none; letter-spacing: 0;
    font-size: 11.5px;
    color: var(--ink); border-bottom: 1px dotted var(--ink-3);
  }

  /* ---------- in-flight upload strip ---------- */
  body.ws-vault .upload-strip,
  body.ws-vault .vault-uploads-strip {
    display: flex; flex-direction: column; gap: 0;
    margin-bottom: 16px;
    border: 1px solid var(--rule-soft); border-radius: 6px;
    background: rgba(255,255,255,.4);
    overflow: hidden;
  }
  body.ws-vault .vault-uploads-strip[hidden] { display: none; }
  body.ws-vault .upload-strip-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 14px;
    border-bottom: 1px solid var(--rule-soft);
    background: var(--paper-2);
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-2);
    letter-spacing: .14em; text-transform: uppercase;
  }
  body.ws-vault .upload-strip-head .live {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--accent-deep);
  }
  body.ws-vault .live-pip {
    width: 6px; height: 6px; border-radius: 50%;
    background: currentColor;
    animation: vaultPulseDim 1.6s ease-in-out infinite;
  }
  @keyframes vaultPulseDim { 0%,100% { opacity: 1; } 50% { opacity: .35; } }

  body.ws-vault .vault-upload-row {
    display: grid; grid-template-columns: 24px 1fr auto auto;
    gap: 14px; align-items: center;
    padding: 10px 14px;
    border-top: 1px dotted var(--rule-soft);
  }
  body.ws-vault .vault-upload-row:first-of-type { border-top: none; }
  body.ws-vault .vault-upload-spinner {
    width: 24px; height: 28px;
    border: 1px solid var(--ink-3); border-radius: 2px;
    position: relative;
    display: flex; align-items: flex-end; justify-content: center;
    padding-bottom: 3px;
    font-family: var(--mono); font-size: 9px; color: var(--ink-3);
    letter-spacing: .04em;
  }
  body.ws-vault .vault-upload-row.is-done .vault-upload-spinner {
    color: var(--accent-deep); border-color: var(--accent-deep);
  }
  body.ws-vault .vault-upload-row.is-failed .vault-upload-spinner {
    color: var(--hi); border-color: var(--hi);
  }
  body.ws-vault .vault-upload-meta {
    display: flex; flex-direction: column; gap: 5px; min-width: 0;
  }
  body.ws-vault .vault-upload-name {
    font-family: var(--sans); font-size: 13px; color: var(--ink);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  body.ws-vault .vault-upload-status {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .08em; text-transform: uppercase;
  }
  body.ws-vault .vault-upload-bar {
    width: 220px; height: 4px;
    background: var(--rule-soft); border-radius: 2px;
    overflow: hidden;
    position: relative;
  }
  body.ws-vault .vault-upload-bar-fill {
    position: absolute; left: 0; top: 0; bottom: 0;
    background: var(--accent-deep);
    width: 0%;
    transition: width .8s var(--motion-snap);
  }
  body.ws-vault .vault-upload-row.is-failed .vault-upload-bar-fill { background: var(--hi); }

  /* ---------- bulk action bar ---------- */
  body.ws-vault .vault-bulk-bar {
    align-items: center; gap: 14px;
    padding: 10px 16px;
    background: var(--ink); color: var(--paper);
    border-radius: 4px;
    margin-bottom: 12px;
    font-family: var(--mono); font-size: 10.5px;
    letter-spacing: .12em; text-transform: uppercase;
  }
  body.ws-vault .vault-bulk-bar:not([hidden]) { display: flex; }
  body.ws-vault .vault-bulk-bar .vault-bulk-count {
    color: var(--accent);
  }
  body.ws-vault .vault-bulk-bar .ws-btn,
  body.ws-vault .vault-bulk-bar .ws-btn-ghost {
    background: transparent !important;
    color: var(--paper) !important;
    border: 1px solid rgba(243,239,230,.3) !important;
    padding: 5px 11px !important;
    border-radius: 2px;
    cursor: pointer;
    font-family: var(--mono); font-size: 9.5px;
    letter-spacing: .12em; text-transform: uppercase;
    transition: background .15s, border-color .15s;
  }
  body.ws-vault .vault-bulk-bar .ws-btn:hover,
  body.ws-vault .vault-bulk-bar .ws-btn-ghost:hover {
    background: var(--accent-deep) !important;
    border-color: var(--accent-deep) !important;
  }
  body.ws-vault .vault-bulk-progress {
    margin-bottom: 12px; padding: 8px 14px;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    background: var(--paper-2);
    font-family: var(--mono); font-size: 10.5px; color: var(--ink-2);
    letter-spacing: .04em;
  }

  /* ---------- vault layout ----------
     The detail panel is right-side sticky. When it's hidden (no item
     selected) the list takes the full width; when shown it shrinks
     to leave 360px for the panel. The .has-detail flag is added on
     the parent by JS when openDetail fires. */
  body.ws-vault .vault-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
    align-items: start;
    padding: 0 !important;
    background: transparent !important;
    border: none !important;
  }
  body.ws-vault .vault-layout.has-detail {
    grid-template-columns: 1fr 360px;
  }
  @media (max-width: 1100px) {
    body.ws-vault .vault-layout,
    body.ws-vault .vault-layout.has-detail { grid-template-columns: 1fr; }
    body.ws-vault .vault-detail { position: relative !important; top: auto !important; }
  }

  body.ws-vault .vault-list-wrap,
  body.ws-vault .vault-card {
    border: 1px solid var(--rule-soft); border-radius: 8px;
    background: var(--paper-2);
    overflow: visible;
  }

  /* table head — sits at top of the card (not sticky to avoid
     overlap glitches with the first row when the page scrolls). */
  body.ws-vault .vault-list-head,
  body.ws-vault .vault-head {
    display: grid;
    grid-template-columns: 28px 100px 1fr 200px 80px 110px;
    gap: 14px; align-items: center;
    padding: 11px 18px;
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule-soft);
    border-top-left-radius: 8px; border-top-right-radius: 8px;
    font-family: var(--mono); font-size: 9.5px; color: var(--ink-3);
    letter-spacing: .14em; text-transform: uppercase;
  }
  body.ws-vault .vault-list-head .vault-row-check,
  body.ws-vault .vault-list-head input[type="checkbox"] {
    accent-color: var(--accent-deep);
  }

  /* --- rows --- */
  body.ws-vault .vault-row {
    display: grid;
    grid-template-columns: 28px 100px 1fr 200px 80px 110px;
    gap: 14px; align-items: center;
    padding: 12px 18px;
    border-top: 1px dotted var(--rule-soft);
    cursor: pointer;
    transition: background .15s, padding-left .15s var(--motion-snap);
    position: relative;
  }
  body.ws-vault .vault-row.sk-list-item { cursor: default; }
  body.ws-vault .vault-row:hover { background: rgba(255,255,255,.5); padding-left: 22px; }
  body.ws-vault .vault-row.is-active {
    background: var(--accent-tint, rgba(215,237,224,.5));
    padding-left: 22px;
  }
  body.ws-vault .vault-row.is-active::before {
    content: ''; position: absolute; left: 0; top: 8px; bottom: 8px;
    width: 2px; background: var(--accent-deep);
  }
  body.ws-vault .vault-row.is-selected { background: rgba(255,255,255,.65); }

  body.ws-vault .vault-row-check,
  body.ws-vault .vault-row > .vault-col-check {
    display: inline-flex; align-items: center;
  }
  body.ws-vault .vault-row-check input[type="checkbox"] { accent-color: var(--accent-deep); }

  /* kind badge */
  body.ws-vault .vr-kind,
  body.ws-vault .vault-kind-badge {
    font-family: var(--mono); font-size: 9px;
    color: var(--accent-deep);
    letter-spacing: .12em; text-transform: uppercase;
    border: 1px solid var(--accent-deep);
    padding: 2px 7px; border-radius: 2px;
    display: inline-flex; align-items: center; justify-content: center;
    text-align: center;
  }
  body.ws-vault .vr-kind.is-pdf,
  body.ws-vault .vault-kind-badge.is-pdf,
  body.ws-vault .vault-kind-document.is-pdf { color: var(--hi); border-color: var(--hi); }
  body.ws-vault .vr-kind.is-doc,
  body.ws-vault .vault-kind-badge.is-doc,
  body.ws-vault .vault-kind-document.is-doc { color: var(--ink-2); border-color: var(--ink-2); }
  body.ws-vault .vr-kind.is-mail,
  body.ws-vault .vault-kind-badge.is-mail,
  body.ws-vault .vault-kind-chat { color: var(--lo); border-color: var(--lo); }
  body.ws-vault .vr-kind.is-img,
  body.ws-vault .vault-kind-badge.is-img,
  body.ws-vault .vault-kind-review_finding { color: var(--md); border-color: var(--md); }
  body.ws-vault .vr-kind.is-txt,
  body.ws-vault .vault-kind-badge.is-txt,
  body.ws-vault .vault-kind-manual_note { color: var(--ink-3); border-color: var(--ink-3); }

  /* title + sub line */
  body.ws-vault .vr-title-wrap,
  body.ws-vault .vault-col-title {
    display: flex; flex-direction: column; gap: 3px; min-width: 0;
  }
  body.ws-vault .vr-title,
  body.ws-vault .vault-row-title {
    font-family: var(--serif); font-size: 17px;
    color: var(--ink); line-height: 1.15;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  body.ws-vault .vr-title em { font-style: italic; }
  body.ws-vault .vr-sub,
  body.ws-vault .vault-row-summary {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .08em; text-transform: uppercase;
    display: flex; gap: 10px;
  }
  body.ws-vault .vr-sub .ok { color: var(--accent-deep); }
  body.ws-vault .vr-sub .pending { color: var(--md); }

  /* tag chips */
  body.ws-vault .vr-tags,
  body.ws-vault .vault-col-tags {
    display: flex; gap: 4px; flex-wrap: wrap;
  }
  body.ws-vault .tag-chip,
  body.ws-vault .vault-tag {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .04em;
    border: 1px solid var(--rule-soft);
    padding: 2px 7px; border-radius: 2px;
    background: rgba(255,255,255,.4);
    display: inline-flex; align-items: center;
  }
  body.ws-vault .tag-chip.acc {
    color: var(--accent-deep); border-color: var(--accent-deep);
  }

  /* size + updated */
  body.ws-vault .vr-size,
  body.ws-vault .vr-updated,
  body.ws-vault .vault-col-meta {
