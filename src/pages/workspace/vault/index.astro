    border-bottom: 1px solid var(--rule-soft);
    padding-bottom: 6px;
  }
  body.ws-vault .dp-section-l span:last-child {
    color: var(--ink-4); font-size: 9px;
  }
  body.ws-vault .dp-meta-grid {
    display: grid; grid-template-columns: 88px 1fr;
    gap: 6px 12px;
    font-size: 12.5px;
  }
  body.ws-vault .dp-meta-grid dt {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .12em; text-transform: uppercase;
    padding-top: 2px;
  }
  body.ws-vault .dp-meta-grid dd {
    margin: 0; color: var(--ink); font-family: var(--sans);
  }
  body.ws-vault .dp-snippet,
