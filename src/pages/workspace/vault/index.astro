  async function doAction(item, action) {
    try {
      if (action === 'pin') {
        await call('workspace-vault-update', { id: item.id, pinned: !item.pinned });
      } else if (action === 'archive') {
        await call('workspace-vault-update', { id: item.id, archived: !item.archived_at });
      } else if (action === 'delete') {
        if (!confirm('Permanently delete this vault item? This cannot be undone.')) return;
        await call('workspace-vault-delete', { id: item.id, hard: true });
        document.getElementById('vault-detail').hidden = true;
        document.querySelector('.vault-layout')?.classList.remove('has-detail');
        await loadList();
        return;
      }
      await loadList();
      await openDetail(item.id);
    } catch (err) {
      alert('Action failed: ' + err.message);
    }
  }

  // ---- Search ----
  let searchTimer = null;
  document.getElementById('vault-search').addEventListener('input', (e) => {
    if (searchTimer) clearTimeout(searchTimer);
    const q = e.target.value.trim();
    if (!q) { loadList(); return; }
    searchTimer = setTimeout(() => runSearch(q), 350);
  });
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
