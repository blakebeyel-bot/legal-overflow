  document.getElementById('vault-bulk-delete').addEventListener('click', async () => {
    if (selected.size === 0) return;
    const n = selected.size;
    if (!confirm('Permanently delete ' + n + ' vault item' + (n === 1 ? '' : 's') + '? This cannot be undone.')) return;
    await runBulk(Array.from(selected), async (id) => {
      const r = await fetch('/.netlify/functions/workspace-vault-delete', {
        method: 'POST',
