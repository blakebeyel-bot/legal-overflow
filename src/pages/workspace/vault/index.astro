  body.ws-vault .ws-modal-actions .ws-btn:hover {
    background: var(--accent-deep); border-color: var(--accent-deep);
  }
  body.ws-vault .ws-modal-actions .ws-btn-ghost {
    background: transparent; color: var(--ink); border-color: var(--rule-soft);
  }
  body.ws-vault .ws-modal-actions .ws-btn-ghost:hover {
    background: var(--ink); color: var(--paper); border-color: var(--ink);
  }

  body.ws-vault .vault-bulk-dest-options {
    display: flex; flex-direction: column; gap: 8px;
