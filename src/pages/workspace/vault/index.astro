    border-radius: 4px;
    padding: 12px 14px;
    max-height: 320px; overflow: auto;
    white-space: pre-wrap; word-break: break-word;
    color: var(--ink);
    margin: 0;
  }

  body.ws-vault .vault-card-tags { display: flex; gap: 4px; flex-wrap: wrap; }
  body.ws-vault .vault-pin-dot { font-size: 11px; }
  body.ws-vault .vault-arch-chip {
    font-family: var(--mono); font-size: 9px;
    color: var(--md); border: 1px solid var(--md);
