    display: flex; flex-direction: column;
    overflow: hidden;
    position: relative;
  }
  body.ws-vault .ws-modal-inner::before, body.ws-vault .ws-modal-inner::after {
    content: ''; position: absolute;
    width: 12px; height: 12px;
    border: 1px solid var(--ink); pointer-events: none;
  }
  body.ws-vault .ws-modal-inner::before { top: 6px; left: 6px; border-right: none; border-bottom: none; }
  body.ws-vault .ws-modal-inner::after { top: 6px; right: 6px; border-left: none; border-bottom: none; }
  body.ws-vault .ws-modal-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 16px 22px 14px;
    border-bottom: 1px solid var(--rule-soft);
  }
  body.ws-vault .ws-modal-head h2 {
    font-family: var(--serif); font-weight: 400;
    font-size: 22px; letter-spacing: -.005em;
    margin: 0;
  }
  body.ws-vault .ws-modal-close {
    width: 28px; height: 28px;
    background: transparent; border: 1px solid var(--rule-soft);
    border-radius: 4px;
    color: var(--ink-3); cursor: pointer;
    font-size: 14px; line-height: 1;
    transition: border-color .15s, color .15s;
  }
  body.ws-vault .ws-modal-close:hover {
    border-color: var(--ink); color: var(--ink);
  }
  body.ws-vault .ws-modal-body {
    flex: 1; min-height: 0; overflow-y: auto;
    padding: 18px 22px;
  }

  body.ws-vault .vault-tabs {
    display: flex; border: 1px solid var(--rule-soft); border-radius: 4px;
    overflow: hidden;
    margin-bottom: 14px;
  }
  body.ws-vault .vault-tab {
    flex: 1;
    padding: 8px 12px;
    background: transparent; border: none;
    border-right: 1px solid var(--rule-soft);
    cursor: pointer;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--ink-3);
