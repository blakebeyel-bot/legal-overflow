    background: rgba(215,237,224,.4);
  }
  body.ws-vault .vault-modal-upload-status {
    margin-top: 10px;
    padding: 10px 12px;
    background: var(--paper-2); border: 1px solid var(--rule-soft);
    border-radius: 4px;
    font-family: var(--mono); font-size: 11px;
    color: var(--ink-2); letter-spacing: .04em;
  }

  /* row spinner inside detail "Loading…" */
  body.ws-vault .rv-spin {
    display: inline-block;
    width: 10px; height: 10px;
    border: 1.5px solid var(--rule-thread);
    border-top-color: var(--accent-deep);
    border-radius: 50%;
    animation: vaultSpin .7s linear infinite;
    vertical-align: -1px;
  }
  @keyframes vaultSpin { to { transform: rotate(360deg); } }
</style>
