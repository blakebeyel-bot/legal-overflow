  /* responsive collapse — hide some columns */
  @media (max-width: 1100px) {
    body.ws-vault .vault-list-head { grid-template-columns: 28px 80px 1fr 100px; }
    body.ws-vault .vault-row { grid-template-columns: 28px 80px 1fr 100px; }
    body.ws-vault .vault-list-head .vault-col-tags,
    body.ws-vault .vault-list-head .vault-col-tags-h,
    body.ws-vault .vault-row .vr-tags,
    body.ws-vault .vault-row .vault-col-tags,
    body.ws-vault .vault-list-head .vault-col-size,
    body.ws-vault .vault-row .vr-size,
    body.ws-vault .vault-row .vault-col-size { display: none; }
