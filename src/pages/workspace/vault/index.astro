  }
  body.ws-vault .dp-title,
  body.ws-vault .vault-detail-title {
    font-family: var(--serif); font-size: 22px;
    line-height: 1.2; letter-spacing: -.005em;
    color: var(--ink); margin: 0;
  }
  body.ws-vault .dp-title em { font-style: italic; }
  body.ws-vault .dp-meta {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .08em; text-transform: uppercase;
    display: flex; gap: 12px; flex-wrap: wrap;
    margin-top: 8px;
  }
  body.ws-vault .dp-meta b { color: var(--ink); font-weight: 500; }

  body.ws-vault .dp-body,
  body.ws-vault #vault-detail-body {
    flex: 1; overflow-y: auto; min-height: 0;
    padding: 14px 18px 18px;
    display: flex; flex-direction: column; gap: 18px;
  }
  body.ws-vault #vault-detail-body::-webkit-scrollbar { width: 6px; }
  body.ws-vault #vault-detail-body::-webkit-scrollbar-thumb {
    background: var(--rule-soft); border-radius: 3px;
  }

  body.ws-vault .dp-section { display: flex; flex-direction: column; gap: 8px; }
  body.ws-vault .dp-section-l {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3);
    letter-spacing: .14em; text-transform: uppercase;
