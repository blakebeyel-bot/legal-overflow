  body.ws-vault .dp-tag-row { display: flex; gap: 5px; flex-wrap: wrap; }

  body.ws-vault .dp-actions,
  body.ws-vault .vault-detail-actions {
    display: grid; grid-template-columns: 1fr 1fr; gap: 6px;
  }
  body.ws-vault .dp-action,
  body.ws-vault .vault-detail-actions .ws-btn,
  body.ws-vault .vault-detail-actions .ws-btn-ghost {
    display: inline-flex; align-items: center; justify-content: center; gap: 7px;
    padding: 9px 12px;
    cursor: pointer;
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .12em; text-transform: uppercase;
    background: transparent !important;
    color: var(--ink-2) !important;
    border: 1px solid var(--rule-soft) !important; border-radius: 4px;
    transition: background .15s, border-color .15s, color .15s;
  }
  body.ws-vault .dp-action:hover,
  body.ws-vault .vault-detail-actions .ws-btn:hover,
  body.ws-vault .vault-detail-actions .ws-btn-ghost:hover {
    background: var(--ink) !important; color: var(--paper) !important;
    border-color: var(--ink) !important;
  }
  body.ws-vault .dp-action.primary {
    background: var(--ink) !important; color: var(--paper) !important;
    border-color: var(--ink) !important;
    grid-column: 1 / 3;
  }
  body.ws-vault .dp-action.primary:hover {
    background: var(--accent-deep) !important;
    border-color: var(--accent-deep) !important;
  }
  body.ws-vault .dp-action svg { width: 11px; height: 11px; }
  body.ws-vault .vault-detail-delete {
    color: var(--hi) !important; border-color: rgba(178,34,34,.3) !important;
