    border-radius: 2px;
  }
  @keyframes vaultShimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  body.ws-vault .vault-row.sk-list-item {
    grid-template-columns: 1fr;
    padding: 18px;
  }

  body.ws-vault .vault-empty {
    grid-column: 1 / -1;
    padding: 60px 28px; text-align: center;
    color: var(--ink-3);
