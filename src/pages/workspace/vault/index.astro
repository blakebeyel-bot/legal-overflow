  }
  body.ws-vault .vault-provider-name {
    font-family: var(--serif); font-size: 15px; color: var(--ink);
  }
  body.ws-vault .vault-provider-meta {
    font-family: var(--mono); font-size: 9.5px;
    color: var(--ink-3); letter-spacing: .04em;
  }

  body.ws-vault .vault-checkbox {
    display: flex; align-items: center; gap: 8px;
    margin: 6px 0;
    font-size: 13.5px; color: var(--ink);
  }
  body.ws-vault .vault-checkbox input { accent-color: var(--accent-deep); }

  body.ws-vault .ws-modal-actions {
    display: flex; justify-content: flex-end; gap: 8px;
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--rule-soft);
  }
  body.ws-vault .ws-modal-actions .ws-btn,
  body.ws-vault .ws-modal-actions .ws-btn-ghost {
    padding: 9px 16px; cursor: pointer;
    font-family: var(--mono); font-size: 10.5px;
    letter-spacing: .12em; text-transform: uppercase;
