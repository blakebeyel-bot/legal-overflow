  body.ws-vault .vault-form-label:first-child { margin-top: 0; }
  body.ws-vault .vault-form-hint {
    font-family: var(--mono); font-size: 10px;
    color: var(--ink-4);
    letter-spacing: .04em;
    text-transform: none;
  }
  body.ws-vault .vault-form-input,
  body.ws-vault .vault-form-textarea {
    width: 100%; padding: 9px 12px;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    background: var(--paper);
    font-family: var(--sans); font-size: 14px;
    color: var(--ink);
    outline: none;
  }
  body.ws-vault .vault-form-input:focus,
  body.ws-vault .vault-form-textarea:focus {
