  // ---- Bulk import ----
  const bulkInput = document.getElementById('vault-bulk-import-input');
  document.getElementById('vault-bulk-import-btn').addEventListener('click', () => bulkInput.click());
  bulkInput.addEventListener('change', async () => {
    const files = Array.from(bulkInput.files || []);
    bulkInput.value = '';
    if (!files.length) return;
    const destination = await askBulkDestination(files.length);
    if (!destination) return;
    const prog = document.getElementById('vault-bulk-progress');
    prog.hidden = false;
    let done = 0, failed = 0;
    const total = files.length;
    prog.textContent = 'Uploading 0/' + total + '…';
    for (let i = 0; i < files.length; i += 3) {
      const slice = files.slice(i, i + 3);
      await Promise.all(slice.map(async (file) => {
        try { await uploadOneFile(file, { destination }); done++; } catch (err) { console.error(err); failed++; }
        prog.textContent = 'Uploading ' + (done + failed) + '/' + total + '…';
      }));
    }
    prog.textContent = (failed === 0)
      ? 'Uploaded ' + done + ' file' + (done === 1 ? '' : 's') + destLabel(destination)
      : 'Uploaded ' + done + ' · ' + failed + ' failed';
    setTimeout(() => { prog.hidden = true; }, 4500);
    if (destination !== 'library') await loadList();
  });

  function askBulkDestination(n) {
    return new Promise((resolve) => {
      const modal = document.getElementById('vault-bulk-dest-modal');
      const countEl = document.getElementById('vault-bulk-dest-count');
      countEl.textContent = String(n);
      modal.hidden = false;
      const cleanup = () => {
        modal.hidden = true;
        modal.querySelectorAll('[data-bulk-dest]').forEach((b) => b.removeEventListener('click', onPick));
        modal.querySelector('[data-bulk-dest-cancel]').removeEventListener('click', onCancel);
      };
      const onPick = (e) => { cleanup(); resolve(e.currentTarget.dataset.bulkDest); };
      const onCancel = () => { cleanup(); resolve(null); };
      modal.querySelectorAll('[data-bulk-dest]').forEach((b) => b.addEventListener('click', onPick));
      modal.querySelector('[data-bulk-dest-cancel]').addEventListener('click', onCancel);
    });
  }

  // ---- Upload helper ----
  function destFlags(destination) {
    if (destination === 'library') return { skip_vault_ingest: true,  library_hidden: false };
    if (destination === 'vault')   return { skip_vault_ingest: false, library_hidden: true  };
    return                                { skip_vault_ingest: false, library_hidden: false };
  }
  function destLabel(destination) {
    if (destination === 'library') return ' · Library only';
    if (destination === 'vault')   return ' · Vault only';
    return ' · Library + Vault';
  }

  async function uploadOneFile(file, opts = {}) {
    const destination = opts.destination || 'both';
    const flags = destFlags(destination);
    const docId = crypto.randomUUID();
    const versionId = crypto.randomUUID();
    const ext = (file.name.split('.').pop() || 'bin').toLowerCase().replace(/[^a-z0-9]/g, '') || 'bin';
    const storagePath = userId + '/' + docId + '/' + versionId + '.' + ext;
    const progressRow = startUploadProgress({ docId, filename: file.name, destination, initialStatus: 'Uploading to storage…' });
    try {
      const { error: upErr } = await supabase.storage
        .from('library')
        .upload(storagePath, file, { contentType: file.type || 'application/octet-stream', upsert: false });
      if (upErr) throw new Error('Storage upload: ' + upErr.message);
      progressRow.update('Extracting text…');
      const r = await fetch('/.netlify/functions/workspace-library-register', {
        method: 'POST',
        headers: { Authorization: 'Bearer ' + accessToken, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          filename: file.name, original_filename: file.name,
          file_type: file.type || 'application/octet-stream',
          size_bytes: file.size, storage_path: storagePath,
          skip_vault_ingest: flags.skip_vault_ingest,
          library_hidden: flags.library_hidden,
        }),
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || ('HTTP ' + r.status));
      const status = j.extraction?.status;
      const tail = destLabel(destination);
      if (status === 'pending_ocr') {
        progressRow.update('OCR queued — running in background…');
        progressRow.poll({ destination });
        const vaultBit = (destination !== 'library') ? ' (vault add follows OCR)' : '';
        return { ok: true, message: file.name + ' uploaded; OCR running in background' + vaultBit };
      }
      if (status === 'done') {
        progressRow.complete({ chars: j.extraction?.chars || 0, destination });
        return { ok: true, message: file.name + ' ready · ' + (j.extraction?.chars || 0).toLocaleString() + ' chars' + tail };
      }
      progressRow.complete({ chars: 0, destination, message: 'uploaded · status: ' + (status || 'unknown') });
      return { ok: true, message: file.name + ' uploaded · status: ' + (status || 'unknown') };
    } catch (err) {
      progressRow.fail(err.message || String(err));
      throw err;
    }
  }

  function startUploadProgress({ docId, filename, destination, initialStatus }) {
    const strip = document.getElementById('vault-uploads-strip');
    if (strip.children.length === 0) {
      strip.innerHTML = '<div class="upload-strip-head"><span class="live"><span class="live-pip"></span>UPLOAD QUEUE · ACTIVE</span><span style="color:var(--ink-4)">QUEUE</span></div>';
    }
    strip.hidden = false;
    const row = document.createElement('div');
    row.className = 'vault-upload-row';
    row.dataset.docId = docId;
    const ext = (filename.split('.').pop() || 'BIN').toUpperCase().slice(0, 3);
    row.innerHTML =
      '<span class="vault-upload-spinner">' + escapeAttr(ext) + '</span>' +
      '<div class="vault-upload-meta">' +
        '<span class="vault-upload-name">' + escapeAttr(filename) + '</span>' +
        '<span class="vault-upload-status">' + escapeAttr(initialStatus || 'Uploading…') + '</span>' +
      '</div>' +
      '<div class="vault-upload-bar"><div class="vault-upload-bar-fill" style="width: 0%"></div></div>' +
      '<button class="up-cancel" type="button" style="font-family:var(--mono);font-size:9.5px;color:var(--ink-3);letter-spacing:.12em;text-transform:uppercase;background:transparent;border:none;cursor:pointer;">Hide</button>';
    strip.appendChild(row);

    const statusEl = row.querySelector('.vault-upload-status');
    const spinnerEl = row.querySelector('.vault-upload-spinner');
    const fillEl = row.querySelector('.vault-upload-bar-fill');
    row.querySelector('.up-cancel').addEventListener('click', () => row.remove());
    let pollTimer = null;

    function update(text, pct) {
      statusEl.textContent = text;
      if (typeof pct === 'number') fillEl.style.width = Math.max(0, Math.min(100, pct)) + '%';
    }
    function complete({ chars, destination, message }) {
      stopPoll();
      row.classList.add('is-done');
      spinnerEl.textContent = '✓';
      fillEl.style.width = '100%';
      const charsBit = chars ? Math.round(chars / 1000) + 'k chars · ' : '';
      statusEl.textContent = message || (charsBit + (destination === 'library' ? 'Library only' : destination === 'vault' ? 'Added to Vault' : 'Library + Vault'));
      if (destination !== 'library') loadList();
      scheduleStripCleanup(row);
    }
    function fail(detail) {
      stopPoll();
      row.classList.add('is-failed');
      spinnerEl.textContent = '✗';
      fillEl.style.width = '100%';
      statusEl.textContent = 'Failed: ' + detail;
      scheduleStripCleanup(row, 12000);
    }
    function poll({ destination }) {
      stopPoll();
      pollTimer = setInterval(async () => {
        try {
          const r = await fetch('/.netlify/functions/workspace-library-get?id=' + encodeURIComponent(docId), {
            headers: { Authorization: 'Bearer ' + accessToken },
          });
          const j = await r.json();
          if (!r.ok) throw new Error(j.error || ('HTTP ' + r.status));
          const versions = j.versions || [];
          const v = versions[0];
          if (!v) return;
          const status = v.extraction_status;
          const detail = v.extraction_detail || '';
          const m = detail.match(/(\d+)\/(\d+)\s+chunks/);
          if (m) {
            const pct = Math.round((parseInt(m[1], 10) / Math.max(1, parseInt(m[2], 10))) * 100);
            update(detail, Math.max(5, pct - 5));
          } else if (detail) update(detail);
          else if (status === 'running') update('OCR running…');

          if (status === 'done') complete({ chars: v.extracted_chars || 0, destination });
          else if (status === 'failed') fail(detail || 'unknown error');
          else if (status === 'skipped') fail('Extraction skipped');
        } catch (err) {
          console.warn('[vault-upload-poll] failed:', err.message);
        }
      }, 3000);
    }
    function stopPoll() { if (pollTimer) { clearInterval(pollTimer); pollTimer = null; } }
    return { update, complete, fail, poll };
  }

  function scheduleStripCleanup(row, ms = 6000) {
    setTimeout(() => {
      row.remove();
      const strip = document.getElementById('vault-uploads-strip');
      if (!strip.querySelector('.vault-upload-row')) strip.hidden = true;
    }, ms);
  }

  // ---- Settings modal ----
  const settingsModal = document.getElementById('vault-settings-modal');
  document.getElementById('vault-settings-btn').addEventListener('click', async () => {
    settingsModal.hidden = false;
    try {
      const r = await fetch('/.netlify/functions/workspace-vault-settings-get', {
        headers: { Authorization: 'Bearer ' + accessToken },
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Failed to load settings');
      const s = j.settings || {};
      const provRadio = document.querySelector('input[name="vault-provider"][value="' + (s.vault_embedding_provider || 'gemini') + '"]');
      if (provRadio) provRadio.checked = true;
      document.getElementById('vault-auto-uploads').checked = !!s.vault_auto_ingest_uploads;
      document.getElementById('vault-auto-chats').checked = !!s.vault_auto_ingest_chats;
      document.getElementById('vault-auto-use').checked = !!s.vault_auto_use_in_chats;
    } catch (err) {
      alert('Failed to load settings: ' + err.message);
    }
  });
  settingsModal.querySelectorAll('[data-vault-settings-close]').forEach((b) => b.addEventListener('click', () => { settingsModal.hidden = true; }));
  document.getElementById('vault-settings-save').addEventListener('click', async () => {
    const provider = document.querySelector('input[name="vault-provider"]:checked')?.value || 'gemini';
    const auto_uploads = document.getElementById('vault-auto-uploads').checked;
    const auto_chats = document.getElementById('vault-auto-chats').checked;
    const auto_use = document.getElementById('vault-auto-use').checked;
    const btn = document.getElementById('vault-settings-save');
    btn.disabled = true; btn.textContent = 'Saving…';
    try {
      const r = await fetch('/.netlify/functions/workspace-vault-settings-update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + accessToken },
        body: JSON.stringify({
          vault_embedding_provider: provider,
          vault_auto_ingest_uploads: auto_uploads,
          vault_auto_ingest_chats: auto_chats,
          vault_auto_use_in_chats: auto_use,
        }),
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Save failed');
      settingsModal.hidden = true;
      // Update meta-strip embedding label
      const provEl = document.getElementById('ms-embed-provider');
      if (provEl) provEl.textContent = (provider || '').toUpperCase();
      if (j.reembed_kicked_off && typeof window.siteToast === 'function') {
        window.siteToast('Embedding provider changed — re-embedding your vault in the background. May take a few minutes.', { kind: 'info' });
      }
    } catch (err) {
      alert('Save failed: ' + err.message);
    } finally {
      btn.disabled = false; btn.textContent = 'Save settings';
    }
  });

  document.querySelectorAll('[data-vault-close]').forEach((b) => b.addEventListener('click', () => {
    document.getElementById('vault-detail').hidden = true;
    document.querySelector('.vault-layout')?.classList.remove('has-detail');
    document.querySelectorAll('.vault-row').forEach((r) => r.classList.remove('is-active'));
  }));

  async function call(fn, body) {
    const r = await fetch('/.netlify/functions/' + fn, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + accessToken },
      body: JSON.stringify(body),
    });
    const j = await r.json();
    if (!r.ok) throw new Error(j.error || 'Failed');
    return j;
  }

  // ---- Initial load + URL ?id= deep link ----
  // Pull settings to populate the embedding-provider in the meta-strip.
  fetch('/.netlify/functions/workspace-vault-settings-get', {
    headers: { Authorization: 'Bearer ' + accessToken },
  }).then((r) => r.ok ? r.json() : null).then((j) => {
    if (!j) return;
    const s = j.settings || {};
    const prov = s.vault_embedding_provider || 'gemini';
    const dims = prov === 'gemini' ? '768d' : prov === 'openai' ? '1536d' : '1024d';
    const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
    set('ms-embed-provider', prov.toUpperCase());
    set('ms-embed-meta', dims + ' VECTOR INDEX');
  }).catch(() => {});

  const initialId = new URL(location.href).searchParams.get('id');
  loadList().then(() => { if (initialId) openDetail(initialId); });
</script>
</body>
</html>
