  async function runSearch(q) {
    const list = document.getElementById('vault-list');
    list.innerHTML = '<div class="vault-empty"><span class="rv-spin"></span> Searching your vault…</div>';
    try {
      const r = await fetch('/.netlify/functions/workspace-vault-search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + accessToken },
        body: JSON.stringify({ query: q, top_k: 30, kinds: activeKindFilter ? [activeKindFilter] : undefined }),
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Search failed');
      const seen = new Set();
      items = (j.results || []).reduce((acc, res) => {
        if (!res.item || seen.has(res.item.id)) return acc;
        seen.add(res.item.id);
        acc.push({ ...res.item, score: res.score, content_chars: res.item.content_chars || 0 });
        return acc;
      }, []);
      isSearchMode = true;
      selected.clear();
      renderList();
      updateBulkBar();
      updateMetaStrip();
      updateFilterCounts();
    } catch (err) {
      list.innerHTML = '<div class="vault-empty">Search failed: ' + escapeAttr(err.message) + '</div>';
    }
  }

