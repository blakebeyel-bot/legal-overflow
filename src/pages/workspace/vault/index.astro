  body.ws-vault .dp-head::before { top: 4px; left: 4px; border-top: 1px solid; border-left: 1px solid; }
  body.ws-vault .dp-head::after  { top: 4px; right: 4px; border-top: 1px solid; border-right: 1px solid; }

  body.ws-vault .dp-kicker,
