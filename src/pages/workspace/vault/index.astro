    const bar = document.getElementById('vault-bulk-bar');
    const count = document.getElementById('vault-bulk-count');
    const master = document.getElementById('vault-master-check');
    bar.hidden = selected.size === 0;
    count.textContent = selected.size === 1 ? '1 selected' : selected.size + ' selected';
    if (master) {
      master.indeterminate = selected.size > 0 && selected.size < items.length;
