  async function runBulk(ids, fn, verb) {
    const prog = document.getElementById('vault-bulk-progress');
    prog.hidden = false;
    let done = 0, failed = 0;
    const total = ids.length;
    prog.textContent = verb + ' 0/' + total + '…';
    for (let i = 0; i < ids.length; i += 5) {
      const slice = ids.slice(i, i + 5);
      await Promise.all(slice.map(async (id) => {
        try { await fn(id); done++; } catch { failed++; }
        prog.textContent = verb + ' ' + (done + failed) + '/' + total + '…';
      }));
    }
    prog.textContent = (failed === 0)
      ? verb.replace(/ing$/, 'ed') + ' ' + done + ' item' + (done === 1 ? '' : 's')
      : verb.replace(/ing$/, 'ed') + ' ' + done + ' · ' + failed + ' failed';
    setTimeout(() => { prog.hidden = true; }, 3500);
  }

