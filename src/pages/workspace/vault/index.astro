  }
  body.ws-vault .vault-form-textarea { resize: vertical; min-height: 120px; }

  body.ws-vault .vault-provider-radios {
    display: flex; flex-direction: column; gap: 8px;
  }
  body.ws-vault .vault-provider-radio {
    display: flex; flex-direction: column; gap: 4px;
    padding: 10px 12px;
    border: 1px solid var(--rule-soft); border-radius: 4px;
    background: rgba(255,255,255,.4);
    cursor: pointer;
    transition: border-color .15s, background .15s;
  }
  body.ws-vault .vault-provider-radio:hover { border-color: var(--ink-2); }
  body.ws-vault .vault-provider-radio:has(input:checked) {
    border-color: var(--accent-deep);
