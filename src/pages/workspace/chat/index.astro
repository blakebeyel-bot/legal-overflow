---
// Workspace chat page. Reads ?id=<chatId> from the URL since Astro
// static-mode can't dynamic-route to user-generated UUIDs at runtime.
// All data + streaming happens client-side.
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Chat — Legal Overflow</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<script src="/nav-autohide.js" defer></script>
<script src="/site-dialog.js" defer></script>
<link rel="stylesheet" href="/workspace.css" />
</head>
<body class="chat-page">
<div id="grain"></div>

<header class="nav">
  <a href="/" class="brand">
    <svg class="brand-mark" viewBox="0 0 40 40"><circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="1"/><path d="M20 6 L20 34 M8 14 L32 14 M8 26 L32 26" stroke="currentColor" stroke-width="1" fill="none"/><circle cx="20" cy="14" r="2.5" fill="currentColor"/><circle cx="20" cy="26" r="2.5" fill="var(--accent)"/></svg>
    <span class="brand-text"><span>Legal</span><span class="brand-over">Overflow</span></span>
  </a>
  <nav class="nav-links">
    <a href="/#skills">Skills</a>
    <a href="/#articles">Resources</a>
    <a href="/agents/">Agents</a>
    <a href="/workspace/" class="is-active">Workspace</a>
    <a href="/tracker/">Tracker</a>
    <a href="/#services">Services</a>
    <a href="/about/">About</a>
  </nav>
  <div class="nav-right">
    <a href="/account/" class="nav-sub">Account</a>
  </div>
</header>

<!-- Collapse / expand the top nav so the chat has more vertical room.
     Sits flush along the bottom of the nav when expanded; floats at
     the top of the viewport when collapsed. -->
<button id="nav-toggle" class="nav-toggle" type="button" aria-label="Hide navigation" title="Hide navigation">
  <span class="nav-toggle-arrow">▲</span>
</button>

<main class="chat-shell">
  <aside class="chat-rail">
    <a href="/workspace/" class="chat-rail-back">← Workspace</a>
    <button id="new-chat" class="chat-rail-new">+ New chat</button>
    <div id="rail-list" class="chat-rail-list"></div>
  </aside>
  <!-- Draggable resize handle between sidebar and chat. -->
  <div id="rail-resize" class="rail-resize" role="separator" aria-label="Resize sidebar" aria-orientation="vertical" tabindex="0"></div>

  <section class="chat-main">
    <header class="chat-head">
      <input type="text" id="chat-title" class="chat-title-input" placeholder="Untitled chat" />
      <button type="button" id="chat-project-pill" class="chat-project-pill" aria-haspopup="true" title="Set project">
        <span id="chat-project-pill-label">…</span>
        <span class="chat-project-pill-caret">▾</span>
      </button>
      <div id="chat-project-popover" class="chat-project-popover" hidden></div>
      <div class="chat-head-right">
        <label class="chat-privacy-toggle" id="chat-privacy-toggle" title="Privacy mode (FL Rule 4-1.6 / ABA Op. 512). Rewrites every message and attached document as an abstract hypothetical before sending — names, entities, dates, addresses, and amounts are stripped. The LLM never sees client-identifying content.">
          <input type="checkbox" id="toggle-privacy" />
          <span class="chat-privacy-toggle-label"><span class="chat-privacy-toggle-lock" aria-hidden="true">🔒</span> Privacy</span>
        </label>
        <select id="model-select" class="chat-model-select" aria-label="Model"></select>
        <span id="key-source" class="chat-key-source" aria-live="polite"></span>
      </div>
    </header>

    <div id="messages" class="chat-messages">
      <div class="chat-empty">Ask something. The legal research desk is open.</div>
    </div>

    <div id="composer-attachments" class="composer-attachments"></div>

    <!-- Research-mode toolbar — sits directly above the composer so
         the toggles are visually attached to the message the user is
         about to send. State persists per-chat in workspace_chats. -->
    <div id="research-bar" class="composer-research-bar">
      <span class="research-state-label" aria-hidden="true">State:</span>
      <select id="toggle-state" class="research-toggle-state" aria-label="State"
        data-tip="Sets which state any &ldquo;State&rdquo; toggle below applies to. Federal toggles ignore this."></select>

      <span class="research-divider" aria-hidden="true">|</span>
      <span class="research-group">
        <span class="research-group-label">Statutes:</span>
        <label class="research-toggle"
          data-tip="<b>State statutes.</b> Grounds the response in the selected state&rsquo;s codified statutes.">
          <input type="checkbox" id="toggle-state-statutes" />
          <span class="research-toggle-label">State</span>
        </label>
        <label class="research-toggle"
          data-tip="<b>Federal statutes.</b> Grounds the response in the U.S. Code and federal regulations.">
          <input type="checkbox" id="toggle-federal-statutes" />
          <span class="research-toggle-label">Federal</span>
        </label>
      </span>

      <span class="research-divider" aria-hidden="true">|</span>
      <span class="research-group">
        <span class="research-group-label">Case law:</span>
        <label class="research-toggle"
          data-tip="<b>State case law.</b> Pulls relevant decisions from the selected state&rsquo;s appellate and supreme courts.">
          <input type="checkbox" id="toggle-state-caselaw" />
          <span class="research-toggle-label">State</span>
        </label>
        <label class="research-toggle"
          data-tip="<b>Federal case law.</b> Pulls relevant decisions from the U.S. Supreme Court and the federal circuits. Citations are verified after the response.">
          <input type="checkbox" id="toggle-federal-caselaw" />
          <span class="research-toggle-label">Federal</span>
        </label>
      </span>

      <span class="research-divider" aria-hidden="true">|</span>
      <span class="research-group">
        <span class="research-group-label">Bills:</span>
        <label class="research-toggle"
          data-tip="<b>State bills.</b> Surfaces pending or recent legislation in the selected state, and flags cited statutes that may have pending amendments.">
          <input type="checkbox" id="toggle-state-bills" />
          <span class="research-toggle-label">State</span>
        </label>
        <label class="research-toggle"
          data-tip="<b>Federal bills.</b> Surfaces pending or recent legislation in the U.S. Congress, and flags cited federal statutes that may have pending amendments.">
          <input type="checkbox" id="toggle-federal-bills" />
          <span class="research-toggle-label">Federal</span>
        </label>
      </span>

      <span class="research-status" id="research-status"></span>
    </div>

    <form id="composer" class="chat-composer">
      <button type="button" id="composer-paperclip" class="composer-paperclip" aria-label="Attach document" title="Attach document from library">📎</button>
      <textarea id="composer-input" rows="2" placeholder="Ask a legal research question…"></textarea>
      <button type="submit" id="composer-send" class="ws-btn">Send</button>
    </form>
    <p class="chat-discl">Output is AI-generated and not legal advice. Verify every citation before relying on it.</p>

    <!-- Attach modal (hidden by default) -->
    <div id="attach-modal" class="attach-modal" hidden>
      <div class="attach-modal-inner">
        <header class="attach-modal-head">
          <h2 class="attach-modal-title">Attach document</h2>
          <button type="button" id="attach-close" class="attach-modal-close" aria-label="Close">×</button>
        </header>
        <div class="attach-modal-body">
          <div class="attach-upload-row">
            <button type="button" id="attach-upload-btn" class="ws-btn">+ Upload new</button>
            <input type="file" id="attach-upload-input" hidden multiple
              accept=".pdf,.docx,.txt,.md,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,text/markdown" />
            <span class="attach-upload-hint">Goes into your library and auto-attaches</span>
          </div>
          <div id="attach-upload-progress" class="attach-upload-progress"></div>
          <input id="attach-search" class="attach-search" type="search" placeholder="Search your library…" />
          <div id="attach-list" class="attach-list">
            <div class="ws-empty">Loading…</div>
          </div>
        </div>
        <footer class="attach-modal-foot">
          <a href="/workspace/library/" class="lib-back">Manage library →</a>
          <button type="button" id="attach-confirm" class="ws-btn" disabled>Attach selected</button>
        </footer>
      </div>
    </div>

    <!-- Citation verification modal — opens when user clicks the
         small Citations summary pill below an assistant message,
         or any inline cite badge. Lists every detected citation
         with its verification status, source URL, and (when
         applicable) amendment notes from LegiScan. -->
    <div id="cite-modal" class="cite-modal" hidden>
      <div class="cite-modal-overlay"></div>
      <div class="cite-modal-inner">
        <header class="cite-modal-head">
          <h2 class="cite-modal-title">Citation verification</h2>
          <button type="button" class="cite-modal-close" data-cite-modal-close aria-label="Close">×</button>
        </header>
        <div class="cite-modal-body" id="cite-modal-body"></div>
      </div>
    </div>

    <!-- Privacy mode info modal — opens when the user clicks the
         🔒 badge on an abstracted message. Explains the policy +
         the technique + cites the bar guidance. -->
    <div id="privacy-modal" class="cite-modal" hidden>
      <div class="cite-modal-overlay"></div>
      <div class="cite-modal-inner">
        <header class="cite-modal-head">
          <h2 class="cite-modal-title">🔒 Privacy mode — what just happened</h2>
          <button type="button" class="cite-modal-close" data-privacy-modal-close aria-label="Close">×</button>
        </header>
        <div class="cite-modal-body">
          <p>This chat is in <strong>Privacy mode</strong>. Before your message left the server, it was rewritten by an abstractor LLM into an abstract legal hypothetical:</p>
          <ul style="font-size: 13px; line-height: 1.55; padding-left: 20px;">
            <li><strong>Stripped:</strong> client and party names, entity names (companies, firms, agencies), street addresses, specific dates, dollar amounts, account / SSN / EIN / docket numbers, phone, email.</li>
            <li><strong>Replaced with:</strong> role-based descriptors ("the CFO", "an insurance company", "last year").</li>
            <li><strong>Preserved:</strong> the legal issue, jurisdiction, statutes, regulations, procedural posture, and abstract fact pattern.</li>
          </ul>
          <p>The original raw text was <strong>never written to our database</strong>. The version you see in your message bubble is the abstracted form — the same thing the LLM saw.</p>
          <p>This is the gold-standard "fully abstracted hypothetical" technique used in legal research to comply with client-confidence rules. References:</p>
          <ul style="font-size: 13px; line-height: 1.55; padding-left: 20px;">
            <li>Florida Bar Ethics Op. 24-1 (Jan 19, 2024)</li>
            <li>ABA Formal Op. 512 (July 29, 2024)</li>
            <li>Florida R. Regulating Fla. Bar 4-1.6 (Confidentiality of Information)</li>
            <li>ABA Model R. of Prof. Conduct 1.6</li>
          </ul>
          <p style="font-size: 12px; color: var(--ink-3);">Privacy mode is best-effort, not absolute. You should still review every prompt before sending. If the abstractor misclassifies something obvious, please flag it.</p>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
  import { getSupabase } from '../../../lib/supabase';

  const supabase = getSupabase();

  document.body.style.visibility = 'hidden';
  let session = null;
  try {
    const { data, error } = await supabase.auth.getSession();
    if (error) throw error;
    session = data?.session || null;
    if (!session) {
      const here = location.pathname + location.search;
      location.href = '/login/?redirect=' + encodeURIComponent(here);
      throw new Error('not signed in');
    }
    const { data: profile, error: profileErr } = await supabase
      .from('profiles').select('approved_at').eq('id', session.user.id).maybeSingle();
    if (profileErr) throw profileErr;
    if (!profile) {
      document.body.style.visibility = '';
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">No profile</h1><p>We could not find a profile for your account. Try signing out and creating the account again.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('no profile');
    }
    if (!profile.approved_at) {
      document.body.style.visibility = '';
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Pending approval</h1><p>Your account is pending operator approval.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('pending approval');
    }
    document.body.style.visibility = '';
  } catch (err) {
    if (err && err.message && !['pending approval','no profile','not signed in'].includes(err.message)) {
      console.error('Workspace chat gate failed:', err);
      document.body.style.visibility = '';
      document.body.innerHTML = `<main style="max-width:680px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Workspace error</h1><p>The chat failed to load. Open your browser console for details.</p><pre style="background:#f5f5f5;padding:14px;border-radius:6px;font-size:12px;white-space:pre-wrap;word-break:break-word">${(err && err.message ? err.message : String(err)).replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]))}</pre><p><a href="/workspace/">← Back to workspace</a></p></main>`;
    }
    throw err;
  }

  const accessToken = session.access_token;
  const chatId = new URL(location.href).searchParams.get('id');
  if (!chatId) {
    location.href = '/workspace/';
    throw new Error('missing chat id');
  }

  const els = {
    messages: document.getElementById('messages'),
    title: document.getElementById('chat-title'),
    model: document.getElementById('model-select'),
    keySource: document.getElementById('key-source'),
    composer: document.getElementById('composer'),
    input: document.getElementById('composer-input'),
    send: document.getElementById('composer-send'),
    railList: document.getElementById('rail-list'),
    newChat: document.getElementById('new-chat'),
    paperclip: document.getElementById('composer-paperclip'),
    attachments: document.getElementById('composer-attachments'),
    attachModal: document.getElementById('attach-modal'),
    attachClose: document.getElementById('attach-close'),
    attachSearch: document.getElementById('attach-search'),
    attachList: document.getElementById('attach-list'),
    attachConfirm: document.getElementById('attach-confirm'),
    attachUploadBtn: document.getElementById('attach-upload-btn'),
    attachUploadInput: document.getElementById('attach-upload-input'),
    attachUploadProgress: document.getElementById('attach-upload-progress'),
  };

  // Models are fetched live from /api/workspace-models-list which pulls
  // each provider's current model catalog. The list updates whenever
  // a provider ships a new model (cache TTL 1h server, 24h browser).
  // Fallback list keeps the dropdown usable if the API fails.
  const MODEL_CACHE_KEY = 'workspace.models.v4';   // bump on dropdown shape changes
  const MODEL_CACHE_TTL = 24 * 60 * 60 * 1000;
  const FALLBACK_MODELS = [
    { id: 'claude-sonnet-4-5', label: 'Claude Sonnet 4.5', provider: 'anthropic' },
    { id: 'gpt-5-mini',        label: 'GPT-5 mini',        provider: 'openai' },
    { id: 'gemini-2.5-flash',  label: 'Gemini 2.5 Flash',  provider: 'google' },
  ];
  function renderModelOptions(models, current) {
    const byProvider = { anthropic: [], openai: [], google: [], xai: [] };
    for (const m of models) (byProvider[m.provider] || []).push(m);
    const optGroup = (label, items) =>
      items.length
        ? `<optgroup label="${label}">${items.map((m) => `<option value="${escapeHtml(m.id)}"${m.id === current ? ' selected' : ''}>${escapeHtml(m.label)}</option>`).join('')}</optgroup>`
        : '';
    els.model.innerHTML =
      optGroup('Anthropic', byProvider.anthropic) +
      optGroup('OpenAI', byProvider.openai) +
      optGroup('Google', byProvider.google) +
      optGroup('xAI', byProvider.xai);
  }
  function loadCachedModels() {
    try {
      const raw = localStorage.getItem(MODEL_CACHE_KEY);
      if (!raw) return null;
      const { models, ts } = JSON.parse(raw);
      if (!Array.isArray(models) || Date.now() - ts > MODEL_CACHE_TTL) return null;
      return models;
    } catch { return null; }
  }
  async function refreshModels(currentSelection) {
    try {
      const r = await fetch('/.netlify/functions/workspace-models-list', {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok || !Array.isArray(j.models)) return;
      const models = j.models;
      renderModelOptions(models, currentSelection || els.model.value);
      try { localStorage.setItem(MODEL_CACHE_KEY, JSON.stringify({ models, ts: Date.now() })); } catch {}
    } catch (err) {
      console.warn('models refresh failed', err);
    }
  }
  // Show cached or fallback immediately; refresh in background.
  renderModelOptions(loadCachedModels() || FALLBACK_MODELS, null);

  let chat = null;
  let messages = [];
  let titleDirty = false;
  let sending = false;

  function escapeHtml(s) {
    return String(s ?? '').replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]));
  }
  function renderMarkdownInline(text, opts = {}) {
    // Inline-only markdown: bold, italic, inline code, line breaks,
    // plus a safety net for headings (we ask the model NOT to use
    // them, but if one slips through we render as a styled span
    // rather than leaving raw `#` characters visible).
    //
    // While streaming (opts.optimistic) we render any UNCLOSED
    // trailing marker as if it were already closed — `**foo` becomes
    // <strong>foo</strong>. When the closing pair arrives, the
    // formatting is unchanged and the marker characters never
    // appeared. This is what eliminates the `**` flash.
    let out = escapeHtml(text || '');
    // 0. Headings (safety net — the model is instructed not to use these).
    //    Match `#`, `##`, `###` at start of a line; turn into a styled span.
    out = out.replace(/^(#{1,3})\s+([^\n]*)$/gm, (_m, hashes, body) => {
      const level = hashes.length;
      const cls = level === 1 ? 'msg-h1' : (level === 2 ? 'msg-h2' : 'msg-h3');
      return `<span class="${cls}">${body}</span>`;
    });
    // 1. Closed bold pairs first (greedy on `**`s, lazy on inner text).
    out = out.replace(/\*\*([^*\n]+?)\*\*/g, '<strong>$1</strong>');
    if (opts.optimistic) {
      // 2. Unclosed trailing bold opener — render as open <strong>.
      out = out.replace(/\*\*([^*\n]*)$/, '<strong>$1</strong>');
    }
    // 3. Closed italic pairs (single `*`, not part of `**`).
    out = out.replace(/(^|[^*])\*([^*\n]+?)\*(?!\*)/g, '$1<em>$2</em>');
    if (opts.optimistic) {
      // 4. Unclosed trailing italic opener.
      out = out.replace(/(^|[^*])\*([^*\n]*)$/, '$1<em>$2</em>');
    }
    // 5. Closed inline code spans.
    out = out.replace(/`([^`\n]+?)`/g, '<code>$1</code>');
    if (opts.optimistic) {
      // 6. Unclosed trailing code span.
      out = out.replace(/`([^`\n]*)$/, '<code>$1</code>');
    }
    // 6.1. Markdown links — render `[text](url)` and `[[N]](url)` /
    // `[N](url)` footnote-style references as proper anchors. Long
    // legal source URLs look noisy in prose; rendering them as small
    // superscript footnote chips (for numeric labels) or hostname-
    // only links (for bare URLs) keeps the response readable while
    // preserving click-through. We use null-byte placeholders so the
    // bare-URL pass below doesn't double-process URLs already inside
    // an anchor tag.
    const linkSlots: string[] = [];
    // Footnote-style first: `[1](url)` or `[[1]](url)`
    out = out.replace(/\[\[?\s*(\d+)\s*\]?\]\(([^)\s]+)\)/g, (_m, num, url) => {
      const idx = linkSlots.length;
      linkSlots.push(
        `<sup class="msg-footref"><a href="${url}" target="_blank" rel="noopener" title="${url}">${num}</a></sup>`
      );
      return `L${idx}`;
    });
    // Generic markdown links `[text](url)` next.
    out = out.replace(/\[([^\]\n]+)\]\(([^)\s]+)\)/g, (_m, txt, url) => {
      const idx = linkSlots.length;
      linkSlots.push(
        `<a href="${url}" target="_blank" rel="noopener" class="msg-link">${txt}</a>`
      );
      return `L${idx}`;
    });
    if (opts.optimistic) {
      // Unclosed link openers during streaming. The model writes
      // `[1](https://...` token by token; before the closing `)`
      // arrives, the URL chars would otherwise stream visibly into
      // the response. We replace any TRAILING unclosed opener with
      // a placeholder chip so the URL never flashes for the user.
      // The closed-form regex above runs FIRST every render, so
      // once the `)` arrives the placeholder is replaced by the
      // real chip with the working URL on the next frame.
      //
      // Footnote opener: `[1](...` or `[[1]](...`
      out = out.replace(/\[\[?\s*(\d+)\s*\]?\]\([^)\n]*$/, (_m, num) => {
        const slotIdx = linkSlots.length;
        linkSlots.push(
          `<sup class="msg-footref msg-footref-pending"><a href="#" onclick="return false">${num}</a></sup>`
        );
        return `L${slotIdx}`;
      });
      // Generic-link opener: `[text](...`
      out = out.replace(/\[([^\]\n]+)\]\([^)\n]*$/, (_m, linkTxt) => {
        const slotIdx = linkSlots.length;
        linkSlots.push(
          `<a href="#" onclick="return false" class="msg-link msg-link-pending">${linkTxt}</a>`
        );
        return `L${slotIdx}`;
      });
      // Bracket opened with no closer yet — render contents only,
      // hide the bracket itself so user doesn't see raw '['.
      out = out.replace(/\[([^\]\n]*)$/, '<span class="msg-link-pending">$1</span>');
    }
    // Bare URLs — render as hostname only with the full URL on hover.
    // Strips trailing punctuation that was accidentally captured.
    out = out.replace(/https?:\/\/[^\s<]+/g, (url) => {
      const trailMatch = url.match(/[.,;:!?)\]]+$/);
      let trail = '';
      if (trailMatch) { trail = trailMatch[0]; url = url.slice(0, -trail.length); }
      let host = url;
      try { host = new URL(url).hostname.replace(/^www\./, ''); } catch {}
      const idx = linkSlots.length;
      linkSlots.push(
        `<a href="${url}" target="_blank" rel="noopener" class="msg-url" title="${url}">${host}</a>`
      );
      return `L${idx}${trail}`;
    });
    // 7. Line breaks.
    out = out.replace(/\n/g, '<br>');
    // Restore link placeholders last so <br>/<strong>/<em>/<code>
    // around them are already in place.
    out = out.replace(/L(\d+)/g, (_m, idx) => linkSlots[parseInt(idx, 10)] || '');
    return out;
  }
  function bubble(role, content, opts = {}) {
    const cls = role === 'user' ? 'msg user' : 'msg asst';
    const meta = opts.meta ? `<div class="msg-meta">${escapeHtml(opts.meta)}</div>` : '';
    const attachments = Array.isArray(opts.attachments) && opts.attachments.length
      ? `<div class="msg-attach-row">${opts.attachments.map((a) => `<span class="msg-attach">📎 ${escapeHtml(a.filename || a.name || 'attachment')}</span>`).join('')}</div>`
      : '';
    // Per-message Privacy badge was removed — the chat-wide visual
    // (amber-tinted chat container + animated lock in the header)
    // already conveys that Privacy mode is active. Keep the
    // `data-privacy` attribute on the bubble for any tooling/CSS
    // that might key off it later, but don't render any chrome.
    const privacyAttr = opts.privacy_applied ? ' data-privacy="1"' : '';
    // Copy button for assistant messages — sits in the message
    // chrome and grabs the raw text from the bubble's data-src
    // attribute so what gets copied is plain prose, not the
    // rendered markdown (no asterisks, footnote numbers, etc.).
    const copyBtn = role === 'assistant'
      ? `<div class="msg-actions"><button type="button" class="msg-copy" aria-label="Copy response">${COPY_ICON_SVG} <span class="msg-copy-label">Copy</span></button></div>`
      : '';
    const dataSrc = role === 'assistant' ? ` data-src="${escapeAttr(content || '')}"` : '';
    return `<div class="${cls}" data-role="${role}"${opts.id ? ` data-id="${opts.id}"` : ''}${privacyAttr}${dataSrc}><div class="msg-body">${renderMarkdownInline(content)}${attachments}</div>${meta}${copyBtn}</div>`;
  }
  function escapeAttr(s) {
    return String(s ?? '').replace(/[<>&"'\n\r]/g, (c) => ({
      '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;', "'": '&#39;',
      '\n': '&#10;', '\r': '&#13;',
    }[c]));
  }
  const COPY_ICON_SVG = '<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><rect x="4" y="3" width="9" height="11" rx="1.5"/><path d="M3 5v8a1 1 0 001 1h7"/></svg>';
  function scrollToBottom() {
    els.messages.scrollTop = els.messages.scrollHeight;
  }

  // Per-chat content cache. Stores chat metadata + messages keyed by
  // chat id, so reload-on-an-existing-chat renders instantly from
  // localStorage instead of waiting for the network round-trip. The
  // server fetch runs in the background and silently overwrites the
  // cache when it returns. Only complete (non-streaming) messages are
  // cached.
  const CHAT_CACHE_KEY = 'workspace.chat.' + chatId;

  function renderMessages(msgs) {
    if (!msgs?.length) {
      els.messages.innerHTML = '<div class="chat-empty">Ask something. The legal research desk is open.</div>';
      return;
    }
    els.messages.innerHTML = msgs
      .filter((m) => m.role === 'user' || m.role === 'assistant')
      .map((m) => bubble(m.role, m.content || '', { attachments: m.attachments || [], privacy_applied: !!m.privacy_applied }))
      .join('');
    scrollToBottom();
  }

  function applyChatMeta(meta) {
    if (!meta) return;
    els.title.value = meta.title || '';
    els.title.placeholder = 'Untitled chat';
    if (meta.model) els.model.value = meta.model;
    syncPillFromChat();
    // Hydrate research-mode toggles from the persisted row
    if (typeof hydrateLawSettings === 'function') hydrateLawSettings(meta.law_settings || {});
  }

  function loadChatFromCache() {
    try {
      const raw = localStorage.getItem(CHAT_CACHE_KEY);
      if (!raw) return false;
      const cached = JSON.parse(raw);
      if (!cached?.messages) return false;
      chat = cached.chat || null;
      messages = cached.messages || [];
      applyChatMeta(chat);
      renderMessages(messages);
      return true;
    } catch { return false; }
  }

  async function loadChat() {
    const r = await fetch(`/.netlify/functions/workspace-chats-get?id=${encodeURIComponent(chatId)}`, {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) {
      // If we already painted from cache, leave the cache visible and
      // surface the error in the title; otherwise show the empty
      // state with the error.
      if (!chat) {
        els.messages.innerHTML = `<div class="chat-empty">Failed to load chat: ${escapeHtml(j.error || 'unknown')}</div>`;
      }
      return;
    }
    chat = j.chat;
    messages = j.messages || [];
    applyChatMeta(chat);
    renderMessages(messages);
    // Update cache with fresh data.
    try {
      localStorage.setItem(CHAT_CACHE_KEY, JSON.stringify({ chat, messages }));
    } catch {}
  }

  // Cache the sidebar list in localStorage. The cache renders
  // instantly on reload so the sidebar isn't blank during the network
  // round-trip; the live list overwrites it as soon as the fetch
  // returns. Per-user key so multi-account testing works cleanly.
  const RAIL_CACHE_KEY = 'workspace.rail.' + (session.user?.id || 'anon');
  function renderRail(chats) {
    els.railList.innerHTML = (chats || []).map((c) => {
      const title = c.title || 'Untitled';
      const cls = c.id === chatId ? 'rail-row is-active' : 'rail-row';
      return `<div class="rail-row-wrap">
        <a href="/workspace/chat/?id=${c.id}" class="${cls}" title="${escapeHtml(title)}">${escapeHtml(title)}</a>
        <button type="button" class="rail-row-del" data-del="${c.id}" data-title="${escapeHtml(title)}" aria-label="Delete chat" title="Delete">×</button>
      </div>`;
    }).join('');

    // Wire delete buttons. If the user deletes the CURRENTLY-OPEN
    // chat, send them back to the workspace landing.
    els.railList.querySelectorAll('[data-del]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.dataset.del;
        const t = btn.dataset.title;
        if (!confirm(`Delete "${t}"? This cannot be undone.`)) return;
        btn.disabled = true;
        const r = await fetch('/.netlify/functions/workspace-chats-delete', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          alert('Delete failed: ' + (j.error || 'unknown'));
          btn.disabled = false;
          return;
        }
        try { localStorage.removeItem(RAIL_CACHE_KEY); } catch {}
        if (id === chatId) {
          location.href = '/workspace/';
          return;
        }
        loadRail();
      });
    });
  }
  function renderRailFromCache() {
    try {
      const raw = localStorage.getItem(RAIL_CACHE_KEY);
      if (!raw) return false;
      const cached = JSON.parse(raw);
      if (!Array.isArray(cached) || cached.length === 0) return false;
      renderRail(cached);
      return true;
    } catch { return false; }
  }
  async function loadRail() {
    try {
      const r = await fetch('/.netlify/functions/workspace-chats-list?limit=30', {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok) return;
      const chats = j.chats || [];
      renderRail(chats);
      try { localStorage.setItem(RAIL_CACHE_KEY, JSON.stringify(chats)); } catch {}
    } catch (err) {
      console.error('rail load failed', err);
    }
  }

  async function sendMessage(text, opts = {}) {
    if (sending || !text.trim()) return;
    sending = true;
    els.send.disabled = true;
    els.input.disabled = true;

    const attachmentIds = opts.attachments || [];
    const attachmentNames = opts.attachmentNames || [];

    // optimistic user bubble — include attachment chips if any
    if (els.messages.querySelector('.chat-empty')) els.messages.innerHTML = '';
    const attachLabel = attachmentNames.length
      ? `<div class="msg-attach-row">${attachmentNames.map((a) => `<span class="msg-attach">📎 ${escapeHtml(a.filename)}</span>`).join('')}</div>`
      : '';
    els.messages.insertAdjacentHTML('beforeend',
      `<div class="msg user" data-role="user" data-pending-user="1"><div class="msg-body">${renderMarkdownInline(text)}${attachLabel}</div></div>`);
    scrollToBottom();

    // assistant bubble: msg-text gets re-rendered with live markdown
    // every drainer frame, so bold/italic/code formatting appears
    // progressively as the response streams (no raw `**` showing then
    // disappearing). The drainer ticks at most ~60Hz so the renders
    // are cheap even for long responses.
    const asstId = 'pending-' + Date.now();
    // Cursor handling: hidden by default. The spinner indicator is
    // the activity marker until the first text token arrives, at
    // which point the cursor reveals and blinks at the trailing
    // edge of the streaming response. Applies to ALL chats now —
    // research-mode and regular — since the heartbeat always runs.
    els.messages.insertAdjacentHTML('beforeend', `<div class="msg asst" data-pending="${asstId}"><div class="msg-body"><span class="msg-text"></span><div class="msg-status" hidden><span class="msg-status-spinner" aria-hidden="true"></span><span class="msg-status-text"></span></div><span class="cursor" hidden>▍</span></div></div>`);
    const asstWrap = els.messages.querySelector(`[data-pending="${asstId}"] .msg-body`);
    const asstText = asstWrap.querySelector('.msg-text');
    const asstStatus = asstWrap.querySelector('.msg-status');
    const asstStatusText = asstWrap.querySelector('.msg-status-text');
    const asstCursor = asstWrap.querySelector('.cursor');
    // Live "what we're doing right now" indicator — single line that
    // fades between phases as the server reports progress. Disappears
    // entirely once the model starts streaming text. The cursor keeps
    // blinking throughout.
    let pendingPhaseText = '';
    function setPhase(message) {
      if (!message) {
        // Hide immediately — when text starts streaming we want a
        // clean swap to the cursor, not an overlap.
        asstStatus.hidden = true;
        asstStatus.classList.remove('is-fading', 'is-entering');
        return;
      }
      pendingPhaseText = message;
      if (asstStatus.hidden) {
        // First reveal — opacity goes 0 → 1.
        asstStatusText.textContent = message;
        asstStatus.hidden = false;
        asstStatus.classList.add('is-entering');
        void asstStatus.offsetWidth;       // force reflow so the transition runs
        asstStatus.classList.remove('is-entering');
        scrollToBottom();
        return;
      }
      // Already visible — fade only the text out, swap, fade back in.
      // Spinner keeps spinning the whole time.
      asstStatus.classList.add('is-fading');
      setTimeout(() => {
        // Only apply the latest queued message in case multiple status
        // events arrived within the fade window.
        asstStatusText.textContent = pendingPhaseText;
        asstStatus.classList.remove('is-fading');
        scrollToBottom();
      }, 180);
    }
    let displayed = '';   // chars actually shown to user (drained from smoothBuffer)
    scrollToBottom();

    // Show an immediate spinner indicator the moment the user clicks
    // Send — BEFORE the fetch round-trip completes. Without this, the
    // bubble looks frozen during the request (especially in Privacy
    // mode where server-side abstraction can take 5-15s before the
    // SSE stream opens). The first real status event from the server
    // will replace this initial message via the same setPhase swap.
    if (lawSettings.privacy_enabled) {
      setPhase('🔒 Abstracting your message + attachments for privacy…');
    } else {
      setPhase('Sending…');
    }

    let acc = '';
    let titleFromServer = null;
    let asstMessageId = null;
    let verifyingFlag = false;

    // Smoothing queue. Tokens from the model arrive in bursts (Anthropic
    // batches tokens server-side, OpenAI sends 1-3 at a time). Pushing
    // them straight into the DOM gives a stuttery feel. Instead we
    // buffer the inbound text and drain it at ~60fps with an adaptive
    // chunk size: when the buffer is small we drain slowly (1 char per
    // frame); when it's large we drain faster so we never lag too far
    // behind. Same trick the major chat UIs use to make streaming
    // feel like a steady typewriter.
    let smoothBuffer = '';
    let streamFinished = false;
    let drainerRunning = false;
    // Base draw rate, chars/sec. Conversational pace.
    const BASE_CHARS_PER_SEC = 35;
    let charBudget = 0;   // fractional chars not yet drawn
    function startDrainer() {
      if (drainerRunning) return;
      drainerRunning = true;
      let lastTime = performance.now();
      function tick(now) {
        const elapsed = now - lastTime;
        lastTime = now;
        if (smoothBuffer.length === 0) {
          if (streamFinished) {
            drainerRunning = false;
            return;
          }
          requestAnimationFrame(tick);
          return;
        }
        // Time-based budget for precise CPS control. At BASE we add
        // (BASE * elapsed / 1000) chars to the budget each frame, then
        // draw floor(budget) chars and keep the fractional remainder.
        // This gives exactly BASE_CHARS_PER_SEC over time, regardless
        // of frame rate (60fps, 30fps, even bursty frames).
        let rate = BASE_CHARS_PER_SEC;
        // Catch-up: if the API has run far ahead (large buffer),
        // accelerate gently so we don't lag visibly behind. Caps at
        // ~3x base so reading rhythm stays steady.
        if (smoothBuffer.length > 600) rate = BASE_CHARS_PER_SEC * 3;
        else if (smoothBuffer.length > 300) rate = BASE_CHARS_PER_SEC * 2;
        else if (smoothBuffer.length > 120) rate = BASE_CHARS_PER_SEC * 1.4;
        charBudget += (rate * elapsed) / 1000;
        const chunkSize = Math.min(Math.floor(charBudget), smoothBuffer.length);
        if (chunkSize > 0) {
          charBudget -= chunkSize;
          const chunk = smoothBuffer.slice(0, chunkSize);
          smoothBuffer = smoothBuffer.slice(chunkSize);
          displayed += chunk;
          // Live markdown with optimistic open-marker rendering so
          // `**` becomes bold immediately, no flash.
          asstText.innerHTML = renderMarkdownInline(displayed, { optimistic: true });
          scrollToBottom();
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
    try {
      // Use the Edge Function path — Netlify edge runtime streams Web
      // Response bodies natively without the chunk-batching that
      // regular Netlify Functions can introduce.
      const res = await fetch('/api/workspace-chat-stream', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          chat_id: chatId,
          content: text,
          model: els.model.value,
          attachments: attachmentIds,
          law_settings: lawSettings,
        }),
      });
      if (!res.ok || !res.body) {
        const j = await res.json().catch(() => ({}));
        throw new Error(j.error || `HTTP ${res.status}`);
      }
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buf = '';
      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buf += decoder.decode(value, { stream: true });
        let nl;
        while ((nl = buf.indexOf('\n\n')) !== -1) {
          const record = buf.slice(0, nl);
          buf = buf.slice(nl + 2);
          let event = 'message';
          let data = '';
          for (const line of record.split('\n')) {
            if (line.startsWith('event:')) event = line.slice(6).trim();
            else if (line.startsWith('data:')) data += line.slice(5).trimStart();
          }
          if (!data) continue;
          let evt;
          try { evt = JSON.parse(data); } catch { continue; }
          if (event === 'start') {
            els.keySource.textContent = evt.key_source === 'user' ? 'using your key' : '';
            // Privacy mode: replace the optimistic user bubble's text
            // with the abstracted version that actually went out. The
            // chat-wide privacy chrome (amber-tinted container + lock
            // in the header) communicates the privacy state — no
            // per-message badge needed.
            if (evt.privacy_applied && evt.user_msg_content) {
              const userBubble = els.messages.querySelector('[data-pending-user="1"]');
              if (userBubble) {
                const body = userBubble.querySelector('.msg-body');
                const attachExisting = body.querySelector('.msg-attach-row');
                if (body) {
                  body.innerHTML = renderMarkdownInline(evt.user_msg_content) + (attachExisting ? attachExisting.outerHTML : '');
                }
                userBubble.removeAttribute('data-pending-user');
                userBubble.setAttribute('data-privacy', '1');
              }
            } else {
              // Clear pending marker for non-privacy sends
              const userBubble = els.messages.querySelector('[data-pending-user="1"]');
              if (userBubble) userBubble.removeAttribute('data-pending-user');
            }
          } else if (event === 'status') {
            // Pre-grounding progress. evt.phase is one of
            //   pregrounding | statutes | statutes_done |
            //   caselaw | caselaw_done |
            //   legiscan | legiscan_done |
            //   thinking | streaming
            // We show ONE current activity line — the spinner means
            // "still working". Each new event replaces the current
            // line with a fade transition. The 'streaming' phase
            // hides the indicator entirely so the cursor + text
            // takes over.
            if (evt.phase === 'streaming') {
              setPhase('');
            } else if (evt.message) {
              setPhase(evt.message);
            }
          } else if (event === 'text' && evt.delta) {
            // Reveal the cursor on the first text delta so it blinks
            // at the trailing edge of the streaming response.
            if (asstCursor.hidden) asstCursor.hidden = false;
            acc += evt.delta;
            // Push into the smoothing buffer; the rAF drainer will
            // dispense it to the DOM at a steady rate.
            smoothBuffer += evt.delta;
            startDrainer();
          } else if (event === 'done') {
            titleFromServer = evt.title;
            asstMessageId = evt.message_id || null;
            verifyingFlag = !!evt.verifying;
          } else if (event === 'error') {
            throw new Error(evt.error || 'stream error');
          }
        }
      }
      // Stream finished. Wait for the smoothing buffer to fully drain
      // (so the user sees the last few chars typed in) before
      // applying the final markdown render.
      streamFinished = true;
      while (smoothBuffer.length > 0) {
        await new Promise((r) => setTimeout(r, 30));
      }
      asstCursor.remove();
      // If no content was received at all, surface a clear fallback
      // (some models — especially Gemini — silently return empty
      // bodies under their own safety filters even when the stream
      // technically "completes" without an error event).
      if (acc.length === 0) {
        asstWrap.innerHTML = '<span class="msg-error">No response received. The model may have refused or hit a content filter. Try rephrasing or switching models.</span>';
        return;
      }
      // Final render — no hideOpenMarkers because the response is
      // complete; any orphan `*` should display as-is.
      asstText.innerHTML = renderMarkdownInline(acc);
      // Hide the phase indicator (defensive — server should have
      // sent status:streaming on first text, but in case it missed).
      setPhase('');
      // Attach copy-button + data-src on the live bubble so the
      // copy click handler can grab the raw plain text.
      const bubbleEl = asstWrap.parentElement;
      if (bubbleEl) {
        bubbleEl.setAttribute('data-src', acc);
        if (!bubbleEl.querySelector('.msg-actions')) {
          bubbleEl.insertAdjacentHTML(
            'beforeend',
            `<div class="msg-actions"><button type="button" class="msg-copy" aria-label="Copy response">${COPY_ICON_SVG} <span class="msg-copy-label">Copy</span></button></div>`
          );
        }
      }
      // Kick off verification polling when the edge function flagged
      // verifying=true on the "done" event. Polling decorates each
      // detected citation with a status badge as results resolve.
      if (verifyingFlag && asstMessageId) {
        pollVerification(asstMessageId, asstWrap);
      }
      // Append to in-memory cache so reload reflects the new turn.
      messages.push({ role: 'user', content: text, status: 'complete' });
      messages.push({ role: 'assistant', content: acc, status: 'complete' });
      try {
        localStorage.setItem(CHAT_CACHE_KEY, JSON.stringify({ chat, messages }));
      } catch {}
    } catch (err) {
      // Make the drainer exit so it's not spinning in the background.
      streamFinished = true;
      asstWrap.innerHTML = `<span class="msg-error">${escapeHtml(err.message || String(err))}</span>`;
      console.error('Chat send error:', err);
    } finally {
      sending = false;
      els.send.disabled = false;
      els.input.disabled = false;
      els.input.focus();
      if (titleFromServer && !els.title.value) els.title.value = titleFromServer;
      if (titleFromServer) loadRail();
    }
  }

  // ---- Research-mode toggles (statutes / case law / LegiScan) ----
  // Per-chat persistent state. The toolbar is in the composer area,
  // toggles are sent in the request body alongside `attachments`,
  // and post-hoc verification badges render inline on the assistant
  // response after streaming completes.
  // First entry is "Federal" — selecting it switches research to
  // federal-only mode (U.S. Code, SCOTUS, all circuits, Congress).
  // For every state below, federal sources are ALWAYS included
  // alongside the state-specific sources.
  const US_STATES = [
    ['US','— Federal (U.S. only) —'],
    ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],
    ['CA','California'],['CO','Colorado'],['CT','Connecticut'],['DE','Delaware'],
    ['DC','District of Columbia'],['FL','Florida'],['GA','Georgia'],['HI','Hawaii'],
    ['ID','Idaho'],['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],
    ['KY','Kentucky'],['LA','Louisiana'],['ME','Maine'],['MD','Maryland'],
    ['MA','Massachusetts'],['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],
    ['MO','Missouri'],['MT','Montana'],['NE','Nebraska'],['NV','Nevada'],
    ['NH','New Hampshire'],['NJ','New Jersey'],['NM','New Mexico'],['NY','New York'],
    ['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
    ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],
    ['SD','South Dakota'],['TN','Tennessee'],['TX','Texas'],['UT','Utah'],
    ['VT','Vermont'],['VA','Virginia'],['WA','Washington'],['WV','West Virginia'],
    ['WI','Wisconsin'],['WY','Wyoming'],
  ];
  const lawEls = {
    bar: document.getElementById('research-bar'),
    state: document.getElementById('toggle-state'),
    stateLabel: document.querySelector('#research-bar .research-state-label'),
    stateStatutes:   document.getElementById('toggle-state-statutes'),
    federalStatutes: document.getElementById('toggle-federal-statutes'),
    stateCaselaw:    document.getElementById('toggle-state-caselaw'),
    federalCaselaw:  document.getElementById('toggle-federal-caselaw'),
    stateBills:      document.getElementById('toggle-state-bills'),
    federalBills:    document.getElementById('toggle-federal-bills'),
    privacy:         document.getElementById('toggle-privacy'),
    status: document.getElementById('research-status'),
  };

  // ── Custom tooltip for the research bar ───────────────────────────
  // Native title="" tooltips are an OS-styled rectangle with no
  // wrapping, no styling, and a long delay. We replace them with a
  // styled bubble that uses data-tip for content (HTML allowed).
  (() => {
    const bar = document.getElementById('research-bar');
    if (!bar) return;
    let tipEl = document.getElementById('research-tip');
    if (!tipEl) {
      tipEl = document.createElement('div');
      tipEl.id = 'research-tip';
      tipEl.className = 'research-tip';
      tipEl.setAttribute('role', 'tooltip');
      document.body.appendChild(tipEl);
    }
    let hideTimer = null;
    function showTip(target) {
      const html = target.getAttribute('data-tip');
      if (!html) return;
      if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
      tipEl.innerHTML = html;
      tipEl.classList.add('is-visible');
      // Position above the target, centered horizontally. Clamp to
      // viewport so it never gets clipped on narrow windows.
      const r = target.getBoundingClientRect();
      const tipW = tipEl.offsetWidth;
      const tipH = tipEl.offsetHeight;
      const margin = 8;
      let left = r.left + r.width / 2 - tipW / 2;
      left = Math.max(margin, Math.min(left, window.innerWidth - tipW - margin));
      let top = r.top - tipH - 10;
      let placement = 'top';
      if (top < margin) {
        top = r.bottom + 10;
        placement = 'bottom';
      }
      tipEl.style.left = `${Math.round(left)}px`;
      tipEl.style.top = `${Math.round(top)}px`;
      tipEl.dataset.placement = placement;
      // Position the arrow to point at the center of the target
      const arrowX = r.left + r.width / 2 - left;
      tipEl.style.setProperty('--tip-arrow-x', `${Math.round(arrowX)}px`);
    }
    function hideTip() {
      if (hideTimer) clearTimeout(hideTimer);
      hideTimer = setTimeout(() => { tipEl.classList.remove('is-visible'); }, 80);
    }
    bar.addEventListener('mouseover', (e) => {
      const t = e.target.closest('[data-tip]');
      if (t && bar.contains(t)) showTip(t);
    });
    bar.addEventListener('mouseout', (e) => {
      const t = e.target.closest('[data-tip]');
      if (t && bar.contains(t)) hideTip();
    });
    bar.addEventListener('focusin', (e) => {
      const t = e.target.closest('[data-tip]');
      if (t && bar.contains(t)) showTip(t);
    });
    bar.addEventListener('focusout', (e) => {
      const t = e.target.closest('[data-tip]');
      if (t && bar.contains(t)) hideTip();
    });
  })();
  // Populate the state dropdown
  if (lawEls.state && !lawEls.state.options.length) {
    lawEls.state.innerHTML = US_STATES
      .map(([code, name]) => `<option value="${code}">${escapeHtml(name)}</option>`)
      .join('');
    lawEls.state.value = 'FL';
  }
  let lawSettings = {
    state: 'FL',
    state_statutes_enabled: false,
    federal_statutes_enabled: false,
    state_caselaw_enabled: false,
    federal_caselaw_enabled: false,
    state_bills_enabled: false,
    federal_bills_enabled: false,
    privacy_enabled: false,
  };
  function anyStateToggleOn() {
