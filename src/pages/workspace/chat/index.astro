  // ---- Upload-from-modal flow ----
  // User picks a file inside the attach modal → we upload it directly
  // to Supabase Storage (just like the library page does) → call
  // workspace-library-register to create DB rows + extract text →
  // auto-select the new doc so the user can hit "Attach selected"
  // immediately without browsing back through the list.
  async function uploadFromModal(file) {
    const docId = crypto.randomUUID();
    const versionId = crypto.randomUUID();
    const ext = file.name.split('.').pop().toLowerCase().replace(/[^a-z0-9]/g, '') || 'bin';
    const storagePath = `${session.user.id}/${docId}/${versionId}.${ext}`;

    const tempId = 'modal-up-' + Date.now() + '-' + Math.random().toString(36).slice(2, 6);
    els.attachUploadProgress.insertAdjacentHTML('beforeend', `
      <div class="lib-upload" data-temp="${tempId}">
        <span class="lib-upload-name">${escapeHtml(file.name)}</span>
        <span class="lib-upload-status">Uploading…</span>
      </div>`);
    const row = els.attachUploadProgress.querySelector(`[data-temp="${tempId}"]`);

    try {
      const { error: upErr } = await supabase.storage
        .from('library')
        .upload(storagePath, file, { contentType: file.type, upsert: false });
      if (upErr) throw new Error(`Storage upload: ${upErr.message}`);

      row.querySelector('.lib-upload-status').textContent = 'Extracting text…';

      const r = await fetch('/.netlify/functions/workspace-library-register', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          filename: file.name,
          original_filename: file.name,
          file_type: file.type || 'application/octet-stream',
          size_bytes: file.size,
          storage_path: storagePath,
        }),
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || `HTTP ${r.status}`);

      row.classList.add('is-done');
      row.querySelector('.lib-upload-status').textContent = 'Ready · auto-attached';
      setTimeout(() => row.remove(), 3500);

      // Push the new doc to the library list (top), auto-select it,
      // and re-render so the user can immediately confirm.
      const newDoc = {
        id: j.document.id,
        filename: j.document.filename,
        file_type: j.document.file_type,
        size_bytes: j.document.size_bytes,
        updated_at: j.document.updated_at,
        current_version: {
          id: j.version.id,
          extraction_status: j.version.extraction_status,
          extracted_chars: j.version.extracted_chars,
        },
      };
      libraryDocs = [newDoc, ...libraryDocs.filter((d) => d.id !== newDoc.id)];
      pickedIds.add(newDoc.id);
      renderLibraryList(libraryDocs);
    } catch (err) {
      row.classList.add('is-error');
      row.querySelector('.lib-upload-status').textContent = `Failed: ${err.message}`;
    }
  }

  els.attachUploadBtn.addEventListener('click', () => els.attachUploadInput.click());
  els.attachUploadInput.addEventListener('change', async (e) => {
    const files = Array.from(e.target.files || []);
    e.target.value = '';
    for (const f of files) await uploadFromModal(f);
  });

  // ---- Project picker pill ----
  // Click the pill in the chat header to assign the chat to a project,
  // remove it from one, or create a new project inline. Same pattern
  // as Notion / Linear's quick-pick popovers.
  const pill = document.getElementById('chat-project-pill');
  const pillLabel = document.getElementById('chat-project-pill-label');
  const popover = document.getElementById('chat-project-popover');
  let cachedProjects = null;

  function setPillLabel(projectName) {
    pillLabel.textContent = projectName ? projectName : 'No project';
    pill.classList.toggle('has-project', !!projectName);
  }
  // Fill the pill once chat metadata loads (loadChat sets `chat`)
  function syncPillFromChat() {
    if (!chat) return;
    if (chat.project_id && chat.project_name) {
      setPillLabel(chat.project_name);
    } else if (chat.project_id) {
      setPillLabel('Loading project…');
      // We don't carry project_name in the chat row; fetch the name once.
      fetch('/.netlify/functions/workspace-projects-list', { headers: { Authorization: `Bearer ${accessToken}` } })
        .then((r) => r.json())
        .then((j) => {
          cachedProjects = j.projects || [];
          const found = cachedProjects.find((p) => p.id === chat.project_id);
          setPillLabel(found ? found.name : 'Project (deleted)');
        })
        .catch(() => setPillLabel('Project'));
    } else {
      setPillLabel(null);
    }
  }

  async function openPopover() {
    // Position popover under the pill
    const rect = pill.getBoundingClientRect();
    popover.style.top = (rect.bottom + window.scrollY + 4) + 'px';
    popover.style.left = (rect.left + window.scrollX) + 'px';
    popover.hidden = false;

    // Fetch projects fresh
    popover.innerHTML = '<div class="cpop-loading">Loading projects…</div>';
    const r = await fetch('/.netlify/functions/workspace-projects-list', {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    cachedProjects = j.projects || [];
    renderPopover();
  }

  function renderPopover() {
    const projects = cachedProjects || [];
    const inAProject = !!chat?.project_id;
    const lines = [
      `<input type="text" class="cpop-search" placeholder="Filter projects…" />`,
      `<div class="cpop-list">`,
      ...projects.map((p) => {
        const sel = p.id === chat?.project_id ? ' is-current' : '';
        return `<button type="button" class="cpop-item${sel}" data-pick="${p.id}" data-name="${escapeHtml(p.name)}">${escapeHtml(p.name)}${sel ? ' ✓' : ''}</button>`;
      }),
      projects.length === 0 ? `<div class="cpop-empty">No projects yet.</div>` : '',
      `</div>`,
      `<div class="cpop-divider"></div>`,
      inAProject ? `<button type="button" class="cpop-action" data-action="remove">Remove from project</button>` : '',
      `<button type="button" class="cpop-action cpop-new" data-action="new">+ New project…</button>`,
    ];
    popover.innerHTML = lines.filter(Boolean).join('');
    const search = popover.querySelector('.cpop-search');
    search?.focus();
    search?.addEventListener('input', () => {
      const q = search.value.toLowerCase();
      popover.querySelectorAll('[data-pick]').forEach((b) => {
        const name = (b.dataset.name || '').toLowerCase();
        b.style.display = name.includes(q) ? '' : 'none';
      });
    });
    popover.querySelectorAll('[data-pick]').forEach((b) => {
      b.addEventListener('click', () => moveToProject(b.dataset.pick, b.dataset.name));
    });
    popover.querySelector('[data-action="remove"]')?.addEventListener('click', () => moveToProject(null, null));
    popover.querySelector('[data-action="new"]')?.addEventListener('click', openInlineNewProject);
  }

  function closePopover() { popover.hidden = true; }

  async function moveToProject(projectId, projectName) {
    closePopover();
    setPillLabel(projectId ? (projectName || 'Loading…') : null);
    const r = await fetch('/.netlify/functions/workspace-chats-update', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: chat.id, project_id: projectId }),
    });
    if (!r.ok) {
      const j = await r.json().catch(() => ({}));
      alert('Move failed: ' + (j.error || 'unknown'));
      return;
    }
    if (chat) chat.project_id = projectId;
    // Bust the rail cache so the workspace landing reflects the move.
    try { localStorage.removeItem(RAIL_CACHE_KEY); } catch {}
  }

  function openInlineNewProject() {
    popover.innerHTML = `
      <div class="cpop-newform">
        <div class="cpop-label">Project name</div>
        <input type="text" class="cpop-input" placeholder="Acme Corp acquisition" maxlength="200" />
        <div class="cpop-actions">
          <button type="button" class="cpop-cancel">Cancel</button>
          <button type="button" class="cpop-create">Create &amp; assign</button>
        </div>
      </div>`;
    const input = popover.querySelector('.cpop-input');
    input.focus();
    popover.querySelector('.cpop-cancel').addEventListener('click', renderPopover);
    const create = async () => {
      const name = input.value.trim();
      if (!name) { input.focus(); return; }
      popover.querySelector('.cpop-create').disabled = true;
      const r = await fetch('/.netlify/functions/workspace-projects-create', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      const j = await r.json();
      if (!r.ok) { alert('Failed: ' + (j.error || 'unknown')); return; }
      cachedProjects = [j.project, ...(cachedProjects || [])];
      await moveToProject(j.project.id, j.project.name);
    };
    popover.querySelector('.cpop-create').addEventListener('click', create);
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') create(); });
  }

  pill.addEventListener('click', (e) => {
    e.stopPropagation();
    if (popover.hidden) openPopover();
    else closePopover();
  });
  document.addEventListener('click', (e) => {
    if (!popover.hidden && !popover.contains(e.target)) closePopover();
  });

  // ---- Resizable sidebar ----
  // Drag the slim handle between sidebar and chat to widen or shrink
  // the sidebar. Layout uses a CSS variable --rail-width on the chat
  // shell, so the chat area auto-fills the rest. Persists across
  // reloads in localStorage.
  const RAIL_KEY = 'workspace.rail.width';
  const RAIL_MIN = 160;
  const RAIL_MAX = 480;
  const RAIL_DEFAULT = 240;
  const shellEl = document.querySelector('.chat-shell');
  const resizeEl = document.getElementById('rail-resize');
  function applyRail(px) {
    const clamped = Math.min(RAIL_MAX, Math.max(RAIL_MIN, Math.round(px)));
    shellEl.style.setProperty('--rail-width', clamped + 'px');
    return clamped;
  }
  applyRail(parseInt(localStorage.getItem(RAIL_KEY) || RAIL_DEFAULT, 10) || RAIL_DEFAULT);
  let dragging = false;
  resizeEl.addEventListener('mousedown', (e) => {
    e.preventDefault();
    dragging = true;
    document.body.style.cursor = 'col-resize';
    document.body.style.userSelect = 'none';
  });
  window.addEventListener('mousemove', (e) => {
    if (!dragging) return;
    // Sidebar starts at the left edge of the chat-shell, which itself
    // is centered with max-width 1400. Offset accordingly.
    const rect = shellEl.getBoundingClientRect();
    const desired = e.clientX - rect.left;
    applyRail(desired);
  });
  window.addEventListener('mouseup', () => {
    if (!dragging) return;
    dragging = false;
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
    const current = shellEl.style.getPropertyValue('--rail-width').replace('px', '');
    try { localStorage.setItem(RAIL_KEY, current); } catch {}
  });
  // Keyboard nudge: Left/Right when handle is focused.
  resizeEl.addEventListener('keydown', (e) => {
    if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
    e.preventDefault();
    const delta = e.key === 'ArrowRight' ? 16 : -16;
    const cur = parseInt(shellEl.style.getPropertyValue('--rail-width') || RAIL_DEFAULT, 10);
    const next = applyRail(cur + delta);
    try { localStorage.setItem(RAIL_KEY, next); } catch {}
  });

  // ---- Auto-hiding top nav ----
  // The shared /nav-autohide.js script (loaded in <head>) handles
  // inactivity-based reveal/hide for the top nav across all pages.
  // No inline JS needed here anymore — just remove the old chevron
  // toggle which auto-hide replaces.
  document.getElementById('nav-toggle')?.remove();

  els.composer.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = els.input.value;
    els.input.value = '';
    const attachmentIds = attachedDocs.map((a) => a.id);
    const wasAttached = attachedDocs.slice();
    attachedDocs = [];
    renderAttachmentChips();
    sendMessage(text, { attachments: attachmentIds, attachmentNames: wasAttached });
  });
  els.input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      els.composer.requestSubmit();
    }
  });
  els.title.addEventListener('change', async () => {
    if (!chat) return;
    const newTitle = els.title.value.trim();
    await fetch('/.netlify/functions/workspace-chats-update', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: chat.id, title: newTitle }),
    });
    loadRail();
  });
  els.model.addEventListener('change', async () => {
    if (!chat) return;
    await fetch('/.netlify/functions/workspace-chats-update', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: chat.id, model: els.model.value }),
    });
  });
  els.newChat.addEventListener('click', async () => {
    const r = await fetch('/.netlify/functions/workspace-chats-create', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: '{}',
    });
    const j = await r.json();
    if (j.id) location.href = `/workspace/chat/?id=${j.id}`;
  });

  // Render BOTH sidebar and chat content from localStorage cache
  // immediately so reload feels instant. The server fetch then runs
  // in parallel and silently overwrites if anything changed.
  loadChatFromCache();
  renderRailFromCache();
  Promise.all([
    loadChat().then(() => refreshModels(chat?.model)),
    loadRail(),
  ]);
  els.input.focus();
</script>
</body>
</html>
