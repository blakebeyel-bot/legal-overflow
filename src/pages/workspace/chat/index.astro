    <!-- Privacy mode info modal — opens when the user clicks the
         🔒 badge on an abstracted message. Explains the policy +
         the technique + cites the bar guidance. -->
    <div id="privacy-modal" class="cite-modal" hidden>
      <div class="cite-modal-overlay"></div>
      <div class="cite-modal-inner">
        <header class="cite-modal-head">
          <h2 class="cite-modal-title">Privacy mode — what just happened</h2>
          <button type="button" class="cite-modal-close" data-privacy-modal-close aria-label="Close">×</button>
        </header>
        <div class="cite-modal-body">
          <p>This chat is in <strong>Privacy mode</strong>. Before your message left the server, it was rewritten by an abstractor LLM into an abstract legal hypothetical:</p>
          <ul style="font-size: 13px; line-height: 1.55; padding-left: 20px;">
            <li><strong>Stripped:</strong> client and party names, entity names (companies, firms, agencies), street addresses, specific dates, dollar amounts, account / SSN / EIN / docket numbers, phone, email.</li>
            <li><strong>Replaced with:</strong> role-based descriptors ("the CFO", "an insurance company", "last year").</li>
            <li><strong>Preserved:</strong> the legal issue, jurisdiction, statutes, regulations, procedural posture, and abstract fact pattern.</li>
          </ul>
          <p>The original raw text was <strong>never written to our database</strong>. The version you see in your message bubble is the abstracted form — the same thing the LLM saw.</p>
          <p>This is the gold-standard "fully abstracted hypothetical" technique used in legal research to comply with client-confidence rules. References:</p>
          <ul style="font-size: 13px; line-height: 1.55; padding-left: 20px;">
            <li>Florida Bar Ethics Op. 24-1 (Jan 19, 2024)</li>
            <li>ABA Formal Op. 512 (July 29, 2024)</li>
            <li>Florida R. Regulating Fla. Bar 4-1.6 (Confidentiality of Information)</li>
            <li>ABA Model R. of Prof. Conduct 1.6</li>
          </ul>
          <p style="font-size: 12px; color: var(--ink-3);">Privacy mode is best-effort, not absolute. You should still review every prompt before sending. If the abstractor misclassifies something obvious, please flag it.</p>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
  import { getSupabase } from '../../../lib/supabase';

  const supabase = getSupabase();

  // Body is never hidden — better for a signed-out user to briefly
  // see the shell than for a signed-in user to see a blank page if
  // the auth gate hiccups (matches the dashboard's hardened pattern).
  console.log('[chat] Script started');
  let session = null;
  try {
    const { data, error } = await supabase.auth.getSession();
    if (error) throw error;
    session = data?.session || null;
    if (!session) {
      const here = location.pathname + location.search;
      console.info('[chat] No session — redirecting to /login/');
      location.href = '/login/?redirect=' + encodeURIComponent(here);
      throw new Error('not signed in');
    }
    const { data: profile, error: profileErr } = await supabase
      .from('profiles').select('approved_at').eq('id', session.user.id).maybeSingle();
    if (profileErr) throw profileErr;
    if (!profile) {
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">No profile</h1><p>We could not find a profile for your account. Try signing out and creating the account again.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('no profile');
    }
    if (!profile.approved_at) {
      document.body.innerHTML = '<main style="max-width:560px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Pending approval</h1><p>Your account is pending operator approval.</p><p><a href="/">Back to homepage</a></p></main>';
      throw new Error('pending approval');
    }
    console.log('[chat] Auth gate passed, user', session.user?.id);
  } catch (err) {
    if (err && err.message && !['pending approval','no profile','not signed in'].includes(err.message)) {
      console.error('[chat] Gate failed:', err);
      document.body.innerHTML = `<main style="max-width:680px;margin:80px auto;padding:0 20px;font-family:Georgia,serif;color:#222"><h1 style="font-weight:400">Workspace error</h1><p>The chat failed to load. Open your browser console for details.</p><pre style="background:#f5f5f5;padding:14px;border-radius:6px;font-size:12px;white-space:pre-wrap;word-break:break-word">${(err && err.message ? err.message : String(err)).replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]))}</pre><p><a href="/workspace/">← Back to workspace</a></p></main>`;
    }
    throw err;
  }

  // accessToken is `let` (mutable) and refreshed automatically when
  // Supabase rotates the session token. Without this, a long-lived
  // chat tab eventually starts seeing "Invalid or expired session"
  // 401s on every API call once the JWT (default 1h TTL) expires —
  // because we'd be sending the original token forever.
  let accessToken = session.access_token;
  // Subscribe to auth state changes so accessToken always reflects
  // the current session. supabase-js auto-refreshes ~5 min before
  // expiry; this listener picks up the new token without requiring
  // a page reload.
  try {
    supabase.auth.onAuthStateChange((event, sess) => {
      if (sess?.access_token) accessToken = sess.access_token;
    });
  } catch (err) {
    console.warn('[chat] auth listener failed:', err?.message);
  }
  // Also expose a getter so any code path that needs the freshest
  // possible token (e.g. retry-after-401) can fetch from Supabase
  // directly. Cheap — supabase-js caches in-memory.
  async function freshAccessToken() {
    try {
      const { data } = await supabase.auth.getSession();
      const t = data?.session?.access_token;
      if (t) accessToken = t;
      return accessToken;
    } catch {
      return accessToken;
    }
  }
  // Pre-warm the token before any background fetches fire.
  freshAccessToken();
  const _url = new URL(location.href);
  // chatId is `let` (not const) so the rail-delete handler can
  // soft-swap to the next chat without a page reload when the user
  // deletes the active conversation.
  let chatId = _url.searchParams.get('id');
  // Optional seed text from the dashboard command bar — prefilled into
  // the composer so the user doesn't retype. We strip it from the URL
  // immediately so a refresh doesn't re-seed the empty box.
  const seedText = _url.searchParams.get('seed');
  if (seedText) {
    _url.searchParams.delete('seed');
    history.replaceState(null, '', _url.toString());
  }
  if (!chatId) {
    location.href = '/workspace/';
    throw new Error('missing chat id');
  }

  const els = {
    messages: document.getElementById('messages'),
    title: document.getElementById('chat-title'),
    model: document.getElementById('model-select'),
    keySource: document.getElementById('key-source'),
    composer: document.getElementById('composer'),
    input: document.getElementById('composer-input'),
    send: document.getElementById('composer-send'),
    railList: document.getElementById('rail-list'),
    newChat: document.getElementById('new-chat'),
    paperclip: document.getElementById('composer-paperclip'),
    attachments: document.getElementById('composer-attachments'),
    attachModal: document.getElementById('attach-modal'),
    attachClose: document.getElementById('attach-close'),
    attachSearch: document.getElementById('attach-search'),
    attachList: document.getElementById('attach-list'),
    attachConfirm: document.getElementById('attach-confirm'),
    attachUploadBtn: document.getElementById('attach-upload-btn'),
    attachUploadInput: document.getElementById('attach-upload-input'),
    attachUploadProgress: document.getElementById('attach-upload-progress'),
  };

  // Models are fetched live from /api/workspace-models-list which pulls
  // each provider's current model catalog. The list updates whenever
  // a provider ships a new model (cache TTL 1h server, 24h browser).
  // Fallback list keeps the dropdown usable if the API fails.
  const MODEL_CACHE_KEY = 'workspace.models.v7';   // v7: tighter xai *-reasoning toggle exclusion + Gemini 3 previews
  const MODEL_CACHE_TTL = 24 * 60 * 60 * 1000;
  const FALLBACK_MODELS = [
    { id: 'claude-sonnet-4-5', label: 'Claude Sonnet 4.5', provider: 'anthropic', vision: true, reasoning: true },
    { id: 'gpt-5-mini',        label: 'GPT-5 mini',        provider: 'openai',    vision: true, reasoning: true },
    { id: 'gemini-2.5-flash',  label: 'Gemini 2.5 Flash',  provider: 'google',    vision: true, reasoning: true },
  ];
  // Cached per render so the change handler can look up vision flag
  // for the currently-selected model without another round-trip.
  let _modelsByIdCache = new Map();
  function renderModelOptions(models, current) {
    _modelsByIdCache = new Map(models.map((m) => [m.id, m]));
    const byProvider = { anthropic: [], openai: [], google: [], xai: [] };
    for (const m of models) (byProvider[m.provider] || []).push(m);
    // Vision-capable models get a "  · vision" suffix in the option
    // label so the user can tell at a glance which models can read
    // image attachments from their vault. Matches the site's
    // mono-caption "· EXTRACT · SUMMARIZE · REDLINE" aesthetic.
    const optHtml = (m) => {
      const visionBit = m.vision ? '  · vision' : '';
      return `<option value="${escapeHtml(m.id)}"${m.id === current ? ' selected' : ''}>${escapeHtml(m.label)}${escapeHtml(visionBit)}</option>`;
    };
    const optGroup = (label, items) =>
      items.length
        ? `<optgroup label="${label}">${items.map(optHtml).join('')}</optgroup>`
        : '';
    els.model.innerHTML =
      optGroup('Anthropic', byProvider.anthropic) +
      optGroup('OpenAI', byProvider.openai) +
      optGroup('Google', byProvider.google) +
      optGroup('xAI', byProvider.xai);
    updateVisionHint();
  }
  function updateVisionHint() {
    const hintEl = document.getElementById('model-vision-hint');
    if (!hintEl) return;
    const sel = els.model?.value;
    const m = _modelsByIdCache.get(sel);
    if (m && m.vision) {
      hintEl.hidden = false;
      hintEl.textContent = '👁 sees images';
    } else {
      hintEl.hidden = true;
    }
    updateDeepThinkVisibility();
  }
  // Deep-think toggle visibility — only shown when the selected
  // model supports the reasoning knob. When the user picks a
  // non-reasoning model, the toggle hides AND its checked state is
  // ignored downstream (chat-stream omits the param).
  function updateDeepThinkVisibility() {
    const wrap = document.getElementById('chat-deep-think-toggle');
    if (!wrap) return;
    const sel = els.model?.value;
    const m = _modelsByIdCache.get(sel);
    wrap.hidden = !(m && m.reasoning);
  }
  function loadCachedModels() {
    try {
      const raw = localStorage.getItem(MODEL_CACHE_KEY);
      if (!raw) return null;
      const { models, ts } = JSON.parse(raw);
      if (!Array.isArray(models) || Date.now() - ts > MODEL_CACHE_TTL) return null;
      return models;
    } catch { return null; }
  }
  async function refreshModels(currentSelection) {
    try {
      // Bypass the server-side 1-hour cache when the local cache is
      // stale or missing — we just bumped MODEL_CACHE_KEY so the
      // first fetch after a deploy must hit the live provider APIs.
      const localStale = !loadCachedModels();
      const url = localStale
        ? '/.netlify/functions/workspace-models-list?refresh=1'
        : '/.netlify/functions/workspace-models-list';
      const r = await fetch(url, {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok || !Array.isArray(j.models)) return;
      const models = j.models;
      renderModelOptions(models, currentSelection || els.model.value);
      try { localStorage.setItem(MODEL_CACHE_KEY, JSON.stringify({ models, ts: Date.now() })); } catch {}
    } catch (err) {
      console.warn('models refresh failed', err);
    }
  }
  // Show cached or fallback immediately; refresh in background.
  renderModelOptions(loadCachedModels() || FALLBACK_MODELS, null);

  let chat = null;
  let messages = [];
  let titleDirty = false;
  let sending = false;

  function escapeHtml(s) {
    return String(s ?? '').replace(/[<>&]/g, (ch) => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[ch]));
  }
  function renderMarkdownInline(text, opts = {}) {
    // Inline-only markdown: bold, italic, inline code, line breaks,
    // plus a safety net for headings (we ask the model NOT to use
    // them, but if one slips through we render as a styled span
    // rather than leaving raw `#` characters visible).
    //
    // While streaming (opts.optimistic) we render any UNCLOSED
    // trailing marker as if it were already closed — `**foo` becomes
    // <strong>foo</strong>. When the closing pair arrives, the
    // formatting is unchanged and the marker characters never
    // appeared. This is what eliminates the `**` flash.
    let out = escapeHtml(text || '');
    // 0. Headings (safety net — the model is instructed not to use these).
    //    Match `#`, `##`, `###` at start of a line; turn into a styled span.
    out = out.replace(/^(#{1,3})\s+([^\n]*)$/gm, (_m, hashes, body) => {
      const level = hashes.length;
      const cls = level === 1 ? 'msg-h1' : (level === 2 ? 'msg-h2' : 'msg-h3');
      return `<span class="${cls}">${body}</span>`;
    });
    // 1. Closed bold pairs first (greedy on `**`s, lazy on inner text).
    out = out.replace(/\*\*([^*\n]+?)\*\*/g, '<strong>$1</strong>');
    if (opts.optimistic) {
      // 2. Unclosed trailing bold opener — render as open <strong>.
      out = out.replace(/\*\*([^*\n]*)$/, '<strong>$1</strong>');
    }
    // 3. Closed italic pairs (single `*`, not part of `**`).
    out = out.replace(/(^|[^*])\*([^*\n]+?)\*(?!\*)/g, '$1<em>$2</em>');
    if (opts.optimistic) {
      // 4. Unclosed trailing italic opener.
      out = out.replace(/(^|[^*])\*([^*\n]*)$/, '$1<em>$2</em>');
    }
    // 5. Closed inline code spans.
    out = out.replace(/`([^`\n]+?)`/g, '<code>$1</code>');
    if (opts.optimistic) {
      // 6. Unclosed trailing code span.
      out = out.replace(/`([^`\n]*)$/, '<code>$1</code>');
    }
    // 6.1. Markdown links — render `[text](url)` and `[[N]](url)` /
    // `[N](url)` footnote-style references as proper anchors. Long
    // legal source URLs look noisy in prose; rendering them as small
    // superscript footnote chips (for numeric labels) or hostname-
    // only links (for bare URLs) keeps the response readable while
    // preserving click-through. We use null-byte placeholders so the
    // bare-URL pass below doesn't double-process URLs already inside
    // an anchor tag.
    const linkSlots: string[] = [];
    // Footnote-style first: `[1](url)` or `[[1]](url)`
    out = out.replace(/\[\[?\s*(\d+)\s*\]?\]\(([^)\s]+)\)/g, (_m, num, url) => {
      const idx = linkSlots.length;
      linkSlots.push(
        `<sup class="msg-footref"><a href="${url}" target="_blank" rel="noopener" title="${url}">${num}</a></sup>`
      );
      return `L${idx}`;
    });
    // Generic markdown links `[text](url)` next.
    out = out.replace(/\[([^\]\n]+)\]\(([^)\s]+)\)/g, (_m, txt, url) => {
      const idx = linkSlots.length;
      linkSlots.push(
        `<a href="${url}" target="_blank" rel="noopener" class="msg-link">${txt}</a>`
      );
      return `L${idx}`;
    });
    if (opts.optimistic) {
      // Unclosed link openers during streaming. The model writes
      // `[1](https://...` token by token; before the closing `)`
      // arrives, the URL chars would otherwise stream visibly into
      // the response. We replace any TRAILING unclosed opener with
      // a placeholder chip so the URL never flashes for the user.
      // The closed-form regex above runs FIRST every render, so
      // once the `)` arrives the placeholder is replaced by the
      // real chip with the working URL on the next frame.
      //
      // Footnote opener: `[1](...` or `[[1]](...`
      out = out.replace(/\[\[?\s*(\d+)\s*\]?\]\([^)\n]*$/, (_m, num) => {
        const slotIdx = linkSlots.length;
        linkSlots.push(
          `<sup class="msg-footref msg-footref-pending"><a href="#" onclick="return false">${num}</a></sup>`
        );
        return `L${slotIdx}`;
      });
      // Generic-link opener: `[text](...`
      out = out.replace(/\[([^\]\n]+)\]\([^)\n]*$/, (_m, linkTxt) => {
        const slotIdx = linkSlots.length;
        linkSlots.push(
          `<a href="#" onclick="return false" class="msg-link msg-link-pending">${linkTxt}</a>`
        );
        return `L${slotIdx}`;
      });
      // Bracket opened with no closer yet — render contents only,
      // hide the bracket itself so user doesn't see raw '['.
      out = out.replace(/\[([^\]\n]*)$/, '<span class="msg-link-pending">$1</span>');
    }
    // Bare URLs — render as hostname only with the full URL on hover.
    // Strips trailing punctuation that was accidentally captured.
    out = out.replace(/https?:\/\/[^\s<]+/g, (url) => {
      const trailMatch = url.match(/[.,;:!?)\]]+$/);
      let trail = '';
      if (trailMatch) { trail = trailMatch[0]; url = url.slice(0, -trail.length); }
      let host = url;
      try { host = new URL(url).hostname.replace(/^www\./, ''); } catch {}
      const idx = linkSlots.length;
      linkSlots.push(
        `<a href="${url}" target="_blank" rel="noopener" class="msg-url" title="${url}">${host}</a>`
      );
      return `L${idx}${trail}`;
    });
    // 7. Line breaks.
    out = out.replace(/\n/g, '<br>');
    // Restore link placeholders last so <br>/<strong>/<em>/<code>
    // around them are already in place.
    out = out.replace(/L(\d+)/g, (_m, idx) => linkSlots[parseInt(idx, 10)] || '');
    return out;
  }
  function bubble(role, content, opts = {}) {
    const cls = role === 'user' ? 'msg user' : 'msg asst';
    const meta = opts.meta ? `<div class="msg-meta">${escapeHtml(opts.meta)}</div>` : '';
    const attachments = Array.isArray(opts.attachments) && opts.attachments.length
      ? `<div class="msg-attach-row">${opts.attachments.map((a) => `<span class="msg-attach"><span class="msg-attach-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 1 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 1 1-2.83-2.83l8.49-8.48"/></svg></span> ${escapeHtml(a.filename || a.name || 'attachment')}</span>`).join('')}</div>`
      : '';
    // Per-message Privacy badge was removed — the chat-wide visual
    // (amber-tinted chat container + animated lock in the header)
    // already conveys that Privacy mode is active. Keep the
    // `data-privacy` attribute on the bubble for any tooling/CSS
    // that might key off it later, but don't render any chrome.
    const privacyAttr = opts.privacy_applied ? ' data-privacy="1"' : '';
    // Action chrome — Copy is shown on BOTH user and assistant bubbles
    // (handler reads data-src below, which is now set for both roles so
    // the user can copy their own questions). Save-to-Vault stays
    // assistant-only — saving the user's own question alone isn't
    // useful; the response (or the whole conversation via the chat-head
    // button) is the keepable artifact.
    const isAsst = role === 'assistant';
    const copyBtn = `<div class="msg-actions">
        <button type="button" class="msg-copy" aria-label="${isAsst ? 'Copy response' : 'Copy message'}">${COPY_ICON_SVG} <span class="msg-copy-label">Copy</span></button>
        ${isAsst ? `
          <button type="button" class="save-to-vault-btn msg-save-vault" data-msg-save-vault aria-label="Save to Vault">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
            </svg>
            <span>Save to Vault</span>
          </button>` : ''}
      </div>`;
    const dataSrc = ` data-src="${escapeAttr(content || '')}"`;
    // Empty-content message with attachments — render just the chip
    // (no empty paragraph above). Happens on attachment-only sends.
    const bodyMd = (content && content.trim()) ? renderMarkdownInline(content) : '';
    return `<div class="${cls}" data-role="${role}"${opts.id ? ` data-id="${opts.id}"` : ''}${privacyAttr}${dataSrc}><div class="msg-body">${bodyMd}${attachments}</div>${meta}${copyBtn}</div>`;
  }
  function escapeAttr(s) {
    return String(s ?? '').replace(/[<>&"'\n\r]/g, (c) => ({
      '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;', "'": '&#39;',
      '\n': '&#10;', '\r': '&#13;',
    }[c]));
  }
  const COPY_ICON_SVG = '<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><rect x="4" y="3" width="9" height="11" rx="1.5"/><path d="M3 5v8a1 1 0 001 1h7"/></svg>';
  function scrollToBottom() {
    els.messages.scrollTop = els.messages.scrollHeight;
  }

  // Per-chat content cache. Stores chat metadata + messages keyed by
  // chat id, so reload-on-an-existing-chat renders instantly from
  // localStorage instead of waiting for the network round-trip. The
  // server fetch runs in the background and silently overwrites the
  // cache when it returns. Only complete (non-streaming) messages are
  // cached.
  const CHAT_CACHE_KEY = 'workspace.chat.' + chatId;

  // Shared empty-state markup so the static fallback in index.astro AND
  // the dynamic re-renders here both show the same suggested-prompt
  // grid. Eight curated entry-point prompts; click handler at the bottom
  // of this file pre-fills the composer with `data-prompt`.
  const EMPTY_STATE_HTML = `
    <div class="chat-empty">
      <div class="chat-empty-text">Ask something. The legal research desk is open.</div>
      <div class="suggested" id="suggested-prompts">
        <div class="suggested-head">— TRY ONE OF THESE TO START</div>
        <button type="button" class="sg-card" data-prompt="What does Florida's prompt-payment statute (§ 218.74) say about late SaaS subscription invoices to a state agency?">
          <span class="sg-cat">— STATUTE</span>
          <span class="sg-prompt">Florida <em>prompt-payment</em> applicability to SaaS state-agency contracts</span>
        </button>
        <button type="button" class="sg-card" data-prompt="Compare 'reasonable best efforts' vs. 'commercially reasonable efforts' under Delaware law and tell me which favors the obligor.">
          <span class="sg-cat">— DOCTRINE</span>
          <span class="sg-prompt">Reasonable <em>best efforts</em> vs. commercially reasonable (Delaware)</span>
        </button>
        <button type="button" class="sg-card" data-prompt="Draft a mutual NDA confidentiality clause that survives termination by 3 years for trade secrets and indefinitely for intellectual property.">
          <span class="sg-cat">— DRAFTING</span>
          <span class="sg-prompt">Mutual <em>NDA</em> survival — 3 years / indefinite</span>
        </button>
        <button type="button" class="sg-card" data-prompt="Summarize the key elements of a Florida tortious-interference claim and the leading defenses, with citations to controlling appellate authority.">
          <span class="sg-cat">— RESEARCH</span>
          <span class="sg-prompt">FL <em>tortious interference</em> — elements + defenses</span>
        </button>
        <button type="button" class="sg-card" data-prompt="Draft a memo analyzing personal jurisdiction over a Florida defendant served via Florida's long-arm statute (§ 48.193) for a contract claim arising out of an out-of-state SaaS subscription.">
          <span class="sg-cat">— MEMO</span>
          <span class="sg-prompt">FL long-arm <em>personal jurisdiction</em> over a SaaS counterparty</span>
        </button>
        <button type="button" class="sg-card" data-prompt="What's the standard for piercing the corporate veil under Delaware law, and how does it differ from Florida?">
          <span class="sg-cat">— DOCTRINE</span>
          <span class="sg-prompt"><em>Piercing the veil</em> — DE vs. FL standards</span>
        </button>
        <button type="button" class="sg-card" data-prompt="I'm reviewing a SaaS MSA on the customer side. Walk me through the top 8 risk-allocation provisions I should pay closest attention to and what good looks like for each.">
          <span class="sg-cat">— REVIEW</span>
          <span class="sg-prompt">Customer-side <em>SaaS MSA</em> — top 8 risk provisions</span>
        </button>
        <button type="button" class="sg-card" data-prompt="Outline a deposition prep for a corporate representative deponent under FRCP 30(b)(6) on a breach-of-contract case. What objections should I be ready to make?">
          <span class="sg-cat">— LITIGATION</span>
          <span class="sg-prompt"><em>30(b)(6)</em> deposition prep + objection-spotting</span>
        </button>
      </div>
    </div>
  `;

  function renderMessages(msgs) {
    // Sync the "Save conversation" header button's enabled/disabled
    // state on every render — disabled when there are zero messages.
    refreshSaveConvoBtnState?.();
    if (!msgs?.length) {
      els.messages.innerHTML = EMPTY_STATE_HTML;
      return;
    }
    els.messages.innerHTML = msgs
      .filter((m) => m.role === 'user' || m.role === 'assistant')
      .map((m) => bubble(m.role, m.content || '', { attachments: m.attachments || [], privacy_applied: !!m.privacy_applied }))
      .join('');
    scrollToBottom();
  }

  function applyChatMeta(meta) {
    if (!meta) return;
    els.title.value = meta.title || '';
    els.title.placeholder = 'Untitled chat';
    if (meta.model) els.model.value = meta.model;
    syncPillFromChat();
    // Hydrate research-mode toggles from the persisted row
    if (typeof hydrateLawSettings === 'function') hydrateLawSettings(meta.law_settings || {});
  }

  function loadChatFromCache() {
    try {
      const raw = localStorage.getItem(CHAT_CACHE_KEY);
      if (!raw) return false;
      const cached = JSON.parse(raw);
      if (!cached?.messages) return false;
      chat = cached.chat || null;
      messages = cached.messages || [];
      applyChatMeta(chat);
      renderMessages(messages);
      return true;
    } catch { return false; }
  }

  async function loadChat() {
    const r = await fetch(`/.netlify/functions/workspace-chats-get?id=${encodeURIComponent(chatId)}`, {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) {
      // If we already painted from cache, leave the cache visible and
      // surface the error in the title; otherwise show the empty
      // state with the error.
      if (!chat) {
        els.messages.innerHTML = `<div class="chat-empty">Failed to load chat: ${escapeHtml(j.error || 'unknown')}</div>`;
      }
      return;
    }
    chat = j.chat;
    messages = j.messages || [];
    applyChatMeta(chat);
    renderMessages(messages);
    renderAnchors(j.anchors || [], []);
    // renderWorkflow handles BOTH the workflow chip AND the
    // body.workflow-active class. Pass null when no workflow so it
    // strips the class on chats without a bound workflow (the user
    // navigated from a workflow chat to a plain one).
    renderWorkflow(j.workflow || null);
    // Update cache with fresh data.
    try {
      localStorage.setItem(CHAT_CACHE_KEY, JSON.stringify({ chat, messages, anchors: j.anchors || [], workflow: j.workflow || null }));
    } catch {}
  }

  // ---- Workflow chip + intro card ----
  // When the chat is bound to a saved prompt pack (workflow_id !=
  // null), make that visible to the user so they know what's loaded.
  // Renders:
  //   1. A small "WORKFLOW · <title>" chip in the anchor strip area
  //   2. An intro card in the messages area when no messages yet,
  //      showing the title + description + sample starter prompt.
  // Without this, freshly-created workflow chats look identical to
  // empty plain chats — the user can't tell the prompt pack is
  // active until they send a message and see the model's behavior.
  function renderWorkflow(wf) {
    // Toggle the body-level "workflow-active" class. Triggers the
    // teal tint / pulsing stripe on .chat-container so the user has
    // a visible cue that a guided prompt-pack is running. Only fires
    // for is_prompt_pack workflows (homepage imports) — user-created
    // workflows stay in normal chat aesthetic.
    const isPack = !!(wf && wf.is_prompt_pack);
    document.body.classList.toggle('workflow-active', isPack);

    const wrap = document.getElementById('chat-anchors');
    if (wrap && wf && wf.id) {
      // Append a workflow chip alongside any anchor chips. We
      // build it via direct DOM so the click handler stays bound
      // (vs. innerHTML which would replace the anchor chips).
      const existing = wrap.querySelector('[data-workflow-chip]');
      if (existing) existing.remove();
      const chip = document.createElement('span');
      chip.setAttribute('data-workflow-chip', '1');
      chip.className = 'chat-workflow-chip';
      chip.title = (wf.description || '').slice(0, 200) || 'Workflow loaded — its prompt pack is active for every message in this chat.';
      chip.innerHTML = `<span class="chat-workflow-chip-icon">⚡</span> Workflow · ${escapeHtml(wf.title || 'Untitled')}`;
      wrap.appendChild(chip);
      wrap.hidden = false;
    }
    // Empty-state intro card — only shown when no messages yet AND
    // a workflow is loaded. Replaces the generic "Type a question"
    // empty state so the user sees what they're starting from.
    if (wf && wf.id && (messages?.length || 0) === 0) {
      const messagesEl = els.messages;
      if (messagesEl) {
        const introHtml = `
          <div class="chat-workflow-intro">
            <div class="chat-workflow-intro-kicker">⚡ Workflow loaded</div>
            <h3 class="chat-workflow-intro-title">${escapeHtml(wf.title || 'Workflow')}</h3>
            ${wf.description ? `<p class="chat-workflow-intro-desc">${escapeHtml(wf.description)}</p>` : ''}
            ${wf.prompt_chars ? `<div class="chat-workflow-intro-meta">System prompt active · ${(wf.prompt_chars).toLocaleString()} chars</div>` : ''}
            <div class="chat-workflow-intro-cta">Type your question or task below — the model is already running this prompt pack.</div>
          </div>
        `;
        messagesEl.innerHTML = introHtml;
      }
    }
  }

  // ---- Anchor chip strip ----
  // Currently-anchored items are shown as solid blue chips with an ×
  // to remove. Items the LAST turn used (but aren't anchored yet)
  // appear as dashed "+ Anchor X" suggestion pills. Click → call the
  // anchor endpoint, re-render. The anchor list is per-chat and
  // persisted server-side; the current-turn `suggestions` are a
  // session-only hint that gets refreshed on each new vault_items
  // SSE event.
  let _lastTurnVaultItems = [];   // [{item_id, title, source_kind, anchored}]
  function renderAnchors(anchors, suggestions) {
    const wrap = document.getElementById('chat-anchors');
    if (!wrap) return;
    const anchored = Array.isArray(anchors) ? anchors : [];
    const sugRaw = Array.isArray(suggestions) ? suggestions : _lastTurnVaultItems;
    const anchoredIds = new Set(anchored.map((a) => a.id));
    const sug = sugRaw.filter((s) => !anchoredIds.has(s.item_id));
    if (anchored.length === 0 && sug.length === 0) {
      wrap.hidden = true;
      wrap.innerHTML = '';
      return;
    }
    wrap.hidden = false;
    const parts = [];
    if (anchored.length) {
      parts.push('<span class="chat-anchors-label">📌 Anchored ·</span>');
      for (const a of anchored) {
        parts.push(
          `<span class="chat-anchor-chip" title="Pinned to this chat. Every turn includes its chunks + images.">` +
          `${escapeHtml(a.title || 'Untitled')}` +
          `<button type="button" class="chat-anchor-x" data-anchor-remove="${escapeAttr(a.id)}" aria-label="Unanchor">×</button>` +
          `</span>`,
        );
      }
    }
    for (const s of sug) {
      parts.push(
        `<button type="button" class="chat-anchor-suggest" data-anchor-add="${escapeAttr(s.item_id)}" title="Anchor this doc to the chat — every follow-up turn will include its chunks + images.">` +
        `+ Anchor ${escapeHtml(s.title || 'this doc')}` +
        `</button>`,
      );
    }
    wrap.innerHTML = parts.join('');
    // Wire remove buttons
    wrap.querySelectorAll('[data-anchor-remove]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-anchor-remove');
        await callAnchor(id, false);
      });
    });
    wrap.querySelectorAll('[data-anchor-add]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-anchor-add');
        await callAnchor(id, true);
      });
    });
  }
  async function callAnchor(itemId, on) {
    if (!chatId || !itemId) return;
    try {
      const r = await fetch('/.netlify/functions/workspace-chat-anchor', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, item_id: itemId, anchored: on }),
      });
      const j = await r.json();
      if (!r.ok) { alert(j.error || 'Anchor failed'); return; }
      renderAnchors(j.anchors || [], _lastTurnVaultItems);
    } catch (err) {
      alert('Anchor failed: ' + err.message);
    }
  }
  // (escapeAttr is defined elsewhere in this file — chip strip uses
  // the existing helper. Avoiding a duplicate declaration.)

  // Cache the sidebar list in localStorage. The cache renders
  // instantly on reload so the sidebar isn't blank during the network
  // round-trip; the live list overwrites it as soon as the fetch
  // returns. Per-user key so multi-account testing works cleanly.
  const RAIL_CACHE_KEY = 'workspace.rail.' + (session.user?.id || 'anon');
  // Cache of all chats so search filter can re-render without refetch.
  let railCacheChats = [];
  let railSearchQuery = '';
  function timeLabel(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    const pad = (n) => String(n).padStart(2,'0');
    return pad(d.getHours()) + ':' + pad(d.getMinutes());
  }
  function dateLabel(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    return d.toLocaleDateString(undefined, { day: '2-digit', month: 'short' });
  }
  function bucketFor(iso) {
    if (!iso) return 'Older';
    const ms = Date.now() - new Date(iso).getTime();
    const d = new Date(iso);
    const today = new Date();
    const sameDay = d.toDateString() === today.toDateString();
    if (sameDay) return 'Today';
    const yest = new Date(today); yest.setDate(today.getDate() - 1);
    if (d.toDateString() === yest.toDateString()) return 'Yesterday';
    if (ms < 7 * 24 * 60 * 60 * 1000) return 'Last week';
    return 'Older';
  }
  function shortModelName(m) {
    if (!m) return '';
    // Prefer the live registry's pretty label so the meta strip
    // tracks whatever the user actually has selected (e.g.
    // "claude sonnet 4.5" not a hardcoded "sonnet-4"). Falls back
    // to a smart prefix-strip if the model isn't in the cache yet
    // (e.g. on first paint before /workspace-models-list resolves).
    try {
      const cached = _modelsByIdCache?.get?.(m);
      if (cached?.label) return cached.label.toLowerCase();
    } catch {}
    const s = String(m).toLowerCase();
    // Strip provider prefix; keep the version/variant part. Cleaner
    // than echoing the full ID and stays readable in the mono meta.
    if (s.startsWith('claude-')) return s.replace(/^claude-/, '').replace(/-/g, ' ');
    if (s.startsWith('gpt-'))    return s;
    if (s.startsWith('gemini-')) return s.replace(/^gemini-/, '').replace(/-/g, ' ');
    if (s.startsWith('grok-'))   return s.replace(/^grok-/, '').replace(/-/g, ' ');
    if (/^o[1-9]/.test(s))       return s;
    return s;
  }
  function renderRail(chats) {
    railCacheChats = Array.isArray(chats) ? chats : [];
    paintRail();
  }
  function paintRail() {
    if (!els.railList) return;
    const q = (railSearchQuery || '').toLowerCase().trim();
    const filtered = railCacheChats.filter((c) => {
      if (!q) return true;
      return (c.title || '').toLowerCase().includes(q);
    });
    if (!filtered.length) {
      els.railList.innerHTML = `<div style="padding:18px 4px; font-family:var(--mono); font-size:10px; color:var(--ink-3); letter-spacing:.08em; text-transform:uppercase;">${q ? 'No matches' : 'No chats yet'}</div>`;
      return;
    }
    // Group by Today / Yesterday / Last week / Older preserving order.
    const groups = { 'Today': [], 'Yesterday': [], 'Last week': [], 'Older': [] };
    for (const c of filtered) {
      groups[bucketFor(c.updated_at)].push(c);
    }
    const sections = ['Today','Yesterday','Last week','Older'].filter((k) => groups[k].length);
    els.railList.innerHTML = sections.map((k, idx) => {
      const items = groups[k];
      const label = `<div class="side-section-l"${idx === 0 ? '' : ' style="padding-top: 12px"'}>
          <span>${k}</span>
          <span>${items.length}</span>
        </div>`;
      const rows = items.map((c) => {
        const title = c.title || 'Untitled';
        const cls = c.id === chatId ? 'rail-row side-item is-active' : 'rail-row side-item';
        const meta = [];
        const t = bucketFor(c.updated_at) === 'Today' || bucketFor(c.updated_at) === 'Yesterday'
          ? timeLabel(c.updated_at) : dateLabel(c.updated_at);
        if (t) meta.push(`<span>${escapeHtml(t)}</span>`);
        if (c.model) meta.push(`<span class="dot">·</span><span>${escapeHtml(shortModelName(c.model))}</span>`);
        return `<div class="rail-row-wrap" style="position:relative;">
          <a href="/workspace/chat/?id=${c.id}" class="${cls}" title="${escapeHtml(title)}">
            <span class="side-item-title">${escapeHtml(title)}</span>
            <span class="side-item-meta">${meta.join('')}</span>
          </a>
          <button type="button" class="rail-row-del" data-del="${c.id}" data-title="${escapeHtml(title)}" aria-label="Delete chat" title="Delete">×</button>
        </div>`;
      }).join('');
      return label + rows;
    }).join('');

    // Wire delete buttons. If the user deletes the CURRENTLY-OPEN
    // chat, send them back to the workspace landing.
    els.railList.querySelectorAll('[data-del]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.dataset.del;
        const t = btn.dataset.title;
        const ok = await window.siteConfirm(`Delete "${t}"? This cannot be undone.`, {
          okLabel: 'Delete',
          danger: true,
        });
        if (!ok) return;
        // Optimistic: pluck the row from the rail immediately so the
        // user sees instant feedback. Roll back on server error.
        const row = btn.closest('.rail-item, .rail-row, li, [data-chat-id]') || btn.parentElement;
        const removedHTML = row?.outerHTML;
        const removedNext = row?.nextSibling;
        const removedParent = row?.parentNode;
        if (row) row.remove();
        // Drop the cached rail snapshot so the next loadRail() can't
        // re-render the deleted row from stale localStorage.
        try {
          const cached = JSON.parse(localStorage.getItem(RAIL_CACHE_KEY) || '[]');
          if (Array.isArray(cached)) {
            const next = cached.filter((c) => c.id !== id);
            localStorage.setItem(RAIL_CACHE_KEY, JSON.stringify(next));
          }
        } catch {}
        const r = await fetch('/.netlify/functions/workspace-chats-delete', {
          method: 'POST',
          headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (!r.ok) {
          const j = await r.json().catch(() => ({}));
          window.siteToast('Delete failed: ' + (j.error || 'unknown'), { kind: 'error' });
          // Rollback — re-insert the row at its original position.
          if (removedParent && removedHTML) {
            const tmp = document.createElement('div');
            tmp.innerHTML = removedHTML;
            const restored = tmp.firstElementChild;
            if (restored) {
              if (removedNext) removedParent.insertBefore(restored, removedNext);
              else removedParent.appendChild(restored);
            }
          }
          return;
        }
        // Success — toast and stay on the chat page. If the user
        // deleted the chat they were viewing, swap to the next chat
        // in the rail; otherwise just refresh the rail.
        window.siteToast(`"${t}" deleted`, { kind: 'success', duration: 2400 });
        if (id === chatId) {
          // Find the next chat in the rail (the row immediately
          // adjacent to the deleted one in the cached chats list).
          let nextChatId = null;
          try {
            const cached = JSON.parse(localStorage.getItem(RAIL_CACHE_KEY) || '[]');
            if (Array.isArray(cached) && cached.length > 0) {
              nextChatId = cached[0]?.id || null;
            }
          } catch {}
          if (nextChatId) {
            // Soft-swap the URL + reload the chat content in place.
            // history.replaceState updates the URL bar without a
            // page reload; we then re-run the chat loader against
            // the new id.
            chatId = nextChatId;
            try { history.replaceState(null, '', `/workspace/chat/?id=${encodeURIComponent(nextChatId)}`); } catch {}
            await loadChat();
          } else {
            // No remaining chats — clear the chat view and show an
            // empty-state message. User stays on the chat page.
            chat = null;
            messages = [];
            chatId = null;
            els.messages.innerHTML = `<div class="chat-empty" style="padding:40px 20px;text-align:center;color:var(--ink-3);font-family:var(--mono);font-size:13px;letter-spacing:.04em;">No chats. Click <b style="color:var(--ink)">+ New chat</b> to start one.</div>`;
            try { history.replaceState(null, '', '/workspace/chat/'); } catch {}
            // Clear meta strip
            const startedEl = document.getElementById('chat-meta-started');
            const msgsEl = document.getElementById('chat-meta-msgs');
            const modelEl = document.getElementById('chat-meta-model');
            if (startedEl) startedEl.textContent = '—';
            if (msgsEl) msgsEl.textContent = '0';
            if (modelEl) modelEl.textContent = '—';
          }
        }
        // Background refresh — picks up any server-side reordering
        // without blocking the user.
        loadRail();
      });
    });
  }
  function renderRailFromCache() {
    try {
      const raw = localStorage.getItem(RAIL_CACHE_KEY);
      if (!raw) return false;
      const cached = JSON.parse(raw);
      if (!Array.isArray(cached) || cached.length === 0) return false;
      renderRail(cached);
      return true;
    } catch { return false; }
  }
  async function loadRail() {
    try {
      const r = await fetch('/.netlify/functions/workspace-chats-list?limit=30', {
        headers: { Authorization: `Bearer ${accessToken}` },
      });
      const j = await r.json();
      if (!r.ok) return;
      const chats = j.chats || [];
      renderRail(chats);
      try { localStorage.setItem(RAIL_CACHE_KEY, JSON.stringify(chats)); } catch {}
    } catch (err) {
      console.error('rail load failed', err);
    }
  }

  async function sendMessage(text, opts = {}) {
    // Allow empty text when at least one attachment is provided —
    // user can send a file solo and the model will react to it.
    const hasAttachments = Array.isArray(opts.attachments) && opts.attachments.length > 0;
    if (sending || (!text.trim() && !hasAttachments)) return;
    sending = true;
    els.send.disabled = true;
    els.input.disabled = true;

    const attachmentIds = opts.attachments || [];
    const attachmentNames = opts.attachmentNames || [];

    // optimistic user bubble — include attachment chips if any
    if (els.messages.querySelector('.chat-empty')) els.messages.innerHTML = '';
    const attachLabel = attachmentNames.length
      ? `<div class="msg-attach-row">${attachmentNames.map((a) => `<span class="msg-attach"><span class="msg-attach-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 1 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 1 1-2.83-2.83l8.49-8.48"/></svg></span> ${escapeHtml(a.filename)}</span>`).join('')}</div>`
      : '';
    // When the user sent only an attachment (no text), the bubble
    // body just contains the chip — no empty paragraph above it.
    const bodyMarkdown = text.trim() ? renderMarkdownInline(text) : '';
    els.messages.insertAdjacentHTML('beforeend',
      `<div class="msg user" data-role="user" data-pending-user="1"><div class="msg-body">${bodyMarkdown}${attachLabel}</div></div>`);
    scrollToBottom();

    // assistant bubble: msg-text gets re-rendered with live markdown
    // every drainer frame, so bold/italic/code formatting appears
    // progressively as the response streams (no raw `**` showing then
    // disappearing). The drainer ticks at most ~60Hz so the renders
    // are cheap even for long responses.
    const asstId = 'pending-' + Date.now();
    // Cursor handling: hidden by default. The spinner indicator is
    // the activity marker until the first text token arrives, at
    // which point the cursor reveals and blinks at the trailing
    // edge of the streaming response. Applies to ALL chats now —
    // research-mode and regular — since the heartbeat always runs.
    els.messages.insertAdjacentHTML('beforeend', `<div class="msg asst" data-pending="${asstId}"><div class="msg-body"><span class="msg-text"></span><div class="msg-status" hidden><span class="msg-status-spinner" aria-hidden="true"></span><span class="msg-status-text"></span></div><span class="cursor" hidden>▍</span></div></div>`);
    const asstWrap = els.messages.querySelector(`[data-pending="${asstId}"] .msg-body`);
    const asstText = asstWrap.querySelector('.msg-text');
    const asstStatus = asstWrap.querySelector('.msg-status');
    const asstStatusText = asstWrap.querySelector('.msg-status-text');
    const asstCursor = asstWrap.querySelector('.cursor');
    // Live "what we're doing right now" indicator — single line that
    // fades between phases as the server reports progress. Disappears
    // entirely once the model starts streaming text. The cursor keeps
    // blinking throughout.
    let pendingPhaseText = '';
    function setPhase(message) {
      if (!message) {
        // Hide immediately — when text starts streaming we want a
        // clean swap to the cursor, not an overlap.
        asstStatus.hidden = true;
        asstStatus.classList.remove('is-fading', 'is-entering');
        return;
      }
      pendingPhaseText = message;
      if (asstStatus.hidden) {
        // First reveal — opacity goes 0 → 1.
        asstStatusText.textContent = message;
        asstStatus.hidden = false;
        asstStatus.classList.add('is-entering');
        void asstStatus.offsetWidth;       // force reflow so the transition runs
        asstStatus.classList.remove('is-entering');
        scrollToBottom();
        return;
      }
      // Already visible — fade only the text out, swap, fade back in.
      // Spinner keeps spinning the whole time.
      asstStatus.classList.add('is-fading');
      setTimeout(() => {
        // Only apply the latest queued message in case multiple status
        // events arrived within the fade window.
        asstStatusText.textContent = pendingPhaseText;
        asstStatus.classList.remove('is-fading');
        scrollToBottom();
      }, 180);
    }
    let displayed = '';   // chars actually shown to user (drained from smoothBuffer)
    scrollToBottom();

    // Show an immediate spinner indicator the moment the user clicks
    // Send — BEFORE the fetch round-trip completes. Without this, the
    // bubble looks frozen during the request (especially in Privacy
    // mode where server-side abstraction can take 5-15s before the
    // SSE stream opens). The first real status event from the server
    // will replace this initial message via the same setPhase swap.
    if (lawSettings.privacy_enabled) {
      setPhase('Abstracting your message + attachments for privacy…');
    } else {
      setPhase('Sending…');
    }

    let acc = '';
    let titleFromServer = null;
    let asstMessageId = null;
    let verifyingFlag = false;

    // Smoothing queue. Tokens from the model arrive in bursts (Anthropic
    // batches tokens server-side, OpenAI sends 1-3 at a time). Pushing
    // them straight into the DOM gives a stuttery feel. Instead we
    // buffer the inbound text and drain it at ~60fps with an adaptive
    // chunk size: when the buffer is small we drain slowly (1 char per
    // frame); when it's large we drain faster so we never lag too far
    // behind. Same trick the major chat UIs use to make streaming
    // feel like a steady typewriter.
    let smoothBuffer = '';
    let streamFinished = false;
    let drainerRunning = false;
    // Base draw rate, chars/sec. Conversational pace.
    const BASE_CHARS_PER_SEC = 35;
    let charBudget = 0;   // fractional chars not yet drawn
    function startDrainer() {
      if (drainerRunning) return;
      drainerRunning = true;
      let lastTime = performance.now();
      function tick(now) {
        const elapsed = now - lastTime;
        lastTime = now;
        if (smoothBuffer.length === 0) {
          if (streamFinished) {
            drainerRunning = false;
            return;
          }
          requestAnimationFrame(tick);
          return;
        }
        // Time-based budget for precise CPS control. At BASE we add
        // (BASE * elapsed / 1000) chars to the budget each frame, then
        // draw floor(budget) chars and keep the fractional remainder.
        // This gives exactly BASE_CHARS_PER_SEC over time, regardless
        // of frame rate (60fps, 30fps, even bursty frames).
        let rate = BASE_CHARS_PER_SEC;
        // Catch-up: if the API has run far ahead (large buffer),
        // accelerate gently so we don't lag visibly behind. Caps at
        // ~3x base so reading rhythm stays steady.
        if (smoothBuffer.length > 600) rate = BASE_CHARS_PER_SEC * 3;
        else if (smoothBuffer.length > 300) rate = BASE_CHARS_PER_SEC * 2;
        else if (smoothBuffer.length > 120) rate = BASE_CHARS_PER_SEC * 1.4;
        charBudget += (rate * elapsed) / 1000;
        const chunkSize = Math.min(Math.floor(charBudget), smoothBuffer.length);
        if (chunkSize > 0) {
          charBudget -= chunkSize;
          const chunk = smoothBuffer.slice(0, chunkSize);
          smoothBuffer = smoothBuffer.slice(chunkSize);
          displayed += chunk;
          // Live markdown with optimistic open-marker rendering so
          // `**` becomes bold immediately, no flash.
          asstText.innerHTML = renderMarkdownInline(displayed, { optimistic: true });
          scrollToBottom();
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
    try {
      // Use the Edge Function path — Netlify edge runtime streams Web
      // Response bodies natively without the chunk-batching that
      // regular Netlify Functions can introduce.
      // Read the deep-think toggle state. Only honored server-side
      // when the chosen model supports reasoning; otherwise the
      // chat-stream silently ignores it.
      const deepThinkEl = document.getElementById('toggle-deep-think');
      const deepThink = !!(deepThinkEl && deepThinkEl.checked && !document.getElementById('chat-deep-think-toggle')?.hidden);
      const res = await fetch('/api/workspace-chat-stream', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          chat_id: chatId,
          content: text,
          model: els.model.value,
          attachments: attachmentIds,
          law_settings: lawSettings,
          deep_think: deepThink,
        }),
      });
      if (!res.ok || !res.body) {
        const j = await res.json().catch(() => ({}));
        throw new Error(j.error || `HTTP ${res.status}`);
      }
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buf = '';
      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buf += decoder.decode(value, { stream: true });
        let nl;
        while ((nl = buf.indexOf('\n\n')) !== -1) {
          const record = buf.slice(0, nl);
          buf = buf.slice(nl + 2);
          let event = 'message';
          let data = '';
          for (const line of record.split('\n')) {
            if (line.startsWith('event:')) event = line.slice(6).trim();
            else if (line.startsWith('data:')) data += line.slice(5).trimStart();
          }
          if (!data) continue;
          let evt;
          try { evt = JSON.parse(data); } catch { continue; }
          if (event === 'start') {
            els.keySource.textContent = evt.key_source === 'user' ? 'using your key' : '';
            // Privacy mode: replace the optimistic user bubble's text
            // with the abstracted version that actually went out. The
            // chat-wide privacy chrome (amber-tinted container + lock
            // in the header) communicates the privacy state — no
            // per-message badge needed.
            if (evt.privacy_applied && evt.user_msg_content) {
              const userBubble = els.messages.querySelector('[data-pending-user="1"]');
              if (userBubble) {
                const body = userBubble.querySelector('.msg-body');
                const attachExisting = body.querySelector('.msg-attach-row');
                if (body) {
                  body.innerHTML = renderMarkdownInline(evt.user_msg_content) + (attachExisting ? attachExisting.outerHTML : '');
                }
                userBubble.removeAttribute('data-pending-user');
                userBubble.setAttribute('data-privacy', '1');
              }
            } else {
              // Clear pending marker for non-privacy sends
              const userBubble = els.messages.querySelector('[data-pending-user="1"]');
              if (userBubble) userBubble.removeAttribute('data-pending-user');
            }
          } else if (event === 'status') {
            // Pre-grounding progress. evt.phase is one of
            //   pregrounding | statutes | statutes_done |
            //   caselaw | caselaw_done |
            //   legiscan | legiscan_done |
            //   thinking | streaming
            // We show ONE current activity line — the spinner means
            // "still working". Each new event replaces the current
            // line with a fade transition. The 'streaming' phase
            // hides the indicator entirely so the cursor + text
            // takes over.
            if (evt.phase === 'streaming') {
              setPhase('');
            } else if (evt.message) {
              setPhase(evt.message);
            }
          } else if (event === 'vault_items' && Array.isArray(evt.items)) {
            // Server tells us which vault items contributed chunks +
            // images this turn. Stash them so the anchor chip strip
            // can render "+ Anchor X" suggestions for any that
            // aren't already pinned. The current `anchors` set lives
            // server-side; we read it from the loadChat() refresh
            // OR fetch on toggle.
            _lastTurnVaultItems = evt.items;
            // Re-render with the LATEST persisted anchor list. We
            // refetch because the server may have changed it
            // (rare — the user could have anchored mid-turn).
            try {
              const r = await fetch(`/.netlify/functions/workspace-chats-get?id=${encodeURIComponent(chatId)}`, {
                headers: { Authorization: `Bearer ${accessToken}` },
              });
              const cj = await r.json();
              if (r.ok) renderAnchors(cj.anchors || [], _lastTurnVaultItems);
            } catch {}
          } else if (event === 'text' && evt.delta) {
            // Reveal the cursor on the first text delta so it blinks
            // at the trailing edge of the streaming response.
            if (asstCursor.hidden) asstCursor.hidden = false;
            acc += evt.delta;
            // Push into the smoothing buffer; the rAF drainer will
            // dispense it to the DOM at a steady rate.
            smoothBuffer += evt.delta;
            startDrainer();
          } else if (event === 'done') {
            titleFromServer = evt.title;
            asstMessageId = evt.message_id || null;
            verifyingFlag = !!evt.verifying;
          } else if (event === 'error') {
            throw new Error(evt.error || 'stream error');
          }
        }
      }
      // Stream finished. Wait for the smoothing buffer to fully drain
      // (so the user sees the last few chars typed in) before
      // applying the final markdown render.
      streamFinished = true;
      while (smoothBuffer.length > 0) {
        await new Promise((r) => setTimeout(r, 30));
      }
      asstCursor.remove();
      // If no content was received at all, surface a clear fallback
      // (some models — especially Gemini — silently return empty
      // bodies under their own safety filters even when the stream
      // technically "completes" without an error event).
      if (acc.length === 0) {
        asstWrap.innerHTML = '<span class="msg-error">No response received. The model may have refused or hit a content filter. Try rephrasing or switching models.</span>';
        return;
      }
      // Final render — no hideOpenMarkers because the response is
      // complete; any orphan `*` should display as-is.
      asstText.innerHTML = renderMarkdownInline(acc);
      // Hide the phase indicator (defensive — server should have
      // sent status:streaming on first text, but in case it missed).
      setPhase('');
      // Attach copy-button + data-src on the live bubble so the
      // copy click handler can grab the raw plain text.
      const bubbleEl = asstWrap.parentElement;
      if (bubbleEl) {
        bubbleEl.setAttribute('data-src', acc);
        if (!bubbleEl.querySelector('.msg-actions')) {
          bubbleEl.insertAdjacentHTML(
            'beforeend',
            `<div class="msg-actions"><button type="button" class="msg-copy" aria-label="Copy response">${COPY_ICON_SVG} <span class="msg-copy-label">Copy</span></button></div>`
          );
        }
      }
      // Kick off verification polling when the edge function flagged
      // verifying=true on the "done" event. Polling decorates each
      // detected citation with a status badge as results resolve.
      if (verifyingFlag && asstMessageId) {
        pollVerification(asstMessageId, asstWrap);
      }
      // Append to in-memory cache so reload reflects the new turn.
      messages.push({ role: 'user', content: text, status: 'complete' });
      messages.push({ role: 'assistant', content: acc, status: 'complete' });
      try {
        localStorage.setItem(CHAT_CACHE_KEY, JSON.stringify({ chat, messages }));
      } catch {}
    } catch (err) {
      // Make the drainer exit so it's not spinning in the background.
      streamFinished = true;
      asstWrap.innerHTML = `<span class="msg-error">${escapeHtml(err.message || String(err))}</span>`;
      console.error('Chat send error:', err);
    } finally {
      sending = false;
      els.send.disabled = false;
      els.input.disabled = false;
      els.input.focus();
      if (titleFromServer && !els.title.value) els.title.value = titleFromServer;
      if (titleFromServer) loadRail();
    }
  }

  // ---- Research-mode toggles (statutes / case law / LegiScan) ----
  // Per-chat persistent state. The toolbar is in the composer area,
  // toggles are sent in the request body alongside `attachments`,
  // and post-hoc verification badges render inline on the assistant
  // response after streaming completes.
  // First entry is "Federal" — selecting it switches research to
  // federal-only mode (U.S. Code, SCOTUS, all circuits, Congress).
  // For every state below, federal sources are ALWAYS included
  // alongside the state-specific sources.
  const US_STATES = [
    ['US','— Federal (U.S. only) —'],
    ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],
    ['CA','California'],['CO','Colorado'],['CT','Connecticut'],['DE','Delaware'],
    ['DC','District of Columbia'],['FL','Florida'],['GA','Georgia'],['HI','Hawaii'],
    ['ID','Idaho'],['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],
    ['KY','Kentucky'],['LA','Louisiana'],['ME','Maine'],['MD','Maryland'],
    ['MA','Massachusetts'],['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],
    ['MO','Missouri'],['MT','Montana'],['NE','Nebraska'],['NV','Nevada'],
    ['NH','New Hampshire'],['NJ','New Jersey'],['NM','New Mexico'],['NY','New York'],
    ['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
    ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],
    ['SD','South Dakota'],['TN','Tennessee'],['TX','Texas'],['UT','Utah'],
    ['VT','Vermont'],['VA','Virginia'],['WA','Washington'],['WV','West Virginia'],
    ['WI','Wisconsin'],['WY','Wyoming'],
  ];
  const lawEls = {
    bar: document.getElementById('research-bar'),
    state: document.getElementById('toggle-state'),
    stateLabel: document.querySelector('#research-bar .research-state-label'),
    stateStatutes:   document.getElementById('toggle-state-statutes'),
    federalStatutes: document.getElementById('toggle-federal-statutes'),
    stateCaselaw:    document.getElementById('toggle-state-caselaw'),
    federalCaselaw:  document.getElementById('toggle-federal-caselaw'),
    stateBills:      document.getElementById('toggle-state-bills'),
    federalBills:    document.getElementById('toggle-federal-bills'),
    privacy:         document.getElementById('toggle-privacy'),
    vault:           document.getElementById('toggle-vault'),
    status: document.getElementById('research-status'),
  };

  // ── Custom tooltip for the research bar ───────────────────────────
  // Native title="" tooltips are an OS-styled rectangle with no
  // wrapping, no styling, and a long delay. We replace them with a
  // styled bubble that uses data-tip for content (HTML allowed).
  (() => {
    const bar = document.getElementById('research-bar');
    if (!bar) return;
    let tipEl = document.getElementById('research-tip');
    if (!tipEl) {
      tipEl = document.createElement('div');
      tipEl.id = 'research-tip';
      tipEl.className = 'research-tip';
      tipEl.setAttribute('role', 'tooltip');
      document.body.appendChild(tipEl);
    }
    let hideTimer = null;
    function showTip(target) {
      const html = target.getAttribute('data-tip');
      if (!html) return;
      if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
      tipEl.innerHTML = html;
      tipEl.classList.add('is-visible');
      // Position above the target, centered horizontally. Clamp to
      // viewport so it never gets clipped on narrow windows.
      const r = target.getBoundingClientRect();
      const tipW = tipEl.offsetWidth;
      const tipH = tipEl.offsetHeight;
      const margin = 8;
      let left = r.left + r.width / 2 - tipW / 2;
      left = Math.max(margin, Math.min(left, window.innerWidth - tipW - margin));
      let top = r.top - tipH - 10;
      let placement = 'top';
      if (top < margin) {
        top = r.bottom + 10;
        placement = 'bottom';
      }
      tipEl.style.left = `${Math.round(left)}px`;
      tipEl.style.top = `${Math.round(top)}px`;
      tipEl.dataset.placement = placement;
      // Position the arrow to point at the center of the target
      const arrowX = r.left + r.width / 2 - left;
      tipEl.style.setProperty('--tip-arrow-x', `${Math.round(arrowX)}px`);
    }
    function hideTip() {
      if (hideTimer) clearTimeout(hideTimer);
      hideTimer = setTimeout(() => { tipEl.classList.remove('is-visible'); }, 80);
    }
    bar.addEventListener('mouseover', (e) => {
      const t = e.target.closest('[data-tip]');
      if (t && bar.contains(t)) showTip(t);
    });
    bar.addEventListener('mouseout', (e) => {
      const t = e.target.closest('[data-tip]');
      if (t && bar.contains(t)) hideTip();
    });
    bar.addEventListener('focusin', (e) => {
      const t = e.target.closest('[data-tip]');
      if (t && bar.contains(t)) showTip(t);
    });
    bar.addEventListener('focusout', (e) => {
      const t = e.target.closest('[data-tip]');
      if (t && bar.contains(t)) hideTip();
    });
  })();
  // Populate the state dropdown
  if (lawEls.state && !lawEls.state.options.length) {
    lawEls.state.innerHTML = US_STATES
      .map(([code, name]) => `<option value="${code}">${escapeHtml(name)}</option>`)
      .join('');
    lawEls.state.value = 'FL';
  }
  let lawSettings = {
    state: 'FL',
    state_statutes_enabled: false,
    federal_statutes_enabled: false,
    state_caselaw_enabled: false,
    federal_caselaw_enabled: false,
    state_bills_enabled: false,
    federal_bills_enabled: false,
    privacy_enabled: false,
    // Vault toggle. true = use vault for this chat. false = skip.
    // null = follow the user's global vault_auto_use_in_chats default.
    vault_enabled: null,
  };
  function anyStateToggleOn() {
    return lawSettings.state_statutes_enabled || lawSettings.state_caselaw_enabled || lawSettings.state_bills_enabled;
  }
  function anyToggleOn() {
    return lawSettings.state_statutes_enabled || lawSettings.federal_statutes_enabled
        || lawSettings.state_caselaw_enabled  || lawSettings.federal_caselaw_enabled
        || lawSettings.state_bills_enabled    || lawSettings.federal_bills_enabled;
  }
  function applyResearchUI() {
    // The State picker is only relevant when at least one *State*
    // toggle is on. Federal toggles don't read the state.
    const showState = anyStateToggleOn();
    if (lawEls.state) lawEls.state.hidden = !showState;
    if (lawEls.stateLabel) lawEls.stateLabel.hidden = !showState;
    // Show/hide dividers in the same beat so the bar collapses
    // cleanly when nothing's on.
    const anyOn = anyToggleOn();
    lawEls.bar?.querySelectorAll('.research-divider').forEach((div) => {
      div.hidden = !anyOn;
    });
    // Privacy mode: paint the entire chat container amber so the
    // user has constant visual confirmation. Animation runs once
    // when privacy first turns on, then settles into a steady tint.
    const chatMain = document.querySelector('.chat-main');
    if (chatMain) {
      const wasOn = chatMain.classList.contains('is-privacy-on');
      const nowOn = !!lawSettings.privacy_enabled;
      chatMain.classList.toggle('is-privacy-on', nowOn);
      if (nowOn && !wasOn) {
        chatMain.classList.add('is-privacy-just-toggled');
        setTimeout(() => chatMain.classList.remove('is-privacy-just-toggled'), 1400);
      }
    }
  }
  function hydrateLawSettings(persisted) {
    // Backward compat: legacy settings used three combined toggles
    // (statutes_enabled / case_law_enabled / legiscan_enabled). Map
    // each legacy on-state to BOTH state + federal of the same kind
    // since that was the previous behavior.
    const legacyStat = !!persisted?.statutes_enabled;
    const legacyCase = !!persisted?.case_law_enabled;
    const legacyBill = !!persisted?.legiscan_enabled;
    lawSettings = {
      state: (persisted?.state && /^[A-Z]{2}$/.test(persisted.state)) ? persisted.state : 'FL',
      state_statutes_enabled:   persisted?.state_statutes_enabled   !== undefined ? !!persisted.state_statutes_enabled   : legacyStat,
      federal_statutes_enabled: persisted?.federal_statutes_enabled !== undefined ? !!persisted.federal_statutes_enabled : legacyStat,
      state_caselaw_enabled:    persisted?.state_caselaw_enabled    !== undefined ? !!persisted.state_caselaw_enabled    : legacyCase,
      federal_caselaw_enabled:  persisted?.federal_caselaw_enabled  !== undefined ? !!persisted.federal_caselaw_enabled  : legacyCase,
      state_bills_enabled:      persisted?.state_bills_enabled      !== undefined ? !!persisted.state_bills_enabled      : legacyBill,
      federal_bills_enabled:    persisted?.federal_bills_enabled    !== undefined ? !!persisted.federal_bills_enabled    : legacyBill,
      privacy_enabled:          !!persisted?.privacy_enabled,
      // vault_enabled: null = default (use the user's global pref)
      // true/false = explicit per-chat override
      vault_enabled: typeof persisted?.vault_enabled === 'boolean' ? persisted.vault_enabled : null,
    };
    if (lawEls.state)           lawEls.state.value = lawSettings.state;
    if (lawEls.stateStatutes)   lawEls.stateStatutes.checked = lawSettings.state_statutes_enabled;
    if (lawEls.federalStatutes) lawEls.federalStatutes.checked = lawSettings.federal_statutes_enabled;
    if (lawEls.stateCaselaw)    lawEls.stateCaselaw.checked = lawSettings.state_caselaw_enabled;
    if (lawEls.federalCaselaw)  lawEls.federalCaselaw.checked = lawSettings.federal_caselaw_enabled;
    if (lawEls.stateBills)      lawEls.stateBills.checked = lawSettings.state_bills_enabled;
    if (lawEls.federalBills)    lawEls.federalBills.checked = lawSettings.federal_bills_enabled;
    if (lawEls.privacy)         lawEls.privacy.checked = lawSettings.privacy_enabled;
    if (lawEls.vault) {
      // For UI: null defaults to checked (since user-level default is
      // ON). Once the user clicks, it becomes an explicit boolean.
      lawEls.vault.checked = lawSettings.vault_enabled !== false;
    }
    applyResearchUI();
    refreshLawStatusPill();
  }
  function refreshLawStatusPill() {
    if (!lawEls.status) return;
    const st = lawSettings.state;
    const parts = [];
    if (lawSettings.state_statutes_enabled)   parts.push(`${st} statutes`);
    if (lawSettings.federal_statutes_enabled) parts.push('U.S. Code');
    if (lawSettings.state_caselaw_enabled)    parts.push(`${st} cases`);
    if (lawSettings.federal_caselaw_enabled)  parts.push('federal cases');
    if (lawSettings.state_bills_enabled)      parts.push(`${st} bills`);
    if (lawSettings.federal_bills_enabled)    parts.push('Congress bills');
    if (lawSettings.privacy_enabled)          parts.unshift('privacy');
    if (!parts.length) {
      lawEls.status.hidden = true;
      lawEls.status.textContent = '';
      lawEls.bar?.classList.remove('is-active');
      lawEls.bar?.classList.remove('is-privacy-on');
    } else {
      lawEls.status.hidden = false;
      lawEls.status.textContent = `Research: ${parts.join(' · ')}`;
      lawEls.bar?.classList.add('is-active');
      lawEls.bar?.classList.toggle('is-privacy-on', lawSettings.privacy_enabled);
    }
  }
  let lawSaveTimer = null;
  function saveLawSettingsDebounced() {
    if (lawSaveTimer) clearTimeout(lawSaveTimer);
    lawSaveTimer = setTimeout(() => {
      fetch('/.netlify/functions/workspace-chats-update', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: chatId, law_settings: lawSettings }),
      }).catch(() => {});
    }, 400);
  }
  function onLawToggleChange() {
    lawSettings = {
      state: lawEls.state?.value || 'FL',
      state_statutes_enabled:   !!lawEls.stateStatutes?.checked,
      federal_statutes_enabled: !!lawEls.federalStatutes?.checked,
      state_caselaw_enabled:    !!lawEls.stateCaselaw?.checked,
      federal_caselaw_enabled:  !!lawEls.federalCaselaw?.checked,
      state_bills_enabled:      !!lawEls.stateBills?.checked,
      federal_bills_enabled:    !!lawEls.federalBills?.checked,
      privacy_enabled:          !!lawEls.privacy?.checked,
      // Vault: explicit boolean override on toggle change. null
      // (the unchecked-by-default state) is only set on hydrate.
      vault_enabled:            !!lawEls.vault?.checked,
    };
    applyResearchUI();
    refreshLawStatusPill();
    saveLawSettingsDebounced();
  }
  [
    lawEls.state, lawEls.stateStatutes, lawEls.federalStatutes,
    lawEls.stateCaselaw, lawEls.federalCaselaw,
    lawEls.stateBills, lawEls.federalBills,
    lawEls.privacy, lawEls.vault,
  ].forEach((el) => el?.addEventListener('change', onLawToggleChange));
  // ---- Verification polling + inline badges ----
  // After an assistant message finishes streaming with research
  // toggles on, we poll workspace-chat-message-get every 2.5s until
  // verification.status === "complete", then inject inline cite
  // badges next to each detected citation in the rendered DOM.
  const STATUS_ICON = {
    verified: '✓',
    secondary: '⚠',
    pending_amendment: '📝',
    amended_enacted: '🔴',
    unverified: '❌',
    pending: '⌛',
  };
  function badgeHTML(cite) {
    const status = cite.status || 'unverified';
    const icon = STATUS_ICON[status] || '·';
    const detail = JSON.stringify({
      kind: cite.kind, status,
      primary_url: cite.primary_url || null,
      amendment_note: cite.amendment_note || null,
      details: cite.details || null,
    }).replace(/"/g, '&quot;');
    return `<sup class="cite-badge cite-${status}" data-cite="${detail}" title="${escapeHtml(cite.amendment_note || status)}">${icon}</sup>`;
  }
  function decorateCitesInElement(el, cites) {
    if (!el || !cites?.length) return;
    let html = el.innerHTML;
    // Sort descending so we modify from the end backwards (string
    // indices won't shift). The cites already have spans in plain
    // text; for HTML we re-find the raw substring once.
    const sorted = [...cites].sort((a, b) => (b.span?.[0] ?? 0) - (a.span?.[0] ?? 0));
    for (const c of sorted) {
      if (!c.raw) continue;
      // Find the LAST occurrence of c.raw in the rendered HTML
      const idx = html.lastIndexOf(c.raw);
      if (idx === -1) continue;
      // Skip if this raw was already wrapped (avoid double-decoration)
      const after = html.slice(idx + c.raw.length, idx + c.raw.length + 30);
      if (after.startsWith('<sup class="cite-badge')) continue;
      html = html.slice(0, idx + c.raw.length) + badgeHTML(c) + html.slice(idx + c.raw.length);
    }
    el.innerHTML = html;
  }
  async function pollVerification(messageId, asstWrap) {
    if (!messageId || !asstWrap) return;
    // Add a "Verifying citations…" pill to the assistant body
    const pillId = 'verify-pill-' + messageId;
    const txtEl = asstWrap.querySelector('.msg-text');
    if (txtEl && !asstWrap.querySelector('#' + pillId)) {
      asstWrap.insertAdjacentHTML('beforeend', `<div id="${pillId}" class="msg-verify-pill">⌛ Verifying citations…</div>`);
    }
    const maxTries = 24;     // 24 × 2.5s = 60s budget
    for (let i = 0; i < maxTries; i++) {
      await new Promise((r) => setTimeout(r, 2500));
      let r, j;
      try {
        r = await fetch(`/.netlify/functions/workspace-chat-message-get?id=${encodeURIComponent(messageId)}`, {
          headers: { Authorization: `Bearer ${accessToken}` },
        });
        j = await r.json();
      } catch { continue; }
      if (!r.ok) continue;
      const v = j.message?.verification;
      if (!v) continue;
      if (v.status === 'complete') {
        if (txtEl) decorateCitesInElement(txtEl, v.cites || []);
        const pill = document.getElementById(pillId);
        if (pill) {
          const cites = v.cites || [];
          const counts = cites.reduce((a, c) => { a[c.status] = (a[c.status] || 0) + 1; return a; }, {});
          const summary = Object.entries(counts).map(([k, n]) => `${STATUS_ICON[k] || '·'}${n}`).join(' ');
          if (!cites.length) {
            pill.outerHTML = '';
          } else {
            // Compact button — click expands a modal listing every
            // verified citation with its source URL, status, and
            // (if any) amendment note.
            const dataAttr = escapeAttr(JSON.stringify(cites));
            pill.outerHTML = `<button type="button" class="msg-verify-pill is-complete msg-verify-clickable" data-cites="${dataAttr}" title="Click for citation details">${summary}<span class="msg-verify-caret">▾</span></button>`;
          }
        }
        return;
      }
      if (v.status === 'error') {
        const pill = document.getElementById(pillId);
        if (pill) pill.outerHTML = '<div class="msg-verify-pill is-error">⚠ Citation check failed</div>';
        return;
      }
    }
    // Timed out
    const pill = document.getElementById(pillId);
    if (pill) pill.outerHTML = '<div class="msg-verify-pill is-timeout">Citation check timed out</div>';
  }
  // ---- Citation popup modal ----
  // Two entry points:
  //   1. Click an inline cite badge in the response → opens modal
  //      scrolled to that specific cite (highlighted).
  //   2. Click the small Citations summary pill below the response
  //      → opens modal with the FULL list of verified citations.
  function openCiteModal(cites, focusIdx) {
    if (!Array.isArray(cites) || !cites.length) return;
    const modal = document.getElementById('cite-modal');
    const body = document.getElementById('cite-modal-body');
    if (!modal || !body) return;
    const STATUS_LABEL = {
      verified: 'Verified — primary authority',
      secondary: 'Verified — secondary source',
      pending_amendment: 'Pending amendment (still good law)',
      amended_enacted: 'AMENDED by enacted bill — re-verify',
      unverified: 'Could not verify',
      pending: 'Verification in flight',
    };
    body.innerHTML = cites.map((c, i) => {
      const icon = STATUS_ICON[c.status] || '·';
      const statusLabel = STATUS_LABEL[c.status] || c.status || 'unknown';
      const focusCls = (focusIdx != null && i === focusIdx) ? ' is-focus' : '';
      const url = c.primary_url || '';
      const urlHost = url ? (() => { try { return new URL(url).hostname.replace(/^www\./, ''); } catch { return url; } })() : '';
      return `<div class="cite-modal-row cite-modal-row-${c.status}${focusCls}" data-idx="${i}">
        <div class="cite-modal-icon">${icon}</div>
        <div class="cite-modal-content">
          <div class="cite-modal-raw">${escapeHtml(c.raw || '')}</div>
          <div class="cite-modal-status">${escapeHtml(statusLabel)}${c.kind ? ` · ${escapeHtml(c.kind)}` : ''}</div>
          ${c.amendment_note ? `<div class="cite-modal-note">${escapeHtml(c.amendment_note)}</div>` : ''}
          ${url ? `<a href="${escapeAttr(url)}" target="_blank" rel="noopener" class="cite-modal-link">${escapeHtml(urlHost)} ↗</a>` : ''}
        </div>
      </div>`;
    }).join('');
    modal.hidden = false;
    document.body.classList.add('cite-modal-open');
    // Scroll the focused row into view
    if (focusIdx != null) {
      const row = body.querySelector(`[data-idx="${focusIdx}"]`);
      if (row) row.scrollIntoView({ block: 'center', behavior: 'instant' });
    } else {
      body.scrollTop = 0;
    }
  }
  function closeCiteModal() {
    const modal = document.getElementById('cite-modal');
    if (modal) modal.hidden = true;
    document.body.classList.remove('cite-modal-open');
  }

  // Inline cite badge → open modal focused on this cite
  document.addEventListener('click', (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    const badge = t.closest('.cite-badge');
    if (!badge) return;
    e.preventDefault();
    // The badge has a data-cite single-cite blob, but to show the
    // full list we need the parent message's full cite array. We
    // get that from the verify-pill button's data-cites attribute.
    const bubble = badge.closest('.msg.asst');
    const pill = bubble?.querySelector('.msg-verify-pill[data-cites]');
    let allCites = null;
    if (pill) {
      try { allCites = JSON.parse((pill.getAttribute('data-cites') || '').replace(/&quot;/g, '"').replace(/&#39;/g, "'")); } catch {}
    }
    if (Array.isArray(allCites) && allCites.length) {
      // Find the index of this badge's cite in the full list by raw
      // text match, so we can scroll to it in the modal.
      let detail;
      try { detail = JSON.parse((badge.getAttribute('data-cite') || '{}').replace(/&quot;/g, '"')); } catch {}
      const idx = allCites.findIndex((c) => c.raw === detail?.raw && c.status === detail?.status);
      openCiteModal(allCites, idx >= 0 ? idx : null);
    } else {
      // Fallback: badge-only popup with the single cite's data
      let detail;
      try { detail = JSON.parse((badge.getAttribute('data-cite') || '{}').replace(/&quot;/g, '"')); } catch { detail = {}; }
      openCiteModal([{ ...detail, raw: detail.raw || '(citation)' }], 0);
    }
  });

  // Citations summary pill → open modal with full list
  document.addEventListener('click', (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    const pill = t.closest('.msg-verify-pill.msg-verify-clickable');
    if (!pill) return;
    e.preventDefault();
    let cites = null;
    try { cites = JSON.parse((pill.getAttribute('data-cites') || '').replace(/&quot;/g, '"').replace(/&#39;/g, "'")); } catch {}
    if (Array.isArray(cites) && cites.length) openCiteModal(cites, null);
  });

  // Close modal: overlay click, close button, or Escape key
  document.addEventListener('click', (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    if (t.matches('[data-cite-modal-close]') || t.matches('#cite-modal') || t.classList.contains('cite-modal-overlay')) {
      e.preventDefault();
      closeCiteModal();
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeCiteModal();
      closePrivacyModal();
    }
  });

  // Privacy mode info modal — open/close handlers.
  function openPrivacyModal() {
    const modal = document.getElementById('privacy-modal');
    if (!modal) return;
    modal.hidden = false;
    document.body.classList.add('cite-modal-open');
  }
  function closePrivacyModal() {
    const modal = document.getElementById('privacy-modal');
    if (modal) modal.hidden = true;
    document.body.classList.remove('cite-modal-open');
  }
  document.addEventListener('click', (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    // Lock icon in the chat header → open the policy modal.
    // We stop propagation so the surrounding <label> doesn't toggle
    // the checkbox state when the user just wants info.
    if (t.classList.contains('chat-privacy-toggle-lock')) {
      e.preventDefault();
      e.stopPropagation();
      openPrivacyModal();
      return;
    }
    if (t.matches('[data-privacy-modal-close]') || (t.closest('#privacy-modal') && t.classList.contains('cite-modal-overlay'))) {
      e.preventDefault();
      closePrivacyModal();
    }
  });

  // Copy-message button. Works on BOTH user and assistant bubbles —
  // walks up to the closest .msg, reads the raw text from data-src,
  // writes it to the clipboard, and shows a brief "Copied!" pulse.
  document.addEventListener('click', async (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    const btn = t.closest('.msg-copy');
    if (!btn) return;
    e.preventDefault();
    const bubble = btn.closest('.msg');
    if (!bubble) return;
    const src = bubble.getAttribute('data-src') || '';
    if (!src) return;
    try {
      await navigator.clipboard.writeText(src);
      const lbl = btn.querySelector('.msg-copy-label');
      if (lbl) {
        const original = lbl.textContent;
        lbl.textContent = 'Copied!';
        btn.classList.add('is-copied');
        setTimeout(() => {
          lbl.textContent = original;
          btn.classList.remove('is-copied');
        }, 1400);
      }
    } catch (err) {
      console.error('Copy failed:', err);
      alert('Could not copy — your browser may need clipboard permission.');
    }
  });

  // ---- Save-entire-conversation-to-Vault button ----
  // Compiles every (user / assistant) message in the current chat into
  // a single markdown transcript and saves it as one Vault item with
  // source_kind='chat'. Capped at MAX_CONVO_SAVE_MSGS to keep the saved
  // item readable and the embedding cost bounded — when the cap is hit
  // we save only the most-recent chunk and tell the user.
  const MAX_CONVO_SAVE_MSGS = 50;        // ~25 turns of back-and-forth
  const MAX_CONVO_SAVE_CHARS = 60_000;   // hard byte cap as a safety net
  const saveConvoBtn = document.getElementById('save-convo-btn');

  function refreshSaveConvoBtnState() {
    if (!saveConvoBtn) return;
    const count = (messages || []).filter((m) => m.role === 'user' || m.role === 'assistant').length;
    saveConvoBtn.disabled = !chat || count === 0;
  }

  // Compute the trimmed message slice that would be saved. Pulled out
  // so both the confirmation modal (preview) and the actual save
  // operation use the same cut.
  function computeConvoSaveSlice() {
    const all = (messages || []).filter((m) => m.role === 'user' || m.role === 'assistant');
    let trimmed = all.slice(-MAX_CONVO_SAVE_MSGS);
    let body = trimmed.map(formatConvoMessage).join('\n\n---\n\n');
    while (body.length > MAX_CONVO_SAVE_CHARS && trimmed.length > 1) {
      trimmed = trimmed.slice(1);
      body = trimmed.map(formatConvoMessage).join('\n\n---\n\n');
    }
    const droppedCount = all.length - trimmed.length;
    return { all, trimmed, body, droppedCount };
  }

  // Step 1: opening the popup. Populates the dynamic note line with the
  // exact message count the user is about to save (and any truncation
  // detail), then reveals the modal.
  function openSaveConvoModal() {
    if (!chat) return;
    const slice = computeConvoSaveSlice();
    if (!slice.all.length) {
      alert('Nothing to save yet — start a conversation first.');
      return;
    }
    const note = document.getElementById('save-convo-note');
    if (note) {
      note.innerHTML = slice.droppedCount > 0
        ? `<strong>This conversation has ${slice.all.length} messages</strong> — only the <strong>${slice.trimmed.length} most recent</strong> will be saved (about ${Math.round(slice.body.length / 1000)}k chars). The earliest ${slice.droppedCount} message${slice.droppedCount === 1 ? '' : 's'} will be omitted so the Vault item stays readable; the saved item will be tagged <code>truncated</code>.`
        : `<strong>${slice.trimmed.length} message${slice.trimmed.length === 1 ? '' : 's'}</strong> will be saved (about ${Math.round(slice.body.length / 1000)}k chars).`;
    }
    const modal = document.getElementById('save-convo-modal');
    if (modal) modal.hidden = false;
  }

  function closeSaveConvoModal() {
    const modal = document.getElementById('save-convo-modal');
    if (modal) modal.hidden = true;
  }

  // Step 2: actually run the save when the user confirms in the modal.
  async function performConvoSave() {
    if (!chat) return;
    closeSaveConvoModal();
    const lbl = saveConvoBtn?.querySelector('span');
    const wasOriginalLabel = lbl?.textContent;
    const { all, trimmed, body, droppedCount } = computeConvoSaveSlice();
    if (!trimmed.length) return;

    const titleSrc = (chat.title && chat.title.trim() && chat.title.trim() !== 'Untitled chat')
      ? chat.title.trim()
      : (trimmed[0]?.content || 'Saved conversation').slice(0, 80);
    saveConvoBtn.disabled = true;
    if (lbl) lbl.textContent = 'Saving…';
    try {
      const r = await fetch('/.netlify/functions/workspace-vault-add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${accessToken}` },
        body: JSON.stringify({
          source_kind: 'chat',
          source_chat_id: chat.id,
          title: titleSrc,
          content: body,
          tags: ['chat', 'conversation', ...(droppedCount > 0 ? ['truncated'] : [])],
          summary: `Conversation transcript — ${trimmed.length} message${trimmed.length === 1 ? '' : 's'}${droppedCount > 0 ? ` (${droppedCount} earlier message${droppedCount === 1 ? '' : 's'} omitted)` : ''}`,
        }),
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Save failed');
      saveConvoBtn.classList.add('is-saved');
      if (lbl) lbl.textContent = 'Saved';
      if (typeof window.siteToast === 'function') {
        window.siteToast(
          droppedCount > 0
            ? `Saved most-recent ${trimmed.length} of ${all.length} messages to your Vault`
            : `Saved ${trimmed.length}-message conversation to your Vault`,
          { kind: 'success' }
        );
      }
      setTimeout(() => {
        saveConvoBtn.classList.remove('is-saved');
        saveConvoBtn.disabled = false;
        if (lbl) lbl.textContent = wasOriginalLabel || 'Save conversation';
      }, 2400);
    } catch (err) {
      saveConvoBtn.disabled = false;
      if (lbl) lbl.textContent = wasOriginalLabel || 'Save conversation';
      alert('Could not save conversation: ' + err.message);
    }
  }

  saveConvoBtn?.addEventListener('click', openSaveConvoModal);
  document.getElementById('save-convo-confirm')?.addEventListener('click', performConvoSave);
  document.querySelectorAll('[data-save-modal-close]').forEach((el) => {
    el.addEventListener('click', closeSaveConvoModal);
  });
  // Esc closes the modal.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const modal = document.getElementById('save-convo-modal');
      if (modal && !modal.hidden) closeSaveConvoModal();
    }
  });

  function formatConvoMessage(m) {
    const ts = m.created_at ? new Date(m.created_at).toLocaleString() : '';
    const who = m.role === 'user' ? '## You' : '## Assistant';
    const head = ts ? `${who}  *(${ts})*` : who;
    return `${head}\n\n${(m.content || '').trim()}`;
  }

  // Save-to-Vault button on assistant message bubbles. Pulls the
  // bubble's raw response text from data-src and POSTs it to
  // workspace-vault-add with source_kind='chat'.
  document.addEventListener('click', async (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    const btn = t.closest('[data-msg-save-vault]');
    if (!btn) return;
    e.preventDefault();
    if (btn.classList.contains('is-saved')) return;
    const bubble = btn.closest('.msg.asst');
    if (!bubble) return;
    const src = bubble.getAttribute('data-src') || '';
    if (!src.trim()) return;
    const titleSrc = src.trim().replace(/\s+/g, ' ').slice(0, 80) || 'Saved chat snippet';
    btn.disabled = true;
    btn.querySelector('span').textContent = 'Saving…';
    try {
      const r = await fetch('/.netlify/functions/workspace-vault-add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${accessToken}` },
        body: JSON.stringify({
          source_kind: 'chat',
          source_chat_id: chatId,
          source_message_id: bubble.getAttribute('data-id') || null,
          title: titleSrc,
          content: src,
          tags: ['chat'],
        }),
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || 'Save failed');
      btn.classList.add('is-saved');
      btn.querySelector('span').textContent = 'Saved to Vault';
      if (typeof window.siteToast === 'function') {
        window.siteToast('Saved to your Vault', { kind: 'success' });
      }
    } catch (err) {
      btn.disabled = false;
      btn.querySelector('span').textContent = 'Save to Vault';
      alert('Could not save: ' + err.message);
    }
  });

  // ---- Attachment state + library picker ----
  // attachedDocs: array of { id, filename } currently attached to the
  // next message. Cleared after sendMessage. The chat doesn't yet
  // persist attachments per-message; that's a Phase 2.5 enhancement.
  let attachedDocs = [];

  function renderAttachmentChips() {
    if (attachedDocs.length === 0) {
      els.attachments.innerHTML = '';
      return;
    }
    els.attachments.innerHTML = attachedDocs.map((a) => `
      <span class="composer-chip" data-attach-id="${a.id}">
        <span class="composer-chip-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 1 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 1 1-2.83-2.83l8.49-8.48"/></svg></span>
        ${escapeHtml(a.filename)}
        <button type="button" class="composer-chip-x" data-detach="${a.id}" aria-label="Remove">×</button>
      </span>
    `).join('');
    els.attachments.querySelectorAll('[data-detach]').forEach((b) => {
      b.addEventListener('click', () => {
        const id = b.dataset.detach;
        attachedDocs = attachedDocs.filter((a) => a.id !== id);
        renderAttachmentChips();
      });
    });
  }

  let libraryDocs = [];
  let pickedIds = new Set();
  function renderLibraryList(docs) {
    if (!docs?.length) {
      els.attachList.innerHTML = '<div class="ws-empty">No documents in your library yet. Upload some at <a href="/workspace/library/">/workspace/library/</a>.</div>';
      els.attachConfirm.disabled = true;
      return;
    }
    els.attachList.innerHTML = docs.map((d) => {
      const sel = pickedIds.has(d.id) ? ' is-selected' : '';
      const status = d.current_version?.extraction_status || 'unknown';
      const meta = status === 'done' ? `${(d.current_version?.extracted_chars || 0).toLocaleString()} chars`
                : status === 'pending' || status === 'running' ? 'extracting…'
                : 'no preview';
      return `<div class="attach-item${sel}" data-pick="${d.id}" data-name="${escapeHtml(d.filename)}">
        <span class="attach-item-name">${escapeHtml(d.filename)}</span>
        <span class="attach-item-meta">${escapeHtml(meta)}</span>
      </div>`;
    }).join('');
    els.attachList.querySelectorAll('[data-pick]').forEach((row) => {
      row.addEventListener('click', () => {
        const id = row.dataset.pick;
        if (pickedIds.has(id)) pickedIds.delete(id);
        else pickedIds.add(id);
        row.classList.toggle('is-selected');
        els.attachConfirm.disabled = pickedIds.size === 0;
      });
    });
    els.attachConfirm.disabled = pickedIds.size === 0;
  }

  async function loadLibraryForPicker(query = '') {
    const r = await fetch('/.netlify/functions/workspace-library-list' + (query ? `?q=${encodeURIComponent(query)}` : ''), {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    if (!r.ok) {
      els.attachList.innerHTML = `<div class="ws-empty">${escapeHtml(j.error || 'Failed to load')}</div>`;
      return;
    }
    libraryDocs = j.documents || [];
    renderLibraryList(libraryDocs);
  }

  function openAttachModal() {
    pickedIds = new Set(attachedDocs.map((a) => a.id));
    els.attachModal.hidden = false;
    els.attachSearch.value = '';
    loadLibraryForPicker();
    els.attachSearch.focus();
  }
  function closeAttachModal() {
    els.attachModal.hidden = true;
  }
  els.paperclip.addEventListener('click', openAttachModal);
  els.attachClose.addEventListener('click', closeAttachModal);
  els.attachModal.addEventListener('click', (e) => {
    if (e.target === els.attachModal) closeAttachModal();
  });
  let attachSearchTimer = null;
  els.attachSearch.addEventListener('input', () => {
    if (attachSearchTimer) clearTimeout(attachSearchTimer);
    attachSearchTimer = setTimeout(() => loadLibraryForPicker(els.attachSearch.value.trim()), 200);
  });
  els.attachConfirm.addEventListener('click', () => {
    attachedDocs = libraryDocs
      .filter((d) => pickedIds.has(d.id))
      .map((d) => ({ id: d.id, filename: d.filename }));
    renderAttachmentChips();
    closeAttachModal();
  });

  // ---- Upload-from-modal flow ----
  // User picks a file inside the attach modal → we upload it directly
  // to Supabase Storage (just like the library page does) → call
  // workspace-library-register to create DB rows + extract text →
  // auto-select the new doc so the user can hit "Attach selected"
  // immediately without browsing back through the list.
  async function uploadFromModal(file) {
    const docId = crypto.randomUUID();
    const versionId = crypto.randomUUID();
    const ext = file.name.split('.').pop().toLowerCase().replace(/[^a-z0-9]/g, '') || 'bin';
    const storagePath = `${session.user.id}/${docId}/${versionId}.${ext}`;

    const tempId = 'modal-up-' + Date.now() + '-' + Math.random().toString(36).slice(2, 6);
    els.attachUploadProgress.insertAdjacentHTML('beforeend', `
      <div class="lib-upload" data-temp="${tempId}">
        <span class="lib-upload-name">${escapeHtml(file.name)}</span>
        <span class="lib-upload-status">Uploading…</span>
      </div>`);
    const row = els.attachUploadProgress.querySelector(`[data-temp="${tempId}"]`);

    try {
      const { error: upErr } = await supabase.storage
        .from('library')
        .upload(storagePath, file, { contentType: file.type, upsert: false });
      if (upErr) throw new Error(`Storage upload: ${upErr.message}`);

      row.querySelector('.lib-upload-status').textContent = 'Extracting text…';

      const r = await fetch('/.netlify/functions/workspace-library-register', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          filename: file.name,
          original_filename: file.name,
          file_type: file.type || 'application/octet-stream',
          size_bytes: file.size,
          storage_path: storagePath,
        }),
      });
      const j = await r.json();
      if (!r.ok) throw new Error(j.error || `HTTP ${r.status}`);

      row.classList.add('is-done');
      row.querySelector('.lib-upload-status').textContent = 'Attached';
      setTimeout(() => row.remove(), 2000);

      // Push the new doc to the library list (top) so future picker
      // opens show it, and auto-attach it to the composer NOW so
      // the user gets a chip immediately without having to click
      // "Attach selected." That step was being missed — users
      // uploaded the file, closed the modal, and wondered why
      // nothing was attached.
      const newDoc = {
        id: j.document.id,
        filename: j.document.filename,
        file_type: j.document.file_type,
        size_bytes: j.document.size_bytes,
        updated_at: j.document.updated_at,
        current_version: {
          id: j.version.id,
          extraction_status: j.version.extraction_status,
          extracted_chars: j.version.extracted_chars,
        },
      };
      libraryDocs = [newDoc, ...libraryDocs.filter((d) => d.id !== newDoc.id)];
      pickedIds.add(newDoc.id);
      renderLibraryList(libraryDocs);
      // Auto-attach + close modal — single-click upload UX.
      const alreadyAttached = attachedDocs.some((d) => d.id === newDoc.id);
      if (!alreadyAttached) {
        attachedDocs.push({ id: newDoc.id, filename: newDoc.filename });
        renderAttachmentChips();
      }
      // Toast so the user has positive feedback even if they're
      // looking elsewhere on the page when the modal auto-closes.
      if (typeof window.siteToast === 'function') {
        window.siteToast(`"${newDoc.filename}" attached to next message`, { kind: 'success', duration: 2400 });
      }
      // Close the modal after a short pause so the user can see the
      // "Attached" status flash before it disappears. Skip the
      // close if the user opened additional uploads in this session.
      setTimeout(() => {
        if (els.attachUploadProgress.querySelectorAll('.lib-upload:not(.is-done)').length === 0) {
          closeAttachModal();
        }
      }, 600);
    } catch (err) {
      row.classList.add('is-error');
      row.querySelector('.lib-upload-status').textContent = `Failed: ${err.message}`;
    }
  }

  els.attachUploadBtn.addEventListener('click', () => els.attachUploadInput.click());
  els.attachUploadInput.addEventListener('change', async (e) => {
    const files = Array.from(e.target.files || []);
    e.target.value = '';
    for (const f of files) await uploadFromModal(f);
  });

  // ---- Drag-and-drop file upload onto the composer ----
  // Drop a contract / brief / image directly onto the chat input
  // and it auto-uploads + auto-attaches. No modal needed. The
  // existing uploadFromModal handles the heavy lifting; the modal's
  // upload-progress div doesn't have to be visible — its row just
  // stays hidden in the DOM during drop-uploads.
  const composerEl = document.querySelector('.chat-composer');
  let _composerDragDepth = 0;   // counter to handle nested dragenter/leave correctly
  if (composerEl) {
    composerEl.addEventListener('dragenter', (e) => {
      // Only handle drops that carry files
      if (!e.dataTransfer?.types?.includes('Files')) return;
      e.preventDefault();
      e.stopPropagation();
      _composerDragDepth++;
      composerEl.classList.add('is-drop-target');
    });
    composerEl.addEventListener('dragover', (e) => {
      if (!e.dataTransfer?.types?.includes('Files')) return;
      e.preventDefault();
      e.stopPropagation();
      e.dataTransfer.dropEffect = 'copy';
    });
    composerEl.addEventListener('dragleave', (e) => {
      if (!e.dataTransfer?.types?.includes('Files')) return;
      e.preventDefault();
      e.stopPropagation();
      _composerDragDepth = Math.max(0, _composerDragDepth - 1);
      if (_composerDragDepth === 0) composerEl.classList.remove('is-drop-target');
    });
    composerEl.addEventListener('drop', async (e) => {
      if (!e.dataTransfer?.files?.length) return;
      e.preventDefault();
      e.stopPropagation();
      _composerDragDepth = 0;
      composerEl.classList.remove('is-drop-target');
      const files = Array.from(e.dataTransfer.files);
      // Make sure the modal exists in the DOM so uploadFromModal's
      // progress-row insert doesn't crash when no modal is visible.
      // The modal element is always rendered (just hidden); we just
      // need it to be queryable.
      for (const f of files) await uploadFromModal(f);
    });
  }

  // ---- Paste-file support ----
  // Cmd+V / Ctrl+V on the chat input with a file in the clipboard
  // (e.g. screenshot, copy-pasted PDF from explorer) auto-uploads.
  // Doesn't intercept regular text pastes.
  const composerInput = document.getElementById('composer-input');
  if (composerInput) {
    composerInput.addEventListener('paste', async (e) => {
      const items = e.clipboardData?.items;
      if (!items) return;
      const files = [];
      for (const item of items) {
        if (item.kind === 'file') {
          const f = item.getAsFile();
          if (f) files.push(f);
        }
      }
      if (files.length === 0) return;   // text paste — let it through
      e.preventDefault();
      for (const f of files) await uploadFromModal(f);
    });
  }

  // ---- Project picker pill ----
  // Click the pill in the chat header to assign the chat to a project,
  // remove it from one, or create a new project inline. Same pattern
  // as Notion / Linear's quick-pick popovers.
  const pill = document.getElementById('chat-project-pill');
  const pillLabel = document.getElementById('chat-project-pill-label');
  const popover = document.getElementById('chat-project-popover');
  let cachedProjects = null;

  function setPillLabel(projectName) {
    pillLabel.textContent = projectName ? projectName : 'No project';
    pill.classList.toggle('has-project', !!projectName);
  }
  // Fill the pill once chat metadata loads (loadChat sets `chat`)
  function syncPillFromChat() {
    if (!chat) return;
    if (chat.project_id && chat.project_name) {
      setPillLabel(chat.project_name);
    } else if (chat.project_id) {
      setPillLabel('Loading project…');
      // We don't carry project_name in the chat row; fetch the name once.
      fetch('/.netlify/functions/workspace-projects-list', { headers: { Authorization: `Bearer ${accessToken}` } })
        .then((r) => r.json())
        .then((j) => {
          cachedProjects = j.projects || [];
          const found = cachedProjects.find((p) => p.id === chat.project_id);
          setPillLabel(found ? found.name : 'Project (deleted)');
        })
        .catch(() => setPillLabel('Project'));
    } else {
      setPillLabel(null);
    }
  }

  async function openPopover() {
    // Position popover under the pill. CSS uses position:fixed, so coords
    // are viewport-relative — no need to add window.scroll{X,Y}.
    const rect = pill.getBoundingClientRect();
    popover.style.top = (rect.bottom + 6) + 'px';
    popover.style.left = rect.left + 'px';
    popover.hidden = false;

    // Fetch projects fresh
    popover.innerHTML = '<div class="cpop-loading">Loading projects…</div>';
    const r = await fetch('/.netlify/functions/workspace-projects-list', {
      headers: { Authorization: `Bearer ${accessToken}` },
    });
    const j = await r.json();
    cachedProjects = j.projects || [];
    renderPopover();
  }

  function renderPopover() {
    const projects = cachedProjects || [];
    const inAProject = !!chat?.project_id;
    const lines = [
      `<input type="text" class="cpop-search" placeholder="Filter projects…" />`,
      `<div class="cpop-list">`,
      ...projects.map((p) => {
        const sel = p.id === chat?.project_id ? ' is-current' : '';
        return `<button type="button" class="cpop-item${sel}" data-pick="${p.id}" data-name="${escapeHtml(p.name)}">${escapeHtml(p.name)}${sel ? ' ✓' : ''}</button>`;
      }),
      projects.length === 0 ? `<div class="cpop-empty">No projects yet.</div>` : '',
      `</div>`,
      `<div class="cpop-divider"></div>`,
      inAProject ? `<button type="button" class="cpop-action" data-action="remove">Remove from project</button>` : '',
      `<button type="button" class="cpop-action cpop-new" data-action="new">+ New project…</button>`,
    ];
    popover.innerHTML = lines.filter(Boolean).join('');
    const search = popover.querySelector('.cpop-search');
    search?.focus();
    search?.addEventListener('input', () => {
      const q = search.value.toLowerCase();
      popover.querySelectorAll('[data-pick]').forEach((b) => {
        const name = (b.dataset.name || '').toLowerCase();
        b.style.display = name.includes(q) ? '' : 'none';
      });
    });
    popover.querySelectorAll('[data-pick]').forEach((b) => {
      b.addEventListener('click', () => moveToProject(b.dataset.pick, b.dataset.name));
    });
    popover.querySelector('[data-action="remove"]')?.addEventListener('click', () => moveToProject(null, null));
    popover.querySelector('[data-action="new"]')?.addEventListener('click', openInlineNewProject);
  }

  function closePopover() { popover.hidden = true; }

  async function moveToProject(projectId, projectName) {
    closePopover();
    setPillLabel(projectId ? (projectName || 'Loading…') : null);
    const r = await fetch('/.netlify/functions/workspace-chats-update', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: chat.id, project_id: projectId }),
    });
    if (!r.ok) {
      const j = await r.json().catch(() => ({}));
      alert('Move failed: ' + (j.error || 'unknown'));
      return;
    }
    if (chat) chat.project_id = projectId;
    // Bust the rail cache so the workspace landing reflects the move.
    try { localStorage.removeItem(RAIL_CACHE_KEY); } catch {}
  }

  function openInlineNewProject() {
    popover.innerHTML = `
      <div class="cpop-newform">
        <div class="cpop-label">Project name</div>
        <input type="text" class="cpop-input" placeholder="Acme Corp acquisition" maxlength="200" />
        <div class="cpop-actions">
          <button type="button" class="cpop-cancel">Cancel</button>
          <button type="button" class="cpop-create">Create &amp; assign</button>
        </div>
      </div>`;
    const input = popover.querySelector('.cpop-input');
    input.focus();
    popover.querySelector('.cpop-cancel').addEventListener('click', renderPopover);
    const create = async () => {
      const name = input.value.trim();
      if (!name) { input.focus(); return; }
      popover.querySelector('.cpop-create').disabled = true;
      const r = await fetch('/.netlify/functions/workspace-projects-create', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      const j = await r.json();
      if (!r.ok) { alert('Failed: ' + (j.error || 'unknown')); return; }
      cachedProjects = [j.project, ...(cachedProjects || [])];
      await moveToProject(j.project.id, j.project.name);
    };
    popover.querySelector('.cpop-create').addEventListener('click', create);
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') create(); });
  }

  pill.addEventListener('click', (e) => {
    e.stopPropagation();
    if (popover.hidden) openPopover();
    else closePopover();
  });
  document.addEventListener('click', (e) => {
    if (!popover.hidden && !popover.contains(e.target)) closePopover();
  });

  // ---- Resizable sidebar ----
  // Drag the slim handle between sidebar and chat to widen or shrink
  // the sidebar. Layout uses a CSS variable --rail-width on the chat
  // shell, so the chat area auto-fills the rest. Persists across
  // reloads in localStorage.
  const RAIL_KEY = 'workspace.rail.width';
  const RAIL_MIN = 160;
  const RAIL_MAX = 480;
  const RAIL_DEFAULT = 240;
  const shellEl = document.querySelector('.chat-shell');
  const resizeEl = document.getElementById('rail-resize');
  function applyRail(px) {
    const clamped = Math.min(RAIL_MAX, Math.max(RAIL_MIN, Math.round(px)));
    shellEl.style.setProperty('--rail-width', clamped + 'px');
    return clamped;
  }
  applyRail(parseInt(localStorage.getItem(RAIL_KEY) || RAIL_DEFAULT, 10) || RAIL_DEFAULT);
  let dragging = false;
  resizeEl.addEventListener('mousedown', (e) => {
    e.preventDefault();
    dragging = true;
    document.body.style.cursor = 'col-resize';
    document.body.style.userSelect = 'none';
  });
  window.addEventListener('mousemove', (e) => {
    if (!dragging) return;
    // Sidebar starts at the left edge of the chat-shell, which itself
    // is centered with max-width 1400. Offset accordingly.
    const rect = shellEl.getBoundingClientRect();
    const desired = e.clientX - rect.left;
    applyRail(desired);
  });
  window.addEventListener('mouseup', () => {
    if (!dragging) return;
    dragging = false;
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
    const current = shellEl.style.getPropertyValue('--rail-width').replace('px', '');
    try { localStorage.setItem(RAIL_KEY, current); } catch {}
  });
  // Keyboard nudge: Left/Right when handle is focused.
  resizeEl.addEventListener('keydown', (e) => {
    if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
    e.preventDefault();
    const delta = e.key === 'ArrowRight' ? 16 : -16;
    const cur = parseInt(shellEl.style.getPropertyValue('--rail-width') || RAIL_DEFAULT, 10);
    const next = applyRail(cur + delta);
    try { localStorage.setItem(RAIL_KEY, next); } catch {}
  });

  // ---- Resizable chat header ----
  // Three modes the user toggles by dragging the handle vertically:
  //   'full'    — natural height, all rows visible (default)
  //   'meta'    — meta strip hidden but anchors + title + buttons stay
  //   'compact' — ONLY title + action buttons (model picker, Privacy,
  //               Deep Think, Save, Vision badge) — kicker/meta/anchors
  //               all hidden, padding tightens, title font shrinks
  //
  // Modes change as the user drags up/down. Buttons stay clickable in
  // every mode — the goal is to give the user more vertical chat-stream
  // space without ever hiding the action bar. Double-click resets.
  // Persists in localStorage.
  const HEAD_KEY = 'workspace.chat.head-mode';
  const headEl = document.querySelector('.chat-head');
  const headResizeEl = document.getElementById('chat-head-resize');
  function applyHeadMode(mode) {
    if (!headEl) return;
    if (mode === 'compact' || mode === 'meta') {
      headEl.setAttribute('data-compact', mode === 'compact' ? '1' : 'meta');
    } else {
      headEl.removeAttribute('data-compact');
    }
  }
  // Restore persisted mode on load.
  try {
    const saved = localStorage.getItem(HEAD_KEY);
    if (saved === 'compact' || saved === 'meta') applyHeadMode(saved);
  } catch {}
  // The two threshold heights (in px from header top) that gate
  // mode transitions during drag. Pulled from natural header height
  // measured at drag-start so they stay proportional even if the
  // anchor strip / meta line are taller than usual.
  let headDragging = false;
  let dragNaturalHeight = 0;
  if (headResizeEl) {
    headResizeEl.addEventListener('mousedown', (e) => {
      e.preventDefault();
      headDragging = true;
      headResizeEl.classList.add('is-dragging');
      document.body.style.cursor = 'ns-resize';
      document.body.style.userSelect = 'none';
      // Force full mode while dragging so the user sees the
      // full natural extent and can choose where to cut.
      const wasMode = headEl?.getAttribute('data-compact') || '';
      headEl?.removeAttribute('data-compact');
      dragNaturalHeight = headEl ? headEl.getBoundingClientRect().height : 0;
      // Restore prior mode synchronously so visual state is intact
      // until the drag actually crosses a threshold.
      if (wasMode === '1') headEl?.setAttribute('data-compact', '1');
      else if (wasMode === 'meta') headEl?.setAttribute('data-compact', 'meta');
    });
    headResizeEl.addEventListener('dblclick', () => {
      applyHeadMode('full');
      try { localStorage.setItem(HEAD_KEY, 'full'); } catch {}
    });
    headResizeEl.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowUp' && e.key !== 'ArrowDown') return;
      e.preventDefault();
      const cur = headEl?.getAttribute('data-compact') || 'full';
      // Cycle: full → meta → compact (ArrowUp shrinks; ArrowDown grows)
      const order = ['full', 'meta', 'compact'];
      let idx = cur === '1' ? 2 : (cur === 'meta' ? 1 : 0);
      idx += e.key === 'ArrowUp' ? 1 : -1;
      idx = Math.max(0, Math.min(order.length - 1, idx));
      const next = order[idx];
      applyHeadMode(next);
      try { localStorage.setItem(HEAD_KEY, next); } catch {}
    });
  }
  window.addEventListener('mousemove', (e) => {
    if (!headDragging || !headEl) return;
    const rect = headEl.getBoundingClientRect();
    const headerTop = rect.top;
    const desiredHeight = e.clientY - headerTop;
    // Two thresholds based on the natural (full-mode) height:
    //   below 50% of natural → compact mode
    //   below 75% of natural → meta-hidden mode
    //   else → full
    const nat = dragNaturalHeight || rect.height || 100;
    let mode;
    if (desiredHeight < nat * 0.5) mode = 'compact';
    else if (desiredHeight < nat * 0.78) mode = 'meta';
    else mode = 'full';
    applyHeadMode(mode);
  });
  window.addEventListener('mouseup', () => {
    if (!headDragging) return;
    headDragging = false;
    if (headResizeEl) headResizeEl.classList.remove('is-dragging');
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
    if (headEl) {
      const mode = headEl.getAttribute('data-compact') === '1' ? 'compact'
        : headEl.getAttribute('data-compact') === 'meta' ? 'meta'
        : 'full';
      try { localStorage.setItem(HEAD_KEY, mode); } catch {}
    }
  });

  // ---- Auto-hiding top nav ----
  // The shared /nav-autohide.js script (loaded in <head>) handles
  // inactivity-based reveal/hide for the top nav across all pages.
  // No inline JS needed here anymore — just remove the old chevron
  // toggle which auto-hide replaces.
  document.getElementById('nav-toggle')?.remove();

  els.composer.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = els.input.value;
    const attachmentIds = attachedDocs.map((a) => a.id);
    const wasAttached = attachedDocs.slice();
    // Guard: require either some text OR at least one attachment.
    if (!text.trim() && attachmentIds.length === 0) {
      return;
    }
    // Empty message text is allowed when at least one attachment is
    // present — the user bubble will render with just the chip and
    // no text body. The model still receives the attachment content
    // in its system prompt; it sees an empty user turn with the
    // attached doc and responds to that.
    const finalText = text.trim();
    els.input.value = '';
    attachedDocs = [];
    renderAttachmentChips();
    sendMessage(finalText, { attachments: attachmentIds, attachmentNames: wasAttached });
  });
  els.input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      els.composer.requestSubmit();
    }
  });
  els.title.addEventListener('change', async () => {
    if (!chat) return;
    const newTitle = els.title.value.trim();
    await fetch('/.netlify/functions/workspace-chats-update', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: chat.id, title: newTitle }),
    });
    loadRail();
  });
  // Deep-think toggle — restore from localStorage on page load,
  // persist on change. Stored under the universal pref key so the
  // dashboard chip / new-chat default can read it the same way as
  // the model preference.
  (function initDeepThink() {
    const cb = document.getElementById('toggle-deep-think');
    if (!cb) return;
    try {
      const saved = localStorage.getItem('workspace.dash.deep-think');
      if (saved === '1' || saved === 'true') cb.checked = true;
    } catch {}
    cb.addEventListener('change', () => {
      try { localStorage.setItem('workspace.dash.deep-think', cb.checked ? '1' : '0'); } catch {}
    });
  })();

  els.model.addEventListener('change', async () => {
    // Refresh the vision-capability hint whenever the model changes,
    // even when there's no chat bound yet (so the user sees it on a
    // fresh-page selection).
    updateVisionHint();
    // Also refresh the chat-meta MODEL chip so it shows the newly-
    // chosen model immediately (not after a server round-trip / load).
    try {
      if (chat) chat.model = els.model.value;
      const modelEl = document.getElementById('chat-meta-model');
      if (modelEl) modelEl.textContent = shortModelName(els.model.value);
    } catch {}
    if (!chat) return;
    // Mirror the in-chat selection to the universal preference key the
    // dashboard writes / reads. Picking a model anywhere now updates it
    // everywhere — the dashboard model chip will reflect the new choice
    // on the user's next visit, and new chats will default to it.
    try { localStorage.setItem('workspace.dash.model', els.model.value); } catch {}
    await fetch('/.netlify/functions/workspace-chats-update', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: chat.id, model: els.model.value }),
    });
  });
  els.newChat.addEventListener('click', async () => {
    // Use the universal model preference as the default for new chats.
    let preferredModel = '';
    try { preferredModel = localStorage.getItem('workspace.dash.model') || ''; } catch {}
    const r = await fetch('/.netlify/functions/workspace-chats-create', {
      method: 'POST',
      headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
      body: JSON.stringify(preferredModel ? { model: preferredModel } : {}),
    });
    const j = await r.json();
    if (j.id) location.href = `/workspace/chat/?id=${j.id}`;
  });

  // Render BOTH sidebar and chat content from localStorage cache
  // immediately so reload feels instant. The server fetch then runs
  // in parallel and silently overwrites if anything changed.
  loadChatFromCache();
  renderRailFromCache();
  Promise.all([
    loadChat().then(() => refreshModels(chat?.model)),
    loadRail(),
  ]);
  // If the dashboard handed us a seed query, prefill the composer and
  // park the cursor at the end so the user can hit Enter to send.
  if (seedText) {
    els.input.value = seedText;
    els.input.dispatchEvent(new Event('input', { bubbles: true }));
  }
  els.input.focus();
  if (seedText) {
    try { els.input.setSelectionRange(seedText.length, seedText.length); } catch {}
  }

  // ---- Sidebar search — filters railCacheChats client-side ----
  const chatSearchInput = document.getElementById('chat-search');
  if (chatSearchInput) {
    chatSearchInput.addEventListener('input', () => {
      railSearchQuery = chatSearchInput.value || '';
      paintRail();
    });
    // ⌘K / Ctrl-K focuses the sidebar search.
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        chatSearchInput.focus();
        chatSearchInput.select();
      }
    });
  }

  // ---- Suggested-prompt cards in the empty state ----
  // Clicking a card prefills the composer and focuses it. The cards
  // remain visible until the user actually sends a message — the
  // existing render logic replaces .chat-empty when messages load.
  document.addEventListener('click', (e) => {
    const card = e.target?.closest?.('.sg-card');
    if (!card || !card.dataset.prompt) return;
    if (!els.input) return;
    els.input.value = card.dataset.prompt;
    els.input.dispatchEvent(new Event('input', { bubbles: true }));
    els.input.focus();
    try { els.input.setSelectionRange(els.input.value.length, els.input.value.length); } catch {}
  });

  // ---- Chat-meta stat row — updates from the active chat object ----
  function updateChatMeta() {
    const startedEl = document.getElementById('chat-meta-started');
    const msgsEl    = document.getElementById('chat-meta-msgs');
    const modelEl   = document.getElementById('chat-meta-model');
    const coordEl   = document.getElementById('chat-coord');
    if (!chat) return;
    if (startedEl && chat.created_at) {
      const d = new Date(chat.created_at);
      const pad = (n) => String(n).padStart(2,'0');
      startedEl.textContent = `${pad(d.getHours())}:${pad(d.getMinutes())} · ${d.toLocaleDateString(undefined, { day: '2-digit', month: 'short', year: 'numeric' })}`;
    }
    if (msgsEl) {
      const cnt = (els.messages?.querySelectorAll?.('.msg').length) || 0;
      msgsEl.textContent = String(cnt);
    }
    if (modelEl && chat.model) {
      modelEl.textContent = shortModelName(chat.model);
    }
    if (coordEl) {
      const id = (chat.id || '').slice(0, 4).toUpperCase();
      coordEl.textContent = `/WS · CHT-${id || '0000'}`;
    }
  }
  // Refresh the meta line when chat data is loaded or messages change.
  // We poll once a second — cheap and reliable across the various
  // streaming code paths.
  setInterval(updateChatMeta, 1000);
  updateChatMeta();
</script>
</body>
</html>
