    const showState = anyStateToggleOn();
    if (lawEls.state) lawEls.state.hidden = !showState;
    if (lawEls.stateLabel) lawEls.stateLabel.hidden = !showState;
    // Show/hide dividers in the same beat so the bar collapses
    // cleanly when nothing's on.
    const anyOn = anyToggleOn();
    lawEls.bar?.querySelectorAll('.research-divider').forEach((div) => {
      div.hidden = !anyOn;
    });
    // Privacy mode: paint the entire chat container amber so the
    // user has constant visual confirmation. Animation runs once
    // when privacy first turns on, then settles into a steady tint.
    const chatMain = document.querySelector('.chat-main');
    if (chatMain) {
      const wasOn = chatMain.classList.contains('is-privacy-on');
      const nowOn = !!lawSettings.privacy_enabled;
      chatMain.classList.toggle('is-privacy-on', nowOn);
      if (nowOn && !wasOn) {
        chatMain.classList.add('is-privacy-just-toggled');
        setTimeout(() => chatMain.classList.remove('is-privacy-just-toggled'), 1400);
      }
    }
  }
  function hydrateLawSettings(persisted) {
    // Backward compat: legacy settings used three combined toggles
    // (statutes_enabled / case_law_enabled / legiscan_enabled). Map
    // each legacy on-state to BOTH state + federal of the same kind
    // since that was the previous behavior.
    const legacyStat = !!persisted?.statutes_enabled;
    const legacyCase = !!persisted?.case_law_enabled;
    const legacyBill = !!persisted?.legiscan_enabled;
    lawSettings = {
      state: (persisted?.state && /^[A-Z]{2}$/.test(persisted.state)) ? persisted.state : 'FL',
      state_statutes_enabled:   persisted?.state_statutes_enabled   !== undefined ? !!persisted.state_statutes_enabled   : legacyStat,
      federal_statutes_enabled: persisted?.federal_statutes_enabled !== undefined ? !!persisted.federal_statutes_enabled : legacyStat,
      state_caselaw_enabled:    persisted?.state_caselaw_enabled    !== undefined ? !!persisted.state_caselaw_enabled    : legacyCase,
      federal_caselaw_enabled:  persisted?.federal_caselaw_enabled  !== undefined ? !!persisted.federal_caselaw_enabled  : legacyCase,
      state_bills_enabled:      persisted?.state_bills_enabled      !== undefined ? !!persisted.state_bills_enabled      : legacyBill,
      federal_bills_enabled:    persisted?.federal_bills_enabled    !== undefined ? !!persisted.federal_bills_enabled    : legacyBill,
      privacy_enabled:          !!persisted?.privacy_enabled,
    };
    if (lawEls.state)           lawEls.state.value = lawSettings.state;
    if (lawEls.stateStatutes)   lawEls.stateStatutes.checked = lawSettings.state_statutes_enabled;
    if (lawEls.federalStatutes) lawEls.federalStatutes.checked = lawSettings.federal_statutes_enabled;
    if (lawEls.stateCaselaw)    lawEls.stateCaselaw.checked = lawSettings.state_caselaw_enabled;
    if (lawEls.federalCaselaw)  lawEls.federalCaselaw.checked = lawSettings.federal_caselaw_enabled;
    if (lawEls.stateBills)      lawEls.stateBills.checked = lawSettings.state_bills_enabled;
    if (lawEls.federalBills)    lawEls.federalBills.checked = lawSettings.federal_bills_enabled;
    if (lawEls.privacy)         lawEls.privacy.checked = lawSettings.privacy_enabled;
    applyResearchUI();
    refreshLawStatusPill();
  }
  function refreshLawStatusPill() {
    if (!lawEls.status) return;
    const st = lawSettings.state;
    const parts = [];
    if (lawSettings.state_statutes_enabled)   parts.push(`${st} statutes`);
    if (lawSettings.federal_statutes_enabled) parts.push('U.S. Code');
    if (lawSettings.state_caselaw_enabled)    parts.push(`${st} cases`);
    if (lawSettings.federal_caselaw_enabled)  parts.push('federal cases');
    if (lawSettings.state_bills_enabled)      parts.push(`${st} bills`);
    if (lawSettings.federal_bills_enabled)    parts.push('Congress bills');
    if (lawSettings.privacy_enabled)          parts.unshift('🔒 privacy');
    if (!parts.length) {
      lawEls.status.hidden = true;
      lawEls.status.textContent = '';
      lawEls.bar?.classList.remove('is-active');
      lawEls.bar?.classList.remove('is-privacy-on');
    } else {
      lawEls.status.hidden = false;
      lawEls.status.textContent = `Research: ${parts.join(' · ')}`;
      lawEls.bar?.classList.add('is-active');
      lawEls.bar?.classList.toggle('is-privacy-on', lawSettings.privacy_enabled);
    }
  }
  let lawSaveTimer = null;
  function saveLawSettingsDebounced() {
    if (lawSaveTimer) clearTimeout(lawSaveTimer);
    lawSaveTimer = setTimeout(() => {
      fetch('/.netlify/functions/workspace-chats-update', {
        method: 'POST',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: chatId, law_settings: lawSettings }),
      }).catch(() => {});
    }, 400);
  }
  function onLawToggleChange() {
    lawSettings = {
      state: lawEls.state?.value || 'FL',
      state_statutes_enabled:   !!lawEls.stateStatutes?.checked,
      federal_statutes_enabled: !!lawEls.federalStatutes?.checked,
      state_caselaw_enabled:    !!lawEls.stateCaselaw?.checked,
      federal_caselaw_enabled:  !!lawEls.federalCaselaw?.checked,
      state_bills_enabled:      !!lawEls.stateBills?.checked,
      federal_bills_enabled:    !!lawEls.federalBills?.checked,
      privacy_enabled:          !!lawEls.privacy?.checked,
    };
    applyResearchUI();
    refreshLawStatusPill();
    saveLawSettingsDebounced();
  }
  [
    lawEls.state, lawEls.stateStatutes, lawEls.federalStatutes,
    lawEls.stateCaselaw, lawEls.federalCaselaw,
    lawEls.stateBills, lawEls.federalBills,
    lawEls.privacy,
  ].forEach((el) => el?.addEventListener('change', onLawToggleChange));
  // ---- Verification polling + inline badges ----
  // After an assistant message finishes streaming with research
  // toggles on, we poll workspace-chat-message-get every 2.5s until
  // verification.status === "complete", then inject inline cite
  // badges next to each detected citation in the rendered DOM.
  const STATUS_ICON = {
    verified: '✓',
    secondary: '⚠',
    pending_amendment: '📝',
    amended_enacted: '🔴',
    unverified: '❌',
    pending: '⌛',
  };
  function badgeHTML(cite) {
    const status = cite.status || 'unverified';
    const icon = STATUS_ICON[status] || '·';
    const detail = JSON.stringify({
      kind: cite.kind, status,
      primary_url: cite.primary_url || null,
      amendment_note: cite.amendment_note || null,
      details: cite.details || null,
    }).replace(/"/g, '&quot;');
    return `<sup class="cite-badge cite-${status}" data-cite="${detail}" title="${escapeHtml(cite.amendment_note || status)}">${icon}</sup>`;
  }
  function decorateCitesInElement(el, cites) {
    if (!el || !cites?.length) return;
    let html = el.innerHTML;
    // Sort descending so we modify from the end backwards (string
    // indices won't shift). The cites already have spans in plain
    // text; for HTML we re-find the raw substring once.
    const sorted = [...cites].sort((a, b) => (b.span?.[0] ?? 0) - (a.span?.[0] ?? 0));
    for (const c of sorted) {
      if (!c.raw) continue;
      // Find the LAST occurrence of c.raw in the rendered HTML
      const idx = html.lastIndexOf(c.raw);
      if (idx === -1) continue;
      // Skip if this raw was already wrapped (avoid double-decoration)
      const after = html.slice(idx + c.raw.length, idx + c.raw.length + 30);
      if (after.startsWith('<sup class="cite-badge')) continue;
      html = html.slice(0, idx + c.raw.length) + badgeHTML(c) + html.slice(idx + c.raw.length);
    }
    el.innerHTML = html;
  }
  async function pollVerification(messageId, asstWrap) {
    if (!messageId || !asstWrap) return;
    // Add a "Verifying citations…" pill to the assistant body
    const pillId = 'verify-pill-' + messageId;
    const txtEl = asstWrap.querySelector('.msg-text');
    if (txtEl && !asstWrap.querySelector('#' + pillId)) {
      asstWrap.insertAdjacentHTML('beforeend', `<div id="${pillId}" class="msg-verify-pill">⌛ Verifying citations…</div>`);
    }
    const maxTries = 24;     // 24 × 2.5s = 60s budget
    for (let i = 0; i < maxTries; i++) {
      await new Promise((r) => setTimeout(r, 2500));
      let r, j;
      try {
        r = await fetch(`/.netlify/functions/workspace-chat-message-get?id=${encodeURIComponent(messageId)}`, {
          headers: { Authorization: `Bearer ${accessToken}` },
        });
        j = await r.json();
      } catch { continue; }
      if (!r.ok) continue;
      const v = j.message?.verification;
      if (!v) continue;
      if (v.status === 'complete') {
        if (txtEl) decorateCitesInElement(txtEl, v.cites || []);
        const pill = document.getElementById(pillId);
        if (pill) {
          const cites = v.cites || [];
          const counts = cites.reduce((a, c) => { a[c.status] = (a[c.status] || 0) + 1; return a; }, {});
          const summary = Object.entries(counts).map(([k, n]) => `${STATUS_ICON[k] || '·'}${n}`).join(' ');
          if (!cites.length) {
            pill.outerHTML = '';
          } else {
            // Compact button — click expands a modal listing every
            // verified citation with its source URL, status, and
            // (if any) amendment note.
            const dataAttr = escapeAttr(JSON.stringify(cites));
            pill.outerHTML = `<button type="button" class="msg-verify-pill is-complete msg-verify-clickable" data-cites="${dataAttr}" title="Click for citation details">${summary}<span class="msg-verify-caret">▾</span></button>`;
          }
        }
        return;
      }
      if (v.status === 'error') {
        const pill = document.getElementById(pillId);
        if (pill) pill.outerHTML = '<div class="msg-verify-pill is-error">⚠ Citation check failed</div>';
        return;
      }
    }
    // Timed out
    const pill = document.getElementById(pillId);
    if (pill) pill.outerHTML = '<div class="msg-verify-pill is-timeout">Citation check timed out</div>';
  }
  // ---- Citation popup modal ----
  // Two entry points:
  //   1. Click an inline cite badge in the response → opens modal
  //      scrolled to that specific cite (highlighted).
  //   2. Click the small Citations summary pill below the response
  //      → opens modal with the FULL list of verified citations.
  function openCiteModal(cites, focusIdx) {
    if (!Array.isArray(cites) || !cites.length) return;
    const modal = document.getElementById('cite-modal');
    const body = document.getElementById('cite-modal-body');
    if (!modal || !body) return;
    const STATUS_LABEL = {
      verified: 'Verified — primary authority',
      secondary: 'Verified — secondary source',
      pending_amendment: 'Pending amendment (still good law)',
      amended_enacted: 'AMENDED by enacted bill — re-verify',
      unverified: 'Could not verify',
      pending: 'Verification in flight',
    };
    body.innerHTML = cites.map((c, i) => {
      const icon = STATUS_ICON[c.status] || '·';
      const statusLabel = STATUS_LABEL[c.status] || c.status || 'unknown';
      const focusCls = (focusIdx != null && i === focusIdx) ? ' is-focus' : '';
      const url = c.primary_url || '';
      const urlHost = url ? (() => { try { return new URL(url).hostname.replace(/^www\./, ''); } catch { return url; } })() : '';
      return `<div class="cite-modal-row cite-modal-row-${c.status}${focusCls}" data-idx="${i}">
        <div class="cite-modal-icon">${icon}</div>
        <div class="cite-modal-content">
          <div class="cite-modal-raw">${escapeHtml(c.raw || '')}</div>
          <div class="cite-modal-status">${escapeHtml(statusLabel)}${c.kind ? ` · ${escapeHtml(c.kind)}` : ''}</div>
          ${c.amendment_note ? `<div class="cite-modal-note">${escapeHtml(c.amendment_note)}</div>` : ''}
          ${url ? `<a href="${escapeAttr(url)}" target="_blank" rel="noopener" class="cite-modal-link">${escapeHtml(urlHost)} ↗</a>` : ''}
        </div>
      </div>`;
    }).join('');
    modal.hidden = false;
    document.body.classList.add('cite-modal-open');
    // Scroll the focused row into view
    if (focusIdx != null) {
      const row = body.querySelector(`[data-idx="${focusIdx}"]`);
      if (row) row.scrollIntoView({ block: 'center', behavior: 'instant' });
    } else {
      body.scrollTop = 0;
    }
  }
  function closeCiteModal() {
    const modal = document.getElementById('cite-modal');
    if (modal) modal.hidden = true;
    document.body.classList.remove('cite-modal-open');
  }

  // Inline cite badge → open modal focused on this cite
  document.addEventListener('click', (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    const badge = t.closest('.cite-badge');
    if (!badge) return;
    e.preventDefault();
    // The badge has a data-cite single-cite blob, but to show the
    // full list we need the parent message's full cite array. We
    // get that from the verify-pill button's data-cites attribute.
    const bubble = badge.closest('.msg.asst');
    const pill = bubble?.querySelector('.msg-verify-pill[data-cites]');
    let allCites = null;
    if (pill) {
      try { allCites = JSON.parse((pill.getAttribute('data-cites') || '').replace(/&quot;/g, '"').replace(/&#39;/g, "'")); } catch {}
    }
    if (Array.isArray(allCites) && allCites.length) {
      // Find the index of this badge's cite in the full list by raw
      // text match, so we can scroll to it in the modal.
      let detail;
      try { detail = JSON.parse((badge.getAttribute('data-cite') || '{}').replace(/&quot;/g, '"')); } catch {}
      const idx = allCites.findIndex((c) => c.raw === detail?.raw && c.status === detail?.status);
      openCiteModal(allCites, idx >= 0 ? idx : null);
    } else {
      // Fallback: badge-only popup with the single cite's data
      let detail;
      try { detail = JSON.parse((badge.getAttribute('data-cite') || '{}').replace(/&quot;/g, '"')); } catch { detail = {}; }
      openCiteModal([{ ...detail, raw: detail.raw || '(citation)' }], 0);
    }
  });

  // Citations summary pill → open modal with full list
  document.addEventListener('click', (e) => {
    const t = e.target;
