---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Mata Tracker — Legal Overflow</title>
<meta name="description" content="A searchable database of every U.S. case where attorneys were sanctioned for AI hallucinations in court filings. Practitioner analysis, Model Rules breakdown, and prevention tools.">
<link rel="canonical" href="https://legaloverflow.com/tracker/" />
<meta property="og:title" content="Mata Tracker — Every AI Sanction, Annotated" />
<meta property="og:description" content="A searchable database of every U.S. case where attorneys were sanctioned for AI hallucinations in court filings." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://legaloverflow.com/tracker/" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style is:global>
/* ================================================================
   DESIGN TOKENS — Legal Overflow Design System
   ================================================================ */
:root {
  --paper:#f3efe6; --paper-2:#ebe6d9;
  --ink:#0e1512; --ink-2:#2a332d; --ink-3:#5b6760; --ink-4:#8a9690;
  --rule:#1d2622; --rule-soft:#d9d2c0;
  --accent:#10b981; --accent-deep:#0a7d57; --accent-tint:#d7ede0;
  --warn:#b3532f;
  --serif:'Instrument Serif','Times New Roman',serif;
  --sans:'Geist',ui-sans-serif,system-ui,-apple-system,'Segoe UI',sans-serif;
  --mono:'JetBrains Mono',ui-monospace,'SFMono-Regular',Menlo,monospace;
  --max-w:1400px;
  --section-w:1200px;
  --body-w:900px;
}

/* ================================================================
   RESET + BASE
   ================================================================ */
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:var(--paper);color:var(--ink);
  font-family:var(--sans);font-size:16px;line-height:1.5;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}
::selection{background:var(--accent);color:var(--paper)}
a{color:inherit;text-decoration:none}
h1,h2,h3,h4{font-family:var(--serif);font-weight:400;letter-spacing:-.02em}
em{font-style:italic;color:var(--accent-deep)}
img{display:block;max-width:100%}
button{font-family:inherit;cursor:pointer;border:none;background:none}
input{font-family:inherit}

/* ================================================================
   GRAIN OVERLAY
   ================================================================ */
#grain{
  position:fixed;inset:0;z-index:9999;pointer-events:none;
  opacity:.05;mix-blend-mode:multiply;
  background:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size:180px;
}

/* ================================================================
   NAV-LINK MARQUEE SWAP — matches /site-anim.css
   ================================================================ */
.nav-links a.sx-marquee-link {
  overflow: hidden;
  display: inline-block;
  vertical-align: bottom;
  line-height: 1.45;
}
.sx-marquee-text {
  position: relative;
  display: inline-block;
  transition: transform 0.42s cubic-bezier(0.65, 0, 0.35, 1);
}
.sx-marquee-text::before {
  content: attr(data-text);
  position: absolute;
  top: 100%;
  left: 0;
  color: var(--accent-deep);
  white-space: nowrap;
  font-weight: 500;
}
.nav-links a.sx-marquee-link:hover .sx-marquee-text {
  transform: translateY(-100%);
}
@media (prefers-reduced-motion: reduce) {
  .sx-marquee-text { transition: none !important; }
  .nav-links a.sx-marquee-link:hover .sx-marquee-text { transform: none; }
}

/* ================================================================
   READING-PROGRESS BAR — matches /site-anim.css
   ================================================================ */
.sx-progress {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 2px;
  z-index: 998;
  pointer-events: none;
  background: linear-gradient(90deg,
    color-mix(in oklab, var(--accent-deep) 70%, transparent),
    var(--accent-deep) 60%,
    color-mix(in oklab, var(--accent) 80%, transparent));
  transform-origin: left center;
  transform: scaleX(0);
  transition: transform 0.08s linear;
}
@media (prefers-reduced-motion: reduce) {
  .sx-progress { display: none; }
}

/* ================================================================
   UTILITY
   ================================================================ */
.mono{
  font-family:var(--mono);font-size:11px;color:var(--ink-3);
  letter-spacing:.06em;text-transform:uppercase;
}
.wrap{max-width:var(--section-w);margin:0 auto;padding:0 40px}
.wrap-wide{max-width:var(--max-w);margin:0 auto;padding:0 40px}

/* ================================================================
   NAV — copied verbatim from /styles.css to match the rest of the site
   ================================================================ */
.nav {
  position: sticky; top: 0; z-index: 100;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 32px;
  padding: 18px 40px;
  background: rgba(243,239,230,.85);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid var(--rule-soft);
}
.brand { display: flex; align-items: center; gap: 12px; color: var(--ink); }
.brand-mark { width: 28px; height: 28px; color: var(--ink); transition: transform .6s ease; }
.brand:hover .brand-mark { transform: rotate(180deg); }
.brand-text { font-family: var(--serif); font-size: 22px; letter-spacing: -.01em; }
.brand-text .brand-over { font-style: italic; color: var(--accent-deep); margin-left: 2px; }
.nav-links { display: flex; gap: 28px; justify-self: center; }
.nav-links a { font-size: 13.5px; color: var(--ink-2); position: relative; padding: 4px 0; }
.nav-links a::after {
  content: ''; position: absolute; left: 0; bottom: 0; width: 0; height: 1px;
  background: var(--accent); transition: width .35s cubic-bezier(.2,.8,.2,1);
}
.nav-links a:hover { color: var(--ink); }
.nav-links a:hover::after { width: 100%; }
.nav-links a[aria-current="page"] { color: var(--ink); }
.nav-links a[aria-current="page"]::after { width: 100%; }
.nav-right { display: flex; align-items: center; gap: 16px; }
.live-dot {
  width: 7px; height: 7px; border-radius: 50%; background: var(--accent);
  box-shadow: 0 0 0 0 color-mix(in oklab, var(--accent) 50%, transparent);
  animation: pulse 2s infinite;
}
.nav-meta { font-family: var(--mono); font-size: 11px; color: var(--ink-3); letter-spacing: .05em; }
.nav-sub {
  font-size: 13px; padding: 9px 16px; border: 1px solid var(--ink);
  border-radius: 999px; background: var(--ink); color: var(--paper);
  transition: all .25s ease;
}
.nav-sub:hover { background: var(--accent-deep); border-color: var(--accent-deep); }

/* hero CTA buttons — kept from prototype */
.btn-primary{
  display:inline-flex;align-items:center;gap:10px;
  padding:10px 18px;background:var(--ink);color:var(--paper);
  border-radius:999px;font-size:13px;font-weight:500;
  transition:transform .25s ease,background .25s ease;
}
.btn-primary:hover{background:var(--accent-deep);transform:translateY(-2px)}

/* ================================================================
   HERO
   ================================================================ */
.hero{
  padding:80px 40px 0;
  max-width:var(--section-w);margin:0 auto;
}
.hero-kicker{
  display:flex;align-items:center;gap:14px;
  font-family:var(--mono);font-size:11.5px;color:var(--ink-3);
  letter-spacing:.03em;text-transform:uppercase;
  margin-bottom:28px;
  opacity:0;animation:fadeUp .8s .1s forwards;
}
.kicker-dash{width:40px;height:1px;background:var(--ink)}
.hero-title{
  font-family:var(--serif);font-weight:400;
  font-size:clamp(38px,7vw,88px);line-height:.94;
  letter-spacing:-.025em;
  margin-bottom:24px;
}
.hero-title .line{display:block;opacity:0;transform:translateY(20px);animation:riseUp 1.1s cubic-bezier(.2,.8,.2,1) forwards}
.hero-title .line:nth-child(1){animation-delay:.05s}
.hero-title .line:nth-child(2){animation-delay:.18s}
.hero-title .line:nth-child(3){animation-delay:.32s}
.hero-title em{
  font-style:italic;color:var(--accent-deep);position:relative;
}
.hero-title em::after{
  content:'';position:absolute;left:0;right:0;bottom:.08em;
  height:.08em;background:var(--accent);
  transform:scaleX(0);transform-origin:left;
  animation:underline 1.6s cubic-bezier(.7,0,.3,1) .7s forwards;
}
.hero-sub{
  font-size:18px;line-height:1.5;color:var(--ink-2);
  max-width:60ch;margin-bottom:36px;
  opacity:0;animation:fadeUp .8s .4s forwards;
}
.hero-actions{
  display:flex;gap:14px;flex-wrap:wrap;
  margin-bottom:60px;
  opacity:0;animation:fadeUp .8s .5s forwards;
}
.btn-ghost{
  display:inline-flex;align-items:center;gap:10px;
  padding:12px 20px;border:1px solid var(--ink);
  border-radius:999px;font-size:14px;font-weight:500;
  transition:background .25s,color .25s,transform .25s;
}
.btn-ghost:hover{background:var(--ink);color:var(--paper);transform:translateY(-2px)}

/* ================================================================
   STATS BAR
   ================================================================ */
.stats{
  display:grid;grid-template-columns:repeat(5,1fr);
  border-top:1px solid var(--rule-soft);
  border-bottom:1px solid var(--rule-soft);
  margin-bottom:60px;
  opacity:0;animation:fadeUp .8s .6s forwards;
}
.stat{padding:24px 0;border-right:1px solid var(--rule-soft)}
.stat:last-child{border-right:none}
.stat:not(:first-child){padding-left:24px}
.stat-n{font-family:var(--serif);font-size:44px;line-height:1;margin-bottom:6px;letter-spacing:-.02em}
.stat-l{font-family:var(--mono);font-size:10.5px;color:var(--ink-3);letter-spacing:.05em;text-transform:uppercase}
.stat-sub{font-family:var(--mono);font-size:10px;color:var(--ink-4);letter-spacing:.04em;margin-top:4px;text-transform:uppercase}

/* ================================================================
   SEARCH + FILTERS
   ================================================================ */
.controls{
  max-width:var(--section-w);margin:0 auto;
  padding:0 40px 40px;
  opacity:0;animation:fadeUp .8s .7s forwards;
}
.search-row{
  display:flex;gap:12px;margin-bottom:20px;
}
.search-input{
  flex:1;padding:14px 18px 14px 44px;
  background:var(--paper-2);border:1px solid var(--rule-soft);
  border-radius:999px;font-size:15px;color:var(--ink);
  outline:none;transition:border-color .2s;
  background-image:url("data:image/svg+xml,%3Csvg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='%235b6760' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='11' cy='11' r='8'/%3E%3Cpath d='m21 21-4.35-4.35'/%3E%3C/svg%3E");
  background-repeat:no-repeat;
  background-position:16px center;
}
.search-input::placeholder{color:var(--ink-4)}
.search-input:focus{border-color:var(--accent)}
.filter-row{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
.filter-label{font-family:var(--mono);font-size:10.5px;color:var(--ink-3);letter-spacing:.05em;text-transform:uppercase;margin-right:4px}
.filter-pill{
  padding:6px 14px;border-radius:999px;
  font-family:var(--mono);font-size:10px;letter-spacing:.05em;
  text-transform:uppercase;font-weight:500;
  border:1px solid var(--rule-soft);color:var(--ink-3);
  cursor:pointer;transition:all .2s;user-select:none;
}
.filter-pill:hover{border-color:var(--ink-3);color:var(--ink-2)}
.filter-pill.active{
  background:color-mix(in oklab,var(--accent) 12%,white);
  border-color:var(--accent);color:var(--accent-deep);
}
.filter-sep{width:1px;height:20px;background:var(--rule-soft);margin:0 8px}
.severity-dot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:5px}
.severity-dot.low{background:var(--accent)}
.severity-dot.moderate{background:#d4a017}
.severity-dot.high{background:#c45a2d}
.severity-dot.severe{background:var(--warn)}

/* ================================================================
   RESULTS META
   ================================================================ */
.results-meta{
  max-width:var(--section-w);margin:0 auto;
  padding:0 40px 16px;
  display:flex;justify-content:space-between;align-items:baseline;
}
.results-count{font-family:var(--mono);font-size:11px;color:var(--ink-3);letter-spacing:.05em;text-transform:uppercase}
.sort-control{font-family:var(--mono);font-size:11px;color:var(--ink-3);letter-spacing:.04em}
.sort-control select{
  font-family:var(--mono);font-size:11px;
  background:transparent;border:none;color:var(--ink-2);
  cursor:pointer;text-transform:uppercase;letter-spacing:.04em;
}

/* ================================================================
   CASE LIST
   ================================================================ */
/* ============================================================
   TAB STRIP — switch between Cases and Rules & Orders
   ============================================================ */
.tk-tabs {
  max-width: 1200px; margin: 0 auto 12px;
  padding: 0 40px;
  display: flex;
  gap: 4px;
  border-bottom: 1px solid var(--rule-soft);
}
.tk-tab {
  font-family: var(--serif);
  font-size: 22px;
  letter-spacing: -.01em;
  color: var(--ink-3);
  background: transparent;
  border: 0;
  padding: 14px 24px 16px;
  cursor: pointer;
  position: relative;
  transition: color .2s;
  display: inline-flex;
  align-items: baseline;
  gap: 10px;
}
.tk-tab:hover { color: var(--ink-2); }
.tk-tab.active { color: var(--ink); }
.tk-tab.active::after {
  content: '';
  position: absolute;
  left: 24px; right: 24px; bottom: -1px;
  height: 2px;
  background: var(--accent);
}
.tk-tab-count {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--ink-4);
  letter-spacing: .04em;
  font-style: normal;
}
.tk-tab.active .tk-tab-count { color: var(--accent-deep); }
.tk-tab-new {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: .12em;
  text-transform: uppercase;
  background: var(--accent-tint);
  color: var(--accent-deep);
  padding: 2px 8px;
  border-radius: 999px;
  margin-left: 8px;
  vertical-align: 4px;
  font-style: normal;
}

.tk-pane { }
.tk-pane.hidden { display: none; }

.tk-preview-banner {
  max-width: 1200px;
  margin: 0 auto 24px;
  padding: 14px 22px;
  border: 1px dashed var(--accent);
  border-radius: 6px;
  background: var(--accent-tint);
  font-family: var(--mono); font-size: 12px;
  letter-spacing: .04em;
  color: var(--accent-deep);
  display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
}
.tk-preview-banner strong { font-weight: 600; }

.rule-state-select {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .04em;
  padding: 7px 32px 7px 14px;
  border-radius: 999px;
  border: 1px solid var(--rule-soft);
  background: transparent;
  color: var(--ink-2);
  cursor: pointer;
  appearance: none;
  -webkit-appearance: none;
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='10' viewBox='0 0 24 24' fill='none' stroke='%235b6760' stroke-width='2' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='m6 9 6 6 6-6'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 12px center;
  transition: border-color .2s, color .2s;
}
.rule-state-select:hover { border-color: var(--ink-3); color: var(--ink); }
.rule-state-select:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

/* rules cards — mostly mirror case cards but with rule-specific bits */
.rule-card {
  border: 1px solid var(--rule-soft); border-radius: 6px;
  margin-bottom: 16px; overflow: hidden;
  transition: border-color .2s; background: var(--paper);
}
.rule-card:hover { border-color: var(--ink-4); }
.rule-card-header {
  display: grid; grid-template-columns: 1fr auto;
  gap: 20px; padding: 24px 28px;
  cursor: pointer; user-select: none;
}
.rule-meta-top {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 8px; flex-wrap: wrap;
}
.rule-juris-pill {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 3px 10px; border-radius: 999px;
  font-family: var(--mono); font-size: 9.5px; letter-spacing: .06em;
  text-transform: uppercase; font-weight: 600;
}
.rule-juris-pill.aba     { background: color-mix(in oklab, #3b6db5 12%, white); color: #1d3a6b; }
.rule-juris-pill.federal { background: color-mix(in oklab, var(--accent-deep) 12%, white); color: var(--accent-deep); }
.rule-juris-pill.state   { background: color-mix(in oklab, #6e5b1c 12%, white); color: #6e5b1c; }
.rule-type-pill {
  font-family: var(--mono); font-size: 10px; letter-spacing: .04em; color: var(--ink-3);
}
.rule-date {
  font-family: var(--mono); font-size: 10.5px; color: var(--ink-4); letter-spacing: .04em;
}
.rule-title {
  font-family: var(--serif); font-size: 22px; line-height: 1.2;
  letter-spacing: -.015em; margin-bottom: 4px; color: var(--ink);
}
.rule-subtitle {
  font-family: var(--sans); font-size: 14px; color: var(--ink-3);
  font-style: italic; margin-bottom: 8px;
}
.rule-summary {
  font-family: var(--sans); font-size: 15px; color: var(--ink-2);
  line-height: 1.45; max-width: 70ch;
}
.rule-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
.rule-tag {
  font-family: var(--mono); font-size: 9px; letter-spacing: .06em;
  text-transform: uppercase; padding: 3px 9px; border-radius: 999px;
  border: 1px solid var(--rule-soft); color: var(--ink-3);
}
.rule-tag.disclosure   { background: color-mix(in oklab, var(--accent) 8%, white); color: var(--accent-deep); border-color: var(--accent); }
.rule-tag.verification { background: color-mix(in oklab, #c45a2d 8%, white); color: #8b3318; border-color: color-mix(in oklab, #c45a2d 35%, transparent); }
.rule-card-right {
  display: flex; flex-direction: column; align-items: flex-end;
  gap: 8px; min-width: 160px;
}
.rule-rules-implicated {
  font-family: var(--mono); font-size: 9.5px; color: var(--ink-3);
  letter-spacing: .04em; text-align: right; line-height: 1.4;
}
.rule-rules-implicated strong {
  display: block; font-size: 13px; color: var(--ink);
  font-family: var(--serif); font-weight: 400; letter-spacing: -.01em;
  margin-bottom: 4px;
}
.rule-toggle {
  width: 32px; height: 32px; border-radius: 50%;
  border: 1px solid var(--rule-soft);
  display: flex; align-items: center; justify-content: center;
  transition: transform .3s cubic-bezier(.2,.8,.2,1), background .2s;
  background: transparent;
}
.rule-card.open .rule-toggle { transform: rotate(180deg); background: var(--paper-2); }
.rule-detail { max-height: 0; overflow: hidden; transition: max-height .55s cubic-bezier(.2,.8,.2,1); }
.rule-card.open .rule-detail { max-height: 6000px; }
.rule-detail-inner { padding: 0 28px 28px; border-top: 1px solid var(--rule-soft); }
.rule-section { margin-top: 28px; }
.rule-section-title {
  font-family: var(--mono); font-size: 10.5px; color: var(--ink-3);
  letter-spacing: .06em; text-transform: uppercase;
  margin-bottom: 12px; padding-bottom: 8px;
  border-bottom: 1px solid var(--rule-soft);
}
.rule-section-body {
  font-family: var(--sans); font-size: 15px; line-height: 1.6;
  color: var(--ink-2); max-width: 72ch;
}
.rule-section-body p { margin-bottom: 12px; }
.rule-takeaways { list-style: none; margin: 0; padding: 0; }
.rule-takeaways li {
  font-family: var(--sans); font-size: 14.5px; line-height: 1.55;
  color: var(--ink-2); padding: 10px 0 10px 28px; position: relative;
  border-bottom: 1px dashed var(--rule-soft);
}
.rule-takeaways li:last-child { border-bottom: 0; }
.rule-takeaways li::before {
  content: ''; position: absolute; left: 0; top: 18px;
  width: 14px; height: 1px; background: var(--accent-deep);
}
.rule-footer-row {
  display: flex; flex-wrap: wrap; gap: 18px;
  margin-top: 24px; padding-top: 14px;
  border-top: 1px dashed var(--rule-soft);
  align-items: center;
}
.rule-source {
  font-family: var(--mono); font-size: 11px; color: var(--ink-3);
  letter-spacing: .04em;
  border-bottom: 1px dashed var(--rule-soft); padding-bottom: 1px;
  text-decoration: none;
}
.rule-source:hover { color: var(--accent-deep); border-color: var(--accent); }
.rule-citation {
  font-family: var(--mono); font-size: 10px; color: var(--ink-4);
  letter-spacing: .03em; margin-left: auto;
}
@media (max-width: 900px) {
  .tk-tabs { padding: 0 20px; }
  .tk-tab { font-size: 18px; padding: 10px 14px 12px; }
  .tk-tab.active::after { left: 14px; right: 14px; }
  .rule-card-header { grid-template-columns: 1fr; }
  .rule-card-right { flex-direction: row; align-items: center; min-width: 0; }
}

.case-list{
  max-width:var(--section-w);margin:0 auto;
  padding:0 40px 40px;
}
.case-card{
  border:1px solid var(--rule-soft);
  border-radius:6px;
  margin-bottom:16px;
  overflow:hidden;
  transition:border-color .2s;
  background:var(--paper);
}
.case-card:hover{border-color:var(--ink-4)}
.case-header{
  display:grid;
  grid-template-columns:1fr auto;
  gap:20px;
  padding:24px 28px;
  cursor:pointer;
  user-select:none;
}
.case-meta-top{display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap}
.case-severity{
  display:inline-flex;align-items:center;gap:5px;
  padding:3px 10px;border-radius:999px;
  font-family:var(--mono);font-size:9.5px;letter-spacing:.06em;
  text-transform:uppercase;font-weight:600;
}
.case-severity.low{background:color-mix(in oklab,var(--accent) 12%,white);color:var(--accent-deep)}
.case-severity.moderate{background:color-mix(in oklab,#d4a017 12%,white);color:#7a5c00}
.case-severity.high{background:color-mix(in oklab,#c45a2d 12%,white);color:#8b3318}
.case-severity.severe{background:color-mix(in oklab,var(--warn) 12%,white);color:var(--warn)}
.case-court{font-family:var(--mono);font-size:10.5px;color:var(--ink-3);letter-spacing:.04em}
.case-date{font-family:var(--mono);font-size:10.5px;color:var(--ink-4);letter-spacing:.04em}
.case-name{
  font-family:var(--serif);font-size:22px;line-height:1.2;
  letter-spacing:-.015em;margin-bottom:6px;
}
.case-one-line{font-size:15px;color:var(--ink-2);line-height:1.45;max-width:70ch}
.case-tags{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
.case-tag{
  font-family:var(--mono);font-size:9px;letter-spacing:.06em;
  text-transform:uppercase;padding:3px 9px;border-radius:999px;
  border:1px solid var(--rule-soft);color:var(--ink-3);
}
.case-right{display:flex;flex-direction:column;align-items:flex-end;gap:8px;min-width:120px}
.case-penalty{font-family:var(--serif);font-size:24px;line-height:1;color:var(--warn)}
.case-penalty-mono{font-family:var(--mono);font-size:14px;letter-spacing:.03em;color:var(--warn)}
.case-penalty-mono.small{font-size:12px}
.case-penalty-mono.muted{color:var(--ink-4)}
.case-penalty-label{font-family:var(--mono);font-size:9px;color:var(--ink-4);letter-spacing:.06em;text-transform:uppercase}
.case-toggle{
  width:32px;height:32px;border-radius:50%;
  border:1px solid var(--rule-soft);
  display:flex;align-items:center;justify-content:center;
  transition:transform .3s cubic-bezier(.2,.8,.2,1),background .2s;
  margin-top:auto;
  background:transparent;
}
.case-card.open .case-toggle{transform:rotate(180deg);background:var(--paper-2)}

/* ================================================================
   CASE DETAIL (expanded)
   ================================================================ */
.case-detail{
  max-height:0;overflow:hidden;
  transition:max-height .5s cubic-bezier(.2,.8,.2,1);
}
.case-card.open .case-detail{max-height:8000px}
.case-detail-inner{
  padding:0 28px 28px;
  border-top:1px solid var(--rule-soft);
}
.detail-section{margin-top:28px}
.detail-section-title{
  font-family:var(--mono);font-size:10.5px;color:var(--ink-3);
  letter-spacing:.06em;text-transform:uppercase;
  margin-bottom:12px;padding-bottom:8px;
  border-bottom:1px solid var(--rule-soft);
}
.detail-narrative{font-size:15px;line-height:1.6;color:var(--ink-2);max-width:72ch}
.detail-narrative p{margin-bottom:12px}
.detail-narrative p:last-child{margin-bottom:0}

/* Rules grid */
.rules-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px}
.rule-card{
  padding:16px;border:1px solid var(--rule-soft);border-radius:6px;
}
.rule-card-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;gap:8px}
.rule-label{font-family:var(--mono);font-size:11px;letter-spacing:.04em;font-weight:500}
.rule-badge{
  font-family:var(--mono);font-size:9px;letter-spacing:.06em;text-transform:uppercase;
  padding:3px 8px;border-radius:999px;font-weight:600;flex-shrink:0;
}
.rule-badge.applies{background:color-mix(in oklab,var(--warn) 10%,white);color:var(--warn)}
.rule-badge.clear{background:color-mix(in oklab,var(--accent) 10%,white);color:var(--accent-deep)}
.rule-risk{
  font-family:var(--mono);font-size:9px;letter-spacing:.05em;text-transform:uppercase;
  color:var(--ink-4);margin-bottom:6px;
}
.rule-analysis{font-size:14px;line-height:1.5;color:var(--ink-2)}

/* Practice impact section */
.impact-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.impact-block{padding:16px;background:var(--paper-2);border-radius:6px}
.impact-block-title{
  font-family:var(--mono);font-size:10px;letter-spacing:.06em;
  text-transform:uppercase;color:var(--ink-3);margin-bottom:8px;
}
.impact-block-text{font-size:14px;line-height:1.5;color:var(--ink-2)}

/* Skill links */
.skill-links{display:flex;gap:12px;flex-wrap:wrap;margin-top:16px}
.skill-link{
  display:flex;align-items:center;gap:8px;
  padding:10px 16px;border:1px solid var(--accent);
  border-radius:999px;font-size:13px;font-weight:500;
  color:var(--accent-deep);
  transition:background .2s,transform .2s;
}
.skill-link:hover{background:color-mix(in oklab,var(--accent) 8%,white);transform:translateY(-1px)}
.skill-link-note{
  font-size:13px;color:var(--ink-3);line-height:1.4;
  margin-top:6px;padding-left:28px;
}
.skill-link-empty{font-family:var(--mono);font-size:11px;color:var(--ink-4)}

/* Reviewed footer line */
.case-source-row{
  display:flex;justify-content:space-between;align-items:center;
  margin-top:24px;padding-top:14px;
  border-top:1px dashed var(--rule-soft);
  flex-wrap:wrap;gap:10px;
}
.case-reviewed{font-family:var(--mono);font-size:10px;color:var(--ink-4);letter-spacing:.04em}

/* Load more */
.load-more-row{
  max-width:var(--section-w);margin:0 auto;
  padding:0 40px 80px;
  text-align:center;
}
.load-more-btn{
  display:inline-flex;align-items:center;gap:10px;
  padding:12px 28px;border:1px solid var(--ink);
  border-radius:999px;font-size:13px;font-weight:500;
  font-family:var(--sans);
  background:transparent;color:var(--ink);
  transition:background .25s,color .25s,transform .25s;
}
.load-more-btn:hover{background:var(--ink);color:var(--paper);transform:translateY(-2px)}

.list-empty{
  text-align:center;padding:60px 20px;
  font-family:var(--serif);font-style:italic;font-size:18px;color:var(--ink-3);
}
.list-error{
  margin:0 auto 40px;max-width:var(--section-w);
  padding:18px 24px;
  border:1px solid var(--warn);border-radius:6px;
  background:color-mix(in oklab,var(--warn) 8%,white);
  color:var(--warn);font-family:var(--mono);font-size:13px;
}

/* ================================================================
   METHODOLOGY FOOTER
   ================================================================ */
.methodology{
  max-width:var(--section-w);margin:0 auto;
  padding:60px 40px 80px;
  border-top:1px solid var(--rule-soft);
}
.methodology-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:40px}
.methodology h3{font-family:var(--serif);font-size:24px;margin-bottom:32px;grid-column:1/-1;font-weight:400}
.methodology h3 em{font-style:italic;color:var(--accent-deep)}
.meth-block-title{font-family:var(--mono);font-size:10.5px;color:var(--ink-3);letter-spacing:.06em;text-transform:uppercase;margin-bottom:8px}
.meth-block-text{font-size:14px;line-height:1.55;color:var(--ink-2)}
.meth-block-text a{color:var(--accent-deep);border-bottom:1px solid var(--accent)}

/* ================================================================
   SITE FOOTER — copied verbatim from /styles.css
   ================================================================ */
.foot { padding: 80px 40px 40px; max-width: 1400px; margin: 0 auto; }
.foot-top { padding-bottom: 48px; border-bottom: 1px solid var(--rule-soft); }
.foot-logo { font-family: var(--serif); font-size: clamp(60px, 10vw, 160px); line-height: .9; letter-spacing: -.03em; }
.foot-logo .brand-over { font-style: italic; color: var(--accent-deep); }
.foot-tag { font-size: 15px; color: var(--ink-3); margin: 18px 0 0; max-width: 50ch; }
.foot-cols {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px;
  padding: 40px 0; border-bottom: 1px solid var(--rule-soft);
}
.foot-cols h5 { font-family: var(--mono); font-size: 11px; color: var(--ink-3); letter-spacing: .1em; text-transform: uppercase; margin: 0 0 16px; font-weight: 500; }
.foot-cols a { display: block; padding: 6px 0; font-size: 14.5px; color: var(--ink); transition: color .25s ease, padding .25s ease; }
.foot-cols a:hover { color: var(--accent-deep); padding-left: 6px; }
.foot-bot { display: flex; justify-content: space-between; padding-top: 24px; font-family: var(--mono); font-size: 11px; color: var(--ink-3); letter-spacing: .04em; text-transform: uppercase; }
.foot-disclaimer { font-family: var(--mono); font-size: 10.5px; line-height: 1.6; color: var(--ink-4); letter-spacing: .01em; margin: 20px 0 0; padding-top: 18px; border-top: 1px solid var(--rule-soft); max-width: 92ch; }

/* ================================================================
   ANIMATIONS
   ================================================================ */
@keyframes riseUp{to{opacity:1;transform:translateY(0)}}
@keyframes fadeUp{to{opacity:1}}
@keyframes underline{to{transform:scaleX(1)}}
@keyframes pulse{
  0%,100%{box-shadow:0 0 0 0 color-mix(in oklab,var(--accent) 60%,transparent)}
  50%{box-shadow:0 0 0 8px color-mix(in oklab,var(--accent) 0%,transparent)}
}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--accent);animation:pulse 2s infinite;display:inline-block}

@media(prefers-reduced-motion:reduce){
  .hero-title .line{opacity:1;transform:none;animation:none}
  .hero-title em::after{transform:scaleX(1);animation:none}
  .hero-kicker,.hero-sub,.hero-actions,.stats,.controls{opacity:1;animation:none}
  .live-dot{animation:none}
}

/* ================================================================
   RESPONSIVE
   ================================================================ */
@media(max-width:960px){
  .nav { grid-template-columns: auto auto; gap: 14px; padding: 14px 20px; }
  .nav-links { display: none; }
  .foot { padding-left: 20px; padding-right: 20px; }
  .foot-cols { grid-template-columns: repeat(2, 1fr); }
}
@media(max-width:900px){
  .hero{padding:48px 20px 0}
  .wrap,.wrap-wide,.controls,.case-list,.results-meta,.methodology,.load-more-row{padding-left:20px;padding-right:20px}
  .stats{grid-template-columns:repeat(2,1fr)}
  .stat{border-right:1px solid var(--rule-soft)!important}
  .stat:nth-child(2n){border-right:none!important}
  .stat:not(:nth-child(-n+2)){border-top:1px solid var(--rule-soft)}
  .stat:last-child:nth-child(odd){grid-column:1/-1;border-right:none!important}
  .rules-grid{grid-template-columns:1fr}
  .impact-grid{grid-template-columns:1fr}
  .methodology-grid{grid-template-columns:1fr}
  .case-header{grid-template-columns:1fr}
  .case-right{flex-direction:row;align-items:center;margin-top:12px}
  .case-toggle{margin-top:0}
}
@media(max-width:600px){
  .hero-title{font-size:clamp(32px,9vw,52px)}
  .stat-n{font-size:32px}
  .search-row{flex-direction:column}
}
</style>
</head>
