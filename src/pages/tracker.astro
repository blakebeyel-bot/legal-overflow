    <div><h5>About</h5><a href="/about/">Author</a><a href="/about/">Standards</a><a href="/about/">Corrections</a></div>
    <div><h5>Elsewhere</h5><a href="#">Mastodon</a><a href="#">LinkedIn</a><a href="#">RSS</a></div>
    <div><h5>Fine print</h5><a href="#">Not legal advice</a><a href="#">Privacy</a><a href="#">Colophon</a></div>
  </div>
  <p class="foot-disclaimer">Claude™ and Claude Skills are trademarks of Anthropic PBC. GPT is a trademark of OpenAI. Gemini is a trademark of Google LLC. Westlaw is a trademark of Thomson Reuters. Legal Overflow is an independent publication and is not affiliated with, endorsed by, or sponsored by any of these companies.</p>
  <div class="foot-bot"><span>© 2026 Legal Overflow</span><span class="foot-version">v2026.04</span></div>
</footer>

<!-- ============================================================
     Supabase JS client
     ============================================================ -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js" defer></script>

<!-- ============================================================
     JS — boot, data, expand/collapse, filter, search, sort
     ============================================================ -->
<script is:inline define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
(function ready() {
  if (!window.supabase || !window.supabase.createClient) return setTimeout(ready, 30);
  boot();
})();

async function boot() {
  const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const PAGE = 50;

  const state = {
    severity: 'all',
    party: 'all',
    sanctions: new Set(),
    court: 'all',
    sort: 'date_desc',
    q: '',
    rendered: 0,
    all: [],
    filtered: [],
  };

  const $ = id => document.getElementById(id);
  const els = {
    list:        $('case-list'),
    loadMore:    $('load-more'),
    err:         $('list-error'),
    q:           $('searchInput'),
    sort:        $('sort-select'),
    statCases:   $('stat-cases'),
    statCasesSub: $('stat-cases-sub'),
    statPenalty: $('stat-penalty'),
    statBar:     $('stat-bar'),
    statLawyers: $('stat-lawyers'),
    statRules:   $('stat-rules'),
    navClock:    $('nav-clock'),
    heroKicker:  $('hero-kicker-text'),
    countLabel:  document.querySelector('.results-count'),
  };

  /* nav clock — same format as the rest of the site: "COCOA · h:mm AM/PM" */
  function tickClock() {
    if (!els.navClock) return;
    const d = new Date();
    let h = d.getHours();
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12; if (h === 0) h = 12;
    const mm = String(d.getMinutes()).padStart(2, '0');
    els.navClock.textContent = `COCOA · ${h}:${mm} ${ampm}`;
  }
  tickClock();
  setInterval(tickClock, 1000);

  /* nav-link marquee swap — same as /site-anim.js */
  (function installNavMarquee() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;
    try {
      document.querySelectorAll('.nav-links a').forEach(link => {
        // Skip links with non-text children (icons, etc.) so we don't break them
        const hasOnlyText = !link.children.length || (link.children.length === 0);
        if (link.children.length > 0) return;
        const text = link.textContent.trim();
        if (!text) return;
        link.classList.add('sx-marquee-link');
        link.innerHTML = '';
        const span = document.createElement('span');
        span.className = 'sx-marquee-text';
        span.setAttribute('data-text', text);
        span.textContent = text;
        link.appendChild(span);
      });
    } catch (e) { /* noop */ }
  })();

  /* reading-progress bar — same as /site-anim.js */
  (function installProgressBar() {
    try {
      const bar = document.createElement('div');
      bar.className = 'sx-progress';
      document.body.appendChild(bar);
      let rafId = 0, lastY = -1;
      function tick() {
        rafId = 0;
        const doc = document.documentElement;
        const max = doc.scrollHeight - window.innerHeight;
        const y = window.scrollY || doc.scrollTop;
        if (y === lastY) return;
        lastY = y;
        const p = max > 0 ? y / max : 0;
        bar.style.transform = 'scaleX(' + Math.max(0, Math.min(1, p)).toFixed(4) + ')';
      }
      function onScroll() { if (!rafId) rafId = requestAnimationFrame(tick); }
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      tick();
    } catch (e) { /* noop */ }
  })();

  function escapeHtml(s) {
    return String(s ?? '').replace(/[&<>"']/g, c => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c]));
  }
  function formatDate(d) {
    if (!d) return '';
    const dt = new Date(d);
    if (Number.isNaN(+dt)) return d;
    return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }
  function paragraphs(txt) {
    if (!txt) return '';
    return txt.split(/\n\n+/).map(p => `<p>${escapeHtml(p)}</p>`).join('');
  }
  function compactCurrency(n) {
    if (!n) return '$0';
    if (n >= 1_000_000) return `$${(n / 1_000_000).toFixed(n >= 10_000_000 ? 1 : 1).replace(/\.?0+$/, '')}M`;
    if (n >= 1_000)     return `$${Math.round(n / 1_000)}K`;
    return `$${Math.round(n).toLocaleString()}`;
  }

  /* ---------- count-up tween (matches index.astro [data-count] animation) ---------- */
  function tweenNumber(el, target, formatter) {
    if (!el) return;
    const dur = 1400;
    const start = performance.now();
    function tick(t) {
      const p = Math.min(1, (t - start) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = formatter(Math.round(target * eased));
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function armStatAnimation() {
    const stats = document.querySelector('.stats');
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!stats || reduced) {
      // skip the tween, just paint the final value
      return (el, target, formatter) => { if (el) el.textContent = formatter(target); };
    }
    let armed = false;
    const queue = [];
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting || armed) return;
        armed = true;
        queue.forEach(fn => fn());
        io.disconnect();
      });
    }, { threshold: 0.4 });
    io.observe(stats);
    return (el, target, formatter) => {
      const run = () => tweenNumber(el, target, formatter);
      const r = stats.getBoundingClientRect();
      const onscreen = r.top < window.innerHeight * 0.6 && r.bottom > 0;
      if (armed || onscreen) { armed = true; run(); } else { queue.push(run); }
    };
  }

  /* ---------- stats ---------- */
  async function loadStats() {
    const animate  = armStatAnimation();
    const intFmt    = n => n.toLocaleString();
    const dollarFmt = n => compactCurrency(n);

    try {
      const [pub, indexed, lawyer] = await Promise.all([
        sb.from('cases').select('id', { count: 'exact', head: true }).eq('status', 'published'),
        sb.from('cases').select('id', { count: 'exact', head: true }),
        sb.from('cases').select('id', { count: 'exact', head: true }).eq('party_type', 'Lawyer'),
      ]);
      const [pen, bar] = await Promise.all([
        sb.from('annotations').select('monetary_penalty_usd').eq('status', 'published'),
        sb.from('annotations').select('id', { count: 'exact', head: true }).eq('status', 'published').eq('professional_sanction', true),
      ]);
      const total = (pen.data || []).reduce((s, r) => s + (Number(r.monetary_penalty_usd) || 0), 0);
      const publishedCount = pub.count || 0;
      const indexedCount   = indexed.count || 0;

      // hero stat reflects what's actually annotated + published, with the
      // larger "of N indexed" living in the sub-line for context
      animate(els.statCases,   publishedCount,      intFmt);
      animate(els.statPenalty, total,                dollarFmt);
      animate(els.statBar,     bar.count || 0,       intFmt);
      animate(els.statLawyers, lawyer.count || 0,    intFmt);
      if (els.statCasesSub) {
        els.statCasesSub.textContent = `of ${indexedCount.toLocaleString()} indexed`;
      }
      // Set the Cases tab count directly from the data — avoids reading
      // the stat element while it's still tweening from 0 -> publishedCount.
      const tabCases = document.getElementById('tab-cases-count');
      if (tabCases) tabCases.textContent = publishedCount.toLocaleString();

      const today = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
      els.heroKicker.textContent = `Mata Tracker · Updated ${today} · ${indexedCount.toLocaleString()} U.S. cases indexed`;
    } catch (e) { console.warn('stats failed', e); }
  }

  /* ---------- load all published ---------- */
  async function loadAll() {
    try {
      const all = [];
      let from = 0;
      const batch = 1000;
      while (true) {
        const { data, error } = await sb
          .from('v_tracker_cases')
          .select('*')
          .not('annotation_id', 'is', null)
          .order('decision_date', { ascending: false })
          .range(from, from + batch - 1);
        if (error) throw error;
        if (!data || !data.length) break;
        all.push(...data);
        if (data.length < batch) break;
        from += batch;
      }
      state.all = all;
      populateCourtSelect();
      applyFilters();
    } catch (e) {
      console.error(e);
      els.err.style.display = 'block';
      els.list.innerHTML = '';
    }
  }

  /* ---------- Cases State/Court dropdown ---------- */
  // Federal-court heuristic: matches "S.D. New York", "D. Arizona",
  // "Cir.", "BAP", "JPML", "Tax Court", "Bankr", etc. Anything else
  // (e.g., "CA Texas", "SC Connecticut") falls into the State group.
  const FEDERAL_COURT_RE = /^(D\.|S\.D\.|N\.D\.|E\.D\.|W\.D\.|M\.D\.|C\.D\.|D\.D\.|U\.S\.|USDC)\s|\b(Cir\.|Circuit|BAP|JPML|ASBCA|GAO|Tax Court|Bankr|Bankruptcy|U\.S\.D\.C|J\.P\.M\.L)\b/i;

  function populateCourtSelect() {
    const sel = document.getElementById('case-court-select');
    if (!sel) return;
    // Reset to just the "All" option in case loadAll runs twice.
    while (sel.options.length > 1) sel.remove(1);

    const counts = new Map(); // court → count
    state.all.forEach(c => {
      if (!c.court) return;
      counts.set(c.court, (counts.get(c.court) || 0) + 1);
    });
    const courts = [...counts.keys()].sort((a, b) => a.localeCompare(b));
    const federal = courts.filter(c => FEDERAL_COURT_RE.test(c));
    const stateCourts = courts.filter(c => !FEDERAL_COURT_RE.test(c));

    function appendGroup(label, entries) {
      if (!entries.length) return;
      const group = document.createElement('optgroup');
      group.label = label;
      entries.forEach(value => {
        const opt = document.createElement('option');
        opt.value = value;
        opt.textContent = `${value} (${counts.get(value).toLocaleString()})`;
        group.appendChild(opt);
      });
      sel.appendChild(group);
    }
    appendGroup('Federal Courts', federal);
    appendGroup('State Courts',   stateCourts);
  }

  const SEVERITY_ORDER = { severe: 4, high: 3, moderate: 2, low: 1 };

  function applyFilters() {
    const q = state.q.toLowerCase();
    const partyKey = state.party;
    const sevKey = state.severity;
    const wantMonetary = state.sanctions.has('monetary');
    const wantBar      = state.sanctions.has('bar-referral');

    let rows = state.all.filter(r => {
      if (sevKey !== 'all' && r.severity !== sevKey) return false;
      if (partyKey === 'Pro Se') {
        if (!(r.party_type || '').toLowerCase().includes('pro se')) return false;
      } else if (partyKey !== 'all') {
        if (r.party_type !== partyKey) return false;
      }
      if (wantMonetary && !(Number(r.monetary_penalty_usd) > 0)) return false;
      if (wantBar && !r.professional_sanction) return false;
      if (state.court !== 'all' && r.court !== state.court) return false;
      if (q) {
        const blob = `${r.case_name} ${r.court} ${r.judge || ''} ${r.one_line || ''} ${r.ai_tool || ''} ${r.outcome_summary || ''}`.toLowerCase();
        if (!blob.includes(q)) return false;
      }
      return true;
    });

    switch (state.sort) {
      case 'date_asc':
        rows.sort((a, b) => (a.decision_date || '').localeCompare(b.decision_date || ''));
        break;
      case 'severity':
        rows.sort((a, b) =>
          (SEVERITY_ORDER[b.severity] || 0) - (SEVERITY_ORDER[a.severity] || 0)
          || (b.decision_date || '').localeCompare(a.decision_date || '')
        );
        break;
      case 'penalty':
        rows.sort((a, b) => (Number(b.monetary_penalty_usd) || 0) - (Number(a.monetary_penalty_usd) || 0));
        break;
      default:
        rows.sort((a, b) => (b.decision_date || '').localeCompare(a.decision_date || ''));
    }

    state.filtered = rows;
    state.rendered = 0;
    els.list.innerHTML = '';
    renderNextPage();
  }

  function renderNextPage() {
    const slice = state.filtered.slice(state.rendered, state.rendered + PAGE);
    if (state.rendered === 0 && slice.length === 0) {
      els.list.innerHTML = '<div class="list-empty">No cases match these filters.</div>';
      els.countLabel.textContent = `Showing 0 of ${state.all.length.toLocaleString()} cases`;
      els.loadMore.style.display = 'none';
      return;
    }
    els.list.insertAdjacentHTML('beforeend', slice.map(renderCard).join(''));
    state.rendered += slice.length;
    els.countLabel.textContent = `Showing ${state.rendered.toLocaleString()} of ${state.filtered.length.toLocaleString()} cases`;
    els.loadMore.style.display = state.rendered < state.filtered.length ? 'inline-flex' : 'none';

    if (location.hash) {
      const slug = location.hash.slice(1);
      const el = document.getElementById(slug);
      if (el && el.classList.contains('case-card') && !el.classList.contains('open')) {
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        toggleCard(el);
      }
    }
  }

  function renderCard(r) {
    const sev = (r.severity || 'low').toLowerCase();
    const sevLabel = sev[0].toUpperCase() + sev.slice(1);
    const tags = [];
    if (r.ai_tool) tags.push(r.ai_tool);
    if (r.outcome_summary) tags.push(r.outcome_summary);
    if (r.party_type && r.party_type !== 'Unknown') tags.push(r.party_type);

    let penaltyHTML = '';
    const m = Number(r.monetary_penalty_usd) || 0;
    if (m > 0) {
      penaltyHTML = `
        <div class="case-penalty">${compactCurrency(m)}</div>
        <div class="case-penalty-label">Monetary fine</div>`;
    } else if (r.professional_sanction) {
      const label = (r.outcome_summary || 'Bar Referral').toUpperCase();
      const small = label.length > 14 ? ' small' : '';
      penaltyHTML = `
        <div class="case-penalty-mono${small}">${escapeHtml(label)}</div>
        <div class="case-penalty-label">Professional sanction</div>`;
    } else if (r.outcome_summary) {
      const label = r.outcome_summary.toUpperCase();
      const small = label.length > 14 ? ' small' : '';
      penaltyHTML = `
        <div class="case-penalty-mono muted${small}">${escapeHtml(label)}</div>
        <div class="case-penalty-label">No monetary penalty</div>`;
    } else {
      penaltyHTML = `
        <div class="case-penalty-mono muted">—</div>
        <div class="case-penalty-label">No outcome</div>`;
    }

    return `
      <div class="case-card" data-severity="${sev}" data-cid="${r.case_id}" data-aid="${r.annotation_id || ''}" id="${escapeHtml(r.slug || '')}">
        <div class="case-header">
          <div>
            <div class="case-meta-top">
              <span class="case-severity ${sev}"><span class="severity-dot ${sev}"></span>${sevLabel}</span>
              <span class="case-court">${escapeHtml(r.court || '')}</span>
              <span class="case-date">&middot; ${formatDate(r.decision_date)}</span>
            </div>
            <div class="case-name">${escapeHtml(r.case_name || '')}</div>
            <div class="case-one-line">${escapeHtml(r.one_line || '')}</div>
            <div class="case-tags">
              ${tags.map(t => `<span class="case-tag">${escapeHtml(t)}</span>`).join('')}
            </div>
          </div>
          <div class="case-right">
            ${penaltyHTML}
            <div class="case-toggle">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
        </div>
        <div class="case-detail">
          <div class="case-detail-inner" data-loaded="0"></div>
        </div>
      </div>`;
  }

  /* ---------- expand / collapse ---------- */
  els.list.addEventListener('click', e => {
    const header = e.target.closest('.case-header');
    if (!header) return;
    const card = header.closest('.case-card');
    if (card) toggleCard(card);
  });

  function toggleCard(card) {
    const willOpen = !card.classList.contains('open');
    card.classList.toggle('open', willOpen);
    if (willOpen) {
      const inner = card.querySelector('.case-detail-inner');
      if (inner.getAttribute('data-loaded') === '0') {
        const cid = card.dataset.cid;
        const r = state.all.find(x => x.case_id === cid);
        inner.innerHTML = renderDetail(r);
        inner.setAttribute('data-loaded', '1');
        loadSkillLinks(card.dataset.aid, inner);
      }
    }
  }

  function renderDetail(r) {
    if (!r) return '<div class="detail-section"><div class="detail-narrative"><p>Annotation not available.</p></div></div>';

    const ruleEntry = (num, name, j) => {
      if (!j) return '';
      const applies = !!j.applies;
      const risk = (j.risk_level || 'none')[0].toUpperCase() + (j.risk_level || 'none').slice(1);
      return `
        <div class="rule-card">
          <div class="rule-card-header">
            <span class="rule-label">Rule ${num} ${escapeHtml(name)}</span>
            <span class="rule-badge ${applies ? 'applies' : 'clear'}">${applies ? 'Implicated' : 'Not Implicated'}</span>
          </div>
          <div class="rule-risk">Risk level: ${escapeHtml(risk)}</div>
          ${j.analysis ? `<div class="rule-analysis">${escapeHtml(j.analysis)}</div>` : ''}
        </div>`;
    };

    const rulesHTML = [
      ruleEntry('1.1', 'Competence',           r.rule_1_1_competence),
      ruleEntry('1.4', 'Communication',        r.rule_1_4_communication),
      ruleEntry('1.6', 'Confidentiality',      r.rule_1_6_confidentiality),
      ruleEntry('3.3', 'Candor',               r.rule_3_3_candor),
      ruleEntry('5.1', 'Supervisory',          r.rule_5_1_supervisory),
      ruleEntry('5.3', 'Nonlawyer Assistance', r.rule_5_3_nonlawyer),
    ].filter(Boolean).join('');

    const impactCells = [
      ['Insurance Exposure',              r.insurance_exposure],
      ['Bar Referral Risk',               r.bar_referral_risk],
      ['Recommended Firm Policy',         r.firm_policy_takeaway],
      ['What Would Have Prevented This',  r.prevention_notes],
    ].filter(([, body]) => body && body.trim()).map(([title, body]) => `
      <div class="impact-block">
        <div class="impact-block-title">${escapeHtml(title)}</div>
        <div class="impact-block-text">${escapeHtml(body)}</div>
      </div>
    `).join('');

    return `
      ${r.what_happened ? `<div class="detail-section">
        <div class="detail-section-title">What Happened</div>
        <div class="detail-narrative">${paragraphs(r.what_happened)}</div>
      </div>` : ''}

      ${r.what_went_wrong ? `<div class="detail-section">
        <div class="detail-section-title">What Went Wrong</div>
        <div class="detail-narrative">${paragraphs(r.what_went_wrong)}</div>
      </div>` : ''}

      ${rulesHTML ? `<div class="detail-section">
        <div class="detail-section-title">Model Rules Analysis</div>
        <div class="rules-grid">${rulesHTML}</div>
      </div>` : ''}

      ${impactCells ? `<div class="detail-section">
        <div class="detail-section-title">Practice Impact</div>
        <div class="impact-grid">${impactCells}</div>
      </div>` : ''}

      <div class="detail-section">
        <div class="detail-section-title">Relevant Skills</div>
        <div class="skill-links" data-skills><span class="skill-link-empty">Loading…</span></div>
        <div class="skill-link-note" data-skill-note></div>
      </div>

      ${r.reviewed_by ? `<div class="case-source-row">
        <span></span>
        <span class="case-reviewed">Reviewed by ${escapeHtml(r.reviewed_by)} &middot; ${formatDate(r.reviewed_at)}</span>
      </div>` : ''}
    `;
  }

  async function loadSkillLinks(aid, inner) {
    const slot = inner.querySelector('[data-skills]');
    const note = inner.querySelector('[data-skill-note]');
    if (!aid || !slot) return;
    try {
      const { data } = await sb.from('skill_links').select('*').eq('annotation_id', aid).order('display_order');
      if (data && data.length) {
        slot.innerHTML = data.map(s => `
          <a class="skill-link" href="${escapeHtml(s.skill_url)}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/></svg>
            ${escapeHtml(s.skill_name)}
          </a>`).join('');
        if (note) note.textContent = data.map(s => s.relevance_note).filter(Boolean).join(' ');
      } else {
        slot.innerHTML = '<span class="skill-link-empty">No matching Skills flagged for this case.</span>';
        if (note) note.textContent = '';
      }
    } catch (_) {
      slot.innerHTML = '<span class="skill-link-empty">Could not load Skills.</span>';
    }
  }

  /* ---------- filter / sort / search wiring ---------- */
  document.querySelectorAll('.filter-pill[data-filter]').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.filter-pill[data-filter]').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      state.severity = pill.dataset.filter;
      applyFilters();
    });
  });
  document.querySelectorAll('.filter-pill[data-party]').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.filter-pill[data-party]').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      state.party = pill.dataset.party;
      applyFilters();
    });
  });
  document.querySelectorAll('.filter-pill[data-sanction]').forEach(pill => {
    pill.addEventListener('click', () => {
      const v = pill.dataset.sanction;
      if (state.sanctions.has(v)) {
        state.sanctions.delete(v);
        pill.classList.remove('active');
      } else {
        state.sanctions.add(v);
        pill.classList.add('active');
      }
      applyFilters();
    });
  });

  let qTimer;
  els.q.addEventListener('input', () => {
    clearTimeout(qTimer);
    qTimer = setTimeout(() => { state.q = els.q.value.trim(); applyFilters(); }, 200);
  });
  els.sort.addEventListener('change', () => { state.sort = els.sort.value; applyFilters(); });
  const caseCourtSel = document.getElementById('case-court-select');
  if (caseCourtSel) {
    caseCourtSel.addEventListener('change', e => { state.court = e.target.value; applyFilters(); });
  }
  els.loadMore.addEventListener('click', () => renderNextPage());

  /* ---------- boot ---------- */
  loadStats();
  loadAll();

  /* ---------- TAB STRIP ---------- */
  document.querySelectorAll('.tk-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      document.querySelectorAll('.tk-tab').forEach(t => t.classList.toggle('active', t === tab));
      document.querySelectorAll('.tk-pane').forEach(p => {
        p.classList.toggle('hidden', p.dataset.pane !== target);
      });
      // Update the URL hash so deep links work
      history.replaceState(null, '', '#' + target);
      window.scrollTo({ top: document.querySelector('.tk-tabs').offsetTop - 20, behavior: 'smooth' });
    });
  });
  // Honour deep-link to #rules
  if (location.hash === '#rules') {
    document.querySelector('.tk-tab[data-tab="rules"]').click();
  }

  /* ---------- RULES PANE — live from Supabase ---------- */
  let RULES = [];
  try {
    const { data, error } = await sb
      .from('v_tracker_rules')
      .select('*')
      .order('effective_date', { ascending: false });
    if (error) throw error;
    RULES = (data || []).map(r => ({
      ...r,
      // Aliases so renderRuleCard can use either snake_case (Supabase)
      // or camelCase (legacy) keys interchangeably.
      jurisLabel: r.jurisdiction_label,
      typeLabel: r.type_label,
    }));
  } catch (e) {
    console.warn('rules fetch failed', e);
    RULES = [];
  }
  // Tab count goes live as soon as RULES has resolved (avoids TDZ + race
  // with the stat tween).
  const tabRules = document.getElementById('tab-rules-count');
  if (tabRules) tabRules.textContent = RULES.length.toLocaleString();

  // Hero stat for Rules & Orders — same count-up tween as the case stats.
  if (els.statRules) {
    const animateRules = armStatAnimation();
    animateRules(els.statRules, RULES.length, n => n.toLocaleString());
  }

  const ruleState = { juris: 'all', type: 'all', state: 'all', sort: 'date_desc' };

  /* Populate the state dropdown from RULES (alphabetical by label) */
  (function populateStateSelect() {
    const sel = document.getElementById('rule-state-select');
    if (!sel || !Array.isArray(RULES)) return;
    const buckets = new Map(); // value -> label
    RULES.forEach(r => {
      if (r.jurisdiction === 'state' && r.state) {
        buckets.set('state:' + r.state, r.jurisdiction_label || r.state);
      } else if (r.jurisdiction === 'federal') {
        const label = r.court || r.jurisdiction_label || 'Federal';
        buckets.set('court:' + label, label);
      } else if (r.jurisdiction === 'aba') {
        buckets.set('juris:aba', 'ABA');
      }
    });
    // group: ABA → state alphabetical → federal court alphabetical
    const items = [...buckets.entries()];
    const aba = items.filter(([k]) => k.startsWith('juris:'));
    const states = items.filter(([k]) => k.startsWith('state:')).sort((a, b) => a[1].localeCompare(b[1]));
    const courts = items.filter(([k]) => k.startsWith('court:')).sort((a, b) => a[1].localeCompare(b[1]));
    function appendGroup(label, entries) {
      if (!entries.length) return;
      const group = document.createElement('optgroup');
      group.label = label;
      entries.forEach(([value, text]) => {
        const opt = document.createElement('option');
        opt.value = value;
        opt.textContent = text;
        group.appendChild(opt);
      });
      sel.appendChild(group);
    }
    appendGroup('ABA',     aba);
    appendGroup('States',  states);
    appendGroup('Federal Courts', courts);
  })();

  function ruleEscape(s) {
    return String(s ?? '').replace(/[&<>"']/g, c => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c]));
  }
  function ruleDate(d) {
    return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  function renderRuleCard(r) {
    return `
      <article class="rule-card" data-juris="${r.jurisdiction}" data-type="${r.type}" id="${r.slug}">
        <div class="rule-card-header">
          <div>
            <div class="rule-meta-top">
              <span class="rule-juris-pill ${r.jurisdiction}">${ruleEscape(r.jurisLabel)}</span>
              <span class="rule-type-pill">${ruleEscape(r.typeLabel)}</span>
              <span class="rule-date">· ${ruleDate(r.effective_date)}</span>
            </div>
            <div class="rule-title">${ruleEscape(r.title)}</div>
            <div class="rule-subtitle">${ruleEscape(r.subtitle)}</div>
            <p class="rule-summary">${ruleEscape(r.summary.length > 220 ? r.summary.slice(0, 220) + '…' : r.summary)}</p>
            <div class="rule-tags">
              ${r.requires_disclosure ? '<span class="rule-tag disclosure">Requires Disclosure</span>' : ''}
              ${r.requires_verification ? '<span class="rule-tag verification">Verification Required</span>' : ''}
            </div>
          </div>
          <div class="rule-card-right">
            <div class="rule-rules-implicated">
              <strong>${r.rules_implicated.length}</strong>
              Rule${r.rules_implicated.length === 1 ? '' : 's'}<br/>
              implicated
            </div>
            <div class="rule-toggle">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
        </div>
        <div class="rule-detail">
          <div class="rule-detail-inner">
            <div class="rule-section">
              <div class="rule-section-title">Summary</div>
              <div class="rule-section-body"><p>${ruleEscape(r.summary)}</p></div>
            </div>
            <div class="rule-section">
              <div class="rule-section-title">Practitioner Takeaways</div>
              <ul class="rule-takeaways">
                ${r.takeaways.map(t => `<li>${ruleEscape(t)}</li>`).join('')}
              </ul>
            </div>
            <div class="rule-section">
              <div class="rule-section-title">Practitioner Take</div>
              <div class="rule-section-body"><p>${ruleEscape(r.practitioner_take)}</p></div>
            </div>
            <div class="rule-section">
              <div class="rule-section-title">Penalties / Enforcement</div>
              <div class="rule-section-body"><p>${ruleEscape(r.penalties)}</p></div>
            </div>
            <div class="rule-section">
              <div class="rule-section-title">Model Rules Implicated</div>
              <div class="rule-tags" style="margin-top:0">
                ${r.rules_implicated.map(rl => `<span class="rule-tag">Rule ${ruleEscape(rl)}</span>`).join('')}
              </div>
            </div>
            <div class="rule-footer-row">
              <a class="rule-source" href="${ruleEscape(r.source_url)}" target="_blank" rel="noopener">View source ↗</a>
              <span class="rule-citation">${ruleEscape(r.citation)}</span>
            </div>
          </div>
        </div>
      </article>`;
  }

  function applyRuleFilters() {
    let rows = RULES.filter(r => {
      if (ruleState.juris !== 'all' && r.jurisdiction !== ruleState.juris) return false;
      if (ruleState.type  !== 'all' && r.type         !== ruleState.type)  return false;
      if (ruleState.state !== 'all') {
        const sel = ruleState.state;
        if (sel.startsWith('state:')) {
          if (r.jurisdiction !== 'state' || r.state !== sel.slice(6)) return false;
        } else if (sel.startsWith('court:')) {
          const label = sel.slice(6);
          if (r.jurisdiction !== 'federal') return false;
          if ((r.court || r.jurisdiction_label || '') !== label) return false;
        } else if (sel.startsWith('juris:')) {
          if (r.jurisdiction !== sel.slice(6)) return false;
        }
      }
      return true;
    });
    if (ruleState.sort === 'date_asc')  rows.sort((a,b) => a.effective_date.localeCompare(b.effective_date));
    else if (ruleState.sort === 'rules') rows.sort((a,b) => b.rules_implicated.length - a.rules_implicated.length);
    else                                  rows.sort((a,b) => b.effective_date.localeCompare(a.effective_date));
    document.getElementById('rule-list').innerHTML = rows.length
      ? rows.map(renderRuleCard).join('')
      : '<div class="list-empty">No rules match these filters.</div>';
    document.getElementById('rule-count').textContent =
      `Showing ${rows.length} of ${RULES.length} rule${RULES.length === 1 ? '' : 's'}`;
  }

  // initial render
  applyRuleFilters();

  // expand / collapse rule cards
  document.getElementById('rule-list').addEventListener('click', e => {
    const header = e.target.closest('.rule-card-header');
    if (!header) return;
    header.closest('.rule-card').classList.toggle('open');
  });

  // rule filters
  document.querySelectorAll('[data-rule-juris]').forEach(p => {
    p.addEventListener('click', () => {
      document.querySelectorAll('[data-rule-juris]').forEach(x => x.classList.remove('active'));
      p.classList.add('active');
      ruleState.juris = p.dataset.ruleJuris;
      applyRuleFilters();
    });
  });
  document.querySelectorAll('[data-rule-type]').forEach(p => {
    p.addEventListener('click', () => {
      document.querySelectorAll('[data-rule-type]').forEach(x => x.classList.remove('active'));
      p.classList.add('active');
      ruleState.type = p.dataset.ruleType;
      applyRuleFilters();
    });
  });
  document.getElementById('rule-sort').addEventListener('change', e => {
    ruleState.sort = e.target.value;
    applyRuleFilters();
  });
  const stateSel = document.getElementById('rule-state-select');
  if (stateSel) {
    stateSel.addEventListener('change', e => {
      ruleState.state = e.target.value;
      applyRuleFilters();
    });
  }
}
</script>

</body>
</html>
