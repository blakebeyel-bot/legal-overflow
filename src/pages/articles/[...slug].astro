---
// Article display page. Reads from public.articles in Supabase at
// BUILD TIME via getStaticPaths(). Replaces the previous content-
// collection-based version. Edits/new articles via /admin/articles/
// trigger a Netlify rebuild that regenerates these pages.
//
// Markdown body is rendered to HTML using `marked` so we don't need
// Astro's content collection pipeline (which only reads from disk).
import { createClient } from '@supabase/supabase-js';
import { marked } from 'marked';
import { phArt, formatDate, trackLabel } from '../../lib/phArt';
import Consent from '../../partials/consent.astro';
import DownloadGate from '../../partials/download-gate.astro';

export async function getStaticPaths() {
  const url = import.meta.env.SUPABASE_URL || process.env.SUPABASE_URL;
  const key = import.meta.env.SUPABASE_SERVICE_ROLE_KEY || process.env.SUPABASE_SERVICE_ROLE_KEY;
  if (!url || !key) {
    console.warn('[articles/[...slug]] Supabase env not configured at build — generating no article pages');
    return [];
  }
  const sb = createClient(url, key);
  const { data, error } = await sb
    .from('articles')
    .select('*')
    .eq('status', 'published');
  if (error) {
    console.error('[articles/[...slug]] supabase error:', error.message);
    return [];
  }
  return (data || []).map((a) => ({ params: { slug: a.slug }, props: { entry: a } }));
}

const { entry } = Astro.props;
const d = {
  title: entry.title,
  dek: entry.dek,
  kind: entry.kind,
  topic: entry.topic,
  readMinutes: entry.read_minutes,
  date: entry.date ? new Date(entry.date) : new Date(),
  track: entry.track,
  cover: entry.cover,
  cover_image_url: entry.cover_image_url,
};
const bodyHtml = marked.parse(entry.body_md || '', { breaks: false, gfm: true });
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{d.title.replace(/<[^>]*>/g, '')} — Legal Overflow</title>
  <meta name="description" content={d.dek.replace(/<[^>]*>/g, '')} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <link rel="stylesheet" href="/site-anim.css" />
  <script src="/site-anim.js" defer></script>
</head>
<body>
  <div id="grain"></div>

  <header class="nav">
    <a href="/" class="brand" aria-label="Legal Overflow home">
      <svg class="brand-mark" viewBox="0 0 40 40" aria-hidden="true">
        <circle cx="20" cy="20" r="18" fill="none" stroke="currentColor" stroke-width="1"/>
        <path d="M20 6 L20 34 M8 14 L32 14 M8 26 L32 26" stroke="currentColor" stroke-width="1" fill="none"/>
        <circle cx="20" cy="14" r="2.5" fill="currentColor"/>
        <circle cx="20" cy="26" r="2.5" fill="var(--accent)"/>
      </svg>
      <span class="brand-text">
        <span>Legal</span><span class="brand-over">Overflow</span>
      </span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="/#skills">Skills</a>
      <a href="/#articles">Resources</a>
      <a href="/agents/">Agents</a>
      <a href="/tracker/">Tracker</a>
      <a href="/#services">Services</a>
      <a href="/about/">About</a>
    </nav>
    <div class="nav-right">
      <div class="live-dot" aria-hidden="true"></div>
      <span class="nav-meta" id="nav-clock">—</span>
      <a href="/#subscribe" class="nav-sub">Subscribe</a>
    </div>
  </header>

  <section class="article-hero">
    <div class="article-crumbs"><a href="/">Home</a> / <a href="/#articles">Articles</a> / {d.kind}</div>
    <div class="article-kicker">{d.kind} · {d.topic} · {d.readMinutes} min read</div>
    <h1 class="article-title" set:html={d.title}></h1>
    <p class="article-dek" set:html={d.dek}></p>
    <div class="article-meta">
      <span><strong>Published</strong> {formatDate(d.date)}</span>
      <span><strong>Track</strong> {trackLabel(d.track)}</span>
    </div>
  </section>

  <div class="article-cover">
    {d.cover_image_url
      ? <img src={d.cover_image_url} alt="" style="width:100%;height:auto;display:block;border-radius:8px;" />
      : (
        <div class={`ph ${d.cover}`}>
          <Fragment set:html={phArt[d.cover]} />
        </div>
      )
    }
  </div>

  <article class="article-body" set:html={bodyHtml}></article>

  <div class="article-end">
    <span>— {formatDate(d.date)} —</span>
    <a href="/#articles">More articles →</a>
  </div>

  <footer class="foot">
    <div class="foot-grid">
      <div>
        <div class="foot-brand">Legal Overflow</div>
        <p>A field journal on AI and the legal profession.</p>
      </div>
      <div><h5>Read</h5><a href="/#articles">Resources</a><a href="/#skills">Skills</a></div>
      <div><h5>About</h5><a href="/about/">Author</a></div>
      <div><h5>Fine print</h5><a href="/legal/disclaimer/">Disclaimer</a><a href="/legal/privacy/">Privacy</a><a href="/legal/terms/">Terms</a></div>
    </div>
    <p class="foot-bar-disclosure">
      <strong>Blake Beyel, Esq.</strong> · Florida Bar No. 1065044 · Cocoa, Florida ·
      The hiring of a lawyer is an important decision that should not be based solely on advertisements.
      Before you decide, ask for written information about the lawyer's qualifications and experience.
      No representation is made that the quality of the legal services to be performed is greater than
      the quality of legal services performed by other lawyers.
    </p>
    <div class="foot-base">
      <span>© 2026 Legal Overflow</span>
      <span>Published in public<a href="/admin/users/" class="foot-admin-link" aria-label="Admin"></a></span>
    </div>
  </footer>

  <script is:inline>
    (function clock() {
      const el = document.getElementById('nav-clock');
      if (!el) return;
      function tick() {
        const d = new Date();
        const t = d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZone: 'America/New_York' });
        el.textContent = 'COCOA · ' + t;
      }
      tick(); setInterval(tick, 30000);
    })();
  </script>
  <DownloadGate />
  <Consent />
</body>
</html>
